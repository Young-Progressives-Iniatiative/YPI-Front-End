           const headerHtml = `
               <a href="https://weareypi.com" target="_blank" rel="noopener noreferrer">
                   <img src="https://placehold.co/120x40/FFFFFF/37af4b?text=YPI" alt="YPI Logo" class="logo">
               </a>
               <button class="theme-toggle-button" aria-label="Toggle color theme">
