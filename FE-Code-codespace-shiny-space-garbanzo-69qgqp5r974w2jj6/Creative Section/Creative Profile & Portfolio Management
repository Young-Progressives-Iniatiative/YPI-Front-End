       function renderSkills() {
           skillsContainer.innerHTML = '';
           profileData.creativeNiches.forEach(skill => {
               const tag = document.createElement('span');
               tag.className = 'skills-tag';
               tag.innerHTML = `
                   ${skill}
                   <button type="button" class="remove-skill-btn" data-skill="${skill}" aria-label="Remove ${skill}">
                       <svg class="remove-skill-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                           <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                       </svg>
                   </button>`;
               skillsContainer.appendChild(tag);
           });
       }
     
       function renderPortfolio() {
           portfolioGrid.innerHTML = '';
           profileData.portfolioItems.forEach((item, index) => {
               const div = document.createElement('div');
               div.className = 'portfolio-item';
               let mediaHtml = '';
             
               if (item.type === 'image') {
                   mediaHtml = `<img src="${item.url}" alt="${item.title}" class="portfolio-item-img" onerror="this.onerror=null;this.src='https://placehold.co/150x120/2a2a2a/eeeeee?text=Invalid\\nImage';">`;
               } else if (item.type === 'video') {
                    mediaHtml = `<div class="portfolio-item-icon"><svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg></div>`;
               } else { // 'other'
                    mediaHtml = `<div class="portfolio-item-icon"><svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"></path></svg></div>`;
               }
             
               div.innerHTML = `
                   <a href="${item.url}" target="_blank" rel="noopener noreferrer">
                       ${mediaHtml}
                       <div class="portfolio-item-caption">${item.title}</div>
                   </a>
                   <button type="button" class="remove-item-btn" data-index="${index}" aria-label="Remove item">&times;</button>`;
               portfolioGrid.appendChild(div);
           });
       }
     
       function renderLogo() {
           if (profileData.logoUrl) {
               logoDisplay.src = profileData.logoUrl;
               logoDisplay.style.display = 'block';
               logoPlaceholder.style.display = 'none';
           } else {
               logoDisplay.style.display = 'none';
               logoPlaceholder.style.display = 'flex';
           }
       }
     
       function displaySaveMessage(msg, type, duration = 4000) {
           saveMessage.textContent = msg;
           saveMessage.className = `save-message ${type}`;
           setTimeout(() => { saveMessage.textContent = ''; saveMessage.className = 'save-message'; }, duration);
       }


       // --- EVENT LISTENERS ---
       creatorForm.addEventListener('submit', handleSave);


       // Skills
       skillInput.addEventListener('keydown', e => {
           if (e.key === 'Enter' && skillInput.value.trim()) {
               e.preventDefault();
               const newSkill = skillInput.value.trim();
               if (!profileData.creativeNiches.includes(newSkill)) {
                   profileData.creativeNiches.push(newSkill);
                   renderSkills();
               }
               skillInput.value = '';
           }
       });
       skillsContainer.addEventListener('click', e => {
           const removeBtn = e.target.closest('.remove-skill-btn');
           if (removeBtn) {
               const skillToRemove = removeBtn.dataset.skill;
               profileData.creativeNiches = profileData.creativeNiches.filter(s => s !== skillToRemove);
               renderSkills();
           }
       });
     
       // Portfolio
       addPortfolioImageBtn.addEventListener('click', () => portfolioImageInput.click());
       portfolioImageInput.addEventListener('change', async (e) => {
           for(const file of e.target.files) {
               try {
                   const downloadURL = await uploadFile(file, 'portfolio');
                   profileData.portfolioItems.push({ type: 'image', title: file.name, url: downloadURL });
                   renderPortfolio();
               } catch (error) {
                   console.error("Portfolio image upload failed:", error);
                   displaySaveMessage(`Upload failed for ${file.name}.`, 'error');
               }
           }
           portfolioImageInput.value = ''; // Reset file input
       });


       let currentPortfolioLinkType = 'video';
       const openPortfolioLinkModal = (type) => {
           currentPortfolioLinkType = type;
           modalTitle.textContent = `Add ${type.charAt(0).toUpperCase() + type.slice(1)} Link`;
           modalUrlInput.value = '';
           modalTitleInput.value = '';
           modalErrorMessage.textContent = '';
           portfolioLinkModal.classList.remove('hidden');
           modalUrlInput.focus();
       };


       const closePortfolioLinkModal = () => {
           portfolioLinkModal.classList.add('hidden');
       };


       modalSaveBtn.addEventListener('click', () => {
           const url = modalUrlInput.value.trim();
           modalErrorMessage.textContent = '';
           if (!url) {
               modalErrorMessage.textContent = 'Please enter a valid URL.';
               return;
           }
           const title = modalTitleInput.value.trim() || url;
           profileData.portfolioItems.push({ type: currentPortfolioLinkType, title, url });
           renderPortfolio();
           closePortfolioLinkModal();
       });


       modalCancelBtn.addEventListener('click', closePortfolioLinkModal);
       addPortfolioVideoBtn.addEventListener('click', () => openPortfolioLinkModal('video'));
       addPortfolioOtherBtn.addEventListener('click', () => openPortfolioLinkModal('other'));


       portfolioGrid.addEventListener('click', e => {
           const removeBtn = e.target.closest('.remove-item-btn');
           if (removeBtn) {
               e.preventDefault(); // Prevent link navigation
               const indexToRemove = parseInt(removeBtn.dataset.index, 10);
               profileData.portfolioItems.splice(indexToRemove, 1);
               renderPortfolio();
           }
       });
     
       // Branding
       logoUploadBtn.addEventListener('click', () => logoInput.click());
       logoInput.addEventListener('change', async (e) => {
           const file = e.target.files[0];
           if (file) {
               try {
                   const downloadURL = await uploadFile(file, 'logos');
                   profileData.logoUrl = downloadURL;
                   renderLogo();
               } catch (error) {
                    console.error("Logo upload failed:", error);
                    displaySaveMessage('Logo upload failed.', 'error');
               }
           }
       });


       fontUploadBtn.addEventListener('click', () => fontUploadInput.click());
       fontUploadInput.addEventListener('change', async (e) => {
           const file = e.target.files[0];
           if (file) {
                try {
                   const downloadURL = await uploadFile(file, 'fonts');
                   profileData.branding.fontName = file.name;
                   profileData.branding.fontUrl = downloadURL;
                   fontNameDisplay.textContent = file.name;
                   applyCustomFont(file.name, downloadURL);
               } catch (error) {
                    console.error("Font upload failed:", error);
                    displaySaveMessage('Font upload failed.', 'error');
               }
           }
       });
     
