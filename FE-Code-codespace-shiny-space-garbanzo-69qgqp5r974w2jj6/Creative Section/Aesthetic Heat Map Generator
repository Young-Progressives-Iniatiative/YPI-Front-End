                        <span class="bg-white w-1.5 h-6 mr-3 rounded-full"></span> 1. Source
                    </h2>
                    
                    <!-- Toggle Switch -->
                    <div class="flex bg-[var(--bg-main)] rounded-lg p-1 border border-theme">
                        <button onclick="toggleInputMode('script')" id="btnModeScript" class="px-3 py-1 rounded text-xs font-bold bg-[#404040] text-white transition-all">Script</button>
                        <button onclick="toggleInputMode('video')" id="btnModeVideo" class="px-3 py-1 rounded text-xs font-bold text-slate-400 hover:text-white transition-all">Video Link</button>
                    </div>
                </div>

                <div class="space-y-4">
                    
                    <!-- MODE: SCRIPT INPUTS -->
                    <div id="modeScriptInputs">
                        <div class="mb-4">
                            <label class="text-xs uppercase tracking-wider text-slate-500 font-bold mb-1 block">Video Title</label>
                            <input type="text" id="videoTitle" class="w-full bg-[var(--bg-main)] border border-theme rounded-lg p-3 text-sm focus:border-white focus:ring-1 focus:ring-white outline-none transition-colors text-slate-200" placeholder="e.g. The Rise of Y2K Futurism">
                        </div>
                        <div class="mb-4">
                            <label class="text-xs uppercase tracking-wider text-slate-500 font-bold mb-1 block">Description</label>
                            <textarea id="videoDesc" class="w-full bg-[var(--bg-main)] border border-theme rounded-lg p-3 text-sm h-20 focus:border-white focus:ring-1 focus:ring-white outline-none transition-colors resize-none text-slate-200" placeholder="Paste description here..."></textarea>
                        </div>
                    </div>

                    <!-- MODE: VIDEO INPUT -->
                    <div id="modeVideoInputs" class="hidden mb-4">
                        <label class="text-xs uppercase tracking-wider text-slate-500 font-bold mb-1 block">YouTube URL</label>
                        <div class="flex">
                            <input type="text" id="videoUrl" class="w-full bg-[var(--bg-main)] border border-theme rounded-l-lg p-3 text-sm focus:border-white outline-none text-slate-200" placeholder="https://www.youtube.com/watch?v=...">
                            <div class="bg-[#404040] px-3 flex items-center justify-center rounded-r-lg border-y border-r border-theme">
                                <svg class="w-5 h-5 text-red-500" fill="currentColor" viewBox="0 0 24 24"><path d="M19.615 3.184c-3.604-.246-11.631-.245-15.23 0-3.897.266-4.356 2.62-4.385 8.816.029 6.185.484 8.549 4.385 8.816 3.6.245 11.626.246 15.23 0 3.897-.266 4.356-2.62 4.385-8.816-.029-6.185-.484-8.549-4.385-8.816zm-10.615 12.816v-8l8 3.993-8 4.007z"/></svg>
                            </div>
                        </div>
                        <p class="text-[10px] text-slate-500 mt-2 italic">*Note: Due to YouTube privacy restrictions, we cannot auto-fetch transcripts. Please paste the text below manually.</p>
                    </div>

                    <!-- SHARED: SCRIPT BODY -->
                    <div>
                        <label class="text-xs uppercase tracking-wider text-slate-500 font-bold mb-1 block">Transcript / Script Content</label>
                        <textarea id="videoScript" class="w-full bg-[var(--bg-main)] border border-theme rounded-lg p-3 text-sm h-48 focus:border-white focus:ring-1 focus:ring-white outline-none transition-colors text-slate-200" placeholder="Paste the full transcript here..."></textarea>
                    </div>
                </div>
            </div>

            <!-- 2. Custom Aesthetic Input -->
            <div class="bg-card p-5 rounded-2xl shadow-xl border border-theme">
                <h2 class="text-xl font-bold mb-4 flex items-center text-white">
                    <span class="bg-white w-1.5 h-6 mr-3 rounded-full"></span> 2. Add Custom
                </h2>
                
                <div class="space-y-3">
                    <input type="text" id="customName" class="w-full bg-[var(--bg-main)] border border-theme rounded p-2 text-sm outline-none focus:border-white text-slate-200" placeholder="Name (e.g. MyCore)">
                    <textarea id="customKeywords" class="w-full bg-[var(--bg-main)] border border-theme rounded p-2 text-sm h-20 outline-none focus:border-white resize-none text-slate-200" placeholder="Keywords (comma separated): neon, cool, vibe..."></textarea>
                    <button onclick="addCustomAesthetic()" class="w-full py-2 bg-[var(--bg-main)] border border-white text-white hover:bg-white hover:text-black font-bold rounded-lg text-sm transition-colors">Add to Scanner</button>
                </div>
            </div>

            <!-- 3. Gradient Customization (Triggers Modal) -->
            <div class="bg-card p-5 rounded-2xl shadow-xl border border-theme group hover:border-white transition-colors duration-300 cursor-pointer" onclick="openColorModal()">
                <div class="flex justify-between items-center">
                    <h2 class="text-xl font-bold flex items-center text-white">
                        <svg class="w-5 h-5 mr-2 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01"></path></svg>
                        Heat Map Palette
                    </h2>
                    <span class="text-xs bg-[var(--bg-main)] px-2 py-1 rounded text-slate-400 group-hover:text-white transition-colors">Customize &rarr;</span>
                </div>
                
                <div class="mt-4 flex items-center space-x-2">
                    <!-- Current Palette Preview -->
                    <div class="h-2 flex-1 rounded-full overflow-hidden flex" id="sidebarGradientPreview">
                        <!-- Populated by JS -->
                    </div>
                </div>
            </div>

            <!-- Action Button -->
            <button onclick="generateHeatMap()" class="w-full py-4 bg-white hover:bg-slate-200 text-black font-bold rounded-2xl shadow-lg transform active:scale-95 transition-all text-xl tracking-wide">
                GENERATE HEAT MAP
            </button>
        </div>

        <!-- RIGHT COLUMN: Visualization -->
        <div class="col-span-1 lg:col-span-8 flex flex-col h-full min-h-[600px]">
            
            <div class="bg-card p-6 rounded-2xl shadow-xl border border-theme flex-1 flex flex-col">
                <div class="flex justify-between items-end mb-6">
                    <h2 class="text-2xl font-bold flex items-center text-white">
                        <span class="bg-white w-1.5 h-8 mr-3 rounded-full"></span> Results
                    </h2>
                    
                    <!-- Controls -->
                    <div class="flex items-center space-x-4 text-sm">
                        <label class="flex items-center space-x-2 cursor-pointer text-slate-400 hover:text-white">
                            <input type="checkbox" id="showZeroMatches" class="rounded bg-[var(--bg-main)] border-theme text-white focus:ring-white" onchange="renderGrid()">
                            <span>Show 0-match rows</span>
                        </label>
                        <div class="bg-[var(--bg-main)] px-3 py-1 rounded border border-theme text-slate-400">
                            X-Axis: Time (0% &rarr; 100%)
                        </div>
                    </div>
                </div>

                <!-- Video Embed Container (Hidden by default) -->
                <div id="videoEmbedContainer" class="hidden mb-6 rounded-xl overflow-hidden shadow-lg border border-theme bg-black aspect-video relative">
                    <!-- IFrame injected here -->
                </div>

                <!-- Heat Map Container -->
                <div class="flex-1 bg-[var(--bg-main)] rounded-xl border border-theme p-4 results-scroll overflow-y-auto relative min-h-[400px]">
                    
                    <!-- Loading / Empty State -->
                    <div id="emptyState" class="absolute inset-0 flex flex-col items-center justify-center text-slate-500">
                        <svg class="w-16 h-16 mb-4 opacity-20" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path></svg>
                        <p class="text-lg">Waiting for data...</p>
                        <p class="text-sm opacity-60">Select Source & click Generate</p>
                    </div>

                    <!-- The Grid -->
                    <div id="heatmapGrid" class="hidden w-full grid gap-1"></div>
                </div>

                <!-- Tile-Based Legend Key (No Numbers) -->
                <div id="legendKey" class="hidden mt-6 border-t border-theme pt-4">
