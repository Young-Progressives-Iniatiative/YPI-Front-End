<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Aesthetic Heat Map Generator v13</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        :root {
            --bg-main: #1c1c1c;
            --bg-card: #2d2d2d;
            --text-main: #ffffff;
            --border-color: #404040;
            --accent: #ff3842; /* Heat map max intensity */
        }

        body {
            background-color: var(--bg-main);
            color: var(--text-main);
        }

        .bg-card { background-color: var(--bg-card); }
        .border-theme { border-color: var(--border-color); }
        
        .text-accent { color: var(--accent); }
        .bg-accent { background-color: var(--accent); }
        .border-accent { border-color: var(--accent); }
        
        .heatmap-cell {
            transition: all 0.2s;
        }
        .heatmap-cell:hover {
            transform: scale(1.1);
            border: 1px solid white;
            z-index: 10;
        }

        .results-scroll::-webkit-scrollbar {
            width: 8px;
        }
        .results-scroll::-webkit-scrollbar-track {
            background: var(--bg-main); 
        }
        .results-scroll::-webkit-scrollbar-thumb {
            background: var(--border-color); 
            border-radius: 4px;
        }
        .results-scroll::-webkit-scrollbar-thumb:hover {
            background: #505050; 
        }

        /* Modal Transitions */
        .modal {
            opacity: 0;
            visibility: hidden;
            transition: all 0.3s ease-in-out;
        }
        .modal.active {
            opacity: 1;
            visibility: visible;
        }
        .modal-content {
            transform: scale(0.95);
            transition: all 0.3s ease-in-out;
        }
        .modal.active .modal-content {
            transform: scale(1);
        }
    </style>
</head>
<body class="min-h-screen p-4 lg:p-8 font-sans">

    <div class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-12 gap-8 relative z-0">
        
        <!-- Header -->
        <div class="col-span-1 lg:col-span-12 mb-2">
            <h1 class="text-4xl font-extrabold text-white">
                Aesthetic Heat Map Generator
            </h1>
            <p class="text-slate-400 mt-2 text-lg">Mass-analyze your video script against 400+ aesthetic categories instantly.</p>
        </div>

        <!-- LEFT COLUMN: Inputs -->
        <div class="col-span-1 lg:col-span-4 space-y-6">
            
            <!-- 1. Source Input (With Toggle) -->
            <div class="bg-card p-5 rounded-2xl shadow-xl border border-theme">
                
                <div class="flex justify-between items-center mb-4">
