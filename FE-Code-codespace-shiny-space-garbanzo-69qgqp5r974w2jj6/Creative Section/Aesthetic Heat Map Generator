// ---------------------------
// COLOR STOP DEFINITIONS (UPDATED v13)
// ---------------------------

const presetHeatStops = {
    0.0: '#392dda', // Bright Blue (User Requested Low)
    0.1: '#3fcdff', // Light Blue/Cyan (User Requested)
    0.2: '#3dff9e', // Mint Green (User Requested)
    0.3: '#3cff86', // Green (User Requested)
    0.4: '#fffe42', // Yellow (User Requested)
    0.5: '#fcff44', // Canary Yellow (User Requested)
    0.6: '#ffc642',
    0.7: '#ff9f42',
    0.8: '#ff8642',
    0.9: '#ff6b42',
    1.0: '#ff3842'  // Red
};
const PRESET_LOW = '#392dda'; // Updated Base

// State
let activeAesthetics = {}; 
let latestScores = [];     
let latestMaxScore = 0; 
let useCustomColors = false; 
let inputMode = 'script'; // 'script' or 'video'

// ---------------------------
// UI ENGINE
// ---------------------------

function toggleInputMode(mode) {
    inputMode = mode;
    const btnS = document.getElementById('btnModeScript');
    const btnV = document.getElementById('btnModeVideo');
    const inputsS = document.getElementById('modeScriptInputs');
    const inputsV = document.getElementById('modeVideoInputs');

    if(mode === 'script') {
        btnS.className = "px-3 py-1 rounded text-xs font-bold bg-[#404040] text-white transition-all";
        btnV.className = "px-3 py-1 rounded text-xs font-bold text-slate-400 hover:text-white transition-all";
        inputsS.classList.remove('hidden');
        inputsV.classList.add('hidden');
    } else {
        btnV.className = "px-3 py-1 rounded text-xs font-bold bg-[#404040] text-white transition-all";
        btnS.className = "px-3 py-1 rounded text-xs font-bold text-slate-400 hover:text-white transition-all";
        inputsV.classList.remove('hidden');
        inputsS.classList.add('hidden');
    }
}

function openColorModal() {
    document.getElementById('colorModal').classList.add('active');
    updateFromModal(false);
}

function closeColorModal() {
    document.getElementById('colorModal').classList.remove('active');
}

function updateFromModal(isUserInteraction) {
    if (isUserInteraction) useCustomColors = true;

    const low = document.getElementById('modalPickerLow').value;
    const mid = document.getElementById('modalPickerMid').value;
    const high = document.getElementById('modalPickerHigh').value;

    document.documentElement.style.setProperty('--accent', high);
    
    renderModalPreview(low, mid, high);
    updateLegendPreview(low, mid, high);
    if(latestScores.length > 0) renderGrid();
    updateSidebarPreview(low, mid, high);
}

function renderModalPreview(low, mid, high) {
    const strip = document.getElementById('modalPreviewStrip');
    strip.innerHTML = '';
    
    for(let i=0; i<=10; i++) {
        const percent = i / 10;
        const color = getGradientColor(percent, low, mid, high);
        const div = document.createElement('div');
        div.className = "w-full h-full rounded-sm";
        div.style.backgroundColor = color;
        strip.appendChild(div);
    }
}

function updateSidebarPreview(low, mid, high) {
    const bar = document.getElementById('sidebarGradientPreview');
    if (useCustomColors) {
        bar.style.background = `linear-gradient(to right, ${low}, ${mid}, ${high})`;
    } else {
        // Construct standard CSS gradient from stops
        const keys = Object.keys(presetHeatStops).sort();
        let css = 'linear-gradient(to right';
        keys.forEach(k => {
            css += `, ${presetHeatStops[k]} ${k * 100}%`;
        });
        css += ')';
        bar.style.background = css;
    }
}

function updateLegendPreview(low, mid, high) {
    if(!low) {
        low = document.getElementById('modalPickerLow').value;
        mid = document.getElementById('modalPickerMid').value;
        high = document.getElementById('modalPickerHigh').value;
    }
    document.getElementById('legendTile20').style.backgroundColor = getGradientColor(0.2, low, mid, high);
    document.getElementById('legendTile40').style.backgroundColor = getGradientColor(0.4, low, mid, high);
    document.getElementById('legendTile60').style.backgroundColor = getGradientColor(0.6, low, mid, high);
    document.getElementById('legendTile80').style.backgroundColor = getGradientColor(0.8, low, mid, high);
    document.getElementById('legendTile100').style.backgroundColor = getGradientColor(1.0, low, mid, high);
}

function getGradientColor(percent, low, mid, high) {
    if (!useCustomColors) {
        // --- MULTI-STOP PRESET MODE ---
        // Find the bounding stops
        const stops = Object.keys(presetHeatStops).map(parseFloat).sort((a,b) => a-b);
        
        // Handle exact edge cases or below min
        if (percent <= stops[0]) return hexToRgbaStr(presetHeatStops[stops[0]], 0.4);
        if (percent >= stops[stops.length-1]) return hexToRgbaStr(presetHeatStops[stops[stops.length-1]], 1.0);

        // Find range
        let lower = stops[0];
        let upper = stops[stops.length-1];
        
        for(let i=0; i < stops.length - 1; i++) {
            if(percent >= stops[i] && percent < stops[i+1]) {
                lower = stops[i];
                upper = stops[i+1];
                break;
            }
        }

        // Interpolate
        const range = upper - lower;
        const ratio = (percent - lower) / range;
        
        return interpolateHex(
            presetHeatStops[lower], 
            presetHeatStops[upper], 
            ratio, 
            0.4 + (percent * 0.6) // Alpha scale 0.4 -> 1.0
        );

    } else {
        // --- CUSTOM 3-STOP MODE ---
        if (percent <= 0.5) {
            const p = percent * 2; 
            return interpolateHex(low, mid, p, 0.5 + (percent * 0.5));
        } else {
            const p = (percent - 0.5) * 2;
            return interpolateHex(mid, high, p, 0.5 + (percent * 0.5));
        }
    }
}

function interpolateHex(hex1, hex2, ratio, alpha) {
    const c1 = hexToRgb(hex1);
    const c2 = hexToRgb(hex2);
    const r = Math.round(c1.r + (c2.r - c1.r) * ratio);
    const g = Math.round(c1.g + (c2.g - c1.g) * ratio);
    const b = Math.round(c1.b + (c2.b - c1.b) * ratio);
    return `rgba(${r}, ${g}, ${b}, ${alpha})`;
}

function hexToRgbaStr(hex, alpha) {
    const c = hexToRgb(hex);
    return `rgba(${c.r}, ${c.g}, ${c.b}, ${alpha})`;
}

function hexToRgb(hex) {
    var result = /^#?([a-f\d]{2})([a-f\d]{2})([a-f\d]{2})$/i.exec(hex);
    return result ? {
        r: parseInt(result[1], 16),
        g: parseInt(result[2], 16),
        b: parseInt(result[3], 16)
    } : { r:0, g:0, b:0 };
}

// ---------------------------
// LOGIC
// ---------------------------

function init() {
    fullAestheticList.sort().forEach(aes => {
        const keywords = defaultKeywords[aes] || aes.toLowerCase().replace(/core/g, ' core'); 
        activeAesthetics[aes] = keywords;
    });
    updateFromModal(false);
}

function addCustomAesthetic() {
    const name = document.getElementById('customName').value.trim();
    const keywords = document.getElementById('customKeywords').value.trim();
    if (!name || !keywords) { alert("Please enter both a name and keywords."); return; }
    activeAesthetics[name] = keywords;
    if (!fullAestheticList.includes(name)) fullAestheticList.push(name);
    document.getElementById('customName').value = '';
    document.getElementById('customKeywords').value = '';
    if (document.getElementById('videoScript').value) generateHeatMap();
}

function generateHeatMap() {
    const script = document.getElementById('videoScript').value;
    
    // Check for script presence
    if (!script) {
        alert("Please paste a transcript to generate a heat map.");
        return;
    }

    // Video Handling (If URL provided in Video Mode)
    const url = document.getElementById('videoUrl').value;
    const embedContainer = document.getElementById('videoEmbedContainer');
    
    if (inputMode === 'video' && url) {
        const vidId = extractVideoID(url);
        if(vidId) {
            embedContainer.innerHTML = `<iframe class="w-full h-full" src="https://www.youtube.com/embed/${vidId}" frameborder="0" allowfullscreen></iframe>`;
            embedContainer.classList.remove('hidden');
        } else {
            embedContainer.classList.add('hidden');
        }
    } else {
        embedContainer.classList.add('hidden');
        embedContainer.innerHTML = '';
    }

    // Show Results
    document.getElementById('emptyState').classList.add('hidden');
    document.getElementById('heatmapGrid').classList.remove('hidden');
    document.getElementById('statsFooter').classList.remove('hidden');
    document.getElementById('legendKey').classList.remove('hidden');

    // Analysis Logic
    const title = document.getElementById('videoTitle').value.toLowerCase();
    const desc = document.getElementById('videoDesc').value.toLowerCase();
    const scriptWords = script.toLowerCase().replace(/[^\w\s]/g, '').split(/\s+/);
    const chunkSize = Math.ceil(scriptWords.length / 10);
    const chunks = [];
    for (let i = 0; i < 10; i++) chunks.push(scriptWords.slice(i * chunkSize, (i + 1) * chunkSize).join(" "));

    const scores = [];
    let maxScore = 0;
    let totalGlobalHits = 0;
    let activeCategories = 0;

    Object.keys(activeAesthetics).forEach(aesName => {
        const keywordStr = activeAesthetics[aesName];
        if(!keywordStr) return; 
        const keywords = keywordStr.toLowerCase().split(',').map(k => k.trim()).filter(k => k);
        let rowData = { name: aesName, chunks: Array(10).fill(0), total: 0 };
        const titleHits = countMatches(title, keywords) * 3;
        const descHits = countMatches(desc, keywords) * 2;
        chunks.forEach((chunkText, index) => {
            const hits = countMatches(chunkText, keywords);
            rowData.chunks[index] = hits;
            rowData.total += hits;
            if (hits > maxScore) maxScore = hits;
        });
        rowData.total += (titleHits + descHits);
        if (rowData.total > 0) { activeCategories++; totalGlobalHits += rowData.total; }
        scores.push(rowData);
    });

    scores.sort((a, b) => b.total - a.total);
    latestScores = scores;
    latestMaxScore = maxScore;
    
    document.getElementById('statTopName').innerText = scores[0].total > 0 ? scores[0].name : "None";
    document.getElementById('statTotalHits').innerText = totalGlobalHits;
    document.getElementById('statActiveCount').innerText = activeCategories;
    
    const significant = scores.filter(s => s.total > (scores[0].total * 0.1)).length;
    document.getElementById('statVariety').innerText = significant > 1 ? "Eclectic" : "Focused";

    renderGrid();
}

function extractVideoID(url) {
    const regExp = /^.*(youtu.be\/|v\/|u\/\w\/|embed\/|watch\?v=|\&v=)([^#\&\?]*).*/;
    const match = url.match(regExp);
    return (match && match[2].length === 11) ? match[2] : null;
}

function countMatches(text, keywords) {
    let count = 0;
    keywords.forEach(kw => {
        try {
            const regex = new RegExp(`\\b${kw}\\b`, 'g');
            const matches = text.match(regex);
            if (matches) count += matches.length;
        } catch (e) {
            if (text.includes(kw)) count++;
        }
    });
    return count;
}

function renderGrid() {
    const showZero = document.getElementById('showZeroMatches').checked;
    const scores = latestScores;
    const maxVal = latestMaxScore;
    const low = document.getElementById('modalPickerLow').value;
    const mid = document.getElementById('modalPickerMid').value;
    const high = document.getElementById('modalPickerHigh').value;

    const container = document.getElementById('heatmapGrid');
    container.innerHTML = '';
    container.style.gridTemplateColumns = "200px repeat(10, 1fr)";

    const corner = document.createElement('div');
    corner.className = "text-xs font-bold text-slate-500 uppercase flex items-end justify-end pr-2 pb-1 border-b border-theme";
    corner.innerText = "Category";
    container.appendChild(corner);

    for(let i=0; i<10; i++) {
        const h = document.createElement('div');
        h.className = "text-[10px] text-slate-500 text-center pb-1 border-b border-theme flex items-end justify-center";
        h.innerText = `${i*10}%`;
        container.appendChild(h);
    }

    let visibleCount = 0;
    scores.forEach(row => {
        if (!showZero && row.total === 0) return;
        visibleCount++;

        const label = document.createElement('div');
        label.className = "text-xs text-slate-400 font-medium truncate text-right pr-3 py-1.5 flex items-center justify-end h-8 hover:text-white transition-colors cursor-help";
        label.title = `Total Hits: ${row.total}`;
        label.innerText = row.name;
        
        // Decoupled color: always white for highlighting top rows
        if (row.total > 0 && row.total === scores[0].total) {
            label.className += " text-white font-bold";
        }
        container.appendChild(label);

        row.chunks.forEach((val, idx) => {
            const cell = document.createElement('div');
            cell.className = "h-8 w-full rounded-[2px] heatmap-cell relative group";
            const intensity = maxVal > 0 ? (val / maxVal) : 0;
            if (val > 0) {
                const color = getGradientColor(intensity, low, mid, high);
                cell.style.backgroundColor = color; 
                cell.style.boxShadow = `0 0 ${intensity * 10}px ${color.replace(/, [^,]+\)$/, ', 0.5)')}`;
            } else {
                cell.style.backgroundColor = 'rgba(50, 50, 50, 0.3)';
            }
            if (val > 0) {
                cell.innerHTML = `
                    <div class="absolute bottom-full left-1/2 -translate-x-1/2 mb-1 px-2 py-1 bg-black border border-white text-white text-[10px] rounded opacity-0 group-hover:opacity-100 pointer-events-none whitespace-nowrap z-50 shadow-xl">
                        ${row.name}: ${val} hits
                    </div>
                `;
            }
            container.appendChild(cell);
        });
    });

    if (visibleCount === 0 && !showZero) {
        const msg = document.createElement('div');
        msg.className = "col-span-11 text-center py-10 text-slate-500";
        msg.innerHTML = "No matches found in script. <br><span class='text-xs'>Try checking 'Show 0-match rows' or paste a longer script.</span>";
        container.appendChild(msg);
    }
}

// Init
init();

