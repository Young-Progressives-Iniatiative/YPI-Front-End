                            <!-- 0 hits -->
                            <div class="flex flex-col items-center group relative">
                                <div class="w-10 h-10 rounded border border-theme bg-[rgba(100,100,100,0.1)] mb-1"></div>
                                <span>None</span>
                            </div>

                            <!-- 20% -->
                            <div class="flex flex-col items-center group relative">
                                <div id="legendTile20" class="w-10 h-10 rounded border border-theme mb-1 transition-colors duration-200"></div>
                                <span>Low</span>
                            </div>

                             <!-- 40% -->
                             <div class="flex flex-col items-center group relative">
                                <div id="legendTile40" class="w-10 h-10 rounded border border-theme mb-1 transition-colors duration-200"></div>
                                <span>Med</span>
                            </div>

                            <!-- 60% -->
                            <div class="flex flex-col items-center group relative">
                                <div id="legendTile60" class="w-10 h-10 rounded border border-theme mb-1 transition-colors duration-200"></div>
                                <span>High</span>
                            </div>

                            <!-- 80% -->
                             <div class="flex flex-col items-center group relative">
                                <div id="legendTile80" class="w-10 h-10 rounded border border-theme mb-1 transition-colors duration-200"></div>
                                <span>Very</span>
                            </div>

                            <!-- 100% -->
                            <div class="flex flex-col items-center group relative">
                                <div id="legendTile100" class="w-10 h-10 rounded border border-theme mb-1 ring-2 ring-offset-2 ring-offset-[var(--bg-card)] ring-white transition-colors duration-200"></div>
                                <span class="font-bold text-white transition-colors duration-300">Max</span>
                            </div>

                        </div>
                    </div>
                </div>

                <!-- Stats Footer -->
                <div id="statsFooter" class="mt-6 grid grid-cols-2 md:grid-cols-4 gap-4 hidden">
                    <div class="bg-[var(--bg-main)] p-3 rounded-lg border border-theme">
                        <div class="text-[10px] text-slate-500 uppercase font-bold tracking-wider">Top Aesthetic</div>
                        <div id="statTopName" class="text-lg font-bold text-white truncate transition-colors duration-300">-</div>
                    </div>
                    <div class="bg-[var(--bg-main)] p-3 rounded-lg border border-theme">
                        <div class="text-[10px] text-slate-500 uppercase font-bold tracking-wider">Total Keywords</div>
                        <div id="statTotalHits" class="text-lg font-bold text-white">0</div>
                    </div>
                    <div class="bg-[var(--bg-main)] p-3 rounded-lg border border-theme">
                        <div class="text-[10px] text-slate-500 uppercase font-bold tracking-wider">Variety Score</div>
                        <div id="statVariety" class="text-lg font-bold text-white">-</div>
                    </div>
                     <div class="bg-[var(--bg-main)] p-3 rounded-lg border border-theme">
                        <div class="text-[10px] text-slate-500 uppercase font-bold tracking-wider">Active Categories</div>
                        <div id="statActiveCount" class="text-lg font-bold text-white">0</div>
                    </div>
                </div>
            </div>

        </div>
    </div>

    <!-- COLOR EDITOR MODAL -->
    <div id="colorModal" class="modal fixed inset-0 z-50 flex items-center justify-center bg-black/80 backdrop-blur-sm">
        <div class="modal-content bg-card w-full max-w-lg p-6 rounded-2xl border border-theme shadow-2xl relative">
            
            <button onclick="closeColorModal()" class="absolute top-4 right-4 text-slate-400 hover:text-white">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
            </button>

            <h3 class="text-2xl font-bold text-white mb-2">Palette Editor</h3>
            <p class="text-sm text-slate-400 mb-6">Create a 3-stop gradient to map intensity levels.</p>

            <!-- Pickers -->
            <div class="grid grid-cols-3 gap-4 mb-8">
                <div>
                    <label class="text-xs uppercase tracking-wider font-bold text-slate-500 mb-2 block">0% (Low)</label>
                    <div class="flex items-center bg-[var(--bg-main)] p-2 rounded border border-theme">
                        <input type="color" id="modalPickerLow" class="w-full h-8 bg-transparent border-0 cursor-pointer" value="#392dda" oninput="updateFromModal(true)">
                    </div>
                </div>
                <div>
                    <label class="text-xs uppercase tracking-wider font-bold text-slate-500 mb-2 block">50% (Mid)</label>
                    <div class="flex items-center bg-[var(--bg-main)] p-2 rounded border border-theme">
                        <input type="color" id="modalPickerMid" class="w-full h-8 bg-transparent border-0 cursor-pointer" value="#ffdc42" oninput="updateFromModal(true)">
                    </div>
                </div>
                <div>
                    <label class="text-xs uppercase tracking-wider font-bold text-slate-500 mb-2 block">100% (High)</label>
                    <div class="flex items-center bg-[var(--bg-main)] p-2 rounded border border-theme">
                        <input type="color" id="modalPickerHigh" class="w-full h-8 bg-transparent border-0 cursor-pointer" value="#ff3842" oninput="updateFromModal(true)">
                    </div>
                </div>
            </div>

            <!-- Intensity Preview Strip -->
            <div class="mb-6">
                <label class="text-xs uppercase tracking-wider font-bold text-slate-500 mb-3 block">Intensity Breakdown (0% - 100%)</label>
                <div class="grid grid-cols-11 gap-1 h-12" id="modalPreviewStrip">
                    <!-- Populated via JS -->
                </div>
                <div class="flex justify-between text-[10px] text-slate-500 mt-1 px-1">
                    <span>0%</span>
                    <span>50%</span>
                    <span>100%</span>
                </div>
            </div>

            <div class="flex justify-end">
                <button onclick="closeColorModal()" class="px-6 py-2 bg-white text-black font-bold rounded-lg hover:brightness-110">Done</button>
            </div>

        </div>
    </div>

