function getClubInitials(name) {
    if (name === '-') return '';
    const parts = name.split(' ');
    if (parts.length >= 2) return parts[0][0] + parts[1][0];
    return name.substring(0, 2).toUpperCase();
}

function createClubBadge(color, name) {
    const initials = getClubInitials(name);
    return `<div class="club-badge" style="background:${color};">
        <svg viewBox="0 0 18 18" xmlns="http://www.w3.org/2000/svg">
            ${initials ? `<text x="50%" y="54%" dominant-baseline="middle" text-anchor="middle" fill="white" font-size="7" font-weight="700" font-family="Atkinson Hyperlegible, sans-serif">${initials}</text>` : ''}
        </svg>
    </div>`;
}

function createPlayerAvatar() {
    return `<div class="player-avatar">
        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
        </svg>
    </div>`;
}

function renderTable(data) {
    const tbody = document.getElementById('squadBody');
    tbody.innerHTML = '';
    
    data.forEach(p => {
        const infBadge = p.inf === 'Unr' ? '<span class="badge badge-unr">Unr</span>' :
                         p.inf === 'Wnt' ? '<span class="badge badge-wnt">Wnt</span>' :
                         p.inf === 'Sus' ? '<span class="badge badge-sus">Sus</span>' : '-';
        
        const isClubDash = p.club === '-';
        const clubBadge = isClubDash ? '' : createClubBadge(clubColors[p.club] || '#555', p.club);
        const clubClass = isClubDash ? 'dash' : '';
        
        const hasEducation = p.education !== '';
        const educationHtml = hasEducation 
            ? `<span class="education-year-badge">${p.education}</span>` 
            : '';
        const educationCellClass = hasEducation ? '' : 'blank';
        
        const roleColor = positionColors[p.pos] || '';
        
        const tr = document.createElement('tr');
        tr.dataset.id = p.id;
        if (p.picked) tr.classList.add('selected');
        
        tr.innerHTML = `
            <td class="checkbox-cell"><input type="checkbox" ${p.picked ? 'checked' : ''} onchange="togglePick(${p.id}, this)"></td>
            <td class="inf-cell">${infBadge}</td>
            <td>
                <div class="player-cell">
                    ${createPlayerAvatar()}
                    <span class="flag">${p.nationality}</span>
                    <span class="player-name">${p.player}</span>
                </div>
            </td>
            <td class="position-cell ${roleColor}">${p.pos}</td>
            <td class="education-cell ${educationCellClass}">${educationHtml}</td>
            <td>
                <div class="club-cell">
                    ${isClubDash ? '<span class="club-badge" style="background:#333;"></span>' : clubBadge}
                    <span class="club-name ${clubClass}">${isClubDash ? '-' : p.club}</span>
                </div>
            </td>
            <td class="expires-cell">
                <span class="expires-icon">⏰</span>
                <span class="expires-date">${p.expires}</span>
            </td>
            <td class="contract-cell">${p.contract}</td>
            <td class="salary-cell">${p.salary}</td>
            <td class="due-date-cell">${p.dueDate}</td>
            <td class="promises-cell">${p.promises}</td>
            <td class="release-cell">${p.release}</td>
            <td class="workload-cell">${p.workload}</td>
            <td class="plans-cell">${p.plans}</td>
            <td class="happiness-cell">
                <span class="happy-emoji">${p.happyEmoji}</span>
                <span class="happy-text">${p.happiness}</span>
            </td>
        `;
        
        tbody.appendChild(tr);
    });
}

function togglePick(id, checkbox) {
    const player = players.find(p => p.id === id);
    if (player) {
        player.picked = checkbox.checked;
        const tr = checkbox.closest('tr');
        if (checkbox.checked) {
            tr.classList.add('selected');
        } else {
            tr.classList.remove('selected');
        }
    }
}

let currentSort = { column: 'workload', asc: false };

function sortTable(column) {
    const headers = document.querySelectorAll('thead th');
    headers.forEach(h => h.classList.remove('sort-active'));
    
    if (currentSort.column === column) {
        currentSort.asc = !currentSort.asc;
    } else {
        currentSort.column = column;
        currentSort.asc = true;
    }
    
    const activeHeader = headers[getColumnIndex(column)];
    if (activeHeader) {
        activeHeader.classList.add('sort-active');
        activeHeader.querySelector('.sort-icon').textContent = currentSort.asc ? '▲' : '▼';
    }
    
    const sorted = [...players].sort((a, b) => {
        let valA, valB;
        
        switch(column) {
            case 'inf': valA = a.inf; valB = b.inf; break;
            case 'player': valA = a.player.toLowerCase(); valB = b.player.toLowerCase(); break;
            case 'position': valA = a.pos; valB = b.pos; break;
            case 'education': valA = a.education || 'zzz'; valB = b.education || 'zzz'; break;
            case 'club': valA = a.club; valB = b.club; break;
            case 'expires': valA = a.expires; valB = b.expires; break;
            case 'contract': valA = a.contract; valB = b.contract; break;
            case 'salary': valA = a.salary; valB = b.salary; break;
            case 'dueDate': valA = a.dueDate; valB = b.dueDate; break;
            case 'promises': valA = a.promises; valB = b.promises; break;
            case 'release': valA = a.release; valB = b.release; break;
            case 'workload': valA = a.workload; valB = b.workload; break;
            case 'plans': valA = a.plans; valB = b.plans; break;
            case 'happiness': valA = a.happiness; valB = b.happiness; break;
            default: return 0;
        }
        
        if (typeof valA === 'number') {
            return currentSort.asc ? valA - valB : valB - valA;
        }
        
        return currentSort.asc ? valA.localeCompare(valB) : valB.localeCompare(valA);
    });
    
    renderTable(sorted);
}

function getColumnIndex(column) {
    const map = {
        'inf': 1, 'player': 2, 'position': 3, 'education': 4, 'club': 5,
        'expires': 6, 'contract': 7, 'salary': 8, 'dueDate': 9,
        'promises': 10, 'release': 11, 'workload': 12, 'plans': 13, 'happiness': 14
    };
    return map[column];
}

function toggleFilter() {
    const bar = document.getElementById('filterBar');
    bar.classList.toggle('show');
    if (bar.classList.contains('show')) {
        document.getElementById('searchInput').focus();
    }
}

function toggleActions() {
}

function filterTable() {
    const search = document.getElementById('searchInput').value.toLowerCase();
    const posFilter = document.getElementById('posFilter').value.toLowerCase();
    const eduFilter = document.getElementById('eduFilter').value;
    
    const filtered = players.filter(p => {
        const matchSearch = !search || p.player.toLowerCase().includes(search) || p.club.toLowerCase().includes(search);
        const matchPos = !posFilter || p.pos.toLowerCase().includes(posFilter);
        
        let matchEdu = true;
        if (eduFilter === 'in') {
            matchEdu = p.education !== '';
        } else if (eduFilter === 'out') {
            matchEdu = p.education === '';
        }
        
        return matchSearch && matchPos && matchEdu;
    });
    
    renderTable(filtered);
}

// Initialize
renderTable(players);

document.getElementById('squadBody').addEventListener('dblclick', function(e) {
    const tr = e.target.closest('tr');
    if (tr) {
        const id = parseInt(tr.dataset.id);
        const player = players.find(p => p.id === id);
        if (player) {
            alert(`Opening staff profile: ${player.player}`);
        }
    }
});

document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') {
        document.getElementById('filterBar').classList.remove('show');
    }
});
