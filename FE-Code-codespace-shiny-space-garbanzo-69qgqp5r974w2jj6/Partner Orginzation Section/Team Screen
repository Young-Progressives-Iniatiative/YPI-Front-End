<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Squad View</title>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@fontsource/atkinson-hyperlegible@5.0.19/400.css">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@fontsource/atkinson-hyperlegible@5.0.19/500.css">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@fontsource/atkinson-hyperlegible@5.0.19/700.css">
<style>
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    background: #0e0e12;
    color: #c8c8d0;
    font-family: 'Atkinson Hyperlegible', sans-serif;
    font-size: 12px;
    overflow-x: hidden;
}

.top-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 8px 16px;
    background: #181820;
    border-bottom: 1px solid #2a2a35;
}

.top-bar-left {
    display: flex;
    align-items: center;
    gap: 16px;
}

.nav-arrows {
    display: flex;
    flex-direction: column;
    gap: 0;
}

.nav-arrows button {
    background: none;
    border: none;
    color: #6a6a7a;
    cursor: pointer;
    font-size: 10px;
    padding: 1px 6px;
    line-height: 1;
    font-family: inherit;
}

.nav-arrows button:hover {
    color: #fff;
}

.view-selector {
    display: flex;
    align-items: center;
    gap: 6px;
    background: #1a1a24;
    border: 1px solid #3a3a4a;
    border-radius: 6px;
    padding: 4px 12px;
    cursor: pointer;
    color: #e0e0e8;
    font-size: 12px;
    font-weight: 500;
}

.view-selector .eye-icon {
    font-size: 10px;
}

.view-selector select {
    background: transparent;
    border: none;
    color: #e0e0e8;
    font-size: 12px;
    font-weight: 500;
    outline: none;
    cursor: pointer;
    appearance: none;
    -webkit-appearance: none;
    font-family: inherit;
}

.top-bar-right {
    display: flex;
    align-items: center;
    gap: 8px;
}

.top-btn {
    display: flex;
    align-items: center;
    gap: 6px;
    background: #1a1a24;
    border: 1px solid #3a3a4a;
    border-radius: 6px;
    padding: 5px 12px;
    color: #b0b0bc;
    font-size: 12px;
    cursor: pointer;
    transition: all 0.15s;
    font-family: inherit;
}

.top-btn:hover {
    background: #252535;
    color: #e0e0e8;
    border-color: #5a5a6a;
}

.top-btn .dropdown-arrow {
    font-size: 8px;
    opacity: 0.6;
}

.table-container {
    overflow-x: auto;
    overflow-y: auto;
    max-height: calc(100vh - 48px);
    position: relative;
}

table {
    width: 100%;
    border-collapse: collapse;
    min-width: 1400px;
}

thead {
    position: sticky;
    top: 0;
    z-index: 10;
}

thead th {
    background: #1e1e2a;
    padding: 6px 8px;
    text-align: left;
    font-weight: 500;
    font-size: 11px;
    color: #8888a0;
    white-space: nowrap;
    border-bottom: 1px solid #2a2a35;
    border-right: 1px solid #252530;
    cursor: pointer;
    user-select: none;
    position: relative;
    font-family: inherit;
}

thead th:hover {
    color: #c8c8d0;
    background: #252535;
}

thead th.sort-active {
    color: #e0e0e8;
}

thead th .sort-icon {
    display: inline-block;
    margin-left: 4px;
    font-size: 8px;
    opacity: 0.5;
}

thead th.sort-active .sort-icon {
    opacity: 1;
    color: #7b8aff;
}

thead th:last-child {
    border-right: none;
}

tbody tr {
    border-bottom: 1px solid #1a1a24;
    transition: background 0.1s;
}

tbody tr:hover {
    background: #1e1e2e;
}

tbody tr:nth-child(even) {
    background: #13131a;
}

tbody tr:nth-child(even):hover {
    background: #1e1e2e;
}

tbody td {
    padding: 4px 8px;
    white-space: nowrap;
    border-right: 1px solid #1a1a22;
    font-size: 12px;
    vertical-align: middle;
    font-family: inherit;
}

tbody td:last-child {
    border-right: none;
}

.checkbox-cell {
    text-align: center;
    padding: 4px 6px;
}

.checkbox-cell input[type="checkbox"] {
    width: 14px;
    height: 14px;
    accent-color: #7b8aff;
    cursor: pointer;
}

.inf-cell {
    text-align: center;
    min-width: 40px;
}

.badge {
    display: inline-block;
    padding: 1px 6px;
    border-radius: 3px;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.3px;
    font-family: inherit;
}

.badge-unr {
    background: #ff6b6b;
    color: #fff;
}

.badge-wnt {
    background: #4ade80;
    color: #fff;
}

.badge-sus {
    background: #f97316;
    color: #fff;
}

.player-cell {
    display: flex;
    align-items: center;
    gap: 8px;
    min-width: 160px;
}

.player-avatar {
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background: #2a2a3a;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 11px;
    flex-shrink: 0;
    color: #6a6a7a;
}

.player-avatar svg {
    width: 14px;
    height: 14px;
    fill: #6a6a7a;
}

.flag {
    font-size: 12px;
    flex-shrink: 0;
}

.player-name {
    color: #7b8aff;
    font-weight: 500;
    font-size: 12px;
}

.player-name:hover {
    text-decoration: underline;
    cursor: pointer;
}

.position-cell {
    color: #a0a0b0;
    font-size: 11px;
    min-width: 140px;
}

.position-cell.role-leadership {
    color: #f59e0b;
}

.position-cell.role-program {
    color: #34d399;
}

.position-cell.role-dev {
    color: #60a5fa;
}

.position-cell.role-ops {
    color: #a78bfa;
}

.position-cell.role-comms {
    color: #f472b6;
}

.position-cell.role-finance {
    color: #fb923c;
}

.position-cell.role-volunteer {
    color: #2dd4bf;
}

.position-cell.role-grant {
    color: #c084fc;
}

.education-cell {
    color: #c8c8d0;
    text-align: center;
    min-width: 80px;
    font-size: 11px;
}

.education-cell.blank {
    color: #555;
}

.education-year-badge {
    display: inline-block;
    padding: 1px 8px;
    border-radius: 3px;
    font-size: 10px;
    font-weight: 500;
    background: #2a2a40;
    color: #9b9bff;
    border: 1px solid #3a3a55;
}

.club-cell {
    display: flex;
    align-items: center;
    gap: 6px;
    min-width: 130px;
}

.club-badge {
    width: 18px;
    height: 18px;
    border-radius: 50%;
    flex-shrink: 0;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
}

.club-badge svg {
    width: 18px;
    height: 18px;
}

.club-name {
    color: #a0a0b0;
    font-size: 11px;
}

.club-name.dash {
    color: #555;
}

.expires-cell {
    display: flex;
    align-items: center;
    gap: 4px;
    min-width: 100px;
}

.expires-icon {
    color: #ff6b6b;
    font-size: 11px;
}

.expires-date {
    color: #c8c8d0;
    font-size: 11px;
}

.contract-cell {
    color: #a0a0b0;
    font-size: 11px;
    min-width: 80px;
}

.salary-cell {
    color: #c8c8d0;
    font-size: 11px;
    min-width: 90px;
}

.due-date-cell {
    color: #555;
    text-align: center;
    min-width: 60px;
}

.promises-cell {
    color: #c8c8d0;
    text-align: center;
    min-width: 60px;
}

.release-cell {
    color: #c8c8d0;
    min-width: 60px;
}

.workload-cell {
    color: #a0a0b0;
    font-size: 11px;
    min-width: 80px;
}

.plans-cell {
    color: #8888a0;
    font-size: 11px;
    min-width: 160px;
}

.happiness-cell {
    display: flex;
    align-items: center;
    gap: 4px;
    min-width: 110px;
}

.happy-emoji {
    font-size: 14px;
}

.happy-text {
    color: #a0a0b0;
    font-size: 11px;
}

/* Scrollbar styling */
.table-container::-webkit-scrollbar {
    width: 8px;
    height: 8px;
}

.table-container::-webkit-scrollbar-track {
    background: #0e0e12;
}

.table-container::-webkit-scrollbar-thumb {
    background: #2a2a3a;
    border-radius: 4px;
}

.table-container::-webkit-scrollbar-thumb:hover {
    background: #3a3a4a;
}

.table-container::-webkit-scrollbar-corner {
    background: #0e0e12;
}

/* Filter bar */
.filter-bar {
    display: none;
    padding: 8px 16px;
    background: #181820;
    border-bottom: 1px solid #2a2a35;
    gap: 12px;
    align-items: center;
}

.filter-bar.show {
    display: flex;
}

.filter-bar input {
    background: #1a1a24;
    border: 1px solid #3a3a4a;
    border-radius: 4px;
    padding: 4px 10px;
    color: #c8c8d0;
    font-size: 12px;
    outline: none;
    font-family: inherit;
    width: 200px;
}

.filter-bar input:focus {
    border-color: #7b8aff;
}

.filter-bar label {
    color: #8888a0;
    font-size: 11px;
    font-family: inherit;
}

.filter-bar select {
    background: #1a1a24;
    border: 1px solid #3a3a4a;
    border-radius: 4px;
    padding: 4px 8px;
    color: #c8c8d0;
    font-size: 12px;
    outline: none;
    font-family: inherit;
    width: 160px;
}

.filter-bar select:focus {
    border-color: #7b8aff;
}

/* Row selected */
tbody tr.selected {
    background: #1a1a35 !important;
}

tbody tr.selected td {
    border-color: #2a2a45;
}
</style>
</head>
