<div class="top-bar">
    <div class="top-bar-left">
        <div class="nav-arrows">
            <button>▲</button>
            <button>▼</button>
        </div>
        <div class="view-selector">
            <span class="eye-icon"></span>
            <select id="viewSelect">
                <option>Main View</option>
                <option>Alternative View</option>
                <option>Squad Planner</option>
            </select>
        </div>
    </div>
    <div class="top-bar-right">
        <button class="top-btn">
            Quick Pick <span class="dropdown-arrow">▼</span>
        </button>
        <button class="top-btn" onclick="toggleActions()">
            <span>👤</span> Actions <span class="dropdown-arrow">▼</span>
        </button>
        <button class="top-btn" onclick="toggleFilter()">
            Filter <span class="dropdown-arrow">▼</span>
        </button>
    </div>
</div>

<div class="filter-bar" id="filterBar">
    <label>Search:</label>
    <input type="text" id="searchInput" placeholder="Filter staff..." oninput="filterTable()">
    <label>Department:</label>
    <input type="text" id="posFilter" placeholder="e.g. Development" oninput="filterTable()">
    <label>Education:</label>
    <select id="eduFilter" onchange="filterTable()">
        <option value="">All</option>
        <option value="in">In School</option>
        <option value="out">Out of School</option>
    </select>
</div>

<div class="table-container" id="tableContainer">
    <table id="squadTable">
        <thead>
            <tr>
                <th style="width:30px" class="checkbox-cell">✓</th>
                <th style="width:50px" onclick="sortTable('inf')">Inf <span class="sort-icon">▼</span></th>
                <th onclick="sortTable('player')">Staff <span class="sort-icon">▼</span></th>
                <th onclick="sortTable('position')">Position <span class="sort-icon">▼</span></th>
                <th onclick="sortTable('education')" style="width:90px">Education <span class="sort-icon">▼</span></th>
                <th onclick="sortTable('club')">Last Org <span class="sort-icon">▼</span></th>
                <th onclick="sortTable('expires')">Expires <span class="sort-icon">▼</span></th>
                <th onclick="sortTable('contract')">Contract Status <span class="sort-icon">▼</span></th>
                <th onclick="sortTable('salary')">Salary <span class="sort-icon">▼</span></th>
                <th onclick="sortTable('dueDate')">Due Date <span class="sort-icon">▼</span></th>
                <th onclick="sortTable('promises')">Promises <span class="sort-icon">▼</span></th>
                <th onclick="sortTable('release')">Set For Release <span class="sort-icon">▼</span></th>
                <th onclick="sortTable('workload')" class="sort-active">Workload <span class="sort-icon">▲</span></th>
                <th onclick="sortTable('plans')">Short-term Plans <span class="sort-icon">▼</span></th>
                <th onclick="sortTable('happiness')">Happiness <span class="sort-icon">▼</span></th>
            </tr>
        </thead>
        <tbody id="squadBody">
        </tbody>
    </table>
</div>

