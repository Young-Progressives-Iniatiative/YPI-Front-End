    <!-- Scripts -->
    <script>
        // Initialize Icons
        lucide.createIcons();

        // Tab Switching Logic
        function switchTab(tabName) {
            const buttons = document.querySelectorAll('.tab-btn');
            const activeClasses = ['text-green-400', 'decoration-green-400', 'decoration-4', 'underline-offset-8', 'underline'];
            const inactiveClasses = ['text-white', 'hover:text-green-200'];

            buttons.forEach(btn => {
                if (btn.id === `tab-${tabName}`) {
                    btn.classList.add(...activeClasses);
                    btn.classList.remove(...inactiveClasses);
                } else {
                    btn.classList.remove(...activeClasses);
                    btn.classList.add(...inactiveClasses);
                }
            });
        }
    </script>
