<!DOCTYPE html>
<html lang="en" class="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>YPI | Partner Role Management</title>
    
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        ypi: {
                            green: '#37af4b',
                            dark: '#121212',
                            card: '#1c1c1c',
                            element: '#252525',
                            hover: '#2d8c3c',
                            border: '#333333'
                        }
                    },
                    fontFamily: {
                        sans: ['Atkinson Hyperlegible', 'sans-serif'],
                        mono: ['ui-monospace', 'SFMono-Regular', 'Menlo', 'Monaco', 'Consolas', 'Liberation Mono', 'Courier New', 'monospace'],
                        inter: ['Inter', 'sans-serif']
                    }
                }
            }
        }
    </script>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Atkinson+Hyperlegible:ital,wght@0,400;0,700;1,400;1,700&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <!-- FontAwesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>

    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <!-- Tesseract.js for OCR -->
    <script src='https://cdn.jsdelivr.net/npm/tesseract.js@5/dist/tesseract.min.js'></script>
    
    <style>
        :root {
            --bg-main: #121212;
            --bg-panel: #1c1c1c;
            --bg-element: #252525;
            --text-main: #ffffff;
            --text-muted: #9ca3af;
            --border-color: #333;
            --accent-green: #37af4b;
            --highlight-green: #98fb98;
            --danger-red: #ef4444;
            
            /* Analytics Dashboard Colors */
            --db-bg: #0b0b0e;
            --db-card: #15161c;
            --db-muted: #9aa0a6;
            --db-text: #f5f5f7;
            --db-green: #2ecc71;
            --db-red: #e74c3c;
            --db-yellow: #f1c40f;
        }

        body {
            background-color: var(--bg-main); 
            color: #f0f0f0;
            font-family: 'Atkinson Hyperlegible', sans-serif;
            margin: 0;
        }
        
        .font-fm-header { font-family: 'Atkinson Hyperlegible', sans-serif; }

        /* Custom Scrollbar */
        ::-webkit-scrollbar { width: 8px; height: 8px; }
        ::-webkit-scrollbar-track { background: #1a1a1a; }
        ::-webkit-scrollbar-thumb { background: #333; border-radius: 4px; }
        ::-webkit-scrollbar-thumb:hover { background: #37af4b; }

        .no-scrollbar::-webkit-scrollbar { display: none; }
        .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }

        .fade-in { animation: fadeIn 0.3s ease-in-out; }
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .tab-content {
            display: none;
            animation: fadeIn 0.4s ease-out;
            width: 100%;
        }
        
        .tab-content.active { display: flex; flex-direction: column; }

        .trigger-container {
            align-items: center;
            justify-content: flex-start; 
            min-height: calc(100vh - 80px);
            text-align: center;
            padding: 1rem 2rem;
        }
        
        .calendar-container {
            width: 100%;
            max-width: 1100px;
            background: var(--bg-panel);
            border: 1px solid var(--border-color);
            border-radius: 12px;
            overflow: hidden;
            box-shadow: 0 10px 30px rgba(0,0,0,0.3);
            margin-top: 1rem;
            display: flex;
            flex-direction: column;
            min-height: 600px; 
        }
        
        .calendar-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 1.25rem 2rem;
            background: var(--bg-element);
            border-bottom: 1px solid var(--border-color);
        }
        
        .calendar-grid {
            display: grid;
            grid-template-columns: repeat(7, 1fr);
            background: var(--border-color);
            gap: 1px;
            flex: 1;
        }
        
        .calendar-day {
            background: var(--bg-panel);
            min-height: 140px;
            padding: 0.75rem;
            position: relative;
            display: flex;
            flex-direction: column;
            gap: 0.5rem;
        }

        .calendar-event {
            background: rgba(55, 175, 75, 0.15);
            border-left: 3px solid var(--accent-green);
            color: var(--highlight-green);
            padding: 0.4rem 0.6rem;
            font-size: 0.8rem;
            border-radius: 4px;
            cursor: pointer;
            text-align: left;
            font-weight: 600;
        }

        .modal-overlay {
            display: none;
            position: fixed;
            z-index: 2000;
            left: 0;
            top: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0,0,0,0.85);
            backdrop-filter: blur(8px);
            align-items: center;
            justify-content: center;
        }
        .modal-overlay.active { display: flex; }

        .form-page-container {
            position: relative;
            max-width: 1150px;
            width: 95%;
            margin: auto;
            padding: 2.5rem;
            background-color: var(--db-bg);
            border-radius: 14px;
            border: 1px solid #333;
            box-shadow: 0 20px 50px rgba(0,0,0,0.5);
            max-height: 90vh;
            overflow-y: auto;
            animation: slideUp 0.3s cubic-bezier(0.16, 1, 0.3, 1);
        }

        /* --- ROLE BUILDER STYLES (THEME ALIGNED) --- */
        .section-header {
            color: #f8fafc;
            font-weight: 700;
            letter-spacing: -0.015em;
            margin-bottom: 1.25rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
            font-size: 1.125rem;
            border-bottom: 1px solid #333;
            padding-bottom: 0.75rem;
        }
        .step-badge {
            width: 24px;
            height: 24px;
            background-color: #252525;
            color: #37af4b;
            border-radius: 6px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 0.75rem;
            font-weight: 700;
            border: 1px solid #333;
        }
        .input-group { margin-bottom: 1.25rem; text-align: left; }
        .input-label {
            display: block;
            font-size: 0.75rem;
            font-weight: 600;
            text-transform: uppercase;
            color: #9ca3af;
            margin-bottom: 0.35rem;
            letter-spacing: 0.025em;
        }
        .form-input {
            width: 100%;
            padding: 0.5rem 0.75rem;
            border-radius: 0.5rem;
            border: 1px solid #333;
            font-size: 0.875rem;
            color: #f1f5f9;
            background-color: #1c1c1c;
            transition: all 0.15s ease;
        }
        .form-input:focus { outline: none; border-color: #37af4b; box-shadow: 0 0 0 3px rgba(55, 175, 75, 0.1); background-color: #121212; }
        .form-textarea {
            width: 100%;
            padding: 0.5rem 0.75rem;
            border-radius: 0.5rem;
            border: 1px solid #333;
            font-size: 0.875rem;
            color: #f1f5f9;
            background-color: #1c1c1c;
            min-height: 100px;
            resize: vertical;
        }
        .form-textarea:focus { outline: none; border-color: #37af4b; box-shadow: 0 0 0 3px rgba(55, 175, 75, 0.1); background-color: #121212; }
        .list-item { background: #1c1c1c; border: 1px solid #333; border-radius: 6px; padding: 0.5rem; margin-bottom: 0.5rem; display: flex; justify-content: space-between; align-items: flex-start; font-size: 0.875rem; color: #e2e8f0; }
        .col-wrapper { height: 100%; overflow-y: auto; border-right: 1px solid #333; padding: 1.5rem; background-color: #121212; }
        .col-wrapper:last-child { border-right: none; }
        
        select.form-input {
            background-image: url("data:image/svg+xml,%3csvg xmlns='http://www.w3.org/2000/svg' fill='none' viewBox='0 0 20 20'%3e%3cpath stroke='%239ca3af' stroke-linecap='round' stroke-linejoin='round' stroke-width='1.5' d='M6 8l4 4 4-4'/%3e%3c/svg%3e");
            background-position: right 0.5rem center;
            background-repeat: no-repeat;
            background-size: 1.5em 1.5em;
            padding-right: 2.5rem;
            -webkit-appearance: none;
            appearance: none;
        }

        /* --- DASHBOARD STYLES --- */
        .db-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
            gap: 16px;
        }
        .db-card {
            background: linear-gradient(180deg, #1a1b22, #121318);
            border-radius: 14px;
            padding: 20px;
            box-shadow: 0 10px 30px rgba(0,0,0,.35);
        }
        .metric-title { font-weight: 600; font-size: 1.05rem; margin-bottom: 6px; color: var(--db-text); }
        .metric-sub { color: var(--db-muted); font-size: .85rem; margin-bottom: 10px; }
        .metric-value { font-size: 2rem; font-weight: 700; display: flex; align-items: center; gap: 8px; }
        .up { color: var(--db-green); }
        .down { color: var(--db-red); }
        .db-section { margin-top: 32px; }
        .db-section h2 { font-size: 1.2rem; margin-bottom: 12px; color: var(--db-text); }
        .stats-row { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 12px; margin-bottom: 16px; }
        .stat { background: var(--db-card); border-radius: 12px; padding: 14px 16px; display: flex; justify-content: space-between; align-items: center; font-size: .95rem; color: var(--db-text); }
        .stat span { color: var(--db-muted); }
        .legend { display: flex; gap: 16px; margin-top: 10px; font-size: .85rem; color: var(--db-muted); }
        .dot { width: 10px; height: 10px; border-radius: 50%; display: inline-block; margin-right: 6px; }
        .yellow-dot { background: var(--db-yellow); }
        .red-dot { background: var(--db-red); }

        .modal-nav-btn {
            position: absolute;
            top: 50%;
            transform: translateY(-50%);
            background: rgba(255,255,255,0.05);
            border: 1px solid rgba(255,255,255,0.1);
            color: white;
            width: 44px;
            height: 44px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            z-index: 100;
            transition: all 0.2s;
        }
        .modal-nav-btn:hover { background: rgba(255,255,255,0.15); border-color: var(--ypi-green); }
        .modal-nav-btn.left { left: 1rem; }
        .modal-nav-btn.right { right: 1rem; }

        .db-page { display: none; animation: fadeIn 0.3s ease-out; }
        .db-page.active { display: block; }

        .pagination-dots {
            display: flex;
            justify-content: center;
            gap: 8px;
            margin-top: 1.5rem;
            position: sticky;
            bottom: 0;
            padding-bottom: 10px;
            background: var(--db-bg);
            z-index: 50;
        }
        .page-dot { width: 8px; height: 8px; border-radius: 50%; background: #333; transition: all 0.2s; cursor: pointer; }
        .page-dot.active { background: var(--ypi-green); width: 24px; border-radius: 4px; }

        /* Sticky header for Database table */
        .sticky-th { position: sticky; top: 0; z-index: 20; }

        @keyframes slideUp {
            from { transform: translateY(40px); opacity: 0; }
            to { transform: translateY(0); opacity: 1; }
        }

        .message-box-overlay {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background-color: rgba(0, 0, 0, 0.6); backdrop-filter: blur(4px);
            z-index: 10000; display: flex; justify-content: center; align-items: center;
            visibility: hidden; opacity: 0; transition: opacity 0.3s ease-in-out;
        }
        .message-box {
            background-color: var(--bg-panel); color: var(--text-main); padding: 2rem;
            border-radius: 12px; border: 1px solid var(--border-color);
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
            max-width: 400px; width: 90%; text-align: center;
        }
    </style>
</head>
<body>

    <header class="flex flex-col w-full bg-[#1b1b1b] border-b border-[#2a2a2a] shadow-lg sticky top-0 z-50">
        <div class="flex items-center h-16 px-6 gap-6 overflow-x-auto no-scrollbar">
            <div class="flex items-center mr-2 flex-shrink-0">
                <button class="flex items-center justify-center w-8 h-10 bg-[#2a2d35] border border-blue-500/50 rounded-l hover:bg-[#353842] transition-colors group relative">
                    <i data-lucide="chevron-left" class="w-5 h-5 text-gray-300 group-hover:text-white"></i>
                </button>
                <button class="flex items-center justify-center w-8 h-10 bg-[#1f1f1f] hover:bg-[#2a2a2a] transition-colors rounded-r border-y border-r border-[#333]">
                    <i data-lucide="chevron-right" class="w-5 h-5 text-gray-500"></i>
                </button>
            </div>
            <div class="flex-shrink-0 mr-4">
                <div class="h-12 w-auto flex items-center justify-center">
                    <img src="https://weareypi.com/wp-content/uploads/2025/06/Site-Icon-3.png" alt="YPI" class="h-full w-auto object-contain drop-shadow-md" onerror="this.src='https://placehold.co/119x32/1c1c1c/fefefe?text=YPI'"/>
                </div>
            </div>
            <nav class="flex items-center gap-2" id="main-nav"></nav>
        </div>
    </header>

    <div class="main-content w-full">
        <section id="content-Organizing" class="tab-content trigger-container active">
            <div class="w-full border-b border-white/10 mb-8">
                <nav class="flex gap-8" aria-label="Module Navigation">
                    <button id="nav-roles" onclick="switchMainView('roleManagementView')" class="border-b-2 border-green-500 py-4 px-2 text-sm font-bold text-green-500 transition-colors flex items-center gap-2">
                        <i class="fa-solid fa-users-gear"></i> Role Management
                    </button>
                    <button id="nav-calendar" onclick="switchMainView('calendarView')" class="border-b-2 border-transparent py-4 px-2 text-sm font-bold text-neutral-400 hover:text-white hover:border-neutral-500 transition-colors flex items-center gap-2">
                        <i data-lucide="calendar-days"></i> Calendar
                    </button>
                </nav>
            </div>

            <!-- ROLE MANAGEMENT VIEW -->
            <div id="roleManagementView" class="w-full fade-in flex flex-col h-full overflow-hidden">
                <div class="flex justify-center mb-8 flex-shrink-0">
                    <div class="bg-neutral-800/80 p-1.5 rounded-full border border-white/5 shadow-xl inline-flex relative">
                        <button id="myRolesTab" onclick="switchSubTab('myRolesSection')" class="px-8 py-2.5 rounded-full text-sm font-bold transition-all text-white bg-green-600 shadow-lg">
                            Manage Roles
                        </button>
                        <button id="createRoleTab" onclick="switchSubTab('createRoleSection')" class="px-8 py-2.5 rounded-full text-sm font-bold transition-all text-neutral-400 hover:text-white">
                            Post New Role
                        </button>
                    </div>
                </div>

                <!-- SECTION: ACTIVE ROLES -->
                <div id="myRolesSection" class="fade-in space-y-8 overflow-y-auto px-4">
                    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" id="rolesGrid">
                        <div class="role-card cursor-pointer group bg-neutral-800 rounded-xl p-6 border border-neutral-700 hover:border-green-500/50 transition-all hover:-translate-y-1 relative" onclick="openRoleModal()">
                            <h4 class="text-xl font-bold text-white group-hover:text-green-400 transition-colors">Canvasser</h4>
                            <p class="text-neutral-400 text-xs uppercase font-semibold mt-1 mb-4">Non-Profit X</p>
                            <div class="space-y-2 mb-6 text-sm">
                                <div class="flex items-center text-neutral-300"><i class="fa-solid fa-location-dot w-5 text-neutral-500"></i> Bethesda, MD</div>
                                <div class="flex items-center text-green-400"><i class="fa-solid fa-circle-check w-5"></i> Actively Recruiting</div>
                            </div>
                            <div class="border-t border-white/5 pt-4 flex items-center justify-between">
                                <div class="text-sm"><span class="text-white font-bold text-lg">12</span> <span class="text-neutral-500">Applicants</span></div>
                                <button class="bg-green-600/20 text-green-400 px-3 py-1 rounded-lg text-xs font-bold border border-green-600/30">View</button>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- SECTION: ROLE BUILDER -->
                <div id="createRoleSection" class="hidden fade-in flex-1 overflow-hidden">
                    <div class="flex h-full bg-[#121212] border border-[#333] rounded-2xl overflow-hidden shadow-2xl">
                        <!-- Column 1: Core Details -->
                        <div class="w-1/4 col-wrapper border-r border-[#333]">
                            <h2 class="section-header">Core Details</h2>
                            <div class="input-group">
                                <label class="input-label">Role Title</label>
                                <input type="text" id="builder-title" class="form-input font-medium" placeholder="e.g. Data Engineering Intern">
                            </div>
                            
                            <div class="input-group">
                                <label class="input-label">Event Type</label>
                                <select id="builder-event-type" class="form-input">
                                    <option value="Recurring">Recurring Role (Ongoing)</option>
                                    <option value="One-Time">One-Time Event</option>
                                    <option value="Project">Project-Based</option>
                                    <option value="Seasonal">Seasonal / Summer Only</option>
                                </select>
                            </div>

                            <div class="grid grid-cols-2 gap-3 mb-5">
                                <div class="input-group mb-0">
                                    <label class="input-label" id="builder-hours-label">Hours / Week</label>
                                    <input type="number" id="builder-hours" class="form-input" value="10">
                                </div>
                                <div class="input-group mb-0">
                                    <label class="input-label">Role Type</label>
                                    <select id="builder-type" class="form-input">
                                        <option>Internship</option>
                                        <option>Fellowship</option>
                                        <option>Volunteer</option>
                                    </select>
                                </div>
                            </div>

                            <div class="input-group">
                                <label class="input-label">Application Deadline</label>
                                <input type="date" id="builder-deadline" class="form-input">
                            </div>

                            <div class="bg-[#1c1c1c] p-4 rounded-lg border border-[#333] mb-5">
                                <label class="input-label text-white mb-3">Location Targeting</label>
                                <div class="space-y-3">
                                    <div class="flex gap-2">
                                        <div class="w-1/3">
                                            <label class="text-[10px] uppercase text-neutral-500 font-bold mb-1 block">Radius</label>
                                            <input type="number" id="builder-radius" class="form-input text-xs" placeholder="Miles">
                                        </div>
                                        <div class="flex-1">
                                            <label class="text-[10px] uppercase text-neutral-500 font-bold mb-1 block">From Location</label>
                                            <input type="text" id="builder-target-loc" class="form-input text-xs" placeholder="Venue or ZIP">
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="bg-[#1c1c1c] p-4 rounded-lg border border-[#333]">
                                <label class="input-label text-white mb-3">Commitment Structure</label>
                                <div class="space-y-3">
                                    <div><label class="text-[10px] uppercase text-slate-500 font-bold mb-1 block">Schedule</label><input type="text" id="builder-schedule" class="form-input text-xs" value="Part-time"></div>
                                    <div><label class="text-[10px] uppercase text-slate-500 font-bold mb-1 block">Duration</label><input type="text" id="builder-duration" class="form-input text-xs" value="Temporary / Seasonal"></div>
                                </div>
                            </div>
                        </div>

                        <!-- Column 2: Role Definition -->
                        <div class="w-1/4 col-wrapper border-r border-[#333]">
                            <h2 class="section-header">Role Definition</h2>
                            <div class="input-group">
                                <label class="input-label">Mission Summary</label>
                                <textarea id="builder-summary" class="form-textarea h-40" placeholder="Mission goals..."></textarea>
                            </div>
                            <div class="input-group">
                                <label class="input-label flex justify-between items-center">Key Responsibilities <span class="text-[10px] bg-[#252525] px-2 py-0.5 rounded text-neutral-400 border border-[#333]" id="builder-resp-count">0 items</span></label>
                                <div id="builder-responsibilities-container" class="space-y-2 mb-3 min-h-[100px]"></div>
                                <div class="flex gap-2">
                                    <input type="text" id="builder-new-resp" class="form-input text-sm" placeholder="Add...">
                                    <button onclick="addBuilderResponsibility()" class="bg-[#1c1c1c] border border-[#333] hover:bg-neutral-800 text-neutral-300 px-3 rounded-md transition-colors flex-shrink-0"><i class="fa-solid fa-plus text-[#37af4b]"></i></button>
                                </div>
                            </div>
                        </div>

                        <!-- Column 3: Credit & Recognition -->
                        <div class="w-1/4 col-wrapper border-r border-[#333]">
                            <h2 class="section-header">Credit & Recognition</h2>
                            <div class="input-group"><label class="input-label">Credit Type</label><select id="builder-paid" class="form-input"><option value="Volunteer Hours">Volunteer Service Hours</option><option value="School Credit">School Credit / Internship</option><option value="Stipend">Stipend Provided</option></select></div>
                            <div class="input-group">
                                <label class="input-label flex justify-between items-center">Benefits & Outcomes <span class="text-[10px] bg-[#252525] px-2 py-0.5 rounded text-neutral-400 border border-[#333]" id="builder-ben-count">0 items</span></label>
                                <div id="builder-benefits-container" class="space-y-2 mb-4 min-h-[100px]"></div>
                                <div class="bg-[#1c1c1c] p-3 rounded border border-[#333]">
                                    <input type="text" id="builder-new-ben-title" class="form-input text-xs mb-2 font-medium bg-[#121212] border-[#333]" placeholder="Title">
                                    <input type="text" id="builder-new-ben-desc" class="form-input text-xs mb-2 bg-[#121212] border-[#333]" placeholder="Description">
                                    <button onclick="addBuilderBenefit()" class="w-full bg-[#333] hover:bg-neutral-700 text-neutral-200 text-xs font-medium py-1.5 rounded transition-colors shadow-sm">Add Benefit</button>
                                </div>
                            </div>
                        </div>

                        <!-- Column 4: Fit & Quals -->
                        <div class="w-1/4 col-wrapper relative">
                            <h2 class="section-header">Fit & Quals</h2>
                            <div class="input-group">
                                <label class="input-label mb-2">Philosophy Tags</label>
                                <div class="space-y-2">
                                    <label class="flex items-center gap-2 p-2 border border-[#333] rounded bg-[#1c1c1c] hover:border-neutral-500 cursor-pointer transition-colors">
                                        <input type="checkbox" id="builder-check-honors" class="accent-[#37af4b] w-4 h-4 rounded border-[#333] bg-[#252525]">
                                        <span class="text-xs font-medium text-neutral-300">Honors Focus</span>
                                    </label>

