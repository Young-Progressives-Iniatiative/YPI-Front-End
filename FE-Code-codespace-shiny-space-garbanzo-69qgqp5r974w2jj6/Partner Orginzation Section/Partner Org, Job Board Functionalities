    <div class="message-box-overlay" id="messageBoxOverlay"></div>

    <script>
        const builderState = {
            responsibilities: [
                "Create and manage databases tailored to organizational needs.",
                "Collaborate with communications teams to analyze outreach data."
            ],
            benefits: [
                { title: "Service Hours", desc: "Certified verification for requirements." }
            ],
            philosophies: []
        };

        function renderBuilderLists() {
            const respContainer = document.getElementById('builder-responsibilities-container');
            const benContainer = document.getElementById('builder-benefits-container');
            const philContainer = document.getElementById('builder-philosophy-tags-container');
            
            if(respContainer) {
                respContainer.innerHTML = builderState.responsibilities.map((resp, index) => `
                    <div class="list-item group">
                        <span class="pr-2 text-xs break-words whitespace-normal leading-relaxed">${resp}</span>
                        <div class="flex gap-2 flex-shrink-0">
                            <button onclick="editBuilderResp(${index})" class="text-slate-500 hover:text-blue-400 transition-colors p-1">
                                <i class="fa-solid fa-pencil"></i>
                            </button>
                            <button onclick="removeBuilderResp(${index})" class="text-slate-500 hover:text-red-400 transition-colors p-1">
                                <i class="fa-solid fa-xmark"></i>
                            </button>
                        </div>
                    </div>
                `).join('');
                document.getElementById('builder-resp-count').innerText = `${builderState.responsibilities.length} items`;
            }

            if(benContainer) {
                benContainer.innerHTML = builderState.benefits.map((ben, index) => `
                    <div class="list-item group flex-col items-start gap-1">
                        <div class="flex justify-between w-full">
                            <span class="font-semibold text-xs text-slate-300">${ben.title}</span>
                            <button onclick="removeBuilderBen(${index})" class="text-slate-500 hover:text-red-400 transition-colors p-1 -mt-1 -mr-1">
                                <i class="fa-solid fa-xmark"></i>
                            </button>
                        </div>
                        <span class="text-[10px] text-slate-500 leading-tight">${ben.desc}</span>
                    </div>
                `).join('');
                document.getElementById('builder-ben-count').innerText = `${builderState.benefits.length} items`;
            }

            if(philContainer) {
                philContainer.innerHTML = builderState.philosophies.map((phil, index) => `
                    <div class="flex items-center gap-2 p-2 border border-[#333] rounded bg-[#1c1c1c] hover:border-neutral-500 transition-colors">
                        <span class="flex-1 text-xs font-medium text-slate-300">${phil}</span>
                        <button onclick="removeBuilderPhilosophy(${index})" class="text-slate-500 hover:text-red-400 transition-colors p-1">
                            <i class="fa-solid fa-xmark"></i>
                        </button>
                    </div>
                `).join('');
            }
        }

        window.addBuilderResponsibility = function() {
            const inp = document.getElementById('builder-new-resp');
            if(inp.value.trim()){
                builderState.responsibilities.push(inp.value.trim());
                inp.value = '';
                renderBuilderLists();
            }
        };

        window.editBuilderResp = function(index) {
            const inp = document.getElementById('builder-new-resp');
            inp.value = builderState.responsibilities[index];
            builderState.responsibilities.splice(index, 1);
            renderBuilderLists();
            inp.focus();
        };

        window.removeBuilderResp = function(i) { builderState.responsibilities.splice(i, 1); renderBuilderLists(); };

        window.addBuilderBenefit = function() {
            const t = document.getElementById('builder-new-ben-title');
            const d = document.getElementById('builder-new-ben-desc');
            if(t.value.trim() && d.value.trim()){
                builderState.benefits.push({ title: t.value.trim(), desc: d.value.trim() });
                t.value = ''; d.value = '';
                renderBuilderLists();
            }
        };
        window.removeBuilderBen = function(i) { builderState.benefits.splice(i, 1); renderBuilderLists(); };

        window.addBuilderPhilosophy = function() {
            const inp = document.getElementById('builder-new-philosophy');
            if(inp.value.trim()){
                builderState.philosophies.push(inp.value.trim());
                inp.value = '';
                renderBuilderLists();
            }
        };
        window.removeBuilderPhilosophy = function(i) { builderState.philosophies.splice(i, 1); renderBuilderLists(); };

        document.addEventListener('DOMContentLoaded', () => {
            let events = JSON.parse(localStorage.getItem('ypi_events')) || [
                { id: '1', title: 'Annual Food Drive', date: new Date().toISOString().split('T')[0], time: '10:00', location: 'Main Hall', description: 'Sorting donations.' }
            ];
            let currentDate = new Date();
            let modalPage = 0;
            const totalModalPages = 2;

            const navItems = ['Vision', 'Organizing', 'Financials', 'Data Suite'];
            const navContainer = document.getElementById('main-nav');
            navItems.forEach(item => {
                const btn = document.createElement('button');
                btn.className = `px-3 py-2 text-xl font-bold font-fm-header transition-all ${item === 'Organizing' ? 'text-[#98fb98]' : 'text-gray-500 hover:text-white'}`;
                btn.innerHTML = `<span>${item}</span>`;
                btn.onclick = () => {
                    document.querySelectorAll('.tab-content').forEach(s => s.classList.remove('active'));
                    const target = document.getElementById(`content-${item}`);
                    if(target) target.classList.add('active');
                    navContainer.querySelectorAll('button').forEach(b => b.className = 'px-3 py-2 text-xl font-bold font-fm-header text-gray-500 hover:text-white');
                    btn.className = 'px-3 py-2 text-xl font-bold font-fm-header text-[#98fb98]';
                };
                navContainer.appendChild(btn);
            });

            const eventTypeSelect = document.getElementById('builder-event-type');
            const hoursLabel = document.getElementById('builder-hours-label');
            if (eventTypeSelect && hoursLabel) {
                eventTypeSelect.addEventListener('change', (e) => {
                    hoursLabel.innerText = e.target.value === 'One-Time' ? 'Hours' : 'Hours / Week';
                });
            }

            const gpaCheckbox = document.getElementById('builder-check-no-gpa');
            const gpaContainer = document.getElementById('min-gpa-container');
            if(gpaCheckbox && gpaContainer) {
                gpaCheckbox.addEventListener('change', (e) => {
                    gpaContainer.classList.toggle('hidden', e.target.checked);
                });
            }

            window.switchMainView = function(viewId) {
                ['roleManagementView', 'calendarView'].forEach(id => {
                    const el = document.getElementById(id);
                    if(el) el.classList.add('hidden');
                });
                const target = document.getElementById(viewId);
                if(target) target.classList.remove('hidden');
                refreshUI();
            };

            window.switchSubTab = function(sectionId) {
                document.getElementById('myRolesSection').classList.add('hidden');
                document.getElementById('createRoleSection').classList.add('hidden');
                const myTab = document.getElementById('myRolesTab');
                const createTab = document.getElementById('createRoleTab');
                if (sectionId === 'myRolesSection') {
                    myTab.className = "px-8 py-2.5 rounded-full text-sm font-bold transition-all text-white bg-green-600 shadow-lg";
                    createTab.className = "px-8 py-2.5 rounded-full text-sm font-bold transition-all text-neutral-400 hover:text-white";
                } else {
                    createTab.className = "px-8 py-2.5 rounded-full text-sm font-bold transition-all text-white bg-green-600 shadow-lg";
                    myTab.className = "px-8 py-2.5 rounded-full text-sm font-bold transition-all text-neutral-400 hover:text-white";
                    renderBuilderLists();
                }
                document.getElementById(sectionId).classList.remove('hidden');
            };

            window.handlePublish = function(e) {
                e.preventDefault();
                showMessage('Role Builder', 'Role published successfully to the partner network.');
                switchSubTab('myRolesSection');
            };

            function renderCalendar() {
                const grid = document.getElementById('calendarGrid');
                if (!grid) return;
                grid.innerHTML = '';
                const month = currentDate.getMonth();
                const year = currentDate.getFullYear();
                const titleEl = document.getElementById('calendarTitle');
                if(titleEl) titleEl.innerText = `${new Intl.DateTimeFormat('en-US', {month:'long'}).format(currentDate)} ${year}`;
                const firstDay = new Date(year, month, 1).getDay();
                const daysInMonth = new Date(year, month + 1, 0).getDate();
                for (let i = 0; i < firstDay; i++) grid.insertAdjacentHTML('beforeend', '<div class="calendar-day opacity-20"></div>');
                for (let i = 1; i <= daysInMonth; i++) {
                    const dateStr = `${year}-${String(month+1).padStart(2,'0')}-${String(i).padStart(2,'0')}`;
                    const dayEvents = events.filter(e => e.date === dateStr);
                    let eventHtml = dayEvents.map(e => `<div class="calendar-event">${e.title}</div>`).join('');
                    grid.insertAdjacentHTML('beforeend', `
                        <div class="calendar-day ${i === new Date().getDate() && month === new Date().getMonth() ? 'today' : ''}">
                            <span class="day-number text-xs font-bold text-gray-500">${i}</span>
                            <div class="mt-2 space-y-1">${eventHtml}</div>
                        </div>
                    `);
                }
            }

            window.changeModalPage = function(dir) {
                modalPage = (modalPage + dir + totalModalPages) % totalModalPages;
                updateModalUI();
            };

            window.setModalPage = function(page) {
                modalPage = page;
                updateModalUI();
            };

            function updateModalUI() {
                document.querySelectorAll('.db-page').forEach((p, idx) => { p.classList.toggle('active', idx === modalPage); });
                document.querySelectorAll('.page-dot').forEach((d, idx) => { d.classList.toggle('active', idx === modalPage); });
                lucide.createIcons();
            }

            window.openRoleModal = function() {
                modalPage = 0;
                updateModalUI();
                document.getElementById('roleModal').classList.add('active');
            };

            window.closeRoleModal = function() { document.getElementById('roleModal').classList.remove('active'); };

            window.showMessage = function(title, message) {
                const overlay = document.getElementById('messageBoxOverlay');
                overlay.innerHTML = `<div class="message-box"><h3>${title}</h3><p class="text-gray-400 my-4">${message}</p><button class="bg-[#37af4b] text-white px-6 py-2 rounded-lg font-bold" onclick="hideMessageBox()">OK</button></div>`;
                overlay.style.visibility = 'visible';
                overlay.style.opacity = '1';
            };

            window.hideMessageBox = function() {
                const overlay = document.getElementById('messageBoxOverlay');
                overlay.style.opacity = '0';
                setTimeout(() => overlay.style.visibility = 'hidden', 300);
            };

            function refreshUI() { renderCalendar(); lucide.createIcons(); }
            const prevBtn = document.getElementById('prevMonth');
            const nextBtn = document.getElementById('nextMonth');
            if(prevBtn) prevBtn.onclick = () => { currentDate.setMonth(currentDate.getMonth() - 1); refreshUI(); };
            if(nextBtn) nextBtn.onclick = () => { currentDate.setMonth(currentDate.getMonth() + 1); refreshUI(); };

            refreshUI();
        });
    </script>
