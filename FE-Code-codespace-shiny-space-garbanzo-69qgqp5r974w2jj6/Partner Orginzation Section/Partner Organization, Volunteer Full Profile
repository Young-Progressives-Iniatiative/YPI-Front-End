<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Volunteer Profile - Ricky Castro</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Atkinson+Hyperlegible:ital,wght@0,400;0,700;1,400;1,700&display=swap" rel="stylesheet">
    <style>
        :root {
            /* Core UI Surfaces */
            --bg-primary: #1c1c1c;
            --bg-tertiary: #4C6050;

            /* Accents */
            --accent-primary: #B3EDBD;
            --accent-muted: #94A38D;
            --accent-cyan: #17DAE9;
            --accent-teal: #59AEB5;

            /* Text System */
            --text-primary: #FEFEFE;
            --text-secondary: #C8CFC9;
            --text-muted: #8A918C;

            /* Status */
            --status-positive: #F2D94C;
            --status-negative: #E23B3B;
            
            /* UI Constants */
            --border-width: 2px;
        }

        body {
            background-color: var(--bg-primary);
            color: var(--text-primary);
            font-family: 'Atkinson Hyperlegible', sans-serif;
            padding: 2rem;
            -webkit-font-smoothing: antialiased;
        }

        .cyber-panel {
            border: var(--border-width) solid var(--accent-muted);
            border-radius: 4px;
            padding: 1rem;
            position: relative;
            background: transparent;
            transition: border-color 0.3s ease;
        }

        .cyber-panel:hover {
            border-color: var(--accent-primary);
        }

        .accent-text {
            color: var(--accent-primary);
        }

        .secondary-text {
            color: var(--text-secondary);
        }

        .muted-text {
            color: var(--text-muted);
        }

        .metric-bar-bg {
            background: rgba(255, 255, 255, 0.05);
            height: 20px;
            border: var(--border-width) solid var(--accent-muted);
            position: relative;
            overflow: hidden;
        }

        .metric-bar-fill {
            background: var(--accent-primary);
            height: 100%;
            transition: width 1s ease-in-out;
        }

        .status-dot {
            width: 12px;
            height: 12px;
            border-radius: 50%;
            display: inline-block;
            margin-right: 4px;
        }

        .dot-filled { background-color: var(--accent-cyan); }
        .dot-empty { border: var(--border-width) solid var(--accent-cyan); }

        .header-accent {
            background: var(--accent-primary);
            color: var(--bg-primary);
            padding: 2px 8px;
            font-weight: bold;
            text-transform: uppercase;
            font-size: 0.7rem;
            border-radius: 2px;
        }

        .divider {
            border-bottom: var(--border-width) solid var(--bg-tertiary);
        }

        ::-webkit-scrollbar {
            width: 5px;
        }
        ::-webkit-scrollbar-track {
            background: var(--bg-primary);
        }
        ::-webkit-scrollbar-thumb {
            background: var(--accent-muted); 
        }
    </style>
</head>
<body class="text-[11px]">

