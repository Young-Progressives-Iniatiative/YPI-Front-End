        // Main Dashboard Tab Switching
        function switchMainTab(tabId, btnElement) {
            document.getElementById('academic-main').classList.remove('active');
            document.getElementById('volunteerism-main').classList.remove('active');
            const mainButtons = btnElement.parentElement.querySelectorAll('.tab-btn');
            mainButtons.forEach(btn => btn.classList.remove('active'));
            document.getElementById(tabId).classList.add('active');
            btnElement.classList.add('active');
        }

        function switchSubTab(subTabId, btnElement) {
            const container = btnElement.parentElement.parentElement;
            const subPanes = container.querySelectorAll('.sub-tab-pane');
            subPanes.forEach(pane => pane.classList.remove('active'));
            const subButtons = btnElement.parentElement.querySelectorAll('.sub-tab-btn');
            subButtons.forEach(btn => btn.classList.remove('active'));
            document.getElementById(subTabId).classList.add('active');
            btnElement.classList.add('active');
        }

        // Popup Modal Logic
        function openDashboard() {
            const modal = document.getElementById('dashboard-modal');
            const content = document.getElementById('modal-content');
            modal.classList.remove('hidden');
            setTimeout(() => {
                modal.classList.remove('opacity-0');
            }, 10);
        }

        function closeDashboard() {
            const modal = document.getElementById('dashboard-modal');
            modal.classList.add('opacity-0');
            setTimeout(() => {
                modal.classList.add('hidden');
            }, 300);
        }

        // Popup Tab Switching (Zinc Style)
        function switchPopupTab(tabName) {
            const buttons = document.querySelectorAll('.popup-tab-btn');
            const activeClasses = ['text-green-400', 'decoration-green-400', 'decoration-4', 'underline-offset-8', 'underline'];
            const inactiveClasses = ['text-white', 'hover:text-green-200'];

            buttons.forEach(btn => {
                btn.classList.remove(...activeClasses);
                btn.classList.add(...inactiveClasses);
                if (btn.id === `popup-tab-${tabName}`) {
                    btn.classList.add(...activeClasses);
                    btn.classList.remove(...inactiveClasses);
                }
            });

            const views = document.querySelectorAll('.popup-tab-content');
            views.forEach(view => {
                view.classList.remove('active');
                if (view.id === `popup-view-${tabName}`) {
                    view.classList.add('active');
                }
            });
        }
