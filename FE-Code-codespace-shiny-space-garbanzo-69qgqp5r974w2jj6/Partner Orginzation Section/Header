<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard Template - Headers Only</title>
    
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    
    <!-- Google Fonts: Atkinson Hyperlegible -->
    <link href="https://fonts.googleapis.com/css2?family=Atkinson+Hyperlegible:ital,wght@0,400;0,700;1,400;1,700&display=swap" rel="stylesheet">
    
    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>

    <style>
        /* --- CORE THEME VARIABLES --- */
        :root {
            --bg-main: #1c1c1c;
            --bg-panel: #1b1b1b;
            --bg-element: #2a2d35;
            --text-main: #ffffff;
            --text-muted: #9ca3af;
            --border-color: #2a2a2a;
            --accent-green: #37af4b;
            --highlight-green: #98fb98;
        }

        body {
            font-family: 'Atkinson Hyperlegible', sans-serif;
            background-color: var(--bg-main);
            color: var(--text-main);
            margin: 0;
            overflow-x: hidden;
        }
        
        .font-fm-header {
            font-family: 'Atkinson Hyperlegible', sans-serif;
        }

        /* --- TAB CONTENT STYLES --- */
        .tab-content {
            display: none;
            animation: fadeIn 0.4s ease-out;
            width: 100%;
        }
        
        .tab-content.active {
            display: flex;
            flex-direction: column;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        /* --- LAYOUT --- */
        .trigger-container {
            flex-direction: column;
            align-items: center;
            justify-content: flex-start; 
            min-height: calc(100vh - 80px);
            text-align: center;
            padding: 0; /* Removed padding to let sub-header span full width */
        }

        /* Content Area Placeholder */
        .content-area {
            width: 100%;
            display: flex;
            align-items: center;
            justify-content: center;
            height: 60vh;
            color: var(--text-muted);
            font-style: italic;
            padding: 2rem;
        }
        
        /* Custom Scrollbar for horizontal navs */
        .no-scrollbar::-webkit-scrollbar {
            display: none;
        }
        .no-scrollbar {
            -ms-overflow-style: none;
            scrollbar-width: none;
        }
    </style>
</head>
<body>

    <!-- MAIN HEADER -->
    <header class="flex flex-col w-full bg-[#1b1b1b] border-b border-[#2a2a2a] shadow-lg sticky top-0 z-50">
        <div class="flex items-center h-16 px-6 gap-6 overflow-x-auto no-scrollbar">
            
            <!-- Navigation Controls -->
            <div class="flex items-center mr-2 flex-shrink-0">
                <button id="navBackBtn" class="flex items-center justify-center w-8 h-10 bg-[#2a2d35] border border-blue-500/50 rounded-l hover:bg-[#353842] transition-colors group relative opacity-50 cursor-not-allowed">
                    <div class="absolute inset-0 border border-blue-400/30 rounded-l opacity-50"></div>
                    <i data-lucide="chevron-left" class="w-5 h-5 text-gray-500 group-hover:text-white"></i>
                </button>
                <button id="navForwardBtn" class="flex items-center justify-center w-8 h-10 bg-[#1f1f1f] hover:bg-[#2a2a2a] transition-colors rounded-r border-y border-r border-[#333] opacity-50 cursor-not-allowed">
                    <i data-lucide="chevron-right" class="w-5 h-5 text-gray-500"></i>
                </button>
            </div>

            <!-- Logo -->
            <div class="flex-shrink-0 mr-4">
                <div class="h-12 w-auto flex items-center justify-center">
                    <img 
                      src="https://weareypi.com/wp-content/uploads/2025/06/Site-Icon-3.png" 
                      alt="Team Logo" 
                      class="h-full w-auto object-contain drop-shadow-md"
                      onerror="this.src='https://via.placeholder.com/150x50?text=LOGO';this.onerror=null;"
                    />
                </div>
            </div>

            <!-- Main Navigation Menu (Generated by JS) -->
            <nav class="flex items-center gap-2" id="main-nav">
                <!-- Nav items will appear here -->
            </nav>
        </div>
    </header>

    <!-- MAIN CONTENT AREA -->
    <div class="main-content w-full">
        
        <!-- 1. VISION SECTION -->
        <section id="content-Vision" class="tab-content trigger-container active">
            <!-- SUB-HEADER -->
            <div class="w-full bg-[#2a2d35] border-b border-[#2a2a2a] py-3 px-6 mb-6 flex items-center justify-between gap-4 rounded-lg shadow-sm overflow-x-auto no-scrollbar">
                <div class="flex items-center gap-6 flex-shrink-0">
                     <nav class="flex gap-5 text-sm font-medium">
                        <button class="subnav-btn text-white border-b-2 border-[#37af4b] pb-0.5 whitespace-nowrap">Overview</button>
                        <button class="subnav-btn text-gray-400 hover:text-white transition-colors whitespace-nowrap">Partnerships</button>
                        <button class="subnav-btn text-gray-400 hover:text-white transition-colors whitespace-nowrap">Partner Profile</button>
                        <button class="subnav-btn text-gray-400 hover:text-white transition-colors whitespace-nowrap">Trust & Sentiment</button>
                        <button class="subnav-btn text-gray-400 hover:text-white transition-colors whitespace-nowrap">Report Incident</button>
                        <button class="subnav-btn text-gray-400 hover:text-white transition-colors whitespace-nowrap">Recruitment</button>
                        <button class="subnav-btn text-gray-400 hover:text-white transition-colors whitespace-nowrap">Impact Reports</button>
                     </nav>
                </div>
                <div class="flex items-center gap-4 flex-shrink-0">
                     <div class="flex items-center gap-2 mr-2">
                        <button class="p-1.5 text-gray-400 hover:text-white hover:bg-white/5 rounded" title="Filter"><i data-lucide="filter" class="w-4 h-4"></i></button>
                        <button class="p-1.5 text-gray-400 hover:text-white hover:bg-white/5 rounded" title="Export"><i data-lucide="download" class="w-4 h-4"></i></button>
                     </div>
                     <div class="h-8 w-[1px] bg-gray-700"></div>
                     <div class="text-right hidden sm:block">
                        <div class="text-xs text-gray-400">Active Volunteers</div>
                        <div class="text-sm font-bold text-[#98fb98]">128</div>
                     </div>
                     <div class="h-8 w-[1px] bg-gray-700 hidden sm:block"></div>
                     <button class="flex items-center gap-2 text-sm font-medium text-gray-300 hover:text-white transition-colors"><i data-lucide="settings" class="w-4 h-4"></i> Settings</button>
                </div>
            </div>
            <div class="content-area">Vision Dashboard Content</div>
        </section>

        <!-- 2. ORGANIZING SECTION -->
        <section id="content-Organizing" class="tab-content trigger-container">
            <!-- SUB-HEADER -->
            <div class="w-full bg-[#2a2d35] border-b border-[#2a2a2a] py-3 px-6 mb-6 flex items-center justify-between gap-4 rounded-lg shadow-sm overflow-x-auto no-scrollbar">
                <div class="flex items-center gap-6 flex-shrink-0">
                     <nav class="flex gap-5 text-sm font-medium">
                        <button class="subnav-btn text-white border-b-2 border-[#37af4b] pb-0.5 whitespace-nowrap">Calendar</button>
                        <button class="subnav-btn text-gray-400 hover:text-white transition-colors whitespace-nowrap">Canvassing</button>
                        <button class="subnav-btn text-gray-400 hover:text-white transition-colors whitespace-nowrap">Phone Banking</button>
                        <button class="subnav-btn text-gray-400 hover:text-white transition-colors whitespace-nowrap">Events</button>
                        <button class="subnav-btn text-gray-400 hover:text-white transition-colors whitespace-nowrap">Volunteers</button>
                        <button class="subnav-btn text-gray-400 hover:text-white transition-colors whitespace-nowrap">Territory Map</button>
                     </nav>
                </div>
                <div class="flex items-center gap-4 flex-shrink-0">
                     <div class="flex items-center gap-2 mr-2">
                        <button class="p-1.5 text-gray-400 hover:text-white hover:bg-white/5 rounded" title="Filter"><i data-lucide="filter" class="w-4 h-4"></i></button>
                        <button class="p-1.5 text-gray-400 hover:text-white hover:bg-white/5 rounded" title="Export"><i data-lucide="download" class="w-4 h-4"></i></button>
                     </div>
                     <div class="h-8 w-[1px] bg-gray-700"></div>
                     <div class="text-right hidden sm:block">
                        <div class="text-xs text-gray-400">Shifts Scheduled</div>
                        <div class="text-sm font-bold text-[#98fb98]">42</div>
                     </div>
                     <div class="h-8 w-[1px] bg-gray-700 hidden sm:block"></div>
                     <button class="flex items-center gap-2 text-sm font-medium text-gray-300 hover:text-white transition-colors"><i data-lucide="settings" class="w-4 h-4"></i> Settings</button>
                </div>
            </div>
            <div class="content-area">Organizing Tools & Calendar</div>
        </section>

        <!-- 3. FINANCIALS SECTION -->
        <section id="content-Financials" class="tab-content trigger-container">
            <div class="content-area">Financial Reports & Budgets</div>
        </section>

        <!-- 4. DATA SUITE SECTION -->
        <section id="content-Data Suite" class="tab-content trigger-container">
            <!-- SUB-HEADER -->
            <div class="w-full bg-[#2a2d35] border-b border-[#2a2a2a] py-3 px-6 mb-6 flex items-center justify-between gap-4 rounded-lg shadow-sm overflow-x-auto no-scrollbar">
                <div class="flex items-center gap-6 flex-shrink-0">
                     <nav class="flex gap-5 text-sm font-medium">
                        <button class="subnav-btn text-white border-b-2 border-[#37af4b] pb-0.5 whitespace-nowrap">Voter File</button>
                        <button class="subnav-btn text-gray-400 hover:text-white transition-colors whitespace-nowrap">Demographics</button>
                        <button class="subnav-btn text-gray-400 hover:text-white transition-colors whitespace-nowrap">Turnout Models</button>
                        <button class="subnav-btn text-gray-400 hover:text-white transition-colors whitespace-nowrap">Surveys</button>
                        <button class="subnav-btn text-gray-400 hover:text-white transition-colors whitespace-nowrap">Custom Reports</button>
                     </nav>
                </div>
                <div class="flex items-center gap-4 flex-shrink-0">
                     <div class="flex items-center gap-2 mr-2">
                        <button class="p-1.5 text-gray-400 hover:text-white hover:bg-white/5 rounded" title="Search"><i data-lucide="search" class="w-4 h-4"></i></button>
                        <button class="p-1.5 text-gray-400 hover:text-white hover:bg-white/5 rounded" title="Import"><i data-lucide="upload" class="w-4 h-4"></i></button>
                     </div>
                     <div class="h-8 w-[1px] bg-gray-700"></div>
                     <div class="text-right hidden sm:block">
                        <div class="text-xs text-gray-400">Records Updated</div>
                        <div class="text-sm font-bold text-[#98fb98]">2.4K</div>
                     </div>
                     <div class="h-8 w-[1px] bg-gray-700 hidden sm:block"></div>
                     <button class="flex items-center gap-2 text-sm font-medium text-gray-300 hover:text-white transition-colors"><i data-lucide="settings" class="w-4 h-4"></i> Settings</button>
                </div>
            </div>
            <div class="content-area">Analytics & Data Management</div>
        </section>

        <!-- 5. PROJECTS SECTION -->
        <section id="content-Projects" class="tab-content trigger-container">
            <!-- SUB-HEADER -->
            <div class="w-full bg-[#2a2d35] border-b border-[#2a2a2a] py-3 px-6 mb-6 flex items-center justify-between gap-4 rounded-lg shadow-sm overflow-x-auto no-scrollbar">
                <div class="flex items-center gap-6 flex-shrink-0">
                     <nav class="flex gap-5 text-sm font-medium">
                        <button class="subnav-btn text-white border-b-2 border-[#37af4b] pb-0.5 whitespace-nowrap">Active Initiatives</button>
                        <button class="subnav-btn text-gray-400 hover:text-white transition-colors whitespace-nowrap">Proposed</button>
                        <button class="subnav-btn text-gray-400 hover:text-white transition-colors whitespace-nowrap">Completed</button>
                        <button class="subnav-btn text-gray-400 hover:text-white transition-colors whitespace-nowrap">Resources</button>
                        <button class="subnav-btn text-gray-400 hover:text-white transition-colors whitespace-nowrap">Timeline</button>
                     </nav>
                </div>
                <div class="flex items-center gap-4 flex-shrink-0">
                     <div class="flex items-center gap-2 mr-2">
                        <button class="p-1.5 text-gray-400 hover:text-white hover:bg-white/5 rounded" title="Kanban"><i data-lucide="layout-grid" class="w-4 h-4"></i></button>
                        <button class="p-1.5 text-gray-400 hover:text-white hover:bg-white/5 rounded" title="List"><i data-lucide="list" class="w-4 h-4"></i></button>
                     </div>
                     <div class="h-8 w-[1px] bg-gray-700"></div>
                     <div class="text-right hidden sm:block">
                        <div class="text-xs text-gray-400">Projects On Track</div>
                        <div class="text-sm font-bold text-[#98fb98]">8/10</div>
                     </div>
                     <div class="h-8 w-[1px] bg-gray-700 hidden sm:block"></div>
                     <button class="flex items-center gap-2 text-sm font-medium text-gray-300 hover:text-white transition-colors"><i data-lucide="plus" class="w-4 h-4"></i> New</button>
                </div>
            </div>
            <div class="content-area">Project Management Dashboard</div>
        </section>

        <!-- 6. MARKETING SECTION -->
        <section id="content-Marketing" class="tab-content trigger-container">
            <!-- SUB-HEADER -->
            <div class="w-full bg-[#2a2d35] border-b border-[#2a2a2a] py-3 px-6 mb-6 flex items-center justify-between gap-4 rounded-lg shadow-sm overflow-x-auto no-scrollbar">
                <div class="flex items-center gap-6 flex-shrink-0">
                     <nav class="flex gap-5 text-sm font-medium">
                        <button class="subnav-btn text-white border-b-2 border-[#37af4b] pb-0.5 whitespace-nowrap">Assets</button>
                        <button class="subnav-btn text-gray-400 hover:text-white transition-colors whitespace-nowrap">Social Media</button>
                        <button class="subnav-btn text-gray-400 hover:text-white transition-colors whitespace-nowrap">Email Campaigns</button>
                        <button class="subnav-btn text-gray-400 hover:text-white transition-colors whitespace-nowrap">Press</button>
                        <button class="subnav-btn text-gray-400 hover:text-white transition-colors whitespace-nowrap">Analytics</button>
                     </nav>
                </div>
                <div class="flex items-center gap-4 flex-shrink-0">
                     <div class="flex items-center gap-2 mr-2">
                        <button class="p-1.5 text-gray-400 hover:text-white hover:bg-white/5 rounded" title="Upload"><i data-lucide="upload-cloud" class="w-4 h-4"></i></button>
                     </div>
                     <div class="h-8 w-[1px] bg-gray-700"></div>
                     <div class="text-right hidden sm:block">
                        <div class="text-xs text-gray-400">Total Reach</div>
                        <div class="text-sm font-bold text-[#98fb98]">1.2M</div>
                     </div>
                     <div class="h-8 w-[1px] bg-gray-700 hidden sm:block"></div>
                     <button class="flex items-center gap-2 text-sm font-medium text-gray-300 hover:text-white transition-colors"><i data-lucide="settings" class="w-4 h-4"></i> Settings</button>
                </div>
            </div>
            <div class="content-area">Marketing & Communications Hub</div>
        </section>

        <!-- 7. DONORS SECTION -->
        <section id="content-Donors" class="tab-content trigger-container">
            <!-- SUB-HEADER -->
            <div class="w-full bg-[#2a2d35] border-b border-[#2a2a2a] py-3 px-6 mb-6 flex items-center justify-between gap-4 rounded-lg shadow-sm overflow-x-auto no-scrollbar">
                <div class="flex items-center gap-6 flex-shrink-0">
                     <nav class="flex gap-5 text-sm font-medium">
                        <button class="subnav-btn text-white border-b-2 border-[#37af4b] pb-0.5 whitespace-nowrap">Donor Database</button>
                        <button class="subnav-btn text-gray-400 hover:text-white transition-colors whitespace-nowrap">Major Gifts</button>
                        <button class="subnav-btn text-gray-400 hover:text-white transition-colors whitespace-nowrap">Recurring Giving</button>
                        <button class="subnav-btn text-gray-400 hover:text-white transition-colors whitespace-nowrap">Events</button>
                        <button class="subnav-btn text-gray-400 hover:text-white transition-colors whitespace-nowrap">Comms Log</button>
                     </nav>
                </div>
                <div class="flex items-center gap-4 flex-shrink-0">
                     <div class="flex items-center gap-2 mr-2">
                        <button class="p-1.5 text-gray-400 hover:text-white hover:bg-white/5 rounded" title="Add Donor"><i data-lucide="user-plus" class="w-4 h-4"></i></button>
                        <button class="p-1.5 text-gray-400 hover:text-white hover:bg-white/5 rounded" title="Export"><i data-lucide="download" class="w-4 h-4"></i></button>
                     </div>
                     <div class="h-8 w-[1px] bg-gray-700"></div>
                     <div class="text-right hidden sm:block">
                        <div class="text-xs text-gray-400">YTD Raised</div>
                        <div class="text-sm font-bold text-[#98fb98]">$450K</div>
                     </div>
                     <div class="h-8 w-[1px] bg-gray-700 hidden sm:block"></div>
                     <button class="flex items-center gap-2 text-sm font-medium text-gray-300 hover:text-white transition-colors"><i data-lucide="settings" class="w-4 h-4"></i> Settings</button>
                </div>
            </div>
            <div class="content-area">Donor Relations & Fundraising</div>
        </section>

    </div>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            
            // --- MAIN NAVIGATION LOGIC ---
            const navItems = ['Vision', 'Organizing', 'Financials', 'Data Suite', 'Projects', 'Marketing', 'Donors'];
            const navContainer = document.getElementById('main-nav');
            
            // History State
            const navHistory = ['Vision'];
            let historyIndex = 0;
            const navBackBtn = document.getElementById('navBackBtn');
            const navForwardBtn = document.getElementById('navForwardBtn');

            function updateNavButtons() {
                // Lucide replaces <i> with <svg>, so we need to check for either
                const backIcon = navBackBtn.querySelector('i') || navBackBtn.querySelector('svg');
                const forwardIcon = navForwardBtn.querySelector('i') || navForwardBtn.querySelector('svg');

                // Back Button State
                if (historyIndex > 0) {
                    navBackBtn.classList.remove('opacity-50', 'cursor-not-allowed');
                    if(backIcon) backIcon.classList.replace('text-gray-500', 'text-gray-300');
                } else {
                    navBackBtn.classList.add('opacity-50', 'cursor-not-allowed');
                    if(backIcon) backIcon.classList.replace('text-gray-300', 'text-gray-500');
                }

                // Forward Button State
                if (historyIndex < navHistory.length - 1) {
                    navForwardBtn.classList.remove('opacity-50', 'cursor-not-allowed');
                    if(forwardIcon) forwardIcon.classList.replace('text-gray-500', 'text-gray-300');
                } else {
                    navForwardBtn.classList.add('opacity-50', 'cursor-not-allowed');
                    if(forwardIcon) forwardIcon.classList.replace('text-gray-300', 'text-gray-500');
                }
            }

            function navigateTo(tabName, isHistoryNav = false) {
                // 1. Manage History
                if (!isHistoryNav) {
                    // If we are in the middle of the stack and click a new tab, clear forward history
                    if (historyIndex < navHistory.length - 1) {
                        navHistory.splice(historyIndex + 1);
                    }
                    // Only push if it's different from current to avoid duplicates
                    if (navHistory[historyIndex] !== tabName) {
                        navHistory.push(tabName);
                        historyIndex = navHistory.length - 1;
                    }
                }

                // 2. Show Content
                showTabContent(tabName);

                // 3. Update Nav UI (Highlight Active Tab)
                Array.from(navContainer.children).forEach(btn => {
                    const span = btn.querySelector('span');
                    if (span && span.innerText === tabName) {
                        btn.className = 'group flex items-center px-3 py-2 text-xl font-bold tracking-tight font-fm-header transition-all cursor-pointer text-[#98fb98] drop-shadow-[0_0_8px_rgba(152,251,152,0.25)] scale-105';
                    } else {
                        btn.className = 'group flex items-center px-3 py-2 text-xl font-bold tracking-tight font-fm-header transition-all cursor-pointer text-gray-400 hover:text-white hover:scale-105';
                    }
                });

                // 4. Update Controls
                updateNavButtons();
            }

            function showTabContent(tabName) {
                // Hide all tabs
                document.querySelectorAll('.tab-content').forEach(s => s.classList.remove('active'));
                
                // Show selected tab
                const t = document.getElementById(`content-${tabName}`);
                if (t) {
                    t.classList.add('active');
                }
            }

            // Generate Nav Buttons
            navItems.forEach(item => {
                const btn = document.createElement('button');
                const isActive = item === 'Vision'; // Default start
                
                btn.className = `group flex items-center px-3 py-2 text-xl font-bold tracking-tight font-fm-header transition-all cursor-pointer ${isActive ? 'text-[#98fb98] drop-shadow-[0_0_8px_rgba(152,251,152,0.25)] scale-105' : 'text-gray-400 hover:text-white hover:scale-105'}`;
                btn.innerHTML = `<span>${item}</span>`;
                
                btn.addEventListener('click', function() {
                    navigateTo(item);
                });
                
                navContainer.appendChild(btn);
            });

            // Initialize view
            // Note: We don't call navigateTo('Vision') here to avoid double pushing, 
            // but we do need to set initial button state.
            showTabContent('Vision');
            updateNavButtons();

            // --- HEADER BUTTON LISTENERS ---
            navBackBtn.addEventListener('click', () => {
                if (historyIndex > 0) {
                    historyIndex--;
                    navigateTo(navHistory[historyIndex], true);
                }
            });

            navForwardBtn.addEventListener('click', () => {
                if (historyIndex < navHistory.length - 1) {
                    historyIndex++;
                    navigateTo(navHistory[historyIndex], true);
                }
            });

            // --- SUB-NAVIGATION LOGIC (Universal) ---
            const subNavBtns = document.querySelectorAll('.subnav-btn');
            
            subNavBtns.forEach(btn => {
                btn.addEventListener('click', function() {
                    // Scope reset to the specific container of the clicked button
                    const container = this.closest('nav');
                    if(container) {
                        const siblings = container.querySelectorAll('.subnav-btn');
                        siblings.forEach(b => {
                            b.className = 'subnav-btn text-gray-400 hover:text-white transition-colors whitespace-nowrap';
                        });
                    }
                    
                    // Activate clicked button
                    this.className = 'subnav-btn text-white border-b-2 border-[#37af4b] pb-0.5 whitespace-nowrap';
                });
            });

            // Initialize Icons
            lucide.createIcons();
        });
    </script>
</body>
</html>
