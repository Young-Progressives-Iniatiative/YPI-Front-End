<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Dashboard Template - Dynamic Headers</title>
<!-- Tailwind CSS -->
<script src="https://cdn.tailwindcss.com"></script>
<!-- Google Fonts: Atkinson Hyperlegible -->
<link href="https://fonts.googleapis.com/css2?family=Atkinson+Hyperlegible:ital,wght@0,400;0,700;1,400;1,700&display=swap" rel="stylesheet">
<!-- Lucide Icons -->
<script src="https://unpkg.com/lucide@latest"></script>
<style>
/* --- CORE THEME VARIABLES --- */
:root {
--bg-main: #1c1c1c;
--bg-panel: #1b1b1b;
--bg-element: #2a2d35;
--text-main: #ffffff;
--text-muted: #9ca3af;
--border-color: #2a2a2a;
--accent-green: #37af4b;
--highlight-green: #98fb98;
--nav-inactive: #9ca3af;
--nav-active: #98fb98;
--notification-red: #ef4444;
}
/* --- LIGHT MODE OVERRIDES --- */
body.light-mode {
--bg-main: #f3f4f6;
--bg-panel: #ffffff;
--bg-element: #e5e7eb;
--text-main: #111827;
--text-muted: #4b5563;
--border-color: #d1d5db;
--accent-green: #16a34a;
--highlight-green: #15803d;
--nav-inactive: #6b7280;
--nav-active: #16a34a;
}
body {
font-family: 'Atkinson Hyperlegible', sans-serif;
background-color: var(--bg-main);
color: var(--text-main);
margin: 0;
overflow-x: hidden;
transition: background-color 0.3s ease, color 0.3s ease;
}
.font-fm-header {
font-family: 'Atkinson Hyperlegible', sans-serif;
}
/* --- LOGO INVERSION --- */
.logo-img {
transition: filter 0.3s ease;
}
body.light-mode .logo-img {
filter: invert(1);
}
/* --- TAB CONTENT STYLES --- */
.tab-content {
display: none;
animation: fadeIn 0.4s ease-out;
width: 100%;
}
.tab-content.active {
display: flex;
flex-direction: column;
}
@keyframes fadeIn {
from { opacity: 0; transform: translateY(10px); }
to { opacity: 1; transform: translateY(0); }
}
/* --- LAYOUT --- */
.trigger-container {
flex-direction: column;
align-items: center;
justify-content: flex-start;
min-height: calc(100vh - 80px); /* Adjusted for header height */
text-align: center;
padding: 0;
}
/* Content Area Placeholder */
.content-area {
width: 100%;
display: flex;
align-items: center;
justify-content: center;
height: 60vh;
color: var(--text-muted);
font-style: italic;
padding: 2rem;
}
/* Custom Scrollbar for horizontal navs */
.no-scrollbar::-webkit-scrollbar {
display: none;
}
.no-scrollbar {
-ms-overflow-style: none;
scrollbar-width: none;
}
/* Theme-aware utilities */
.theme-bg-panel { background-color: var(--bg-panel); }
.theme-bg-element { background-color: var(--bg-element); }
.theme-border { border-color: var(--border-color); }
.theme-text-muted { color: var(--text-muted); }
.theme-text-main { color: var(--text-main); }
</style>
</head>
<body>
<!-- MAIN HEADER -->
<header class="flex flex-col w-full theme-bg-panel border-b theme-border shadow-lg sticky top-0 z-50 transition-colors">
<div class="flex items-center h-16 px-6 gap-6">
<!-- Navigation Controls -->
<div class="flex items-center mr-2 flex-shrink-0">
<button id="navBackBtn" class="flex items-center justify-center w-8 h-10 theme-bg-element border border-blue-500/50 rounded-l hover:opacity-80 transition-all group relative opacity-50 cursor-not-allowed">
<div class="absolute inset-0 border border-blue-400/30 rounded-l opacity-50"></div>
<i data-lucide="chevron-left" class="w-5 h-5 theme-text-muted group-hover:theme-text-main"></i>
</button>
<button id="navForwardBtn" class="flex items-center justify-center w-8 h-10 theme-bg-panel hover:theme-bg-element transition-colors rounded-r border-y border-r theme-border opacity-50 cursor-not-allowed">
<i data-lucide="chevron-right" class="w-5 h-5 theme-text-muted"></i>
</button>
</div>
<!-- Logo -->
<div class="flex-shrink-0 mr-4">
<div class="h-12 w-auto flex items-center justify-center">
<img
src="https://weareypi.com/wp-content/uploads/2025/06/Site-Icon-3.png"
alt="Team Logo"
class="h-full w-auto object-contain drop-shadow-md logo-img"
onerror="this.src='https://via.placeholder.com/150x50?text=LOGO';this.onerror=null;"
/>
</div>
</div>
<!-- Main Navigation Menu (Generated by JS) -->
<nav class="flex items-center gap-2 flex-1 overflow-x-auto no-scrollbar" id="main-nav">
<!-- Nav items will appear here -->
</nav>
<div class="flex items-center gap-2 flex-shrink-0">
<!-- Notification Container with Hover Dropdown -->
<div class="relative group/notif">
<button id="notifToggle" class="relative flex items-center justify-center p-2 rounded-full theme-bg-element hover:opacity-80 transition-all text-[var(--text-main)]" title="Notifications">
<!-- Unread Count Badge -->
<span id="notifBadge" class="absolute -top-1 -right-1 bg-red-500 text-white text-[10px] font-bold px-1.5 py-0.5 rounded-full border-2 border-[var(--bg-panel)] flex items-center justify-center min-w-[18px]">
3
</span>
<!-- Dark Mode Bell (Filled) -->
<span id="notifIconDark" class="">
<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" class="bi bi-bell-fill" viewBox="0 0 16 16">
<path d="M8 16a2 2 0 0 0 2-2H6a2 2 0 0 0 2 2m.995-14.901a1 1 0 1 0-1.99 0A5 5 0 0 0 3 6c0 1.098-.5 6-2 7h14c-1.5-1-2-5.902-2-7 0-2.42-1.72-4.44-4.005-4.901"/>
</svg>
</span>
<!-- Light Mode Bell (Hollow) -->
<span id="notifIconLight" class="hidden">
<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" class="bi bi-bell" viewBox="0 0 16 16">
<path d="M8 16a2 2 0 0 0 2-2H6a2 2 0 0 0 2 2M8 1.918l-.797.161A4 4 0 0 0 4 6c0 .628-.134 2.197-.459 3.742-.16.767-.376 1.566-.663 2.258h10.244c-.287-.692-.502-1.49-.663-2.258C12.134 8.197 12 6.628 12 6a4 4 0 0 0-3.203-3.92zM14.22 12c.223.447.481.801.78 1H1c.299-.199.557-.553.78-1C2.68 10.2 3 6.88 3 6c0-2.42 1.72-4.44 4.005-4.901a1 1 0 1 1 1.99 0A5 5 0 0 1 13 6c0 .88.32 4.2 1.22 6"/>
</svg>
</span>
</button>
<!-- Push Notifications Dropdown -->
<div class="absolute right-0 top-full pt-2 invisible group-hover/notif:visible opacity-0 group-hover/notif:opacity-100 translate-y-2 group-hover/notif:translate-y-0 transition-all duration-200 z-[60] w-80">
<div class="theme-bg-panel border theme-border shadow-2xl rounded-xl overflow-hidden flex flex-col">
<div class="p-4 border-b theme-border flex justify-between items-center">
<h3 class="font-bold text-sm">Notifications</h3>
<button class="text-xs text-[var(--accent-green)] hover:underline">Mark all read</button>
</div>
<div class="max-h-96 overflow-y-auto no-scrollbar">
<!-- Notification Item 1 -->
<div class="p-4 border-b theme-border hover:theme-bg-element transition-colors cursor-pointer flex gap-3">
<div class="w-8 h-8 rounded-full bg-green-500/20 flex items-center justify-center flex-shrink-0 text-green-500">
<i data-lucide="user-plus" class="w-4 h-4"></i>
</div>
<div class="flex flex-col text-left">
<p class="text-xs font-semibold theme-text-main">New Volunteer registered</p>
<p class="text-[10px] theme-text-muted mt-0.5">Alex Johnson joined the Organizing team in District 4.</p>
<p class="text-[9px] theme-text-muted mt-1">2 mins ago</p>
</div>
</div>
<!-- Notification Item 2 -->
<div class="p-4 border-b theme-border hover:theme-bg-element transition-colors cursor-pointer flex gap-3">
<div class="w-8 h-8 rounded-full bg-blue-500/20 flex items-center justify-center flex-shrink-0 text-blue-500">
<i data-lucide="dollar-sign" class="w-4 h-4"></i>
</div>
<div class="flex flex-col text-left">
<p class="text-xs font-semibold theme-text-main">Major donation received</p>
<p class="text-[10px] theme-text-muted mt-0.5">Recurring donor "Legacy Trust" just contributed $2,500.</p>
<p class="text-[9px] theme-text-muted mt-1">45 mins ago</p>
</div>
</div>
<!-- Notification Item 3 -->
<div class="p-4 border-b theme-border hover:theme-bg-element transition-colors cursor-pointer flex gap-3">
<div class="w-8 h-8 rounded-full bg-amber-500/20 flex items-center justify-center flex-shrink-0 text-amber-500">
<i data-lucide="alert-triangle" class="w-4 h-4"></i>
</div>
<div class="flex flex-col text-left">
<p class="text-xs font-semibold theme-text-main">Campaign Deadline Approaching</p>
<p class="text-[10px] theme-text-muted mt-0.5">Voter file updates for Q4 must be finalized by Friday.</p>
<p class="text-[9px] theme-text-muted mt-1">2 hours ago</p>
</div>
</div>
</div>
<div class="p-3 theme-bg-element text-center">
<button class="text-[10px] theme-text-muted hover:theme-text-main transition-colors font-medium">View all activity history</button>
</div>
</div>
</div>
</div>
<!-- Theme Toggle Button -->
<button id="themeToggle" class="flex items-center justify-center p-2 rounded-full theme-bg-element hover:opacity-80 transition-all text-[var(--text-main)]" title="Toggle Theme">
<span id="themeIconSun" class="">
<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" class="bi bi-sun-fill" viewBox="0 0 16 16">
<path d="M8 12a4 4 0 1 0 0-8 4 4 0 0 0 0 8M8 0a.5.5 0 0 1 .5.5v2a.5.5 0 0 1-1 0v-2A.5.5 0 0 1 8 0m0 13a.5.5 0 0 1 .5.5v2a.5.5 0 0 1-1 0v-2A.5.5 0 0 1 8 13m8-5a.5.5 0 0 1-.5.5h-2a.5.5 0 0 1 0-1h2a.5.5 0 0 1 .5.5M3 8a.5.5 0 0 1-.5.5h-2a.5.5 0 0 1 0-1h2A.5.5 0 0 1 3 8m10.657-5.657a.5.5 0 0 1 0 .707l-1.414 1.415a.5.5 0 1 1-.707-.708l1.414-1.414a.5.5 0 0 1 .707 0m-9.193 9.193a.5.5 0 0 1 0 .707L3.05 13.657a.5.5 0 0 1-.707-.707l1.414-1.414a.5.5 0 0 1 .707 0m9.193 2.121a.5.5 0 0 1-.707 0l-1.414-1.414a.5.5 0 0 1 .707-.707l1.414 1.414a.5.5 0 0 1 0 .707M4.464 4.465a.5.5 0 0 1-.707 0L2.343 3.05a.5.5 0 1 1 .707-.707l1.414 1.414a.5.5 0 0 1 0 .708"/>
</svg>
</span>
<span id="themeIconMoon" class="hidden">
<i data-lucide="moon" class="w-[18px] h-[18px]"></i>
</span>
</button>
<!-- Log Out Button -->
<button id="logoutBtn" class="flex items-center gap-2 px-3 py-2 rounded-lg bg-red-500/10 hover:bg-red-500/20 text-red-500 transition-all font-medium text-sm ml-1 group" title="Log Out">
<i data-lucide="log-out" class="w-4 h-4 group-hover:translate-x-0.5 transition-transform"></i>
<span class="hidden lg:inline">Log Out</span>
</button>
</div>
</div>
</header>

<!-- DYNAMIC SUB-HEADER CONTAINER -->
<!-- This bar appears below the main header and changes based on the selected tab -->
<div id="dynamic-subheader" class="w-full theme-bg-element border-b theme-border py-3 px-6 mb-6 flex items-center justify-between gap-4 shadow-sm transition-colors">
    <!-- Content injected via JS -->
</div>

<!-- MAIN CONTENT AREA -->
<div class="main-content w-full px-6">
<section id="content-Vision" class="tab-content trigger-container active">
<div class="content-area">Vision Dashboard Content</div>
</section>
<!-- Other sections -->
<section id="content-Organizing" class="tab-content trigger-container">
<div class="content-area">Organizing Tools & Calendar</div>
</section>
<section id="content-Financials" class="tab-content trigger-container">
<div class="content-area">Financial Reports & Budgets</div>
</section>
<section id="content-Data Suite" class="tab-content trigger-container">
<div class="content-area">Analytics & Data Management</div>
</section>
<section id="content-Projects" class="tab-content trigger-container">
<div class="content-area">Project Management Dashboard</div>
</section>
<section id="content-Marketing" class="tab-content trigger-container">
<div class="content-area">Marketing & Communications Hub</div>
</section>
<section id="content-Donors" class="tab-content trigger-container">
<div class="content-area">Donor Relations & Fundraising</div>
</section>
</div>

<script>
document.addEventListener('DOMContentLoaded', () => {
// --- DATA CONFIGURATION FOR SUBHEADERS ---
// Define what buttons appear in the sub-header for each section
const sectionData = {
'Vision': {
title: 'Overview',
items: ['Overview', 'Partnerships', 'Partner Profile', 'Trust & Sentiment', 'Report Incident', 'Recruitment', 'Impact Reports'],
actions: ['Filter', 'Export']
},
'Organizing': {
title: 'Field Operations',
items: ['Canvassing', 'Phone Banking', 'Events Calendar', 'Volunteer Shifts', 'Turf Cutting', 'Walk Lists'],
actions: ['New Event', 'Sync VAN']
},
'Financials': {
title: 'Budget Center',
items: ['P&L Statement', 'Cash Flow', 'Expense Reports', 'Invoices', 'Payroll', 'Audit Logs'],
actions: ['Add Expense', 'Download CSV']
},
'Data Suite': {
title: 'Analytics',
items: ['Voter File', 'Demographics', 'Polling Data', 'Custom Queries', 'API Keys', 'Data Hygiene'],
actions: ['Run Query', 'Connect Source']
},
'Projects': {
title: 'Task Manager',
items: ['Kanban Board', 'Timeline View', 'My Tasks', 'Team Workload', 'Archived Projects'],
actions: ['New Project', 'Invite Member']
},
'Marketing': {
title: 'Comms Hub',
items: ['Social Media', 'Email Campaigns', 'Press Releases', 'Asset Library', 'Brand Guidelines'],
actions: ['Create Post', 'Send Blast']
},
'Donors': {
title: 'Fundraising',
items: ['Donor List', 'Major Gifts', 'Recurring Donors', 'Grant Tracking', 'Thank You Letters'],
actions: ['Log Donation', 'Segment List']
}
};

// --- THEME TOGGLE LOGIC ---
const themeToggle = document.getElementById('themeToggle');
const sunIcon = document.getElementById('themeIconSun');
const moonIcon = document.getElementById('themeIconMoon');
const notifIconDark = document.getElementById('notifIconDark');
const notifIconLight = document.getElementById('notifIconLight');
const body = document.body;

themeToggle.addEventListener('click', () => {
body.classList.toggle('light-mode');
const isLight = body.classList.contains('light-mode');
if (isLight) {
sunIcon.classList.add('hidden');
moonIcon.classList.remove('hidden');
notifIconDark.classList.add('hidden');
notifIconLight.classList.remove('hidden');
} else {
sunIcon.classList.remove('hidden');
moonIcon.classList.add('hidden');
notifIconDark.classList.remove('hidden');
notifIconLight.classList.add('hidden');
}
// Re-render current tab's subheader to catch theme changes if needed
const activeTabName = navHistory[historyIndex];
renderSubHeader(activeTabName);
});

// --- NAVIGATION LOGIC ---
const navItems = ['Vision', 'Organizing', 'Financials', 'Data Suite', 'Projects', 'Marketing', 'Donors'];
const navContainer = document.getElementById('main-nav');
const navHistory = ['Vision'];
let historyIndex = 0;

const navBackBtn = document.getElementById('navBackBtn');
const navForwardBtn = document.getElementById('navForwardBtn');

function updateNavButtons() {
const backIcon = navBackBtn.querySelector('i') || navBackBtn.querySelector('svg');
const forwardIcon = navForwardBtn.querySelector('i') || navForwardBtn.querySelector('svg');
if (historyIndex > 0) {
navBackBtn.classList.remove('opacity-50', 'cursor-not-allowed');
if(backIcon) backIcon.style.color = 'var(--text-main)';
} else {
navBackBtn.classList.add('opacity-50', 'cursor-not-allowed');
if(backIcon) backIcon.style.color = 'var(--text-muted)';
}
if (historyIndex < navHistory.length - 1) {
navForwardBtn.classList.remove('opacity-50', 'cursor-not-allowed');
if(forwardIcon) forwardIcon.style.color = 'var(--text-main)';
} else {
navForwardBtn.classList.add('opacity-50', 'cursor-not-allowed');
if(forwardIcon) forwardIcon.style.color = 'var(--text-muted)';
}
}

function renderSubHeader(tabName) {
const container = document.getElementById('dynamic-subheader');
const data = sectionData[tabName] || { items: [], actions: [] };

// Build Left Side (Menu Items)
let leftHtml = `<div class="flex items-center gap-6 flex-shrink-0 overflow-x-auto no-scrollbar">
<nav class="flex gap-5 text-sm font-medium">`;

data.items.forEach((item, index) => {
const isActive = index === 0; // Default first item active
const activeClass = isActive ? 'theme-text-main border-b-2 border-[var(--accent-green)] pb-0.5' : 'theme-text-muted hover:theme-text-main transition-colors';
leftHtml += `<button class="subnav-btn ${activeClass} whitespace-nowrap">${item}</button>`;
});
leftHtml += `</nav></div>`;

// Build Right Side (Actions & Stats)
let rightHtml = `<div class="flex items-center gap-4 flex-shrink-0">
<div class="flex items-center gap-2 mr-2">`;

data.actions.forEach(action => {
// Simple icon mapping for demo purposes
let iconName = 'plus';
if(action.includes('Filter')) iconName = 'filter';
if(action.includes('Export') || action.includes('CSV')) iconName = 'download';
if(action.includes('Sync')) iconName = 'refresh-cw';

rightHtml += `<button class="p-1.5 theme-text-muted hover:theme-text-main hover:bg-white/5 rounded flex items-center gap-1 text-xs" title="${action}">
${action.includes('Filter') || action.includes('Export') || action.includes('Sync') ? `<i data-lucide="${iconName}" class="w-3 h-3"></i>` : ''}
${action}
</button>`;
});

rightHtml += `</div>
<div class="h-8 w-[1px] bg-gray-700/30"></div>
<div class="text-right hidden sm:block">
<div class="text-xs theme-text-muted">Active Items</div>
<div class="text-sm font-bold text-[var(--highlight-green)]">${Math.floor(Math.random() * 50) + 10}</div>
</div>
<div class="h-8 w-[1px] bg-gray-700/30 hidden sm:block"></div>
<button class="flex items-center gap-2 text-sm font-medium theme-text-muted hover:theme-text-main transition-colors"><i data-lucide="settings" class="w-4 h-4"></i> Settings</button>
</div>`;

container.innerHTML = leftHtml + rightHtml;

// Re-initialize icons for the new content
lucide.createIcons();

// Add click listeners to new subnav buttons
const subNavBtns = container.querySelectorAll('.subnav-btn');
subNavBtns.forEach(btn => {
btn.addEventListener('click', function() {
container.querySelectorAll('.subnav-btn').forEach(b => {
b.className = 'subnav-btn theme-text-muted hover:theme-text-main transition-colors whitespace-nowrap';
b.style.borderBottom = 'none';
});
this.className = 'subnav-btn theme-text-main border-b-2 border-[var(--accent-green)] pb-0.5 whitespace-nowrap';
});
});
}

function navigateTo(tabName, isHistoryNav = false) {
if (!isHistoryNav) {
if (historyIndex < navHistory.length - 1) navHistory.splice(historyIndex + 1);
if (navHistory[historyIndex] !== tabName) {
navHistory.push(tabName);
historyIndex = navHistory.length - 1;
}
}
showTabContent(tabName);
renderSubHeader(tabName); // Update the sub-header

// Update Main Nav Styling
Array.from(navContainer.children).forEach(btn => {
const span = btn.querySelector('span');
if (span && span.innerText === tabName) {
btn.style.color = 'var(--nav-active)';
btn.className = 'group flex items-center px-3 py-2 text-xl font-bold tracking-tight font-fm-header transition-all cursor-pointer scale-105';
btn.style.textShadow = '0 0 8px rgba(152,251,152,0.2)';
} else {
btn.style.color = 'var(--nav-inactive)';
btn.className = 'group flex items-center px-3 py-2 text-xl font-bold tracking-tight font-fm-header transition-all cursor-pointer hover:theme-text-main hover:scale-105';
btn.style.textShadow = 'none';
}
});
updateNavButtons();
}

function showTabContent(tabName) {
document.querySelectorAll('.tab-content').forEach(s => s.classList.remove('active'));
const t = document.getElementById(`content-${tabName}`);
if (t) t.classList.add('active');
}

// Initialize Main Nav
navItems.forEach(item => {
const btn = document.createElement('button');
btn.className = 'group flex items-center px-3 py-2 text-xl font-bold tracking-tight font-fm-header transition-all cursor-pointer hover:scale-105';
btn.innerHTML = `<span>${item}</span>`;
btn.style.color = item === 'Vision' ? 'var(--nav-active)' : 'var(--nav-inactive)';
btn.addEventListener('click', () => navigateTo(item));
navContainer.appendChild(btn);
});

// Initial Render
navigateTo('Vision');

navBackBtn.addEventListener('click', () => {
if (historyIndex > 0) { historyIndex--; navigateTo(navHistory[historyIndex], true); }
});
navForwardBtn.addEventListener('click', () => {
if (historyIndex < navHistory.length - 1) { historyIndex++; navigateTo(navHistory[historyIndex], true); }
});

// Logout Action
document.getElementById('logoutBtn').addEventListener('click', () => {
console.log('User logging out...');
});
});
</script>
</body>
</html>
