<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Header Component</title>
    
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    
    <!-- Google Fonts: Atkinson Hyperlegible -->
    <link href="https://fonts.googleapis.com/css2?family=Atkinson+Hyperlegible:ital,wght@0,400;0,700;1,400;1,700&display=swap" rel="stylesheet">
    
    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>

    <style>
        body {
            font-family: 'Atkinson Hyperlegible', sans-serif;
            background-color: #1c1c1c;
            color: white;
            margin: 0;
        }
        
        .font-fm-header {
            font-family: 'Atkinson Hyperlegible', sans-serif;
        }

        /* Custom scrollbar for horizontal scrolling if needed */
        ::-webkit-scrollbar {
            height: 4px;
        }
        ::-webkit-scrollbar-track {
            background: #1c1c1c; 
        }
        ::-webkit-scrollbar-thumb {
            background: #374151; 
            border-radius: 4px;
        }
    </style>
</head>
<body>

    <!-- EXTRACTED HEADER -->
    <header class="flex flex-col w-full bg-[#1b1b1b] border-b border-[#2a2a2a] shadow-lg">
        <div class="flex items-center h-16 px-6 gap-6 overflow-x-auto no-scrollbar">
            
            <!-- Navigation Controls -->
            <div class="flex items-center mr-2 flex-shrink-0">
                <button class="flex items-center justify-center w-8 h-10 bg-[#2a2d35] border border-blue-500/50 rounded-l hover:bg-[#353842] transition-colors group relative">
                    <div class="absolute inset-0 border border-blue-400/30 rounded-l opacity-50"></div>
                    <i data-lucide="chevron-left" class="w-5 h-5 text-gray-300 group-hover:text-white"></i>
                </button>
                <button class="flex items-center justify-center w-8 h-10 bg-[#1f1f1f] hover:bg-[#2a2a2a] transition-colors rounded-r border-y border-r border-[#333]">
                    <i data-lucide="chevron-right" class="w-5 h-5 text-gray-500"></i>
                </button>
            </div>

            <!-- Logo -->
            <div class="flex-shrink-0 mr-4">
                <div class="h-12 w-auto flex items-center justify-center">
                    <img 
                      src="https://weareypi.com/wp-content/uploads/2025/06/Site-Icon-3.png" 
                      alt="Team Logo" 
                      class="h-full w-auto object-contain drop-shadow-md"
                      onerror="this.src='https://via.placeholder.com/150x50?text=LOGO';this.onerror=null;"
                    />
                </div>
            </div>

            <!-- Navigation Menu -->
            <nav class="flex items-center gap-2" id="main-nav">
                <!-- Nav items generated by JS -->
            </nav>
        </div>
    </header>

    <script>
        document.addEventListener('DOMContentLoaded', () => {
            // Setup Navigation
            // Added 'Development' to the list below
            const navItems = ['Vision', 'Organizing', 'Financials', 'Data Suite', 'Projects', 'Development', 'Marketing', 'Donors'];
            const navContainer = document.getElementById('main-nav');
            let activeTab = 'Financials'; // Default active tab
            
            navItems.forEach(item => {
                const btn = document.createElement('button');
                const isActive = item === activeTab;
                btn.className = `group flex items-center px-3 py-2 text-xl font-bold tracking-tight font-fm-header transition-all ${
                    isActive 
                    ? 'text-[#98fb98] drop-shadow-[0_0_8px_rgba(152,251,152,0.25)] scale-105' 
                    : 'text-gray-400 hover:text-white hover:scale-105'
                }`;
                btn.innerHTML = `<span>${item}</span>`;
                
                // Click handler for interactivity
                btn.addEventListener('click', function() {
                    // Reset all
                    Array.from(navContainer.children).forEach(c => {
                        c.className = 'group flex items-center px-3 py-2 text-xl font-bold tracking-tight font-fm-header transition-all text-gray-400 hover:text-white hover:scale-105';
                    });
                    // Set active
                    this.className = 'group flex items-center px-3 py-2 text-xl font-bold tracking-tight font-fm-header transition-all text-[#98fb98] drop-shadow-[0_0_8px_rgba(152,251,152,0.25)] scale-105';
                });
                
                navContainer.appendChild(btn);
            });

            // Initialize Icons
            lucide.createIcons();
        });
    </script>
</body>
</html>
