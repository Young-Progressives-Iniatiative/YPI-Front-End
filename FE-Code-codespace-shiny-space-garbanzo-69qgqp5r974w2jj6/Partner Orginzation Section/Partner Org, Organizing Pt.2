                            <button class="px-2 py-1 text-gray-400 hover:text-white border-l border-[#333]">+</button>
                        </div>
                    </div>
                </div>

                <!-- 4. DATA DENSE RESULTS TABLE -->
                <div class="w-full overflow-x-auto bg-[#121212]">
                    <table class="w-full text-left border-collapse min-w-[1200px]">
                        <thead>
                            <tr class="bg-[#1a1a1a] text-[10px] text-gray-500 uppercase tracking-wider border-b border-[#333]">
                                <!-- Identity Group -->
                                <th class="p-2 border-r border-[#333] sticky left-0 bg-[#1a1a1a] z-10 w-12 text-center">est</th>
                                <th class="p-2 border-r border-[#333] w-10 text-center">INF</th>
                                <th class="p-2 border-r border-[#333] w-48">Name</th>
                                <th class="p-2 border-r border-[#333] w-32">School</th>
                                <th class="p-2 border-r border-[#333] w-32">Desired Role</th>
                                
                                <!-- Financial Group -->
                                <th class="p-2 text-center text-gray-400 border-r border-[#333]">eVL</th>
                                
                                <!-- Performance Group -->
                                <th class="p-2 text-center text-[#98fb98] border-r border-[#333]">eVLA</th>
                                <th class="p-2 text-center text-[#98fb98] border-r border-[#333]">ePVA</th>
                                <th class="p-2 text-center text-gray-300 border-r border-[#333]">LoE+</th>
                                <th class="p-2 text-center text-gray-300 border-r border-[#333]">commTime+</th>
                                
                                <!-- Academic Metrics -->
                                <th class="p-2 text-center font-mono">GPA+</th>
                                <th class="p-2 text-center font-mono">wGPA+</th>
                                <th class="p-2 text-center font-mono">ENG+</th>
                                <th class="p-2 text-center font-mono">MATH+</th>
                                <th class="p-2 text-center font-mono">HIST+</th>
                                <th class="p-2 text-center font-mono">ART+</th>
                                <th class="p-2 text-center font-mono">SSL+</th>
                                <th class="p-2 text-center font-mono border-r border-[#333]">NAT</th>
                                
                                <!-- Actions -->
                                <th class="p-2 text-right sticky right-0 bg-[#1a1a1a] z-10">Action</th>
                            </tr>
                        </thead>
                        <tbody class="text-xs divide-y divide-[#222]">
                            <!-- Row 1 -->
                            <tr class="hover:bg-[#1f1f1f] transition group">
                                <td class="p-2 text-center text-gray-400 font-mono sticky left-0 bg-[#121212] group-hover:bg-[#1f1f1f] border-r border-[#333]">A+</td>
                                
                                <!-- UPDATED Wnt COLUMN WITH HOVER TOOLTIP -->
                                <td class="p-2 text-center border-r border-[#333] relative group/wnt overflow-visible">
                                    <span class="bg-blue-500/20 text-blue-400 px-1.5 py-0.5 rounded text-[9px] font-bold cursor-help border border-blue-500/30">Wnt</span>
                                    
                                    <!-- Hover Card -->
                                    <div class="absolute top-0 left-10 hidden group-hover/wnt:block z-50 w-48 bg-[#181818] border border-[#333] rounded-lg shadow-[0_0_15px_rgba(0,0,0,0.5)] p-3 text-left backdrop-blur-sm">
                                        <div class="flex items-center gap-2 mb-2 border-b border-[#333] pb-2">
                                            <i data-lucide="eye" class="w-3 h-3 text-blue-400"></i>
                                            <span class="text-[10px] font-bold text-blue-400 uppercase tracking-wider">Interest Sources</span>
                                        </div>
                                        <div class="space-y-2">
                                            <div class="flex justify-between items-center text-[11px]">
                                                <span class="text-gray-300">Voter Reg '25</span>
                                                <span class="text-[#98fb98] font-mono bg-[#98fb98]/10 px-1 rounded">High</span>
                                            </div>
                                            <div class="flex justify-between items-center text-[11px]">
                                                <span class="text-gray-300">Outreach Dept</span>
                                                <span class="text-yellow-500 font-mono bg-yellow-500/10 px-1 rounded">Med</span>
                                            </div>
                                        </div>
                                        <div class="mt-2 pt-2 border-t border-[#333] text-[9px] text-gray-500 italic">
                                            Last inquiry: 2 days ago
                                        </div>
                                    </div>
                                </td>
                                
                                <td class="p-2 font-bold text-white border-r border-[#333]">Alex Johnson</td>
                                <td class="p-2 text-gray-400 border-r border-[#333]">B-CC High</td>
                                <td class="p-2 text-[#98fb98] border-r border-[#333]">Canvasser</td>
                                
                                <td class="p-2 text-center text-gray-400 border-r border-[#333] font-mono">1.2K-1.5K</td>
                                
                                <td class="p-2 text-center text-white border-r border-[#333] font-bold">78</td>
                                <td class="p-2 text-center text-white border-r border-[#333] font-bold">82</td>
                                <td class="p-2 text-center text-purple-400 border-r border-[#333] font-bold">Wonderkid</td>
                                <td class="p-2 text-center text-white border-r border-[#333] font-mono">95</td>
                                
                                <td class="p-2 text-center text-white font-mono bg-green-900/20">112</td>
                                <td class="p-2 text-center text-white font-mono">105</td>
                                <td class="p-2 text-center text-gray-500 font-mono">98</td>
                                <td class="p-2 text-center text-white font-mono bg-green-900/20">120</td>
                                <td class="p-2 text-center text-white font-mono">101</td>
                                <td class="p-2 text-center text-gray-500 font-mono">Unknown</td>
                                <td class="p-2 text-center text-white font-mono">110</td>
                                <td class="p-2 text-center border-r border-[#333]"><span class="text-xs">🇺🇸</span></td>
                                
                                <td class="p-2 text-right sticky right-0 bg-[#121212] group-hover:bg-[#1f1f1f]">
                                    <button class="bg-[#37af4b] hover:bg-[#2d8c3c] text-white text-[9px] font-bold px-3 py-1.5 rounded uppercase tracking-wider transition shadow-lg shadow-green-900/20" onclick="openRoleModal()">
                                        Encourage to Apply
