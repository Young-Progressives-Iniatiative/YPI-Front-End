    <script>
        document.addEventListener('DOMContentLoaded', () => {
            // --- INITIAL DATA & STATE ---
            const defaultEvents = [
                { 
                    id: 'evt_' + Date.now() + '_1', 
                    title: 'Annual Food Drive', 
                    time: '10:00', 
                    date: new Date().toISOString().split('T')[0], // Today
                    location: 'Community Center Main Hall',
                    description: 'Collecting non-perishable food items for the local shelter. Volunteers needed for sorting and packing boxes.',
                    meetLink: 'https://meet.google.com/abc-defg-hij',
                    volunteerCount: 5,
                    goalAttendance: 50,
                    goalType: 'Donors',
                    goalTarget: 10,
                    actualAttendance: '',
                    newsletterSignups: '',
                    donorNotes: ''
                },
                { 
                    id: 'evt_' + Date.now() + '_2', 
                    title: 'Voter Registration', 
                    time: '14:00', 
                    date: new Date(new Date().setDate(new Date().getDate() + 5)).toISOString().split('T')[0], // 5 days from now
                    location: 'City Library Plaza',
                    description: 'Helping citizens register to vote for the upcoming elections. Training provided on site.',
                    meetLink: 'https://meet.google.com/xyz-uvwx-yz',
                    volunteerCount: 12,
                    goalAttendance: 200,
                    goalType: 'Voters',
                    goalTarget: 100,
                    actualAttendance: '',
                    newsletterSignups: '',
                    donorNotes: ''
                }
            ];

            const defaultRoster = [
                "Alex Johnson", "Maria Garcia", "David Smith", "Emily White", "Michael Brown"
            ];

            let events = JSON.parse(localStorage.getItem('ypi_events')) || defaultEvents;
            let roster = JSON.parse(localStorage.getItem('ypi_roster')) || defaultRoster;
            let currentDate = new Date();
            let currentView = 'grid'; 
            let monthNames = ["January", "February", "March", "April", "May", "June", "July", "August", "September", "October", "November", "December"];

            function saveToStorage() {
                localStorage.setItem('ypi_events', JSON.stringify(events));
                localStorage.setItem('ypi_roster', JSON.stringify(roster));
            }

            function refreshUI() {
                if (currentView === 'grid') {
                    renderCalendar(currentDate);
                    document.getElementById('calendarGrid').style.display = 'grid';
                    document.getElementById('listView').style.display = 'none';
                    document.getElementById('prevMonth').style.display = 'flex';
                    document.getElementById('nextMonth').style.display = 'flex';
                    
                    document.getElementById('calendarTitle').innerText = `${monthNames[currentDate.getMonth()]} ${currentDate.getFullYear()}`;
                    const icon = document.getElementById('headerIcon');
                    icon.setAttribute('data-lucide', 'calendar');
                    lucide.createIcons({ nameAttr: 'data-lucide', attrs: {class: "w-6 h-6 text-[#37af4b]"}}); 
                } else {
                    renderListView();
                    document.getElementById('calendarGrid').style.display = 'none';
                    document.getElementById('listView').style.display = 'flex';
                    
                    document.getElementById('prevMonth').style.display = 'none';
                    document.getElementById('nextMonth').style.display = 'none';
                    document.getElementById('calendarTitle').innerText = "Upcoming Events";
                    
                    const icon = document.getElementById('headerIcon');
                    icon.setAttribute('data-lucide', 'list');
                    lucide.createIcons({ nameAttr: 'data-lucide', attrs: {class: "w-6 h-6 text-[#37af4b]"}});
                }
            }

            // --- HEADER NAV ---
