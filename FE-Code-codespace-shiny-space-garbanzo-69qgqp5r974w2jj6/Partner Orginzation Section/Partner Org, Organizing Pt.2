                            </select>
                            <input type="number" value="1" class="bg-[#252525] text-white border border-[#333] rounded px-2 py-1 w-16 text-center">
                            <div class="ml-auto flex gap-1">
                                <button class="text-gray-500 hover:text-white"><i data-lucide="minus-circle" class="w-4 h-4"></i></button>
                            </div>
