                            <span>State-Wide</span>
                            <i data-lucide="chevron-down" class="w-3 h-3 text-gray-500 ml-1"></i>
                        </div>
                    </div>

                    <!-- Right: Budget Controls -->
                    <div class="flex flex-col items-end">
                        <span class="text-[10px] uppercase text-gray-500 font-bold tracking-wider mb-1">Stipend Budget</span>
                        <div class="flex items-end gap-3">
                            <div class="text-xl font-bold text-white font-mono tracking-tight">
                                <span class="text-[#98fb98]">£</span>260,000
                            </div>
                            <div class="text-xs text-gray-400 mb-1 font-mono bg-[#252525] px-2 py-0.5 rounded border border-[#333]">
                                Capacity: <span class="text-[#98fb98] font-bold">130</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- 2. FILTER BUILDER & LOGIC ENGINE -->
                <div class="bg-[#121212] p-4 border-b border-[#333]">
                    <div class="flex justify-between items-center mb-3">
                        <h3 class="text-[#98fb98] font-bold text-sm uppercase tracking-wide flex items-center gap-2">
                            <i data-lucide="filter" class="w-4 h-4"></i> Volunteer Of Operation
                        </h3>
                        <div class="flex items-center gap-4">
                            <label class="flex items-center gap-2 text-xs text-gray-400 cursor-pointer">
                                <input type="checkbox" class="accent-[#98fb98] bg-[#252525] border-[#444] rounded"> Unpaid
                            </label>
                            <label class="flex items-center gap-2 text-xs text-gray-400 cursor-pointer">
                                <input type="checkbox" class="accent-[#98fb98] bg-[#252525] border-[#444] rounded" checked> Paid
                            </label>
                        </div>
                    </div>

                    <!-- Filter Rows Container -->
                    <div class="space-y-2 bg-[#1a1a1a] p-3 rounded border border-[#2a2a2a]">
                        <!-- Filter Row 1 -->
                        <div class="flex flex-wrap items-center gap-2 text-xs">
                            <input type="checkbox" checked class="accent-[#98fb98]">
                            <span class="text-gray-500 font-bold w-8 text-center">AND</span>
                            <select class="bg-[#252525] text-white border border-[#333] rounded px-2 py-1 focus:border-[#98fb98] outline-none">
                                <option>Year of High School</option>
                            </select>
                            <span class="text-gray-400">is</span>
                            <select class="bg-[#252525] text-white border border-[#333] rounded px-2 py-1 focus:border-[#98fb98] outline-none">
                                <option>Between</option>
                            </select>
                            <input type="number" value="15" class="bg-[#252525] text-white border border-[#333] rounded px-2 py-1 w-16 text-center">
                            <span class="text-gray-400">and</span>
                            <input type="number" value="18" class="bg-[#252525] text-white border border-[#333] rounded px-2 py-1 w-16 text-center">
                            <div class="ml-auto flex gap-1">
                                <button class="text-gray-500 hover:text-white"><i data-lucide="minus-circle" class="w-4 h-4"></i></button>
                            </div>
                        </div>

                        <!-- Filter Row 2 -->
                        <div class="flex flex-wrap items-center gap-2 text-xs">
                            <input type="checkbox" checked class="accent-[#98fb98]">
                            <span class="text-gray-500 font-bold w-8 text-center">AND</span>
                            <select class="bg-[#252525] text-white border border-[#333] rounded px-2 py-1 focus:border-[#98fb98] outline-none">
