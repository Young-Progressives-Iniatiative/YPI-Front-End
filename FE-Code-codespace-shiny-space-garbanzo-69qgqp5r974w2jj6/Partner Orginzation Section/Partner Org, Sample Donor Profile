// Modal Management System
let modalChartInstance = null;
let activeModal = null;

function openModal(modalId) {
  const modalElement = document.getElementById(`${modalId}Modal`);
  if (!modalElement) return;
  
  activeModal = modalElement;
  modalElement.classList.remove('hidden');
  
  setTimeout(() => {
    modalElement.classList.add('modal-active');
    if (modalId === 'personality' && !modalChartInstance) {
      const ctx = document.getElementById('modalChart').getContext('2d');
      modalChartInstance = new Chart(ctx, mainRadarConfig);
    }
    if (modalId === 'network') {
      setTimeout(() => initNetwork(), 50);
    }
  }, 10);
  
  // Prevent body scroll
  document.body.style.overflow = 'hidden';
}

function closeModal(modalElementId) {
  const modalElement = document.getElementById(modalElementId);
  if (!modalElement) return;
  
  modalElement.classList.remove('modal-active');
  activeModal = null;
  
  setTimeout(() => {
    modalElement.classList.add('hidden');
    document.body.style.overflow = '';
  }, 250);
}

// Keyboard support - ESC to close modal
document.addEventListener('keydown', (e) => {
  if (e.key === 'Escape' && activeModal) {
    closeModal(activeModal.id);
  }
});

// Initialize icons
lucide.createIcons();
