<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Donor Profile: Andy Reid</title>
    
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Atkinson+Hyperlegible:ital,wght@0,400;0,700;1,400;1,700&display=swap" rel="stylesheet">
    
    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    
    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>

    <!-- Vis.js -->
    <script type="text/javascript" src="https://unpkg.com/vis-network/standalone/umd/vis-network.min.js"></script>

    <style>
        :root {
            /* Dark Mode Defaults */
            --bg-body: #1c1c1c;
            --bg-header: #1b1b1b;
            --border-header: #2a2a2a;
            --text-primary: #ffffff;
            --text-secondary: #9ca3af;
            --card-bg: #1c1c1c;
            --accent-color: #98fb98;
            --border-color: #374151;
            --btn-bg: #2a2d35;
            --btn-hover: #333333;
            --input-bg: #111111;
            --modal-overlay: rgba(0, 0, 0, 0.8);
            --chart-grid: #374151;
            --chart-angle: #374151;
            --chart-point-label: #9ca3af;
        }

        body.light-mode {
            /* Light Mode Overrides */
            --bg-body: #f3f4f6;
            --bg-header: #ffffff;
            --border-header: #e5e7eb;
            --text-primary: #111827;
            --text-secondary: #4b5563;
            --card-bg: #ffffff;
            --accent-color: #15803d; /* Darker green for visibility */
            --border-color: #e5e7eb;
            --btn-bg: #f9fafb;
            --btn-hover: #f3f4f6;
            --input-bg: #f9fafb;
            --modal-overlay: rgba(255, 255, 255, 0.8);
            --chart-grid: #e5e7eb;
            --chart-angle: #d1d5db;
            --chart-point-label: #4b5563;
        }

        body {
            font-family: 'Atkinson Hyperlegible', sans-serif;
            background-color: var(--bg-body);
            color: var(--text-primary);
            margin: 0;
            transition: background-color 0.3s ease, color 0.3s ease;
        }

        /* Custom Scrollbar */
        ::-webkit-scrollbar { width: 6px; height: 6px; }
        ::-webkit-scrollbar-track { background: var(--bg-body); }
        ::-webkit-scrollbar-thumb { background: #333; border-radius: 3px; }
        ::-webkit-scrollbar-thumb:hover { background: var(--accent-color); }
        
        body.light-mode ::-webkit-scrollbar-thumb { background: #d1d5db; }

        /* Card Styles */
        .dashboard-card {
            background-color: var(--card-bg);
            border: 2px solid var(--accent-color);
            border-radius: 0.5rem;
            padding: 0.75rem;
            display: flex;
            flex-direction: column;
            transition: background-color 0.3s ease, border-color 0.3s ease;
        }

        /* Headers */
        .section-header {
            color: var(--accent-color);
            font-weight: 700;
            font-style: italic;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            font-size: 0.875rem;
            border-bottom: 1px solid var(--border-color);
            padding-bottom: 0.25rem;
            margin-bottom: 0.5rem;
            transition: color 0.3s ease, border-color 0.3s ease;
        }

        /* Stat Row */
        .stat-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0.25rem 0.5rem;
            border-bottom: 1px solid var(--border-color);
            font-size: 0.75rem;
            transition: background-color 0.2s, border-color 0.3s ease;
        }
        .stat-row:last-child { border-bottom: none; }
        .stat-row:hover { background-color: var(--btn-hover); }
        .stat-label { color: var(--text-secondary); font-weight: 500; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; padding-right: 0.5rem; }
        .stat-value { color: var(--text-primary); font-weight: 700; }

        /* Tables */
        table { width: 100%; border-collapse: collapse; font-size: 0.75rem; }
        td { padding: 0.5rem 0; border-bottom: 1px solid var(--border-color); color: var(--text-secondary); }
        tr:last-child td { border-bottom: none; }
        tr:hover { background-color: var(--btn-hover); }

        .nav-btn {
            color: var(--text-secondary);
            transition: all 0.3s ease;
        }
        .nav-btn:hover { color: var(--text-primary); transform: scale(1.05); }
        .nav-btn.active {
            color: var(--accent-color);
            transform: scale(1.05);
            text-shadow: 0 0 8px rgba(152, 251, 152, 0.25);
        }
        
        body.light-mode .nav-btn.active {
             text-shadow: 0 0 8px rgba(22, 163, 74, 0.25);
        }

        /* Animations */
        .modal-enter { opacity: 0; pointer-events: none; transform: scale(0.95); }
        .modal-active { opacity: 1; pointer-events: auto; transform: scale(1); }
        .modal-transition { transition: all 0.2s ease-in-out; }

        /* Network Graph Specifics */
        #network {
            width: 100%;
            height: 100%;
            background-color: var(--card-bg);
        }
        
        /* Utility classes replacement for color vars */
        .bg-theme-header { background-color: var(--bg-header); }
        .border-theme-header { border-color: var(--border-header); }
        .bg-theme-btn { background-color: var(--btn-bg); }
        .border-theme { border-color: var(--border-color); }
        .text-theme-primary { color: var(--text-primary); }
        .text-theme-secondary { color: var(--text-secondary); }
        .bg-theme-input { background-color: var(--input-bg); }
        
    </style>
</head>
<body class="min-h-screen pb-4">

    <!-- Header -->
    <header class="fixed top-0 left-0 right-0 w-full shadow-lg z-50 bg-theme-header border-b border-theme-header transition-colors duration-300" style="background-color: var(--bg-header); border-color: var(--border-header);">
        <div class="flex items-center h-16 px-6 gap-6 overflow-x-auto">
            <!-- Nav Controls -->
            <div class="flex items-center mr-2 flex-shrink-0">
                <button class="flex items-center justify-center w-8 h-10 border rounded-l transition-colors hover:opacity-80" style="background-color: var(--btn-bg); border-color: var(--border-color);">
                    <i data-lucide="chevron-left" class="w-5 h-5 text-theme-secondary" style="color: var(--text-secondary)"></i>
                </button>
                <button class="flex items-center justify-center w-8 h-10 rounded-r border-y border-r transition-colors hover:opacity-80" style="background-color: var(--bg-header); border-color: var(--border-header);">
                    <i data-lucide="chevron-right" class="w-5 h-5 text-theme-secondary" style="color: var(--text-secondary)"></i>
                </button>
            </div>

            <!-- Logo -->
            <div class="flex-shrink-0 mr-4 h-12 flex items-center">
               <img src="https://weareypi.com/wp-content/uploads/2025/06/Site-Icon-3.png" alt="Logo" class="h-full w-auto object-contain transition-all duration-300" id="headerLogo" onerror="this.src='https://placehold.co/100x40?text=YPI'">
            </div>

            <!-- Nav Items -->
            <nav class="flex items-center gap-2" id="mainNav">
                <!-- Injected via JS -->
            </nav>

            <!-- Theme Toggle -->
            <div class="ml-auto flex items-center pl-4 border-l" style="border-color: var(--border-header)">
                <button id="themeToggle" class="p-2 rounded-full hover:bg-black/10 transition-colors" style="color: var(--text-primary)">
                    <i data-lucide="sun" class="w-5 h-5"></i>
                </button>
            </div>
        </div>
    </header>

    <div class="h-16"></div>

    <!-- Main Content -->
    <div class="max-w-[1800px] mx-auto p-2 sm:p-4">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-2 auto-rows-min">

            <!-- LEFT COLUMN (Profile) -->
            <div class="lg:col-span-3 flex flex-col gap-2">
                <!-- Photo Card -->
                <div class="dashboard-card relative overflow-hidden group gap-3">
                    <div class="absolute top-0 left-0 w-full h-1 opacity-50" style="background-color: var(--accent-color)"></div>
                    <div class="aspect-[4/3] w-full rounded border flex items-center justify-center relative overflow-hidden" style="background-color: var(--input-bg); border-color: var(--border-color)">
                        <!-- Replaced SVG with Image -->
                        <img 
                            src="https://upload.wikimedia.org/wikipedia/commons/thumb/c/c7/Andy_Reid_Aug_2023.jpg/640px-Andy_Reid_Aug_2023.jpg" 
                            alt="Andy Reid" 
                            class="w-full h-full object-cover"
                            onerror="this.src='https://placehold.co/400x300?text=Andy+Reid'"
                        >
                    </div>
                    <button class="w-full font-bold py-2 px-4 border rounded shadow-sm text-sm uppercase tracking-wider flex items-center justify-center gap-2 transition-all hover:opacity-90" style="background-color: var(--btn-bg); color: var(--text-primary); border-color: var(--border-color);">
                        <i data-lucide="mail" class="w-4 h-4"></i> Contact Info
                    </button>
                </div>

                <!-- Personal Info -->
                <div class="dashboard-card flex-grow flex flex-col">
                    <div class="section-header border-0 mb-0 pb-2">Personal</div>
                    <div class="flex items-center justify-between mb-2">
                        <h1 class="text-2xl font-black italic tracking-tight" style="color: var(--text-primary)">Andy Reid</h1>
                        <div class="flex gap-2">
                            <!-- Flag -->
                            <div class="w-8 h-5 bg-blue-900 border border-gray-600 relative overflow-hidden">
                                <div class="absolute right-0 top-0 h-full w-3/4 flex flex-col">
                                    <div class="h-1/2 bg-red-600"></div><div class="h-1/2 bg-white"></div>
                                </div>
                            </div>
                            <!-- Chiefs Icon -->
                            <div class="w-8 h-5 flex items-center justify-center font-bold text-red-600 border border-red-900 bg-white text-[10px]">KC</div>
                        </div>
                    </div>
                    <div class="space-y-1 text-xs font-mono mb-4" style="color: var(--text-secondary)">
                        <p><span style="color: var(--text-secondary); opacity: 0.7">Full Name:</span> Andrew Walter Reid</p>
                        <p><span style="color: var(--text-secondary); opacity: 0.7">AKA:</span> "Big Red"</p>
                        <p><span style="color: var(--text-secondary); opacity: 0.7">High School:</span> John Marshall (CA)</p>
                        <p><span style="color: var(--text-secondary); opacity: 0.7">Born:</span> March 19, 1958 (age 67)</p>
                        <p><span style="color: var(--text-secondary); opacity: 0.7">Location:</span> Kansas City, Missouri, U.S.</p>
                        <div class="h-px my-2" style="background-color: var(--border-color)"></div>
                        <p class="font-bold" style="color: var(--accent-color)">Career Information</p>
                        <p>Head Coach (Chiefs)</p>
                        <p class="font-bold mt-2" style="color: var(--accent-color)">College</p>
                        <p>Glendale CC (1976-1977)</p>
                        <p>BYU (1978-1980)</p>
                    </div>
                    
                    <!-- Social Media Redirect Moved Here & Pushed to Bottom -->
                    <div class="mt-auto">
                        <a href="#" class="w-full font-bold py-2 px-4 border rounded shadow-sm text-sm uppercase tracking-wider flex items-center justify-center gap-2 transition-all hover:opacity-90" style="background-color: var(--btn-bg); color: var(--text-primary); border-color: var(--border-color);">
                            <i data-lucide="thumbs-up" class="w-4 h-4"></i> Social Media
                        </a>
                    </div>
                </div>
            </div>

            <!-- MIDDLE COLUMN (Stats) -->
            <div class="lg:col-span-6 flex flex-col gap-2">
                <!-- Top Tabs -->
                <div class="grid grid-cols-2 gap-2">
                    <div class="dashboard-card p-2 items-center justify-center text-xs uppercase font-bold" style="color: var(--text-secondary)">Political Affiliations</div>
                    <div class="dashboard-card p-2 items-center justify-center text-sm uppercase font-black italic" style="color: var(--text-primary)">Greek Life Affiliations</div>
                </div>

                <!-- Stats Grid -->
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
                    <!-- Economic -->
                    <div class="dashboard-card">
                        <div class="section-header">Economic</div>
                        <div id="economicStats"></div>
                    </div>
                    <!-- Social -->
                    <div class="dashboard-card">
                        <div class="section-header">Social</div>
                        <div id="socialStats"></div>
                    </div>
                </div>

                <!-- Engagement -->
                <div class="dashboard-card">
                    <div class="section-header">Engagement</div>
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-1" id="engagementStats"></div>
                </div>

                <!-- Family / Map -->
                <div class="dashboard-card h-[225px]">
                    <div class="section-header">Family</div>
                    <div class="flex flex-col h-full">
                        <p class="text-xs italic mb-2" style="color: var(--text-secondary)">Given Money to Non-Profits in the Following Countries</p>
                        <div class="flex-grow border relative rounded overflow-hidden" style="background-color: var(--input-bg); border-color: var(--border-color)">
                            <!-- SVG Map -->
                            <svg viewBox="0 0 200 100" class="w-full h-full absolute inset-0 opacity-40" style="fill: var(--border-color)">
                                <path d="M20,20 Q30,10 50,30 T80,40 T50,70 T20,60 Z" />
                                <path d="M90,20 Q110,10 120,30 T130,50 T100,60 Z" />
                                <path d="M140,20 Q160,10 180,30 T170,60 T140,50 Z" />
                            </svg>
                            <!-- Dots -->
                            <svg viewBox="0 0 200 100" class="w-full h-full absolute inset-0">
                                <circle cx="35" cy="38" r="2.5" fill="#ef4444" class="animate-pulse" />
                                <circle cx="48" cy="35" r="2.5" fill="#0f766e" />
                                <circle cx="15" cy="38" r="2" fill="#3b82f6" opacity="0.75" />
                            </svg>
                        </div>
                    </div>
                </div>

                <!-- Ventures Bar (Social Media Removed) -->
                <div class="grid grid-cols-2 gap-1 h-auto min-h-[2.5rem]">
                    <div class="dashboard-card items-center justify-center p-1 text-[9px] font-bold uppercase text-center" style="color: var(--text-secondary)">Entrepreneurial Ventures</div>
                    <div class="dashboard-card items-center justify-center p-1 text-[9px] font-bold uppercase text-center" style="color: var(--text-primary)">Owns a Non-Profit?</div>
                </div>
            </div>

            <!-- RIGHT COLUMN (Lists) -->
            <div class="lg:col-span-3 flex flex-col gap-2">
                <div class="dashboard-card flex-grow max-h-64 lg:max-h-none overflow-hidden">
                    <div class="section-header">Tendencies</div>
                    <div class="overflow-y-auto" id="tendenciesList"></div>
                </div>
                <div class="dashboard-card h-48 overflow-hidden">
                    <div class="section-header">Entertainment Preferences</div>
                    <div class="overflow-y-auto" id="entertainmentList"></div>
                </div>
                <div class="dashboard-card h-48 overflow-hidden">
                    <div class="section-header">Predicted Behaviors</div>
                    <div class="overflow-y-auto" id="behaviorsList"></div>
                </div>
                <div class="dashboard-card p-2 text-xs font-bold uppercase text-center justify-center" style="color: var(--text-secondary)">Places Frequented</div>
            </div>

            <!-- BOTTOM ROW -->
            
            <!-- Career -->
            <div class="lg:col-span-3 h-auto min-h-[16rem] dashboard-card">
                <div class="section-header">Career History</div>
                <div class="overflow-y-auto flex-1 custom-scrollbar">
                    <table id="careerTable"></table>
                </div>
            </div>

            <!-- Chart (Clickable) -->
            <div class="lg:col-span-3 h-auto min-h-[16rem] dashboard-card cursor-pointer transition-all group" style="border-color: var(--accent-color)" onclick="openPersonalityModal()">
                <div class="section-header flex justify-between items-center">
                    <span>Personality Alignment Chart</span>
                    <i data-lucide="maximize-2" class="w-3 h-3 transition-colors" style="color: var(--text-secondary)"></i>
                </div>
                <div class="flex-grow relative min-h-[14rem] pointer-events-none">
                    <canvas id="radarChart"></canvas>
                </div>
            </div>

            <!-- Advocacy -->
            <div class="lg:col-span-3 h-auto min-h-[16rem] dashboard-card">
                <div class="section-header">Advocacy Events</div>
                <div class="overflow-y-auto flex-1 custom-scrollbar">
                    <table id="advocacyTable"></table>
                </div>
            </div>

            <!-- Summary -->
            <div class="lg:col-span-3 h-auto min-h-[16rem] dashboard-card">
                <div class="section-header">Donor Summary</div>
                <div class="p-2 text-xs leading-relaxed font-mono" style="color: var(--text-secondary)">
                    <p class="mb-2">Subject demonstrates immense leadership stability and deep community roots in both Kansas City and Philadelphia. Known for supporting Special Olympics Missouri and domestic violence prevention causes.</p>
                    <p>Philanthropic footprint aligns with long-term, high-impact regional commitments rather than scattered giving. Strong advocate for youth development programs.</p>
                </div>
            </div>

        </div>
    </div>

    <!-- Personality Report Modal -->
    <div id="personalityModal" class="hidden modal-enter fixed inset-0 z-[60] flex items-center justify-center p-4 md:p-8 modal-transition">
        <div class="absolute inset-0 backdrop-blur-sm" style="background-color: var(--modal-overlay)" onclick="closePersonalityModal()"></div>
        <div class="relative w-full max-w-6xl border-2 rounded-xl flex flex-col overflow-hidden shadow-2xl z-[70] max-h-full" style="background-color: var(--bg-body); border-color: var(--accent-color);">
            
            <!-- Modal Header -->
            <div class="flex justify-between items-center p-4 border-b" style="background-color: var(--bg-header); border-color: var(--border-color)">
                <div>
                    <h2 class="text-xl font-black italic uppercase tracking-wide" style="color: var(--accent-color)">Myers Briggs Personality Report</h2>
                    <p class="text-xs font-mono" style="color: var(--text-secondary)">Updated 12/13/2025</p>
                </div>
                <div class="flex items-center gap-4">
                    <img src="https://weareypi.com/wp-content/uploads/2025/06/Site-Icon-3.png" alt="YPI" class="h-8 opacity-80" onerror="this.src='https://placehold.co/60x30?text=YPI'">
                    <button onclick="closePersonalityModal()" class="hover:opacity-80 transition-opacity" style="color: var(--text-secondary)">
                        <i data-lucide="x" class="w-6 h-6"></i>
                    </button>
                </div>
            </div>

            <!-- Modal Content -->
            <div class="flex-grow overflow-y-auto p-4 custom-scrollbar" style="background-color: var(--bg-body)">
                
                <!-- Recommendation Banner -->
                <div class="bg-cyan-900/40 border border-cyan-500/50 rounded p-3 mb-4 text-center">
                    <p class="text-cyan-400 font-bold text-sm italic">
                        This Donor would be a <span style="color: var(--text-primary)">Strategic Partner</span> and <span style="color: var(--text-primary)">he</span> I would recommend <span style="color: var(--text-primary)">immediate stewardship cultivation</span>.
                    </p>
                </div>

                <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
                    
                    <!-- Left Column -->
                    <div class="flex flex-col gap-4">
                        <!-- Personality Types -->
                        <div class="grid grid-cols-2 gap-4 text-center">
                            <div>
                                <div class="text-[10px] uppercase font-bold" style="color: var(--text-secondary)">Expected Myers Briggs Personality</div>
                                <div class="font-black text-xl italic" style="color: var(--text-primary)">ESTJ</div>
                                <div class="text-[10px] mt-1 font-bold" style="color: var(--text-secondary)">Other Possible: ENTJ</div>
                            </div>
                            <div>
                                <div class="text-[10px] uppercase font-bold" style="color: var(--text-secondary)">Eliminated Personalities</div>
                                <div class="font-bold text-lg line-through decoration-red-500" style="color: var(--text-secondary)">INFP</div>
                            </div>
                        </div>

                        <!-- PROS -->
                        <div>
                            <div class="font-bold uppercase text-xs mb-2" style="color: var(--accent-color)">PROS</div>
                            <div class="space-y-2">
                                <div class="flex items-start gap-2 p-2 border-b" style="border-color: var(--border-color)">
                                    <div class="w-6 h-6 rounded-full bg-green-500 flex items-center justify-center flex-shrink-0 text-white"><i data-lucide="smile" class="w-4 h-4"></i></div>
                                    <p class="text-xs" style="color: var(--text-secondary)">Has performed especially well in leadership roles and shows consistent community engagement.</p>
                                </div>
                                <div class="flex items-start gap-2 p-2 border-b" style="border-color: var(--border-color)">
                                    <div class="w-6 h-6 rounded-full bg-green-500 flex items-center justify-center flex-shrink-0 text-white"><i data-lucide="target" class="w-4 h-4"></i></div>
                                    <p class="text-xs" style="color: var(--text-secondary)">Very consistent performer in long-term philanthropic commitments.</p>
                                </div>
                                <div class="flex items-start gap-2 p-2 border-b" style="border-color: var(--border-color)">
                                    <div class="w-6 h-6 rounded-full bg-green-500 flex items-center justify-center flex-shrink-0 text-white"><i data-lucide="users" class="w-4 h-4"></i></div>
                                    <p class="text-xs" style="color: var(--text-secondary)">Reid fits in well with the majority of the organizational culture.</p>
                                </div>
                                <div class="flex items-start gap-2 p-2 border-b" style="border-color: var(--border-color)">
                                    <div class="w-6 h-6 rounded-full bg-green-500 flex items-center justify-center flex-shrink-0 text-white"><i data-lucide="handshake" class="w-4 h-4"></i></div>
                                    <p class="text-xs" style="color: var(--text-secondary)">Personal touch is key to him being a highly effective advocate.</p>
                                </div>
                                <div class="flex items-start gap-2 p-2">
                                    <div class="w-6 h-6 rounded-full bg-green-500 flex items-center justify-center flex-shrink-0 text-white"><i data-lucide="trending-up" class="w-4 h-4"></i></div>
                                    <p class="text-xs" style="color: var(--text-secondary)">The donor has put in some really good support performances recently.</p>
                                </div>
                            </div>
                        </div>

                        <!-- CONS -->
                        <div>
                            <div class="text-red-400 font-bold uppercase text-xs mb-2">CONS</div>
                            <div class="space-y-2">
                                <div class="flex items-start gap-2 p-2 border-b" style="border-color: var(--border-color)">
                                    <div class="w-6 h-6 rounded-full bg-red-500 flex items-center justify-center flex-shrink-0 text-white"><i data-lucide="clock" class="w-4 h-4"></i></div>
                                    <p class="text-xs" style="color: var(--text-secondary)">Extreme time scarcity from August to February due to NFL season demands.</p>
                                </div>
                                <div class="flex items-start gap-2 p-2 border-b" style="border-color: var(--border-color)">
                                    <div class="w-6 h-6 rounded-full bg-orange-500 flex items-center justify-center flex-shrink-0 text-white"><i data-lucide="map-pin" class="w-4 h-4"></i></div>
                                    <p class="text-xs" style="color: var(--text-secondary)">Highly region-specific giving; unlikely to engage with causes outside KC/Philly/LA axis.</p>
                                </div>
                                <div class="flex items-start gap-2 p-2">
                                    <div class="w-6 h-6 rounded-full bg-orange-500 flex items-center justify-center flex-shrink-0 text-white"><i data-lucide="eye-off" class="w-4 h-4"></i></div>
                                    <p class="text-xs" style="color: var(--text-secondary)">Prefers low-profile philanthropy; often declines public recognition or galas.</p>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Right Column -->
                    <div class="flex flex-col gap-4">
                        <!-- Chart -->
                        <div class="rounded-lg p-2 border h-64 relative" style="background-color: var(--btn-bg); border-color: var(--border-color)">
                            <div class="absolute top-2 left-2 text-[10px] font-bold uppercase" style="color: var(--accent-color)">Personality Chart</div>
                            <canvas id="modalChart"></canvas>
                        </div>

                        <!-- Answered Questions -->
                        <div>
                            <div class="font-bold italic text-sm mb-2" style="color: var(--text-primary)">Answered Questions</div>
                            <div class="space-y-2">
                                <div class="flex items-start gap-2 p-1">
                                    <div class="w-5 h-5 rounded-full bg-green-500 flex items-center justify-center flex-shrink-0 text-white text-[10px]"><i data-lucide="check" class="w-3 h-3"></i></div>
                                    <p class="text-xs" style="color: var(--text-secondary)">"I believe in giving people second chances if they show they're willing to work for it."</p>
                                </div>
                                <div class="flex items-start gap-2 p-1">
                                    <div class="w-5 h-5 rounded-full bg-green-500 flex items-center justify-center flex-shrink-0 text-white text-[10px]"><i data-lucide="check" class="w-3 h-3"></i></div>
                                    <p class="text-xs" style="color: var(--text-secondary)">"Community support is a team effort; you can't do it alone."</p>
                                </div>
                                <div class="flex items-start gap-2 p-1">
                                    <div class="w-5 h-5 rounded-full bg-green-500 flex items-center justify-center flex-shrink-0 text-white text-[10px]"><i data-lucide="check" class="w-3 h-3"></i></div>
                                    <p class="text-xs" style="color: var(--text-secondary)">"Preparation and detail are just as important in charity as they are on the field."</p>
                                </div>
                            </div>
                        </div>

                        <!-- Expected Answers -->
                        <div>
                            <div class="font-bold italic text-sm mb-2" style="color: var(--text-primary)">Expected Answers Based On Statements Discussion</div>
                            <div class="space-y-2">
                                <div class="flex items-start gap-2 p-1">
                                    <div class="w-5 h-5 rounded-full bg-orange-500 flex items-center justify-center flex-shrink-0 text-white text-[10px]"><i data-lucide="message-square" class="w-3 h-3"></i></div>
                                    <p class="text-xs" style="color: var(--text-secondary)">Likely to ask: "What is the long-term sustainability plan for this initiative?"</p>
                                </div>
                                <div class="flex items-start gap-2 p-1">
                                    <div class="w-5 h-5 rounded-full bg-orange-500 flex items-center justify-center flex-shrink-0 text-white text-[10px]"><i data-lucide="clock" class="w-3 h-3"></i></div>
                                    <p class="text-xs" style="color: var(--text-secondary)">Will likely defer immediate decisions to trusted advisors during the season.</p>
                                </div>
                            </div>
                        </div>
                    </div>

                </div>
            </div>
        </div>
    </div>

    <!-- Network Graph Modal -->
    <div id="networkModal" class="hidden modal-enter fixed inset-0 z-[80] flex items-center justify-center p-4 md:p-8 modal-transition">
        <div class="absolute inset-0 backdrop-blur-sm" style="background-color: var(--modal-overlay)" onclick="closeNetworkModal()"></div>
        <div class="relative w-full h-full border-2 rounded-xl flex flex-col overflow-hidden shadow-2xl z-[90]" style="background-color: var(--bg-body); border-color: var(--accent-color)">
            
            <!-- Modal Header -->
            <div class="flex justify-between items-center p-4 border-b shrink-0" style="background-color: var(--bg-header); border-color: var(--border-color)">
                <div class="flex items-center gap-3">
                    <div class="text-black p-1.5 rounded" style="background-color: var(--accent-color)">
                        <i data-lucide="share-2" class="w-5 h-5"></i>
                    </div>
                    <div>
                        <h2 class="text-xl font-black italic uppercase tracking-wide" style="color: var(--text-primary)">Social Network Mapper</h2>
                        <p class="text-xs font-mono" style="color: var(--text-secondary)">Central Node: Andy Reid</p>
                    </div>
                </div>
                <button onclick="closeNetworkModal()" class="hover:opacity-80 transition-opacity p-2 rounded-full" style="color: var(--text-secondary)">
                    <i data-lucide="x" class="w-6 h-6"></i>
                </button>
            </div>

            <!-- Graph Container -->
            <div class="flex-grow relative overflow-hidden" style="background-color: var(--card-bg)">
                <div id="network" class="w-full h-full"></div>
                
                <!-- Legend -->
                <div class="absolute bottom-4 right-4 bg-black/80 p-3 rounded-lg border border-gray-700 text-xs text-gray-300 pointer-events-none">
                    <div class="font-bold mb-2 border-b border-gray-600 pb-1" style="color: var(--accent-color)">Legend</div>
                    <div class="flex items-center gap-2 mb-1"><div class="w-3 h-3 rounded bg-[#ffffff] border border-gray-500"></div> Key Hub</div>
                    <div class="flex items-center gap-2 mb-1"><div class="w-3 h-3 rounded-full bg-[#ef4444]"></div> Chiefs/Player</div>
                    <div class="flex items-center gap-2 mb-1"><div class="w-3 h-3 rounded-full bg-[#10b981]"></div> Eagles/Alum</div>
                    <div class="flex items-center gap-2 mb-1"><div class="w-3 h-3 rounded-full bg-[#3b82f6]"></div> Coaching Tree</div>
                    <div class="flex items-center gap-2 mb-1"><div class="w-3 h-3 rounded-full bg-[#ec4899]"></div> Family</div>
                    <div class="flex items-center gap-2"><div class="w-3 h-3 rounded-full bg-[#eab308]"></div> Charity</div>
                </div>
            </div>
        </div>
    </div>

    <script>
        // --- Theme Logic ---
        const themeBtn = document.getElementById('themeToggle');
        themeBtn.onclick = () => {
            document.body.classList.toggle('light-mode');
            const isLight = document.body.classList.contains('light-mode');
            const icon = themeBtn.querySelector('i');
            
            if (isLight) {
                icon.setAttribute('data-lucide', 'moon');
                document.getElementById('headerLogo').style.filter = 'invert(1)';
            } else {
                icon.setAttribute('data-lucide', 'sun');
                document.getElementById('headerLogo').style.filter = 'none';
            }
            lucide.createIcons();
            
            // Re-render charts to pick up new colors
            updateChartsTheme(isLight);
        };

        function updateChartsTheme(isLight) {
            // Helper to update chart colors
            const gridColor = isLight ? '#e5e7eb' : '#374151';
            const textColor = isLight ? '#4b5563' : '#9ca3af';
            const accent = isLight ? '#15803d' : '#98fb98';
            
            const updateChart = (chartInstance) => {
                if(!chartInstance) return;
                chartInstance.options.scales.r.angleLines.color = gridColor;
                chartInstance.options.scales.r.grid.color = gridColor;
                chartInstance.options.scales.r.pointLabels.color = textColor;
                
                // Update datasets if needed (e.g. border color)
                chartInstance.data.datasets[0].borderColor = '#4ade80'; // Keep green consistent
                chartInstance.data.datasets[1].borderColor = '#facc15'; // Keep yellow consistent
                
                chartInstance.update();
            };

            // Assuming we have global references or can get instances
            Chart.helpers.each(Chart.instances, (instance) => {
                updateChart(instance);
            });
        }

        // --- Navigation Logic ---
        const navItems = ['Vision', 'Organizing', 'Financials', 'Data Suite', 'Projects', 'Marketing', 'Fundraising'];
        const navContainer = document.getElementById('mainNav');
        let currentTab = 'Marketing';

        navItems.forEach(item => {
            const btn = document.createElement('button');
            const isActive = item === currentTab;
            btn.className = `group flex items-center px-3 py-2 text-xl font-bold tracking-tight transition-all duration-300 font-sans hover:scale-105 nav-btn ${isActive ? 'active' : ''}`;
            btn.innerText = item;
            btn.onclick = () => {
                Array.from(navContainer.children).forEach(c => c.classList.remove('active'));
                btn.classList.add('active');
            };
            navContainer.appendChild(btn);
        });

        // --- Data Population Functions ---
        function createStatRow(label, value) {
            return `
                <div class="stat-row">
                    <span class="stat-label">${label}</span>
                    <span class="stat-value">${value}</span>
                </div>
            `;
        }

        // Stats Data
        const ecoStats = [
            ['wexSol+', '98'], ['wexTaxBracket+', '98'], ['wexLiquidity+', '98'], ['wexVolatility+', '98'],
            ['wexExpenses+', '98'], ['wexIncome+', '98'], ['wexAssets+', '98'], ['wexLiabilities+', '98']
        ];
        document.getElementById('economicStats').innerHTML = ecoStats.map(s => createStatRow(s[0], s[1])).join('');

        const socStats = [
            ['wEducation+', '98'], ['wEmpathy', '98'], ['Relationship Status+', '98'],
            ['NPG Age+', '98'], ['wFamily Prestige+', '98'], ['wexFamily Prestige+', '98'],
            ['Alignment Score+', '98'], ['wexPolicy Alignment+', '98'], ['wexReligion Alignment+', '98']
        ];
        document.getElementById('socialStats').innerHTML = socStats.map(s => createStatRow(s[0], s[1])).join('');

        const engStats = [
            ['wexRelated SM+', '98'], ['wPosting+', '98'], ['wAns. Calls+', '98'], ['wAns. Texts+', '98'],
            ['wLiking+', '98'], ['wReposting+', '98'], ['wAttending+', '98'], ['wexAttend+', '98']
        ];
        document.getElementById('engagementStats').innerHTML = engStats.map(s => createStatRow(s[0], s[1])).join('');

        // Lists
        function createList(id, items) {
            document.getElementById(id).innerHTML = `<ul class="space-y-1">${items.map(i => `<li class="text-xs leading-tight" style="color: var(--text-secondary)">• ${i}</li>`).join('')}</ul>`;
        }
        createList('tendenciesList', [
            "High brand loyalty to heritage American labels (e.g. Tommy Bahama)",
            "Prioritizes functional comfort over high-fashion trends",
            "Frequent patron of local, established dining staples (BBQ/Diners)",
            "Invests in tangible assets (Classic Cars/Restoration)",
            "Late technology adopter; prefers analog/simple interfaces",
            "Responds to word-of-mouth recommendations from close peers",
            "Value-driven spending on durable, high-quality goods"
        ]);
        createList('entertainmentList', ['Sci-Fi Movies', 'Classic Rock', 'Golf', 'Cooking Shows', 'Historical Fiction', 'Local Theatre']);
        createList('behaviorsList', [
            "High likelihood of recurring donation", 
            "Prefers email communication", 
            "Attends gala events", 
            "Responds to crisis appeals",
            "Consults wife (<a href='#' class='hover:underline' style='color: var(--accent-color)'>Tammy</a>) on major decisions"
        ]);

        // Tables
        function createTable(id, data) {
            const table = document.getElementById(id);
            table.innerHTML = data.map(row => `
                <tr>
                    <td class="w-24 whitespace-nowrap" style="color: var(--text-secondary)">${row.year}</td>
                    <td class="flex items-center gap-2">
                        <div class="w-4 h-4 rounded-full flex items-center justify-center bg-[#2a2d35] ${row.color} text-white">
                            <i data-lucide="globe" class="w-2.5 h-2.5"></i>
                        </div>
                        <span class="truncate" style="color: var(--text-secondary)">${row.name}</span>
                    </td>
                    <td class="text-right whitespace-nowrap" style="color: var(--text-secondary)">${row.role}</td>
                </tr>
            `).join('');
        }

        const careerData = [
            { year: '2013 - Pres', name: 'Kansas City Chiefs', role: 'Head Coach', color: 'bg-red-600' },
            { year: '1999 - 2012', name: 'Philadelphia Eagles', role: 'Head Coach / EVP', color: 'bg-teal-700' },
            { year: '1997 - 1998', name: 'Green Bay Packers', role: 'QB Coach / Asst HC', color: 'bg-green-700' },
            { year: '1992 - 1996', name: 'Green Bay Packers', role: 'Asst OL / TE Coach', color: 'bg-green-600' },
            { year: '1989 - 1991', name: 'Missouri Tigers', role: 'OL Coach', color: 'bg-yellow-500' },
            { year: '1987 - 1988', name: 'UTEP Miners', role: 'OL Coach', color: 'bg-orange-600' },
            { year: '1986', name: 'Northern Arizona', role: 'OL Coach', color: 'bg-blue-800' },
            { year: '1983 - 1985', name: 'San Francisco State', role: 'OL Coach / OC', color: 'bg-purple-700' },
            { year: '1982', name: 'BYU Cougars', role: 'Graduate Assistant', color: 'bg-blue-700' },
            { year: '1978 - 1980', name: 'BYU Cougars', role: 'Player (OT)', color: 'bg-blue-700' },
        ];
        createTable('careerTable', careerData);

        const advocacyData = [
            { year: '2019 - Pres', name: 'Evening with Andy Reid', role: 'Host/Fundraiser', color: 'bg-red-600' },
            { year: '2013 - Pres', name: 'Special Olympics MO', role: 'Ambassador', color: 'bg-yellow-400' },
            { year: '2000 - 2012', name: 'Laurel House (PA)', role: 'Honoree/Donor', color: 'bg-teal-700' },
            { year: '1999 - 2012', name: 'Eagles Youth Partnership', role: 'Board Member', color: 'bg-teal-600' },
            { year: '2010', name: 'Anti-Domestic Violence', role: 'Spokesperson', color: 'bg-purple-500' },
        ];
        createTable('advocacyTable', advocacyData);

        // --- Chart.js Radar Chart (Main) ---
        const mainRadarConfig = {
            type: 'radar',
            data: {
                labels: ['ENTJ', 'ENTP', 'INTJ', 'INTP', 'ESTJ', 'ESFJ', 'ISTJ', 'ISFJ', 'ENFJ', 'ENFP', 'INFJ', 'INFP', 'ESTP', 'ESFP', 'ISTP', 'ISFP'],
                datasets: [{
                    label: 'Exhibited Traits',
                    data: [95, 75, 85, 60, 100, 95, 90, 70, 90, 75, 65, 50, 80, 70, 60, 55],
                    fill: true,
                    backgroundColor: 'rgba(74, 222, 128, 0.3)',
                    borderColor: '#4ade80',
                    pointBackgroundColor: '#4ade80',
                    borderWidth: 2,
                    pointRadius: 0
                }, {
                    label: 'Expected Answers',
                    data: [110, 90, 100, 80, 115, 110, 105, 90, 105, 95, 85, 75, 95, 90, 80, 75],
                    fill: true,
                    backgroundColor: 'rgba(250, 204, 21, 0.3)',
                    borderColor: '#facc15',
                    pointBackgroundColor: '#facc15',
                    borderWidth: 2,
                    pointRadius: 0
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                scales: {
                    r: {
                        angleLines: { color: '#374151' },
                        grid: { color: '#374151' },
                        pointLabels: { color: '#9ca3af', font: { size: 10 } },
                        ticks: { display: false, backdropColor: 'transparent' },
                        suggestedMin: 0, suggestedMax: 150
                    }
                },
                plugins: { legend: { display: false } }
            }
        };
        const radarChart = new Chart(document.getElementById('radarChart').getContext('2d'), mainRadarConfig);

        // --- Network Graph Logic ---
        let network = null;
        let nodes = new vis.DataSet([]);
        let edges = new vis.DataSet([]);

        function initNetwork() {
            if(network !== null) return; 
            
            const container = document.getElementById('network');
            const data = { nodes: nodes, edges: edges };
            const options = {
                nodes: {
                    shape: 'dot',
                    size: 20,
                    font: { size: 14, color: '#fff' }, // Default white, updated by theme
                    borderWidth: 2,
                    shadow: true
                },
                edges: {
                    width: 2,
                    color: { color: '#666' }
                },
                physics: {
                    stabilization: false,
                    barnesHut: { gravitationalConstant: -2000 }
                }
            };
            network = new vis.Network(container, data, options);
            
            // Populate Fake Andy Reid Data
            nodes.clear(); edges.clear();
            
            // Center
            nodes.add({ id: 1, label: 'Andy Reid', shape: 'circularImage', image: 'https://upload.wikimedia.org/wikipedia/commons/thumb/c/c7/Andy_Reid_Aug_2023.jpg/640px-Andy_Reid_Aug_2023.jpg', size: 40, color: { border: '#ffffff' } });
            
            // Category: Chiefs (Red)
            nodes.add([
                { id: 2, label: 'Patrick Mahomes', group: 'chiefs', color: '#ef4444' },
                { id: 3, label: 'Travis Kelce', group: 'chiefs', color: '#ef4444' },
                { id: 4, label: 'Brett Veach', group: 'chiefs', color: '#ef4444' },
                { id: 5, label: 'Clark Hunt', group: 'chiefs', color: '#ef4444' }
            ]);
            
            // Category: Eagles/Past (Green)
            nodes.add([
                { id: 6, label: 'Donovan McNabb', group: 'eagles', color: '#10b981' },
                { id: 7, label: 'Brett Favre', group: 'eagles', color: '#10b981' }, // Packers connection actually
                { id: 8, label: 'Jeffrey Lurie', group: 'eagles', color: '#10b981' }
            ]);

            // Category: Coaching Tree (Blue)
            nodes.add([
                { id: 9, label: 'Doug Pederson', group: 'coach', color: '#3b82f6' },
                { id: 10, label: 'Sean McDermott', group: 'coach', color: '#3b82f6' },
                { id: 11, label: 'John Harbaugh', group: 'coach', color: '#3b82f6' },
                { id: 12, label: 'Ron Rivera', group: 'coach', color: '#3b82f6' }
            ]);

            // Category: Family (Pink)
            nodes.add([
                { id: 13, label: 'Tammy Reid', group: 'family', color: '#ec4899' },
                { id: 14, label: 'Britt Reid', group: 'family', color: '#ec4899' }
            ]);

            // Category: Charity (Yellow)
            nodes.add([
                { id: 15, label: 'Special Olympics MO', group: 'charity', color: '#eab308' },
                { id: 16, label: 'Laurel House', group: 'charity', color: '#eab308' }
            ]);

            // Edges
            edges.add([
                { from: 1, to: 2 }, { from: 1, to: 3 }, { from: 1, to: 4 }, { from: 1, to: 5 },
                { from: 1, to: 6 }, { from: 1, to: 7 }, { from: 1, to: 8 },
                { from: 1, to: 9 }, { from: 1, to: 10 }, { from: 1, to: 11 }, { from: 1, to: 12 },
                { from: 1, to: 13 }, { from: 1, to: 14 },
                { from: 1, to: 15 }, { from: 1, to: 16 },
                // Interconnections
                { from: 2, to: 3 }, { from: 9, to: 6 } 
            ]);
        }

        // --- Modal Logic ---
        const modal = document.getElementById('personalityModal');
        const networkModal = document.getElementById('networkModal');
        let modalChartInstance = null;

        window.openPersonalityModal = () => {
            modal.classList.remove('hidden');
            setTimeout(() => modal.classList.add('modal-active'), 10);
            
            if (!modalChartInstance) {
                const ctx = document.getElementById('modalChart').getContext('2d');
                modalChartInstance = new Chart(ctx, {
                    type: 'radar',
                    data: mainRadarConfig.data, 
                    options: mainRadarConfig.options
                });
            }
        };

        window.closePersonalityModal = () => {
            modal.classList.remove('modal-active');
            setTimeout(() => modal.classList.add('hidden'), 200);
        };

        window.openNetworkModal = () => {
            networkModal.classList.remove('hidden');
            setTimeout(() => {
                networkModal.classList.add('modal-active');
                initNetwork(); // Init graph when visible
            }, 10);
        };

        window.closeNetworkModal = () => {
            networkModal.classList.remove('modal-active');
            setTimeout(() => networkModal.classList.add('hidden'), 200);
        };

        // Icons
        lucide.createIcons();
    </script>
</body>
</html>
