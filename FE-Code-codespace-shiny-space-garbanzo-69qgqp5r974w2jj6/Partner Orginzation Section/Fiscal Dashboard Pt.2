        function togglePremiumStatDetails(clickedTitleElement, cardId) {
            const parentStatItem = clickedTitleElement.closest('.premium-stat-item');
            const statDetails = parentStatItem.querySelector('.premium-stat-details');
            const toggleArrow = clickedTitleElement.querySelector('.toggle-arrow');

            parentStatItem.parentNode.querySelectorAll('.premium-stat-details.show').forEach(openDetails => {
                if (openDetails !== statDetails) {
                    openDetails.classList.remove('show');
                    openDetails.classList.add('hidden');
                    const otherArrow = openDetails.previousElementSibling.querySelector('.toggle-arrow');
                    if (otherArrow) otherArrow.classList.remove('open');
                }
            });

            statDetails.classList.toggle('hidden');
            statDetails.classList.toggle('show');
            toggleArrow.classList.toggle('open');

            if (statDetails.classList.contains('show')) {
                const statId = parentStatItem.dataset.statId;
                if (statId === 'roiPerHour') {
                    const canvas = statDetails.querySelector('#dropdownRoiChart');
                    if (canvas && !Chart.getChart(canvas)) {
                        new Chart(canvas.getContext('2d'), {
                             type: 'line',
                             data: { labels: ['P1','P2','P3','P4'], datasets: [{ label: 'ROI', data: [2.5, 3.0, 2.8, 3.2], borderColor: '#7C3AED', borderWidth: 2, tension: 0.3 }] },
                             options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } }, scales: { x: { display: false }, y: { display: false } } }
                        });
                    }
                }
            }
        }

        function populateAndShowDropdown(dropdownContentElement, toggleElement, cardId) {
            const overflowList = dropdownContentElement.querySelector('.overflow-list');
            if (!overflowList) return;

            document.querySelectorAll('.card-dropdown-content.show').forEach(openDropdown => {
                if (openDropdown !== dropdownContentElement) {
                    openDropdown.classList.remove('show');
                    const associatedToggle = openDropdown.closest('.card').querySelector('.insights-dropdown-toggle');
                    if (associatedToggle) associatedToggle.classList.remove('open');
                }
            });

            dropdownContentElement.classList.toggle('show');
            toggleElement.classList.toggle('open');

            if (dropdownContentElement.classList.contains('show')) {
                overflowList.innerHTML = ''; 
                const premiumContentHtml = getPremiumContentHtml(cardId);
                overflowList.innerHTML = premiumContentHtml;

                if (window.isPremiumUser) {
                    overflowList.querySelectorAll('.premium-stat-title').forEach(titleElement => {
                        titleElement.addEventListener('click', (event) => {
                            event.stopPropagation();
                            togglePremiumStatDetails(titleElement, cardId);
                        });
                    });
                }

                if (window.allOverflowInsightsData.length > 0 && cardId === 'userInsightsCard') {
                     const insightsByCategory = window.allOverflowInsightsData.reduce((acc, insight) => {
                        const category = insight.category || 'Uncategorized';
                        if (!acc[category]) acc[category] = [];
                        acc[category].push(insight);
                        return acc;
                    }, {});

                    for (const category in insightsByCategory) {
                        const categoryHeader = document.createElement('h4');
                        categoryHeader.classList.add('category-header');
                        categoryHeader.textContent = category;
                        overflowList.appendChild(categoryHeader);
                        insightsByCategory[category].forEach(data => {
                            const insightDiv = document.createElement('div');
                            insightDiv.classList.add('user-insight-item');
                            insightDiv.innerHTML = `<p class="font-semibold text-white mb-1">${data.title}</p><p>${data.description}</p><p class="meta-info">Submitted: ${data.timestamp}</p>`;
                            overflowList.appendChild(insightDiv);
                        });
                    }
                }
            }
        }

        function updatePremiumToggleBtn() {
            const toggleButton = document.getElementById('togglePremiumAccessBtn');
            if (toggleButton) {
                if (window.isPremiumUser) {
                    toggleButton.textContent = 'Premium: ON';
                    toggleButton.classList.remove('bg-gray-500', 'hover:bg-gray-600');
                    toggleButton.classList.add('bg-[var(--accent-green)]', 'hover:bg-[#5cb85c]');
                } else {
                    toggleButton.textContent = 'Premium: OFF';
                    toggleButton.classList.remove('bg-[var(--accent-green)]', 'hover:bg-[#5cb85c]');
                    toggleButton.classList.add('bg-gray-500', 'hover:bg-gray-600');
                }
            }
        }

        function makeTableSortable(tableId) {
            const table = document.getElementById(tableId);
            if (!table) return;
            const headers = table.querySelectorAll('th');
            headers.forEach((header, index) => {
                header.style.cursor = 'pointer'; 
                header.setAttribute('data-sort-dir', 'none'); 
                const sortIndicator = document.createElement('span');
                sortIndicator.classList.add('sort-indicator');
                header.appendChild(sortIndicator);

                header.addEventListener('click', () => {
                    const currentSortDir = header.getAttribute('data-sort-dir');
                    let newSortDir = currentSortDir === 'asc' ? 'desc' : 'asc';
                     
                    headers.forEach(h => {
                        if (h !== header) {
                            h.setAttribute('data-sort-dir', 'none');
                            h.querySelector('.sort-indicator').textContent = '';
                        }
                    });

                    header.setAttribute('data-sort-dir', newSortDir);
                    sortIndicator.textContent = newSortDir === 'asc' ? ' ▲' : ' ▼';

                    const tbody = table.querySelector('tbody');
                    const rows = Array.from(tbody.querySelectorAll('tr'));
                    rows.sort((rowA, rowB) => {
                        const cellA = rowA.children[index].textContent.trim();
                        const cellB = rowB.children[index].textContent.trim();
                        let valA = cellA, valB = cellB;
                        if (!isNaN(parseFloat(cellA)) && !isNaN(parseFloat(cellB))) {
                            valA = parseFloat(cellA.replace(/[^0-9.-]+/g,""));
                            valB = parseFloat(cellB.replace(/[^0-9.-]+/g,""));
                        } else if (cellA.startsWith('$') && cellB.startsWith('$')) {
                            valA = parseFloat(cellA.replace('$', '').replace(/,/g, ''));
                            valB = parseFloat(cellB.replace('$', '').replace(/,/g, ''));
                        }
                        return newSortDir === 'asc' ? (valA > valB ? 1 : -1) : (valA < valB ? 1 : -1);
                    });
                    rows.forEach(row => tbody.appendChild(row));
                });
            });
        }
        
        function generateReport() {
            const { jsPDF } = window.jspdf;
            const doc = new jsPDF();
            doc.text("Volunteer Engagement Report", 20, 20);
            doc.text(`Date Range: ${document.getElementById('dateRange').value}`, 20, 30);
            doc.text(`Event Type: ${document.getElementById('eventType').value}`, 20, 40);
            doc.save("volunteer-report.pdf");
        }

        function exportToCSV() {
            let csvContent = "data:text/csv;charset=utf-8,Volunteer,Task,Value\r\n";
            document.querySelectorAll("#financialContributionTableBody tr").forEach(row => {
                let rowData = [];
                row.querySelectorAll("td").forEach(cell => rowData.push(cell.textContent));
                csvContent += rowData.join(",") + "\r\n";
            });
            const link = document.createElement("a");
            link.setAttribute("href", encodeURI(csvContent));
            link.setAttribute("download", "volunteer_data.csv");
            document.body.appendChild(link);
            link.click();
        }

