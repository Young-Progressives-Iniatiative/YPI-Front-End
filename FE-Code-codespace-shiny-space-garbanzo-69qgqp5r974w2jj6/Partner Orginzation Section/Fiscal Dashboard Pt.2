            display: block; 
            min-height: 100vh; 
            margin: 0; 
            padding: 0; 
            box-sizing: border-box; 
        }
        
        .dashboard-container { 
            width: 100%; 
            max-width: 1400px; 
            display: flex; 
            flex-direction: column; 
            gap: 25px; 
            /* Added auto margin for centering content */
            margin: 20px auto; 
            padding: 0 20px;
        }
        
        /* Header Styling */
        .dashboard-header { background-color: var(--card-bg); padding: 15px 25px; border-radius: 16px; display: flex; items-center; justify-between; box-shadow: 0 4px 20px rgba(0, 0, 0, 0.2); }
        .header-search { background-color: var(--bg-primary); border: none; padding: 10px 15px; border-radius: 8px; color: var(--text-light); width: 300px; }
        .header-search::placeholder { color: var(--text-medium); }

        /* Card Styling */
        .card { background-color: var(--card-bg); border-radius: 20px; padding: 25px; box-shadow: 0 4px 20px rgba(0, 0, 0, 0.25); display: flex; flex-direction: column; position: relative; border: 1px solid var(--border-color); }
        .card-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; }
        .card-header h3 { margin: 0; font-size: 1.1em; font-weight: 500; color: var(--text-light); }
        
        /* Metric Styling */
        .metric { margin-bottom: 10px; }
        .metric .value { font-size: 2.5em; font-weight: 700; color: var(--text-light); display: block; margin-bottom: 5px; line-height: 1; }
        .metric .value .unit { font-size: 0.5em; font-weight: 500; opacity: 0.7; margin-left: 5px; }
        .metric .label { font-size: 0.9em; color: var(--text-medium); font-weight: 500; }
        
        /* CSAT/ROI Card Styling */
        .csat-card { background: linear-gradient(135deg, #1F2128 0%, #2D2F39 100%); overflow: hidden; }
        .csat-main { display: flex; justify-content: space-between; align-items: flex-end; flex-grow: 1; }
        .csat-score .value { font-size: 4em; font-weight: 800; color: var(--text-light); }
        .csat-score .label { color: var(--text-medium); font-size: 1em; }
        .csat-chart-container { flex-grow: 1; display: flex; flex-direction: column; align-items: flex-end; position: relative; height: 100px; }
        .csat-chart-container p { font-size: 0.8em; color: var(--text-medium); margin-bottom: 5px; }
        .exclamation-mark { position: absolute; top: -10px; right: -10px; bg-white text-[var(--accent-red)] rounded-full w-[30px] h-[30px] flex justify-center items-center text-xl font-bold shadow-md; }

        /* Table Styling */
        table { width: 100%; border-collapse: collapse; font-size: 0.95em; }
        table th, table td { padding: 15px 10px; text-align: left; border-bottom: 1px solid var(--border-color); }
        table th { color: var(--text-medium); font-weight: 500; font-size: 0.85em; text-transform: uppercase; position: relative; padding-right: 20px; letter-spacing: 0.05em; }
        table td { color: var(--text-light); font-weight: 500; }
        .status-offline { color: var(--text-medium); }
        .status-online { color: var(--accent-green); }
        
        /* Modal & Form Styling */
        .modal { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background-color: rgba(0, 0, 0, 0.8); display: flex; justify-content: center; align-items: center; z-index: 1000; visibility: hidden; opacity: 0; transition: visibility 0s, opacity 0.3s; }
        .modal.show { visibility: visible; opacity: 1; }
        .modal-content { background-color: var(--card-bg); padding: 30px; border-radius: 20px; width: 90%; max-width: 500px; position: relative; border: 1px solid var(--border-color); }
        .close-button { position: absolute; top: 20px; right: 20px; background: none; border: none; font-size: 1.5em; color: var(--text-medium); cursor: pointer; transition: color 0.2s; }
        .close-button:hover { color: var(--text-light); }
        .form-group { margin-bottom: 20px; }
        .form-group label { display: block; margin-bottom: 8px; color: var(--text-light); font-weight: 500; }
        .form-group input, .form-group textarea, .form-group select { width: 100%; padding: 12px; border-radius: 8px; border: 1px solid var(--border-color); background-color: var(--bg-primary); color: var(--text-light); box-sizing: border-box; transition: border-color 0.2s; }
        .form-group input:focus, .form-group textarea:focus, .form-group select:focus { border-color: var(--accent-blue); outline: none; }
        
        /* Dropdown & Insights Styling */
        .insights-dropdown-toggle { cursor: pointer; font-size: 1.5em; transform: rotate(90deg); transition: transform 0.3s, opacity 0.3s, color 0.2s; opacity: 0; position: absolute; right: 25px; top: 25px; color: var(--text-medium); z-index: 10; }
        .card:hover .insights-dropdown-toggle { opacity: 1; }
        .insights-dropdown-toggle:hover { color: var(--text-light); }
        .insights-dropdown-toggle.open { transform: rotate(270deg); }
        .card-dropdown-content { position: absolute; top: 100%; left: 0; right: 0; background-color: var(--card-bg); border-radius: 16px; box-shadow: 0 8px 30px rgba(0, 0, 0, 0.5); padding: 20px; margin-top: 10px; z-index: 999; display: none; flex-direction: column; max-height: 400px; overflow-y: auto; border: 1px solid var(--border-color); }
        .card-dropdown-content.show { display: flex; }
        .premium-stat-item { margin-bottom: 15px; border-bottom: 1px solid var(--border-color); padding-bottom: 15px; }
        .premium-stat-item:last-of-type { border-bottom: none; margin-bottom: 0; padding-bottom: 0; }
        .premium-stat-title { font-size: 1.05em; font-weight: 600; color: var(--text-light); cursor: pointer; padding: 5px 0; display: flex; justify-content: space-between; align-items: center; transition: color 0.2s; }
        .premium-stat-title:hover { color: var(--accent-blue); }
        .premium-stat-title .toggle-arrow { transform: rotate(90deg); transition: transform 0.2s; font-size: 0.9em; }
        .premium-stat-title .toggle-arrow.open { transform: rotate(270deg); }
        .premium-stat-details { margin-top: 15px; padding-left: 15px; border-left: 2px solid var(--accent-blue); }
        .premium-stat-details.hidden { display: none; }
        .premium-stat-details.show { display: block; }
        .user-insight-item { background-color: var(--bg-primary); padding: 15px; border-radius: 12px; margin-bottom: 15px; border: 1px solid var(--border-color); }
        .user-insight-item p { margin: 0; font-size: 0.95em; color: var(--text-light); line-height: 1.5; }
