                    <span id="hungerScoreToggle" class="insights-dropdown-toggle">&gt;</span>
                </div>
                <div class="metric mb-6"><span class="value">7.5<span class="unit">/10</span></span><span class="label">Avg. Hunger Score</span></div>
                <div class="metric"><span class="value">1.58<span class="unit">EV</span></span><span class="label">Hunger-Adjusted EV</span></div>
                <div class="card-dropdown-content" id="hungerScoreDropdown"><div class="overflow-list"></div></div>
            </div>

             <!-- Projects Completed -->
             <div class="card col-span-1" id="projectsCompletedCard">
                <div class="card-header">
                    <h3>Projects Leaderboard</h3>
                    <span class="insights-dropdown-toggle" id="projectsCompletedToggle">&gt;</span>
                </div>
                <table class="w-full text-sm" id="projectsCompletedTable">
                    <thead><tr><th>Name</th><th>Proj</th></tr></thead>
                    <tbody>
                        <tr><td>Alice Johnson</td><td>12</td></tr>
                        <tr><td>Bob Williams</td><td>10</td></tr>
                        <tr><td>Charlie Brown</td><td>8</td></tr>
                    </tbody>
                </table>
                <div class="card-dropdown-content" id="projectsCompletedDropdown"><div class="overflow-list"></div></div>
            </div>

            <!-- Financial Value -->
            <div class="card col-span-1" id="financialValueCard">
                <div class="card-header">
                    <h3>Financial Value</h3>
                    <span class="insights-dropdown-toggle" id="financialValueToggle">&gt;</span>
                </div>
                <table class="w-full text-sm mb-4" id="financialContributionTable">
                    <thead><tr><th>Volunteer</th><th>Value</th></tr></thead>
                    <tbody id="financialContributionTableBody">
                        <tr><td>Alice Johnson</td><td>$750</td></tr>
                        <tr><td>Bob Williams</td><td>$1,200</td></tr>
                        <tr><td>Diana Prince</td><td>$2,500</td></tr>
                    </tbody>
                </table>
                <button id="addFinancialContributionBtn" class="bg-[var(--accent-blue)] hover:bg-blue-600 text-white font-medium py-2 px-4 rounded-lg w-full transition-all">Add Contribution</button>
                <div class="card-dropdown-content" id="financialValueDropdown"><div class="overflow-list"></div></div>
            </div>

            <!-- Individual Satisfaction -->
            <div class="card col-span-1" id="individualSatisfactionCard">
                <div class="card-header">
                    <h3>Satisfaction Scores</h3>
                    <span class="insights-dropdown-toggle" id="individualSatisfactionToggle">&gt;</span>
                </div>
                <table class="w-full text-sm" id="individualSatisfactionTable">
                    <thead><tr><th>Name</th><th>Score</th></tr></thead>
                    <tbody>
                        <tr><td>David Lee</td><td class="status-online font-semibold">9.2</td></tr>
                        <tr><td>Emily Chen</td><td class="status-online font-semibold">8.8</td></tr>
                        <tr><td>Sarah Davis</td><td class="status-online font-semibold">8.5</td></tr>
                    </tbody>
                </table>
                <div class="card-dropdown-content" id="individualSatisfactionDropdown"><div class="overflow-list"></div></div>
            </div>

             <!-- User Insights -->
             <div class="card col-span-full" id="userInsightsCard">
                <div class="card-header">
                    <h3>User Insights</h3>
                    <span id="userInsightsToggle" class="insights-dropdown-toggle">&gt;</span>
                </div>
                <div id="userInsightsList" class="grid grid-cols-1 md:grid-cols-3 gap-4">
                    <p class="no-insights-message col-span-full" id="noInsightsMessage">No insights submitted yet.</p>
                </div>
                <div class="card-dropdown-content" id="userInsightsDropdown"><div id="overflowInsightsList" class="overflow-list"></div></div>
            </div>
        </main>

        <!-- Footer (Dashboard Controls) -->
        <footer class="dashboard-footer">
            <div class="flex items-center gap-4">
                <span id="currentUserIdDisplay" class="text-sm text-[var(--text-medium)] font-medium">User ID: Loading...</span>
                <button id="togglePremiumAccessBtn" class="bg-gray-600 hover:bg-gray-700 text-white font-medium py-2 px-4 rounded-lg transition-all">Premium: OFF</button>
            </div>
            <button id="submitInsightBtn" class="bg-[var(--accent-green)] hover:bg-green-600 text-white font-medium py-2 px-4 rounded-lg transition-all">Submit New Insight</button>
        </footer>

        <!-- Add New Financial Contribution Modal -->
        <div id="addFinancialContributionModal" class="modal">
            <div class="modal-content">
                <button class="close-button" id="closeFinancialContributionModalBtn">&times;</button>
                <h2 class="text-xl font-bold mb-6 text-white">Add New Contribution Entry</h2>
                <form id="newFinancialContributionForm">
                    <div class="form-group"><label for="financialContributionVolunteerName">Volunteer Name:</label><input type="text" id="financialContributionVolunteerName" required placeholder="e.g., John Doe"></div>
                    <div class="form-group"><label for="financialContributionTask">Task Performed:</label><input type="text" id="financialContributionTask" required placeholder="e.g., Event Setup"></div>
                    <div class="form-group"><label for="financialContributionValue">Calculated Value:</label><input type="text" id="financialContributionValue" required placeholder="e.g., $500"></div>
                    <button type="submit" class="bg-[var(--accent-blue)] hover:bg-blue-600 text-white font-bold py-3 px-4 rounded-lg w-full transition-all">Add Entry</button>
                </form>
            </div>
        </div>

        <!-- Submit New Insight Modal -->
        <div id="submitInsightModal" class="modal">
            <div class="modal-content">
                <button class="close-button" id="closeInsightModalBtn">&times;</button>
                <h2 class="text-xl font-bold mb-6 text-white">Submit New Insight</h2>
                <form id="newInsightForm">
                    <div class="form-group"><label for="insightTitle">Insight Title:</label><input type="text" id="insightTitle" required placeholder="Short, descriptive title"></div>
                    <div class="form-group"><label for="insightDescription">Description:</label><textarea id="insightDescription" required placeholder="Detailed explanation of the insight..." rows="4"></textarea></div>
                    <div class="form-group"><label for="insightCategory">Category:</label><select id="insightCategory"><option>Total Volunteer Hours</option><option>V-WAR Analysis</option><option>Burnout Risk</option><option>Operational Efficiency</option><option>Other</option></select></div>
                    <button type="submit" class="bg-[var(--accent-green)] hover:bg-green-600 text-white font-bold py-3 px-4 rounded-lg w-full transition-all">Submit Insight</button>
                </form>
            </div>
        </div>
    </div>

</body>
</html>
