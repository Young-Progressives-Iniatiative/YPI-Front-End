<!DOCTYPE html>
<html lang="en" class="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>YPI | Partner Role Management</title>
    
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            darkMode: 'class',
            theme: {
                extend: {
                    colors: {
                        ypi: {
                            green: '#37af4b',
                            dark: '#1c1c1c',
                            card: '#252525',
                            hover: '#2d8c3c'
                        }
                    },
                    fontFamily: {
                        sans: ['Atkinson Hyperlegible', 'sans-serif'],
                        mono: ['ui-monospace', 'SFMono-Regular', 'Menlo', 'Monaco', 'Consolas', 'Liberation Mono', 'Courier New', 'monospace']
                    }
                }
            }
        }
    </script>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Atkinson+Hyperlegible:ital,wght@0,400;0,700;1,400;1,700&display=swap" rel="stylesheet">
    
    <!-- FontAwesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>

    <style>
        :root {
            --bg-main: #1c1c1c;
            --bg-panel: #1b1b1b;
            --bg-element: #2a2d35;
            --text-main: #ffffff;
            --text-muted: #9ca3af;
            --border-color: #2a2a2a;
            --accent-green: #37af4b;
            --highlight-green: #98fb98;
        }

        body {
            font-family: 'Atkinson Hyperlegible', sans-serif;
            background-color: var(--bg-main);
            color: var(--text-main);
            margin: 0;
            overflow: hidden;
        }

        /* Custom Scrollbar */
        ::-webkit-scrollbar { width: 6px; }
        ::-webkit-scrollbar-track { background: var(--bg-panel); }
        ::-webkit-scrollbar-thumb { background: #333; border-radius: 3px; }
        ::-webkit-scrollbar-thumb:hover { background: var(--accent-green); }

        .tab-content { display: none; width: 100%; height: calc(100vh - 64px); overflow-y: auto; }
        .tab-content.active { display: flex; flex-direction: column; }

        .subnav-btn { padding-bottom: 0.125rem; transition: all 0.2s; }

        .fade-in { animation: fadeIn 0.3s ease-out; }
        @keyframes fadeIn { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: translateY(0); } }

        /* Modal Specific Styles from Image */
        .modal-blur { backdrop-filter: blur(20px); background: rgba(0, 0, 0, 0.8); }
        .score-circle { 
            width: 120px; 
            height: 120px; 
            border-radius: 50%; 
            display: flex; 
            flex-direction: column; 
            align-items: center; 
            justify-content: center;
            border: 4px solid #37af4b;
            box-shadow: 0 0 20px rgba(55, 175, 75, 0.2);
            background: rgba(55, 175, 75, 0.05);
        }

        .stat-card {
            background: rgba(255,255,255,0.03);
            border: 1px solid rgba(255,255,255,0.07);
            border-radius: 12px;
            padding: 12px;
            transition: all 0.2s;
        }
        .stat-card:hover {
            border-color: var(--highlight-green);
            background: rgba(152, 251, 152, 0.05);
        }
    </style>
</head>
<body>

    <!-- MAIN HEADER -->
    <header class="flex flex-col w-full bg-[#1b1b1b] border-b border-[#2a2a2a] shadow-lg sticky top-0 z-50">
        <div class="flex items-center h-16 px-6 gap-6 overflow-x-auto no-scrollbar">
            <div class="flex-shrink-0 mr-4 flex items-center gap-4">
                 <div class="h-10 w-10 bg-ypi-green rounded-lg flex items-center justify-center text-white font-bold text-xl">Y</div>
                 <div class="h-12 w-auto flex items-center">
                    <img src="https://weareypi.com/wp-content/uploads/2025/06/Site-Icon-3.png" alt="YPI" class="h-8 w-auto object-contain" onerror="this.style.display='none'">
                 </div>
            </div>
            <nav class="flex items-center gap-4" id="main-nav"></nav>
        </div>
    </header>

    <!-- MAIN CONTENT AREA -->
    <div class="main-content w-full h-[calc(100vh-64px)]">
        
        <section id="content-Organizing" class="tab-content active">
            <!-- SUB-HEADER -->
            <div class="w-full bg-[#2a2d35] border-b border-[#2a2a2a] py-3 px-6 flex items-center justify-between gap-4 shadow-sm flex-shrink-0">
                <nav class="flex gap-5 text-sm font-medium" id="organizingSubNav">
                    <button class="subnav-btn text-white border-b-2 border-[#37af4b]" onclick="switchMainView('databaseView', this)">Volunteers</button>
                    <button class="subnav-btn text-gray-400 hover:text-white" onclick="switchMainView('roleManagementView', this)">Roles</button>
                    <button class="subnav-btn text-gray-400 hover:text-white" onclick="switchMainView('territoryView', this)">Territory Map</button>
                </nav>
                <div class="flex items-center gap-4">
                    <div class="text-right hidden sm:block">
                        <div class="text-[10px] text-gray-400 uppercase font-bold tracking-widest">Active Volunteers</div>
                        <div class="text-sm font-bold text-[#98fb98]">1,248 Records</div>
                    </div>
                </div>
            </div>

            <div class="w-full flex-grow overflow-y-auto px-6 py-8">
                
                <div id="databaseView" class="w-full max-w-7xl mx-auto fade-in">
                    <!-- Filter Builder -->
                    <div class="bg-[#121212] p-4 border border-[#333] rounded-t-xl mb-4">
                        <div class="flex justify-between items-center mb-3">
                            <h3 class="text-[#98fb98] font-bold text-sm uppercase tracking-wide flex items-center gap-2">
                                <i data-lucide="filter" class="w-4 h-4"></i> Database Search
                            </h3>
                        </div>
                        <div class="relative w-full">
                            <i data-lucide="search" class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-500"></i>
                            <input type="text" placeholder="Search by name, school, or interest..." class="w-full bg-neutral-900 border border-neutral-700 text-white text-sm rounded-lg pl-10 pr-4 py-2 focus:ring-1 focus:ring-ypi-green focus:outline-none">
                        </div>
                    </div>

                    <!-- Table (Image Reference Data) -->
                    <div class="w-full overflow-x-auto bg-[#121212] rounded-xl border border-[#333] shadow-2xl">
                        <table class="w-full text-left border-collapse">
                            <thead>
                                <tr class="bg-[#1a1a1a] text-[10px] text-gray-500 uppercase tracking-wider border-b border-[#333]">
                                    <th class="p-4">Est</th>
                                    <th class="p-4">Name</th>
                                    <th class="p-4">School</th>
                                    <th class="p-4">eVLA</th>
                                    <th class="p-4 text-center">NAT</th>
                                    <th class="p-4 text-right">Action</th>
                                </tr>
                            </thead>
                            <tbody class="text-sm divide-y divide-[#222]">
                                <tr class="hover:bg-[#1f1f1f] transition group">
                                    <td class="p-4 text-gray-400 font-mono">A+</td>
                                    <td class="p-4">
                                        <div class="font-bold text-white">Alex Johnson</div>
                                        <div class="text-xs text-blue-400">ID: 82910</div>
                                    </td>
                                    <td class="p-4 text-gray-400">B-CC High</td>
                                    <td class="p-4 text-white font-bold">78</td>
                                    <td class="p-4 text-center">🇺🇸</td>
                                    <td class="p-4 text-right">
                                        <button class="bg-[#37af4b] hover:bg-[#2d8c3c] text-white text-[11px] font-bold px-4 py-2 rounded-lg uppercase tracking-wider transition" onclick="openVolunteerProfile('Alex Johnson', '82910')">
                                            View Profile
                                        </button>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>

                <div id="roleManagementView" class="hidden text-center py-20 text-gray-500">Role Management Content</div>
                <div id="territoryView" class="hidden text-center py-20 text-gray-500">Territory Map Content</div>

            </div>
        </section>
    </div>

    <!-- VOLUNTEER PROFILE POPUP (BASED ON IMAGE) -->
    <div id="volunteerModal" class="fixed inset-0 z-[100] hidden items-center justify-center p-4">
        <div class="absolute inset-0 modal-blur" onclick="closeVolunteerProfile()"></div>
        
        <div class="relative bg-neutral-900 border border-white/10 w-full max-w-4xl rounded-[2.5rem] overflow-hidden shadow-[0_0_80px_rgba(0,0,0,0.9)] flex flex-col max-h-[92vh] fade-in">
            
            <!-- Header Bar -->
            <div class="p-6 border-b border-white/5 flex justify-between items-center bg-[#151515]">
                <div class="flex items-center gap-3">
                    <div class="h-8 w-8 bg-ypi-green/20 rounded flex items-center justify-center">
                        <i data-lucide="user" class="w-4 h-4 text-ypi-green"></i>
                    </div>
                    <div class="flex flex-col">
                        <span id="headerName" class="text-white font-bold leading-none">Alex Johnson</span>
                        <span id="headerId" class="text-[10px] text-gray-500 font-mono uppercase tracking-widest mt-1">ID: 82910 • B-CC High School</span>
                    </div>
                </div>
                <button class="text-gray-500 hover:text-white transition" onclick="closeVolunteerProfile()">
                    <i data-lucide="x" class="w-6 h-6"></i>
                </button>
            </div>

            <div class="flex flex-col md:flex-row flex-grow overflow-hidden">
                <!-- Left Sidebar: Score & Status -->
                <div class="w-full md:w-64 bg-[#1a1a1a] p-8 border-r border-white/5 flex flex-col items-center">
                    <div class="score-circle mb-6">
                        <span id="profileScore" class="text-4xl font-bold text-white">78</span>
                        <span class="text-[9px] text-gray-500 font-bold uppercase tracking-widest mt-1">eVLA Score</span>
                    </div>
                    
                    <div class="bg-purple-500/10 border border-purple-500/20 text-purple-400 px-4 py-1.5 rounded-full text-xs font-bold uppercase tracking-widest mb-8">
                        Wonderkid
                    </div>

                    <div class="w-full space-y-4">
                        <div class="flex justify-between items-center text-xs">
                            <span class="text-gray-500 font-bold uppercase tracking-widest">Experience</span>
                            <span class="text-white font-bold">Elite</span>
                        </div>
                        <div class="flex justify-between items-center text-xs">
                            <span class="text-gray-500 font-bold uppercase tracking-widest">Comm Time</span>
                            <span class="text-[#98fb98] font-bold">95m / wk</span>
                        </div>
                        <div class="flex justify-between items-center text-xs">
                            <span class="text-gray-500 font-bold uppercase tracking-widest">Reliability</span>
                            <span class="text-blue-400 font-bold">High</span>
                        </div>
                    </div>

                    <div class="mt-auto w-full pt-8">
                        <div class="text-[9px] text-gray-600 font-bold uppercase tracking-widest mb-2">Primary Interest</div>
                        <div class="bg-blue-500/10 border border-blue-500/20 rounded-lg p-3 text-center">
                            <div class="text-xs font-bold text-blue-400">Voter Reg '25</div>
                            <div class="text-[10px] text-blue-300/50 mt-1 italic">Source: Outreach Dept</div>
                        </div>
                    </div>
                </div>

                <!-- Main Data Grid -->
                <div class="flex-grow p-8 overflow-y-auto space-y-8 bg-[#121212]">
                    <!-- Academic Performance -->
                    <section>
                        <h3 class="text-[10px] text-gray-500 font-bold uppercase tracking-widest mb-4 flex items-center gap-2">
                            <i data-lucide="graduation-cap" class="w-3 h-3"></i> Academic Metrics
                        </h3>
                        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
                            <div class="stat-card">
                                <div class="text-[9px] text-gray-500 font-bold uppercase mb-1">GPA+</div>
                                <div class="text-xl font-bold text-white">112</div>
                            </div>
                            <div class="stat-card">
                                <div class="text-[9px] text-gray-500 font-bold uppercase mb-1">wGPA+</div>
                                <div class="text-xl font-bold text-white">105</div>
                            </div>
                            <div class="stat-card">
                                <div class="text-[9px] text-gray-500 font-bold uppercase mb-1">SSL Hours</div>
                                <div class="text-xl font-bold text-[#98fb98]">110</div>
                            </div>
                            <div class="stat-card">
                                <div class="text-[9px] text-gray-500 font-bold uppercase mb-1">English</div>
                                <div class="text-xl font-bold text-white">98</div>
                            </div>
                        </div>
                    </section>

                    <!-- Organizing Profile -->
                    <section>
                        <h3 class="text-[10px] text-gray-500 font-bold uppercase tracking-widest mb-4 flex items-center gap-2">
                            <i data-lucide="network" class="w-3 h-3"></i> Organizing Potential
                        </h3>
                        <div class="grid grid-cols-2 gap-4">
                            <div class="stat-card flex justify-between items-center">
                                <div>
                                    <div class="text-[9px] text-gray-500 font-bold uppercase mb-1">History Potential</div>
                                    <div class="text-xl font-bold text-white">101</div>
                                </div>
                                <i data-lucide="trending-up" class="w-5 h-5 text-gray-600"></i>
                            </div>
                            <div class="stat-card flex justify-between items-center">
                                <div>
                                    <div class="text-[9px] text-gray-500 font-bold uppercase mb-1">Math Potential</div>
                                    <div class="text-xl font-bold text-white">120</div>
                                </div>
                                <i data-lucide="zap" class="w-5 h-5 text-ypi-green"></i>
                            </div>
                        </div>
                    </section>

                    <!-- Internal Note -->
                    <div class="bg-neutral-800/40 rounded-2xl p-6 border border-white/5 italic text-gray-400 text-sm leading-relaxed">
                        "Candidate demonstrates extremely high initiative in local Voter Registration drives. Recommended for Lead Canvasser role for the Spring 2026 cycle given their SSL engagement."
                    </div>
                </div>
            </div>

            <!-- Footer Actions (Based on Image) -->
            <div class="p-8 border-t border-white/5 bg-[#151515] flex items-center justify-between">
                <button class="flex items-center gap-2 text-gray-500 hover:text-white transition font-bold text-sm" onclick="alert('Shortlisted')">
                    <i data-lucide="star" class="w-4 h-4"></i>
                    Add to Shortlist
                </button>
                <div class="flex gap-4">
                    <button class="px-6 py-3 rounded-xl bg-neutral-800 text-white font-bold border border-white/5 hover:bg-neutral-700 transition" onclick="closeVolunteerProfile()">
                        Close
                    </button>
                    <button class="px-8 py-3 rounded-xl bg-[#37af4b] text-white font-bold hover:bg-[#2d8c3c] transition shadow-lg shadow-green-900/40" onclick="alert('Encouragement Sent!')">
                        Send Encouragement
                    </button>
                </div>
            </div>

        </div>
    </div>

    <script>
        // Main Navigation
        const navItems = ['Vision', 'Organizing', 'Financials', 'Analytics'];
        const navContainer = document.getElementById('main-nav');
        let activeTab = 'Organizing';

        function showTabContent(tabName) {
            document.querySelectorAll('.tab-content').forEach(s => s.classList.remove('active'));
            const target = document.getElementById(`content-${tabName}`);
            if(target) target.classList.add('active');
        }

        navItems.forEach(item => {
            const btn = document.createElement('button');
            const isActive = item === activeTab;
            btn.className = `px-4 py-2 text-lg font-bold transition-all ${isActive ? 'text-[#98fb98] drop-shadow-[0_0_8px_rgba(152,251,152,0.25)]' : 'text-gray-400 hover:text-white'}`;
            btn.innerHTML = item;
            btn.addEventListener('click', function() {
                document.querySelectorAll('#main-nav button').forEach(b => b.className = 'px-4 py-2 text-lg font-bold text-gray-400 hover:text-white transition-all');
                this.className = 'px-4 py-2 text-lg font-bold text-[#98fb98] drop-shadow-[0_0_8px_rgba(152,251,152,0.25)]';
                showTabContent(item);
            });
            navContainer.appendChild(btn);
        });

        // View Toggles
        window.switchMainView = function(viewId, btn) {
            ['databaseView', 'roleManagementView', 'territoryView'].forEach(id => {
                const el = document.getElementById(id);
                if(el) el.classList.add('hidden');
            });
            const target = document.getElementById(viewId);
            if(target) target.classList.remove('hidden');

            const navBtns = document.querySelectorAll('#organizingSubNav button');
            navBtns.forEach(b => b.className = 'subnav-btn text-gray-400 hover:text-white');
            if(btn) btn.className = 'subnav-btn text-white border-b-2 border-[#37af4b]';
        }

        // Volunteer Profile Modal Controls
        window.openVolunteerProfile = function(name, id) {
            const modal = document.getElementById('volunteerModal');
            document.getElementById('headerName').innerText = name;
            document.getElementById('headerId').innerText = `ID: ${id} • B-CC High School`;
            
            modal.classList.remove('hidden');
            modal.classList.add('flex');
            document.body.style.overflow = 'hidden';
            if(window.lucide) lucide.createIcons();
        }

        window.closeVolunteerProfile = function() {
            const modal = document.getElementById('volunteerModal');
            modal.classList.add('hidden');
            modal.classList.remove('flex');
            document.body.style.overflow = 'auto';
        }

        document.addEventListener('DOMContentLoaded', () => {
            if(window.lucide) lucide.createIcons();
        });
    </script>
</body>
</html>
