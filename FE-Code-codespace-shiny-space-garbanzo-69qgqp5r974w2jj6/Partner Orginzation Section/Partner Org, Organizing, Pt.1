    <script>
        // GLOBAL VARIABLES
        let map;
        let donorLayer, socialLayer, networkLayer;
        let events = [], roster = []; // Initialize empty or from storage in load
        let currentDate = new Date();
        let currentView = 'grid'; 

        // GLOBAL FUNCTIONS
        window.switchMainView = function(viewId, btn) {
            const views = ['roleManagementView', 'calendarView', 'databaseView', 'remoteDatabaseView', 'eventDatabaseView', 'organizingNetworkView'];
            views.forEach(v => {
                const el = document.getElementById(v);
                if(el) {
                    el.classList.add('hidden');
                    if(v === 'organizingNetworkView') el.style.display = 'none'; 
                }
            });
            
            const target = document.getElementById(viewId);
            if(target) {
                target.classList.remove('hidden');
                
                if (viewId === 'organizingNetworkView') {
                    target.style.display = 'flex';
                    if(window.mapInstance) setTimeout(() => { window.mapInstance.invalidateSize(); }, 100);
                }
                
                // If calendar, refresh UI
                if(viewId === 'calendarView' && window.refreshUI) {
                    window.refreshUI();
                }
            }
            
            // Update button styles
            const navContainer = document.getElementById('organizingSubNav');
            if(navContainer) {
                const btns = navContainer.querySelectorAll('.subnav-btn');
                btns.forEach(b => b.className = 'subnav-btn text-gray-400 hover:text-white transition-colors whitespace-nowrap');
                if(btn) btn.className = 'subnav-btn text-white border-b-2 border-[#37af4b] pb-0.5 whitespace-nowrap';
            }
        }
        
        window.switchSubTab = function(sectionId) {
            const myRoles = document.getElementById('myRolesSection');
            const createRole = document.getElementById('createRoleSection');
            if(myRoles) myRoles.classList.add('hidden');
            if(createRole) createRole.classList.add('hidden');
            
            const target = document.getElementById(sectionId);
            if(target) target.classList.remove('hidden');
        }

        window.handlePublish = function(e) {
            e.preventDefault();
            alert("Role Published!"); 
            window.switchSubTab('myRolesSection');
        }

        window.openRoleModal = function() { const m = document.getElementById('roleModal'); if(m) m.classList.remove('hidden'); }
        window.closeRoleModal = function() { const m = document.getElementById('roleModal'); if(m) m.classList.add('hidden'); }

        window.toggleLayer = function(layerType, btn) {
            const overviewEl = document.getElementById('sidebar-overview');
            const detailEl = document.getElementById('sidebar-detail');
            const isAlreadyActive = btn.classList.contains('active');

            document.querySelectorAll('.layer-btn').forEach(b => b.classList.remove('active'));

            if(map) {
                if(donorLayer) map.removeLayer(donorLayer);
                if(socialLayer) map.removeLayer(socialLayer);
                if(networkLayer) map.removeLayer(networkLayer);

                if (isAlreadyActive) {
                    // Back to default
                    if(donorLayer) map.addLayer(donorLayer);
                    if(overviewEl) overviewEl.classList.remove('hidden');
                    if(detailEl) detailEl.classList.add('hidden');
                } else {
                    btn.classList.add('active');
                    
                    if(layerType === 'donor' && donorLayer) map.addLayer(donorLayer);
                    if(layerType === 'social' && socialLayer) map.addLayer(socialLayer);
                    if(layerType === 'network' && networkLayer) map.addLayer(networkLayer);

                    if(overviewEl) overviewEl.classList.add('hidden');
                    if(detailEl) {
                        detailEl.classList.remove('hidden');
                        let content = '';
                        // Simple content injection for demo
                        if(layerType === 'donor') content = '<div class="text-white text-sm">Donor Layer Active</div>';
                        else if(layerType === 'social') content = '<div class="text-white text-sm">Social Layer Active</div>';
                        else content = '<div class="text-white text-sm">Network Layer Active</div>';
                        detailEl.innerHTML = content;
                    }
                }
            }
        };

        // --- CALENDAR LOGIC HELPERS ---
        window.refreshUI = function() {
            const calGrid = document.getElementById('calendarGrid');
            const listView = document.getElementById('listView');
            const prevBtn = document.getElementById('prevMonth');
            const nextBtn = document.getElementById('nextMonth');
            const calTitle = document.getElementById('calendarTitle');
            const icon = document.getElementById('headerIcon');
            const monthNames = ["January", "February", "March", "April", "May", "June", "July", "August", "September", "October", "November", "December"];

            if (currentView === 'grid') {
                window.renderCalendar(currentDate);
                if(calGrid) calGrid.style.display = 'grid';
                if(listView) listView.style.display = 'none';
                if(prevBtn) prevBtn.style.display = 'flex';
                if(nextBtn) nextBtn.style.display = 'flex';
                if(calTitle) calTitle.innerText = `${monthNames[currentDate.getMonth()]} ${currentDate.getFullYear()}`;
            } else {
                window.renderListView();
                if(calGrid) calGrid.style.display = 'none';
                if(listView) listView.style.display = 'flex';
                if(prevBtn) prevBtn.style.display = 'none';
                if(nextBtn) nextBtn.style.display = 'none';
                if(calTitle) calTitle.innerText = "Upcoming Events";
            }
            if(typeof lucide !== 'undefined') lucide.createIcons();
        }

        window.renderCalendar = function(date) {
            const grid = document.getElementById('calendarGrid');
            if(!grid) return;
            grid.innerHTML = '';
            const year = date.getFullYear();
            const month = date.getMonth();

            ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'].forEach(d => {
                grid.insertAdjacentHTML('beforeend', `<div class="calendar-day-header">${d}</div>`);
            });

            const firstDay = new Date(year, month, 1).getDay();
            const daysInMonth = new Date(year, month + 1, 0).getDate();
            const daysInPrevMonth = new Date(year, month, 0).getDate();

            for (let i = firstDay; i > 0; i--) {
                grid.insertAdjacentHTML('beforeend', `<div class="calendar-day inactive"><span class="day-number">${daysInPrevMonth - i + 1}</span></div>`);
            }

            for (let i = 1; i <= daysInMonth; i++) {
                let isToday = (i === new Date().getDate() && month === new Date().getMonth() && year === new Date().getFullYear()) ? 'today' : '';
                let dayHTML = `<div class="calendar-day ${isToday}"><span class="day-number">${i}</span>`;
                
                const dayString = `${year}-${String(month+1).padStart(2,'0')}-${String(i).padStart(2,'0')}`;
                const dayEvents = events.filter(e => e.date === dayString);
                
                dayEvents.forEach(evt => {
                    let time = evt.time ? evt.time : ''; 
                    dayHTML += `<div class="calendar-event" onclick="window.openAttendanceModal('${evt.id}')"><span class="calendar-event-time">${time}</span>${evt.title}</div>`;
                });
                dayHTML += `</div>`;
                grid.insertAdjacentHTML('beforeend', dayHTML);
            }
        }

        window.renderListView = function() {
            const lv = document.getElementById('listView');
            if(!lv) return;
            lv.innerHTML = '';
            // Simple render for demo
            if(events.length === 0) lv.innerHTML = '<div class="empty-list-message">No events</div>';
            else {
                events.forEach(evt => {
                    lv.insertAdjacentHTML('beforeend', `<div class="event-list-item" onclick="window.openAttendanceModal('${evt.id}')"><div class="event-list-title">${evt.title}</div></div>`);
                });
            }
        }

        window.openAttendanceModal = function(id) {
            const m = document.getElementById('attendanceModalWrapper');
            if(m) m.classList.add('active');
        }

        document.addEventListener('DOMContentLoaded', () => {
            // --- HEADER NAV ---
            const navItems = ['Vision', 'Organizing', 'Financials', 'Data Suite', 'Projects', 'Marketing', 'Donors'];
            const navContainer = document.getElementById('main-nav');
            let activeTab = 'Organizing'; 

            function showTabContent(tabName) {
                document.querySelectorAll('.tab-content').forEach(s => {
                    s.style.display = 'none';
                    s.classList.remove('active');
                });
                
                const t = document.getElementById(`content-${tabName.replace(/\s+/g, '')}`);
                if (t) {
                    t.style.display = 'flex';
                    if(tabName === 'Organizing') t.style.flexDirection = 'column'; 
                    t.classList.add('active');
                    
                    if(tabName === 'Organizing' && window.mapInstance) {
                         setTimeout(() => { window.mapInstance.invalidateSize(); }, 100);
                    }
                }
            }

            navItems.forEach(item => {
                const btn = document.createElement('button');
                const isActive = item === activeTab;
                btn.className = `group flex items-center px-3 py-2 text-xl font-bold tracking-tight font-fm-header transition-all cursor-pointer ${isActive ? 'text-[#98fb98] drop-shadow-[0_0_8px_rgba(152,251,152,0.25)] scale-105' : 'text-gray-400 hover:text-white hover:scale-105'}`;
                btn.innerHTML = `<span>${item}</span>`;
                btn.addEventListener('click', function() {
                    Array.from(navContainer.children).forEach(c => c.className = 'group flex items-center px-3 py-2 text-xl font-bold tracking-tight font-fm-header transition-all cursor-pointer text-gray-400 hover:text-white hover:scale-105');
                    this.className = 'group flex items-center px-3 py-2 text-xl font-bold tracking-tight font-fm-header transition-all cursor-pointer text-[#98fb98] drop-shadow-[0_0_8px_rgba(152,251,152,0.25)] scale-105';
                    activeTab = item;
                    showTabContent(item);
                });
                navContainer.appendChild(btn);
            });
            
            showTabContent('Organizing');

            // --- MAP LOGIC (Leaflet) ---
            const mapContainer = document.getElementById('organizingMap');
            if (mapContainer) {
                map = L.map('organizingMap', {
                    center: [38.9072, -77.0369], // Washington DC
                    zoom: 9, 
                    zoomControl: false
                });
                window.mapInstance = map; 

                L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png', {
                    attribution: '&copy; CARTO',
                    subdomains: 'abcd',
                    maxZoom: 20
                }).addTo(map);

                L.control.zoom({ position: 'bottomright' }).addTo(map);

                // --- 1. DONOR LAYER (Default) ---
                donorLayer = L.layerGroup().addTo(map);
                L.circle([38.9072, -77.0369], { color: '#37af4b', fillColor: '#37af4b', fillOpacity: 0.23, radius: 7500 }).addTo(donorLayer);
                L.circle([38.9072, -77.0369], { color: '#37af4b', fillColor: '#37af4b', fillOpacity: 0.11, radius: 15000 }).addTo(donorLayer);
                L.circle([38.9072, -77.0369], { color: '#37af4b', fillColor: '#37af4b', fillOpacity: 0.06, radius: 35000 }).addTo(donorLayer);
                
                // --- 2. SOCIAL LAYER ---
                socialLayer = L.layerGroup();
                L.circle([38.9897, -76.9378], { color: '#eab308', fillColor: '#eab308', fillOpacity: 0.3, radius: 4000 }).addTo(socialLayer);
                L.circle([38.8048, -77.0469], { color: '#eab308', fillColor: '#eab308', fillOpacity: 0.2, radius: 5000 }).addTo(socialLayer);

                // --- 3. NETWORK LAYER ---
                networkLayer = L.layerGroup();
                const hubIcon = L.divIcon({ className: 'custom-div-icon', html: "<div style='background-color: #3b82f6; width: 12px; height: 12px; border-radius: 50%; border: 2px solid white; box-shadow: 0 0 10px #3b82f6;'></div>", iconSize: [12, 12] });
                const hqIcon = L.divIcon({ className: 'custom-div-icon', html: "<div style='background-color: #ffffff; width: 16px; height: 16px; border-radius: 50%; border: 3px solid #3b82f6; box-shadow: 0 0 15px #3b82f6;'></div>", iconSize: [16, 16] });
                const hq = [38.9072, -77.0369];
                const hubs = [[38.9847, -77.0947], [38.9959, -77.0289], [38.8786, -77.1007], [38.8048, -77.0469], [38.9530, -76.9400]];
                L.marker(hq, {icon: hqIcon}).addTo(networkLayer);
                hubs.forEach(coord => {
                    L.marker(coord, {icon: hubIcon}).addTo(networkLayer);
                    L.polyline([hq, coord], {color: '#3b82f6', weight: 2, opacity: 0.5, dashArray: '5, 10'}).addTo(networkLayer);
                });
            }

            // Init dummy data for calendar
            events = [
                { id: '1', title: 'Voter Drive', date: '2025-09-05', time: '10:00' },
                { id: '2', title: 'Fundraiser', date: '2025-09-12', time: '18:00' }
            ];
            refreshUI();
            lucide.createIcons();
        });
    </script>
</body>
</html>
