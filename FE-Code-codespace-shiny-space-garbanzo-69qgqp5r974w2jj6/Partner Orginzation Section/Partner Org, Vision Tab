overlay.innerHTML = `<div class="message-box"><h3>${title}</h3><p>${message}</p><button onclick="hideMessageBox()">OK</button></div>`;
overlay.style.visibility = 'visible'; overlay.style.opacity = '1';
}
function hideMessageBox() { const o = document.getElementById('messageBoxOverlay'); if (o) { o.style.opacity = '0'; setTimeout(() => { o.style.visibility = 'hidden'; }, 300); } }

// Toast notifications
function showToast(message) {
const container = document.getElementById('toastContainer');
const toast = document.createElement('div');
toast.className = 'toast';
toast.innerHTML = message;
container.appendChild(toast);
setTimeout(() => { toast.remove(); }, 5000);
}

