const org = document.getElementById('consultPartnerOrg').value;
const urgency = document.getElementById('consultUrgency').value;
const duration = document.getElementById('consultDuration').value;
const staff = Array.from(document.querySelectorAll('.consult-staff-checkbox:checked')).map(cb => cb.value);
const request = {
id: 'req_' + Date.now(),
org: org || 'New Organization',
type: document.getElementById('consultType').value,
urgency: urgency,
duration: duration,
date: slot.date,
time: slot.time,
staff: staff,
submittedAt: new Date().toISOString(),
status: 'Awaiting Payment',
agentLog: [
'Analyzed staff calendars',
'Cross-referenced org availability',
'Checked for conflicts',
'Proposed 3 optimal slots',
'Generated invite draft'
]
};
requestQueue.push(request);
saveRequestQueue();
closeModal('consultationModal');
openModal('requestPaymentModal');
calculatePayment();
}
function calculatePayment() {
const urgency = document.getElementById('consultUrgency')?.value || 'standard';
const duration = parseInt(document.getElementById('consultDuration')?.value || 30);
const staffCount = Array.from(document.querySelectorAll('.consult-staff-checkbox:checked')).length || 1;
const base = 50;
const urgMult = urgency === 'priority' ? 75 : urgency === 'rush' ? 150 : 0;
const staffFee = (staffCount - 1) * 25;
const total = base + urgMult + staffFee;
document.getElementById('payUrgencyFee').textContent = `$${urgMult}`;
document.getElementById('payStaffFee').textContent = `$${staffFee}`;
document.getElementById('payTotal').textContent = `$${total}`;
}
function selectPaymentTier(tier) {
if(tier === 'premium') {
showMessage('Premium Upgrade', 'In a real integration, this would redirect to Stripe subscription setup. For now, your request is confirmed as Premium.');
} else {
showMessage('Payment Confirmed', 'Your one-time request has been confirmed. Calendar invite generated.');
}
const req = requestQueue[requestQueue.length - 1];
if(req) {
req.status = 'Confirmed & Scheduled';
req.paymentMethod = tier;
saveRequestQueue();
}
closeModal('requestPaymentModal');
showToast(`Event created · Reminder set 24h before · Invite sent to ${req?.staff?.join(', ') || 'staff'} and ${req?.org || 'org contact'}`);
renderRequestQueue();
}
