<script>
// ================= DATA & STATE =================
const navItems = ['Vision', 'Organizing', 'Financials', 'Data Suite', 'Projects', 'Marketing', 'Donors'];
const navContainer = document.getElementById('main-nav');
let activeTab = 'Vision';
function showTabContent(tabName) {
document.querySelectorAll('.tab-content').forEach(s => s.classList.remove('active'));
const t = document.getElementById(`content-${tabName}`);
if (t) {
t.classList.add('active');
if(tabName === 'Vision') setTimeout(() => { if(window.capacityChartInstance) window.capacityChartInstance.resize(); if(window.efficiencyChartInstance) window.efficiencyChartInstance.resize(); }, 100);
}
}
navItems.forEach(item => {
const btn = document.createElement('button');
const isActive = item === activeTab;
btn.className = `group flex items-center px-3 py-2 text-xl font-bold tracking-tight font-fm-header transition-all cursor-pointer ${isActive ? 'text-[#98fb98] drop-shadow-[0_0_8px_rgba(152,251,152,0.25)] scale-105' : 'text-gray-400 hover:text-white hover:scale-105'}`;
btn.innerHTML = `<span>${item}</span>`;
btn.addEventListener('click', function() {
Array.from(navContainer.children).forEach(c => c.className = 'group flex items-center px-3 py-2 text-xl font-bold tracking-tight font-fm-header transition-all cursor-pointer text-gray-400 hover:text-white hover:scale-105');
this.className = 'group flex items-center px-3 py-2 text-xl font-bold tracking-tight font-fm-header transition-all cursor-pointer text-[#98fb98] drop-shadow-[0_0_8px_rgba(152,251,152,0.25)] scale-105';
activeTab = item;
showTabContent(item);
});
navContainer.appendChild(btn);
});
showTabContent('Vision');

// Sub-nav logic
const subNavBtns = document.querySelectorAll('.subnav-btn');
const visionViews = document.querySelectorAll('.vision-view');
subNavBtns.forEach(btn => {
btn.addEventListener('click', () => {
subNavBtns.forEach(b => b.className = 'subnav-btn text-gray-400 hover:text-white transition-colors whitespace-nowrap');
btn.className = 'subnav-btn text-white border-b-2 border-[#37af4b] pb-0.5 whitespace-nowrap';
visionViews.forEach(view => { view.classList.add('hidden'); view.classList.remove('flex'); });
const targetView = document.getElementById(btn.dataset.target);
if(targetView) { targetView.classList.remove('hidden'); targetView.classList.add('flex'); if(btn.dataset.target === 'view-Trust' && window.sentimentChartInstance) setTimeout(() => window.sentimentChartInstance.resize(), 100); }
});
});

// Modal helpers
function openModal(id) {
const m = document.getElementById(id);
if(m) m.classList.add('active');
lucide.createIcons();
}
function closeModal(id) {
const m = document.getElementById(id);
if(m) m.classList.remove('active');
}
document.addEventListener('keydown', (e) => {
if (e.key === 'Escape') {
document.querySelectorAll('.modal-overlay.active').forEach(m => {
if(m.style.zIndex === '2400') m.classList.remove('active');
else if(m.style.zIndex === '2300') m.classList.remove('active');
else if(m.style.zIndex === '2200') m.classList.remove('active');
else if(m.style.zIndex === '2100') m.classList.remove('active');
else m.classList.remove('active');
});
}
});
document.querySelectorAll('.modal-overlay').forEach(m => {
m.addEventListener('click', (e) => {
if (e.target === m) m.classList.remove('active');
});
});

// Calendar logic
const defaultEvents = [
{ id: 'evt_1', title: 'Annual Food Drive', time: '10:00', date: new Date().toISOString().split('T')[0], location: 'Community Center Main Hall', description: 'Collecting non-perishable food items.', volunteerCount: 5, goalAttendance: 50, goalType: 'Donors', goalTarget: 10 },
{ id: 'evt_2', title: 'Voter Registration', time: '14:00', date: new Date(new Date().setDate(new Date().getDate() + 5)).toISOString().split('T')[0], location: 'City Library Plaza', description: 'Helping citizens register to vote.', volunteerCount: 12, goalAttendance: 200, goalType: 'Voters', goalTarget: 100 }
];
let events = JSON.parse(localStorage.getItem('ypi_events')) || defaultEvents;
let currentDate = new Date();
let currentView = 'grid';
let monthNames = ["January", "February", "March", "April", "May", "June", "July", "August", "September", "October", "November", "December"];
function saveToStorage() { localStorage.setItem('ypi_events', JSON.stringify(events)); }
function refreshUI() {
if (currentView === 'grid') {
renderCalendar(currentDate);
const calGrid = document.getElementById('calendarGrid');
if(calGrid) { calGrid.style.display = 'grid'; document.getElementById('listView').style.display = 'none'; document.getElementById('calendarTitle').innerText = `${monthNames[currentDate.getMonth()]} ${currentDate.getFullYear()}`; }
} else {
renderListView();
const calGrid = document.getElementById('calendarGrid');
if(calGrid) { calGrid.style.display = 'none'; document.getElementById('listView').style.display = 'flex'; }
}
}
function renderCalendar(date) {
const calendarGrid = document.getElementById('calendarGrid');
if(!calendarGrid) return;
calendarGrid.innerHTML = '';
['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'].forEach(d => { const h = document.createElement('div'); h.className = 'calendar-day-header'; h.innerText = d; calendarGrid.appendChild(h); });
const firstDay = new Date(date.getFullYear(), date.getMonth(), 1).getDay();
const daysInMonth = new Date(date.getFullYear(), date.getMonth() + 1, 0).getDate();
const daysInPrevMonth = new Date(date.getFullYear(), date.getMonth(), 0).getDate();
for (let i = firstDay; i > 0; i--) { const d = document.createElement('div'); d.className = 'calendar-day inactive'; d.innerHTML = `<span class="day-number">${daysInPrevMonth - i + 1}</span>`; calendarGrid.appendChild(d); }
for (let i = 1; i <= daysInMonth; i++) {
const d = document.createElement('div'); d.className = 'calendar-day';
const checkDate = new Date();
if (i === checkDate.getDate() && date.getMonth() === checkDate.getMonth() && date.getFullYear() === checkDate.getFullYear()) d.classList.add('today');
let html = `<span class="day-number">${i}</span>`;
const dayString = `${date.getFullYear()}-${String(date.getMonth()+1).padStart(2,'0')}-${String(i).padStart(2,'0')}`;
const dayEvents = events.filter(e => e.date === dayString);
dayEvents.forEach(evt => { html += `<div class="calendar-event" data-event-id="${evt.id}"><span class="calendar-event-time">${formatTime(evt.time)}</span>${evt.title}</div>`; });
d.innerHTML = html;
calendarGrid.appendChild(d);
}
const totalCells = firstDay + daysInMonth;
const nextMonthPadding = (7 - (totalCells % 7)) % 7;
for (let i = 1; i <= nextMonthPadding; i++) { const d = document.createElement('div'); d.className = 'calendar-day inactive'; d.innerHTML = `<span class="day-number">${i}</span>`; calendarGrid.appendChild(d); }
attachEventClickListeners();
}
function renderListView() {
const listView = document.getElementById('listView');
if(!listView) return;
listView.innerHTML = '';
const sortedEvents = [...events].sort((a, b) => new Date(a.date) - new Date(b.date));
if(sortedEvents.length === 0) { listView.innerHTML = `<div class="empty-list-message">No upcoming events found.</div>`; return; }
sortedEvents.forEach(evt => {
const dateObj = new Date(evt.date + 'T' + (evt.time || '00:00'));
const month = dateObj.toLocaleDateString('en-US', { month: 'short' });
const day = dateObj.getDate();
const item = document.createElement('div');
item.className = 'event-list-item';
item.innerHTML = `<div class="event-list-date"><span class="list-month">${month}</span><span class="list-day">${day}</span></div><div class="event-list-details"><div class="event-list-title">${evt.title}</div><div class="event-list-meta"><span><i data-lucide="clock" class="w-3 h-3 inline mr-1"></i> ${formatTime(evt.time)}</span><span><i data-lucide="map-pin" class="w-3 h-3 inline mr-1"></i> ${evt.location || 'TBD'}</span></div></div>`;
item.addEventListener('click', () => openDetails(evt));
listView.appendChild(item);
});
lucide.createIcons();
}
function formatTime(timeStr) { if(!timeStr) return ''; try { const [h, m] = timeStr.split(':'); const hours = parseInt(h); const suffix = hours >= 12 ? 'PM' : 'AM'; const h12 = hours % 12 || 12; return `${h12}:${m} ${suffix}`; } catch(e) { return timeStr; } }
if(document.getElementById('prevMonth')) document.getElementById('prevMonth').addEventListener('click', () => { currentDate.setMonth(currentDate.getMonth() - 1); refreshUI(); });
if(document.getElementById('nextMonth')) document.getElementById('nextMonth').addEventListener('click', () => { currentDate.setMonth(currentDate.getMonth() + 1); refreshUI(); });
if(document.getElementById('viewGridBtn') && document.getElementById('viewListBtn')) {
document.getElementById('viewGridBtn').addEventListener('click', () => { currentView = 'grid'; document.getElementById('viewGridBtn').classList.add('active'); document.getElementById('viewListBtn').classList.remove('active'); refreshUI(); });
document.getElementById('viewListBtn').addEventListener('click', () => { currentView = 'list'; document.getElementById('viewListBtn').classList.add('active'); document.getElementById('viewGridBtn').classList.remove('active'); refreshUI(); });
}
if(document.getElementById('addEventBtn')) document.getElementById('addEventBtn').addEventListener('click', () => openEditor());
function attachEventClickListeners() {
document.querySelectorAll('.calendar-event').forEach(chip => {
chip.addEventListener('click', (e) => { e.stopPropagation(); const eid = chip.dataset.eventId; const evt = events.find(x => x.id === eid); if(evt) openDetails(evt); });
});
}
// Attendance details modal (simplified for brevity)
function openDetails(eventData) {
showMessage('Event Details', `${eventData.title}<br>${eventData.description || 'No description.'}<br><br>Location: ${eventData.location || 'TBD'}`);
}
function openEditor(eventData = null) {
