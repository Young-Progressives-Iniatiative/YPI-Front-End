slots.push({ date: d.toISOString().split('T')[0], time: d.toLocaleTimeString([], {hour:'2-digit',minute:'2-digit'}), full: d.toLocaleString() });
}
slotsDiv.innerHTML = slots.map((s, i) => `
<div class="p-3 bg-[#2a2d35] rounded border border-[#2a2a2a] cursor-pointer hover:border-[#37af4b] transition-colors" onclick="selectSlot(${i})">
<div class="font-bold text-white">${s.date}</div>
<div class="text-sm text-gray-400">${s.time}</div>
</div>
`).join('');
window._proposedSlots = slots;
}
function selectSlot(idx) {
