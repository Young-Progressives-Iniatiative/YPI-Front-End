        .message-box h3 {
            margin-top: 0;
            margin-bottom: 1rem;
            color: var(--highlight-green);
            font-weight: 700;
            font-size: 1.5rem;
        }

        .message-box p {
            margin-bottom: 1.5rem;
            font-size: 1.1rem;
            color: var(--text-muted);
        }

        .message-box button {
            background-color: var(--accent-green);
            color: white;
            border: none;
            padding: 0.75rem 2rem;
            border-radius: 6px;
            cursor: pointer;
            font-weight: 700;
