    <script>
        document.addEventListener('DOMContentLoaded', () => {
            // --- INITIAL DATA & STATE ---
            const defaultEvents = [
                { 
                    id: 'evt_' + Date.now() + '_1', 
                    title: 'Annual Food Drive', 
