filteredSquadData.sort((a, b) => {
let valA = a[column] || '', valB = b[column] || '';
if(column === 'player' || column === 'position' || column === 'club') { valA = valA.toLowerCase(); valB = valB.toLowerCase(); }
return currentSquadSort.asc ? (valA > valB ? 1 : -1) : (valA < valB ? 1 : -1);
});
renderSquadTable(filteredSquadData);
}
