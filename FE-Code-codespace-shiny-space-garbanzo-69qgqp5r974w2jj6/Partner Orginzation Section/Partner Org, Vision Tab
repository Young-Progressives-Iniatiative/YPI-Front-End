                    }
                } else {
                    renderListView();
                    const calGrid = document.getElementById('calendarGrid');
                    if(calGrid) {
                        calGrid.style.display = 'none';
                        document.getElementById('listView').style.display = 'flex';
                        
                        document.getElementById('prevMonth').style.display = 'none';
                        document.getElementById('nextMonth').style.display = 'none';
                        document.getElementById('calendarTitle').innerText = "Upcoming Events";
                        
                        const icon = document.getElementById('headerIcon');
                        icon.setAttribute('data-lucide', 'list');
                        lucide.createIcons({ nameAttr: 'data-lucide', attrs: {class: "w-6 h-6 text-[#37af4b]"}});
                    }
                }
            }

            // --- HEADER NAV ---
            // Restored original nav items
            const navItems = ['Vision', 'Organizing', 'Financials', 'Data Suite', 'Projects', 'Marketing', 'Donors'];
            const navContainer = document.getElementById('main-nav');
            let activeTab = 'Vision'; 
            
            function showTabContent(tabName) {
                document.querySelectorAll('.tab-content').forEach(s => s.classList.remove('active'));
                const t = document.getElementById(`content-${tabName}`);
                if (t) {
                    t.classList.add('active');
                    // Resize charts if tab is Vision
                    if(tabName === 'Vision') {
                        setTimeout(() => {
                            if(window.capacityChartInstance) window.capacityChartInstance.resize();
                            if(window.efficiencyChartInstance) window.efficiencyChartInstance.resize();
                        }, 100);
                    }
                }
            }

            navItems.forEach(item => {
                const btn = document.createElement('button');
                const isActive = item === activeTab;
                btn.className = `group flex items-center px-3 py-2 text-xl font-bold tracking-tight font-fm-header transition-all cursor-pointer ${isActive ? 'text-[#98fb98] drop-shadow-[0_0_8px_rgba(152,251,152,0.25)] scale-105' : 'text-gray-400 hover:text-white hover:scale-105'}`;
                btn.innerHTML = `<span>${item}</span>`;
                btn.addEventListener('click', function() {
                    Array.from(navContainer.children).forEach(c => c.className = 'group flex items-center px-3 py-2 text-xl font-bold tracking-tight font-fm-header transition-all cursor-pointer text-gray-400 hover:text-white hover:scale-105');
                    this.className = 'group flex items-center px-3 py-2 text-xl font-bold tracking-tight font-fm-header transition-all cursor-pointer text-[#98fb98] drop-shadow-[0_0_8px_rgba(152,251,152,0.25)] scale-105';
                    activeTab = item;
                    showTabContent(item);
                });
                navContainer.appendChild(btn);
            });
            showTabContent('Vision');

            // --- VIEW TOGGLE LOGIC ---
            const viewGridBtn = document.getElementById('viewGridBtn');
            const viewListBtn = document.getElementById('viewListBtn');

            // --- VISION SUB-NAV LOGIC ---
            const subNavBtns = document.querySelectorAll('.subnav-btn');
            const visionViews = document.querySelectorAll('.vision-view');

            subNavBtns.forEach(btn => {
                btn.addEventListener('click', () => {
                    const targetId = btn.dataset.target;
                    
                    // Update Button Styles
                    subNavBtns.forEach(b => {
                        b.className = 'subnav-btn text-gray-400 hover:text-white transition-colors whitespace-nowrap';
                    });
                    btn.className = 'subnav-btn text-white border-b-2 border-[#37af4b] pb-0.5 whitespace-nowrap';

                    // Update View Visibility
                    visionViews.forEach(view => {
                        view.classList.add('hidden');
                        view.classList.remove('flex');
                    });
                    const targetView = document.getElementById(targetId);
                    if(targetView) {
                        targetView.classList.remove('hidden');
                        targetView.classList.add('flex');
                        
                        // Resize charts if showing Trust tab
                        if(targetId === 'view-Trust' && window.sentimentChartInstance) {
                            window.sentimentChartInstance.resize();
                        }
                    }
                });
            });

            if(viewGridBtn && viewListBtn) {
                viewGridBtn.addEventListener('click', () => {
                    currentView = 'grid';
                    viewGridBtn.classList.add('active');
                    viewListBtn.classList.remove('active');
                    refreshUI();
                });

                viewListBtn.addEventListener('click', () => {
                    currentView = 'list';
                    viewListBtn.classList.add('active');
                    viewGridBtn.classList.remove('active');
                    refreshUI();
                });
            }

            // --- CALENDAR RENDERER ---
            const calendarGrid = document.getElementById('calendarGrid');
            const calendarTitle = document.getElementById('calendarTitle');

            function renderCalendar(date) {
                if(!calendarGrid) return;
                calendarGrid.innerHTML = '';
                const year = date.getFullYear();
                const month = date.getMonth();

                ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'].forEach(d => {
                    const h = document.createElement('div');
                    h.className = 'calendar-day-header';
                    h.innerText = d;
                    calendarGrid.appendChild(h);
                });

                const firstDay = new Date(year, month, 1).getDay();
                const daysInMonth = new Date(year, month + 1, 0).getDate();
                const daysInPrevMonth = new Date(year, month, 0).getDate();

                for (let i = firstDay; i > 0; i--) {
                    const d = document.createElement('div');
                    d.className = 'calendar-day inactive';
                    d.innerHTML = `<span class="day-number">${daysInPrevMonth - i + 1}</span>`;
                    calendarGrid.appendChild(d);
                }

                for (let i = 1; i <= daysInMonth; i++) {
                    const d = document.createElement('div');
                    d.className = 'calendar-day';
                    
                    const checkDate = new Date();
                    if (i === checkDate.getDate() && month === checkDate.getMonth() && year === checkDate.getFullYear()) {
                        d.classList.add('today');
                    }

                    let html = `<span class="day-number">${i}</span>`;
                    
                    const dayString = `${year}-${String(month+1).padStart(2,'0')}-${String(i).padStart(2,'0')}`;
                    const dayEvents = events.filter(e => e.date === dayString);
                    
                    dayEvents.forEach(evt => {
                        let timeString = formatTime(evt.time);
                        html += `
                            <div class="calendar-event" data-event-id="${evt.id}">
                                <span class="calendar-event-time">${timeString}</span>
                                ${evt.title}
                            </div>
                        `;
                    });

                    d.innerHTML = html;
                    calendarGrid.appendChild(d);
                }

                const totalCells = firstDay + daysInMonth;
                const nextMonthPadding = (7 - (totalCells % 7)) % 7;
                for (let i = 1; i <= nextMonthPadding; i++) {
                    const d = document.createElement('div');
                    d.className = 'calendar-day inactive';
                    d.innerHTML = `<span class="day-number">${i}</span>`;
                    calendarGrid.appendChild(d);
                }
                
                attachEventClickListeners();
            }

            // --- LIST RENDERER ---
            const listView = document.getElementById('listView');
            
            function renderListView() {
                if(!listView) return;
                listView.innerHTML = '';
                const sortedEvents = [...events].sort((a, b) => new Date(a.date) - new Date(b.date));
                
                if(sortedEvents.length === 0) {
                    listView.innerHTML = `<div class="empty-list-message">No upcoming events found. Click + to add one.</div>`;
                    return;
                }

                sortedEvents.forEach(evt => {
                    const dateObj = new Date(evt.date + 'T' + (evt.time || '00:00'));
                    const month = dateObj.toLocaleDateString('en-US', { month: 'short' });
                    const day = dateObj.getDate();
                    const timeString = formatTime(evt.time);
                    
                    let goalHtml = '';
                    if(evt.volunteerCount) {
                        goalHtml += `<span class="meta-badge text-purple-400 border border-purple-400/20"><i data-lucide="user-check" class="w-3 h-3"></i> Volunteers: ${evt.volunteerCount}</span>`;
                    }
                    if(evt.goalAttendance) {
                        goalHtml += `<span class="meta-badge text-[#98fb98] border border-[#98fb98]/20"><i data-lucide="users" class="w-3 h-3"></i> Attendees: ${evt.goalAttendance}</span>`;
                    }
                    if(evt.goalTarget) {
                        goalHtml += `<span class="meta-badge text-blue-400 border border-blue-400/20"><i data-lucide="target" class="w-3 h-3"></i> ${evt.goalType || 'Goal'}: ${evt.goalTarget}</span>`;
                    }
                    
                    const item = document.createElement('div');
                    item.className = 'event-list-item';
                    item.dataset.eventId = evt.id;
                    item.innerHTML = `
                        <div class="event-list-date">
                            <span class="list-month">${month}</span>
                            <span class="list-day">${day}</span>
                        </div>
                        <div class="event-list-details">
                            <div class="event-list-title">${evt.title}</div>
                            <div class="event-list-meta">
                                <span class="flex items-center gap-1 mr-3"><i data-lucide="clock" class="w-3 h-3"></i> ${timeString}</span>
                                <span class="flex items-center gap-1 mr-3"><i data-lucide="map-pin" class="w-3 h-3"></i> ${evt.location || 'TBD'}</span>
                                ${goalHtml}
                            </div>
                        </div>
                        <i data-lucide="chevron-right" class="text-gray-500 w-5 h-5"></i>
                    `;
                    item.addEventListener('click', () => openDetails(evt));
                    listView.appendChild(item);
                });
                lucide.createIcons();
            }

            function formatTime(timeStr) {
                if(!timeStr) return '';
                try {
                    const [h, m] = timeStr.split(':');
                    const hours = parseInt(h);
                    const suffix = hours >= 12 ? 'PM' : 'AM';
                    const h12 = hours % 12 || 12;
                    return `${h12}:${m} ${suffix}`;
                } catch(e) { return timeStr; }
            }

            if(document.getElementById('prevMonth')) {
                document.getElementById('prevMonth').addEventListener('click', () => {
                    currentDate.setMonth(currentDate.getMonth() - 1);
                    refreshUI(); 
                });
            }
            if(document.getElementById('nextMonth')) {
                document.getElementById('nextMonth').addEventListener('click', () => {
                    currentDate.setMonth(currentDate.getMonth() + 1);
                    refreshUI();
                });
            }

            if(document.getElementById('syncCalendarBtn')) {
                document.getElementById('syncCalendarBtn').addEventListener('click', () => {
                    if(events.length === 0) {
                        alert("No events to sync.");
                        return;
                    }
                    let icsContent = "BEGIN:VCALENDAR\nVERSION:2.0\nPRODID:-//YPI//Attendance Calendar//EN\n";
                    events.forEach(evt => {
                        let startHour = 9, startMin = 0;
                        if(evt.time) {
                            const parts = evt.time.split(':');
                            startHour = parseInt(parts[0]) || 9;
                            startMin = parseInt(parts[1]) || 0;
                        }
                        const dParts = evt.date.split('-');
                        const year = dParts[0];
                        const month = dParts[1];
                        const day = dParts[2];
                        const startStr = `${year}${month}${day}T${String(startHour).padStart(2,'0')}${String(startMin).padStart(2,'0')}00`;
                        const endHour = (startHour + 2) % 24; 
                        const endStr = `${year}${month}${day}T${String(endHour).padStart(2,'0')}${String(startMin).padStart(2,'0')}00`;
                        
                        icsContent += "BEGIN:VEVENT\n";
                        icsContent += `DTSTART:${startStr}\n`;
                        icsContent += `DTEND:${endStr}\n`;
                        icsContent += `SUMMARY:${evt.title}\n`;
                        icsContent += `DESCRIPTION:${evt.description || ''}\n`;
                        if(evt.location) icsContent += `LOCATION:${evt.location}\n`;
                        icsContent += "END:VEVENT\n";
                    });
                    icsContent += "END:VCALENDAR";
                    
                    const blob = new Blob([icsContent], { type: 'text/calendar;charset=utf-8' });
                    const link = document.createElement('a');
                    link.href = window.URL.createObjectURL(blob);
                    link.setAttribute('download', 'ypi_events.ics');
                    document.body.appendChild(link);
                    link.click();
                    document.body.removeChild(link);
                });
            }

            // --- MODALS & FORMS ---
            const modalDetails = document.getElementById("attendanceModalWrapper");
            const modalEditor = document.getElementById("eventEditorModal");
            
            const detTitle = document.getElementById("modalEventTitle");
            const detTime = document.getElementById("modalEventTime");
            const detLoc = document.getElementById("modalEventLocation");
            const detDesc = document.getElementById("modalEventDesc");
            const detLink = document.getElementById("modalMeetLink");
            const detId = document.getElementById("modalEventId");
            const studentList = document.getElementById("student-list");
            
            const goalsMetricsContainer = document.getElementById("goalsMetricsContainer");
            const goalVol = document.getElementById("modalGoalVolunteers");
            const goalAtt = document.getElementById("modalGoalAttendance");
            const goalCustLabel = document.getElementById("modalGoalCustomLabel");
            const goalCustVal = document.getElementById("modalGoalCustomValue");
            
            const repAtt = document.getElementById("reportAttendance");
            const repSign = document.getElementById("reportSignups");
            const repDonors = document.getElementById("reportDonors");
            const newsletterCount = document.getElementById("newsletterCount");
            const donorCount = document.getElementById("donorCount");

            function formatDisplayDate(dateStr, timeStr) {
                const date = new Date(dateStr + 'T' + timeStr);
                return date.toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric', hour: 'numeric', minute: '2-digit' });
            }

            function renderRoster() {
                if(!studentList) return;
                studentList.innerHTML = '';
                roster.forEach((name, idx) => {
                    const tr = document.createElement('tr');
                    
                    // Helper to create select options
                    const gradeOptions = `
                        <option value="standard" selected>Standard</option>
                        <option value="low">Below Standard</option>
                        <option value="above">Above the Call of Duty</option>
                    `;
                    
                    tr.innerHTML = `
                        <td>${name}</td>
                        <td class="attendance-status">
                            <label><input type="radio" name="student_${idx}" value="present" checked onchange="toggleGrade(${idx}, this.value)"> Present</label>
                            <label><input type="radio" name="student_${idx}" value="absent" onchange="toggleGrade(${idx}, this.value)"> Absent</label>
                        </td>
                        <td>
                            <select id="grade_${idx}" class="grade-select" onchange="updateGradeColor(this)">
                                ${gradeOptions}
                            </select>
                        </td>
                    `;
                    studentList.appendChild(tr);
                    
                    // Init color for standard
                    const sel = tr.querySelector(`#grade_${idx}`);
                    updateGradeColor(sel);
                });
            }
            
            window.toggleGrade = function(idx, value) {
                const select = document.getElementById(`grade_${idx}`);
                if(select) {
                    select.disabled = (value === 'absent');
                    if(value === 'absent') {
                        select.value = 'standard';
                        updateGradeColor(select);
                    }
                }
            };
            
            window.updateGradeColor = function(select) {
                const val = select.value;
                select.style.fontWeight = 'bold';
                if (val === 'low') {
                    select.style.color = '#ef4444'; // Red
                } else if (val === 'standard') {
                    select.style.color = '#facc15'; // Yellow
                } else if (val === 'above') {
                    select.style.color = '#60a5fa'; // Light Blue
                }
            };
            
            function updateLineCount(textarea, countSpan) {
                if(!textarea || !countSpan) return;
                const lines = textarea.value.split('\n').filter(line => line.trim() !== '').length;
                countSpan.innerText = `Total: ${lines}`;
            }

            function openDetails(eventData) {
                detTitle.innerText = eventData.title;
                detTime.innerText = formatDisplayDate(eventData.date, eventData.time);
                detLoc.innerText = eventData.location || 'Online';
                detDesc.innerText = eventData.description || 'No description.';
                detLink.href = eventData.meetLink || '#';
                detId.value = eventData.id;
                
                if (eventData.volunteerCount || eventData.goalAttendance || eventData.goalTarget) {
                    goalsMetricsContainer.style.display = 'block';
                    goalVol.innerText = eventData.volunteerCount || '-';
                    goalAtt.innerText = eventData.goalAttendance || '-';
                    goalCustLabel.innerText = eventData.goalType || 'Other Goal';
                    goalCustVal.innerText = eventData.goalTarget || '-';
                } else {
                    goalsMetricsContainer.style.display = 'none';
                }
                
                repAtt.value = eventData.actualAttendance || '';
                repSign.value = eventData.newsletterSignups || '';
                repDonors.value = eventData.donorNotes || '';
                
                updateLineCount(repSign, newsletterCount);
                updateLineCount(repDonors, donorCount);
                
                renderRoster();
                modalDetails.classList.add('active');
            }
            
            // Textarea Listeners for Count
            if(repSign) repSign.addEventListener('input', () => updateLineCount(repSign, newsletterCount));
            if(repDonors) repDonors.addEventListener('input', () => updateLineCount(repDonors, donorCount));

            function attachEventClickListeners() {
                document.querySelectorAll('.calendar-event').forEach(chip => {
                    chip.addEventListener('click', (e) => {
                        e.stopPropagation();
                        const eid = chip.dataset.eventId;
                        const evt = events.find(x => x.id === eid);
                        if(evt) openDetails(evt);
                    });
                });
            }

            // --- CSV & IMAGE IMPORT LOGIC ---
            function handleFileImport(fileInputId, targetTextareaId, countSpanId, type) {
                const fileInput = document.getElementById(fileInputId);
                const textarea = document.getElementById(targetTextareaId);
                const countSpan = document.getElementById(countSpanId);
                
                if(!fileInput || !textarea) return;

                fileInput.addEventListener('change', async (e) => {
                    const file = e.target.files[0];
                    if (!file) return;
                    
                    if (type === 'csv') {
                        const reader = new FileReader();
                        reader.onload = (event) => {
                            const text = event.target.result;
                            // Append new data to existing
                            const existing = textarea.value ? textarea.value + '\n' : '';
                            textarea.value = existing + text;
                            updateLineCount(textarea, countSpan);
                            alert('CSV Imported Successfully!');
                        };
                        reader.readAsText(file);
                    } else if (type === 'image') {
                        // Using Tesseract.js
                        if (typeof Tesseract !== 'undefined') {
                            textarea.setAttribute('placeholder', 'Scanning image... please wait...');
                            try {
                                const result = await Tesseract.recognize(file, 'eng');
                                const existing = textarea.value ? textarea.value + '\n' : '';
                                // Basic cleanup: remove empty lines
                                const cleanText = result.data.text.split('\n').filter(l => l.trim() !== '').join('\n');
                                textarea.value = existing + cleanText;
                                updateLineCount(textarea, countSpan);
                                alert('Image Scanned Successfully!');
                            } catch (err) {
                                console.error(err);
                                alert('Error scanning image. Please try again.');
                            } finally {
                                textarea.setAttribute('placeholder', 'List entries (one per line)...');
                            }
                        } else {
                            alert("OCR Library not loaded. Please check your internet connection.");
                        }
                    }
                    // Reset input
                    fileInput.value = '';
                });
            }
            
            // Initialize Import Listeners
            handleFileImport('csvInputSignups', 'reportSignups', 'newsletterCount', 'csv');
            handleFileImport('imgInputSignups', 'reportSignups', 'newsletterCount', 'image');
            handleFileImport('csvInputDonors', 'reportDonors', 'donorCount', 'csv');
            handleFileImport('imgInputDonors', 'reportDonors', 'donorCount', 'image');


            // --- ADD/EDIT EVENT LOGIC ---
            const editorForm = document.getElementById("eventEditorForm");
            const editorTitle = document.getElementById("editorTitle");
            const inpTitle = document.getElementById("editTitle");
            const inpDate = document.getElementById("editDate");
            const inpTime = document.getElementById("editTime");
            const inpLoc = document.getElementById("editLocation");
            const inpLink = document.getElementById("editLink");
            const inpDesc = document.getElementById("editDesc");
            const inpId = document.getElementById("editEventId");
            
            const inpGoalVol = document.getElementById("editVolunteerCount");
            const inpGoalAtt = document.getElementById("editGoalAttendance");
            const inpGoalType = document.getElementById("editGoalType");
            const inpGoalTarget = document.getElementById("editGoalTarget");

            function openEditor(eventData = null) {
                if(modalDetails) modalDetails.classList.remove('active'); 
                if(modalEditor) modalEditor.classList.add('active');
                
                if(eventData) {
                    editorTitle.innerText = "Edit Event";
                    inpId.value = eventData.id;
                    inpTitle.value = eventData.title;
                    inpDate.value = eventData.date;
                    inpTime.value = eventData.time;
                    inpLoc.value = eventData.location;
                    inpLink.value = eventData.meetLink;
                    inpDesc.value = eventData.description;
                    inpGoalVol.value = eventData.volunteerCount || '';
                    inpGoalAtt.value = eventData.goalAttendance || '';
                    inpGoalType.value = eventData.goalType || 'Donors';
                    inpGoalTarget.value = eventData.goalTarget || '';
                } else {
                    editorTitle.innerText = "Add New Event";
                    editorForm.reset();
                    inpId.value = "";
                    inpDate.value = new Date().toISOString().split('T')[0];
                    inpTime.value = "12:00";
                }
            }

            if(document.getElementById("addEventBtn")) {
                document.getElementById("addEventBtn").addEventListener('click', () => openEditor());
            }
            
            if(document.getElementById("editEventBtn")) {
                document.getElementById("editEventBtn").addEventListener('click', () => {
                    const eid = detId.value;
                    const evt = events.find(x => x.id === eid);
                    if(evt) openEditor(evt);
                });
            }

            if(editorForm) {
                editorForm.addEventListener('submit', (e) => {
                    e.preventDefault();
                    const newEvent = {
                        id: inpId.value || 'evt_' + Date.now(),
                        title: inpTitle.value,
                        date: inpDate.value,
                        time: inpTime.value,
                        location: inpLoc.value,
                        meetLink: inpLink.value,
                        description: inpDesc.value,
                        volunteerCount: inpGoalVol.value,
                        goalAttendance: inpGoalAtt.value,
                        goalType: inpGoalType.value,
                        goalTarget: inpGoalTarget.value,
                        actualAttendance: inpId.value ? (events.find(x=>x.id===inpId.value)?.actualAttendance || '') : '',
                        newsletterSignups: inpId.value ? (events.find(x=>x.id===inpId.value)?.newsletterSignups || '') : '',
                        donorNotes: inpId.value ? (events.find(x=>x.id===inpId.value)?.donorNotes || '') : ''
                    };

                    if(inpId.value) {
                        const idx = events.findIndex(x => x.id === inpId.value);
                        if(idx !== -1) events[idx] = newEvent;
                    } else {
                        events.push(newEvent);
                    }

                    saveToStorage();
                    refreshUI();
                    modalEditor.classList.remove('active');
                    if(inpId.value) openDetails(newEvent);
                });
            }

            // --- MANAGE ROSTER ---
            if(document.getElementById("addStudentBtn")) {
                document.getElementById("addStudentBtn").addEventListener('click', () => {
                    const nameInput = document.getElementById("newStudentName");
                    const name = nameInput.value.trim();
                    if(name) {
                        roster.push(name);
                        saveToStorage();
                        renderRoster();
                        nameInput.value = "";
                    }
                });
            }

            // --- CLOSE HANDLERS ---
            if(document.getElementById("closeAttendanceModalBtn")) {
                document.getElementById("closeAttendanceModalBtn").addEventListener('click', () => modalDetails.classList.remove('active'));
            }
            if(document.getElementById("closeEditorBtn")) {
                document.getElementById("closeEditorBtn").addEventListener('click', () => modalEditor.classList.remove('active'));
            }
            // New Close Handler for Partner Editor
            const partnerModal = document.getElementById("partnerEditorModal");
            if(document.getElementById("closePartnerEditorBtn")) {
                document.getElementById("closePartnerEditorBtn").addEventListener('click', () => partnerModal.classList.remove('active'));
            }
            // New Close Handler for Capacity Editor
            const capacityModal = document.getElementById("capacityEditorModal");
            if(document.getElementById("closeCapacityEditorBtn")) {
                document.getElementById("closeCapacityEditorBtn").addEventListener('click', () => capacityModal.classList.remove('active'));
            }
            // Close Handler for Consultation Modal
            const consultModal = document.getElementById("consultationModal");
            if(document.getElementById("closeConsultationBtn")) {
                document.getElementById("closeConsultationBtn").addEventListener('click', () => consultModal.classList.remove('active'));
            }
            // Close Handler for Partnership Stats Modal
            const partnershipStatsModal = document.getElementById("partnershipStatsModal");
            if(document.getElementById("closePartnershipStatsBtn")) {
                document.getElementById("closePartnershipStatsBtn").addEventListener('click', () => partnershipStatsModal.classList.remove('active'));
            }
            // Close Handler for Sentiment Details Modal
            const sentimentDetailsModal = document.getElementById("sentimentDetailsModal");
            if(document.getElementById("closeSentimentDetailsBtn")) {
                document.getElementById("closeSentimentDetailsBtn").addEventListener('click', () => sentimentDetailsModal.classList.remove('active'));
            }
            // Close Handler for Keyword Intelligence Modal
            const keywordIntelModal = document.getElementById("keywordIntelligenceModal");
            if(document.getElementById("closeKeywordIntelBtn")) {
                document.getElementById("closeKeywordIntelBtn").addEventListener('click', () => keywordIntelModal.classList.remove('active'));
            }
            // Close Handler for Impact Report Modal (FIXED)
            const impactReportModal = document.getElementById("impactReportModal");
            if(document.getElementById("closeImpactReportBtn")) {
                document.getElementById("closeImpactReportBtn").addEventListener('click', () => impactReportModal.classList.remove('active'));
            }
            
            // Open Handler for Sentiment Details (Button & Card)
            const viewSentimentDetailsBtn = document.getElementById("viewSentimentDetailsBtn");
            const sentimentAnalysisCard = document.getElementById("sentimentAnalysisCard");
            
            function openSentimentModal(e) {
                // Prevent bubbling if button is clicked inside card
                if(e) e.stopPropagation(); 
                if(sentimentDetailsModal) sentimentDetailsModal.classList.add('active');
            }

            if(viewSentimentDetailsBtn) {
                viewSentimentDetailsBtn.addEventListener('click', openSentimentModal);
            }
            
            if(sentimentAnalysisCard) {
                sentimentAnalysisCard.addEventListener('click', openSentimentModal);
            }

            // Open Handler for Keyword Intelligence (From inside Sentiment Details)
            const openKeywordIntelBtn = document.getElementById("openKeywordIntelBtn");
            if(openKeywordIntelBtn && keywordIntelModal) {
                openKeywordIntelBtn.addEventListener('click', () => {
                    keywordIntelModal.classList.add('active');
                });
            }

            // Open Handler for Impact Report (FIXED)
            const openImpactReportBtn = document.getElementById("openImpactReportBtn");
            if(openImpactReportBtn && impactReportModal) {
                openImpactReportBtn.addEventListener('click', () => {
                    impactReportModal.classList.add('active');
                });
            }
            
            // --- PARTNERSHIP STATS LOGIC ---
            const partnershipRows = document.querySelectorAll('.partnership-row');
            if(partnershipRows.length > 0 && partnershipStatsModal) {
                partnershipRows.forEach(row => {
                    row.addEventListener('click', () => {
                        const orgName = row.dataset.org;
                        document.getElementById('statsOrgName').innerText = orgName;
                        partnershipStatsModal.classList.add('active');
                        
                        // Initialize charts when modal opens (with delay for layout)
                        setTimeout(() => {
                            initPartnershipCharts();
                        }, 100);
                    });
                });
            }

            function initPartnershipCharts() {
                if(window.partnershipEngagementChartInstance) window.partnershipEngagementChartInstance.destroy();
                if(window.partnershipDemographicsChartInstance) window.partnershipDemographicsChartInstance.destroy();

                const ctxEng = document.getElementById('partnershipEngagementChart').getContext('2d');
                window.partnershipEngagementChartInstance = new Chart(ctxEng, {
                    type: 'line',
                    data: {
                        labels: ['May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct'],
                        datasets: [{
                            label: 'Engagement (Interactions)',
                            data: [1200, 1900, 3000, 2500, 3200, 4500],
                            borderColor: '#37af4b',
                            backgroundColor: 'rgba(55, 175, 75, 0.1)',
                            fill: true,
                            tension: 0.4
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        scales: {
                            x: { grid: { color: '#2a2a2a' }, ticks: { color: '#9ca3af' } },
                            y: { grid: { color: '#2a2a2a' }, ticks: { color: '#9ca3af' } }
                        },
                        plugins: { legend: { display: false } }
                    }
                });

                const ctxDemo = document.getElementById('partnershipDemographicsChart').getContext('2d');
                window.partnershipDemographicsChartInstance = new Chart(ctxDemo, {
                    type: 'pie',
                    data: {
                        labels: ['18-24', '25-34', '35-44', '45+'],
                        datasets: [{
                            data: [45, 30, 15, 10],
                            backgroundColor: ['#37af4b', '#22c55e', '#166534', '#14532d'],
                            borderWidth: 0
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: { legend: { position: 'right', labels: { color: '#ffffff', boxWidth: 10 } } }
                    }
                });
            }
            
            // --- PARTNER PROFILE EDIT LOGIC ---
            const editPartnerBtn = document.getElementById("editPartnerProfileBtn");
            const partnerForm = document.getElementById("partnerEditorForm");

            if(editPartnerBtn && partnerModal && partnerForm) {
                editPartnerBtn.addEventListener('click', () => {
                    // Pre-fill form with current displayed values
                    if(document.getElementById('editOrgName')) document.getElementById('editOrgName').value = document.getElementById('profileOrgName').innerText;
                    if(document.getElementById('editOrgMission')) document.getElementById('editOrgMission').value = document.getElementById('profileMission').innerText;
                    if(document.getElementById('editOrgWebsite')) document.getElementById('editOrgWebsite').value = document.getElementById('profileWebsite').innerText;
                    if(document.getElementById('editOrgLocation')) document.getElementById('editOrgLocation').value = document.getElementById('profileLocation').innerText;
                    if(document.getElementById('editOrgMarketing')) document.getElementById('editOrgMarketing').value = document.getElementById('profileMarketingScore').innerText;
                    if(document.getElementById('editOrgTrust')) document.getElementById('editOrgTrust').value = document.getElementById('profileTrustScore').innerText;
                    
                    partnerModal.classList.add('active');
                });

                partnerForm.addEventListener('submit', (e) => {
                    e.preventDefault();
                    
                    // Update DOM elements with new values
                    if(document.getElementById('profileOrgName')) document.getElementById('profileOrgName').innerText = document.getElementById('editOrgName').value;
                    if(document.getElementById('profileMission')) document.getElementById('profileMission').innerText = document.getElementById('editOrgMission').value;
                    if(document.getElementById('profileWebsite')) {
                        document.getElementById('profileWebsite').innerText = document.getElementById('editOrgWebsite').value;
                        document.getElementById('profileWebsite').href = "https://" + document.getElementById('editOrgWebsite').value.replace(/^https?:\/\//, '');
                    }
                    if(document.getElementById('profileLocation')) document.getElementById('profileLocation').innerText = document.getElementById('editOrgLocation').value;
                    if(document.getElementById('profileMarketingScore')) document.getElementById('profileMarketingScore').innerText = document.getElementById('editOrgMarketing').value;
                    if(document.getElementById('profileTrustScore')) document.getElementById('profileTrustScore').innerText = document.getElementById('editOrgTrust').value;

                    // Update First Contact if provided
                    const cName = document.getElementById('editContactName').value;
                    if(cName) {
                        const contactsList = document.getElementById('profileContactsList');
                        if(contactsList && contactsList.firstElementChild) {
                            const firstContact = contactsList.firstElementChild;
                            const nameEl = firstContact.querySelector('.font-bold');
                            const titleEl = firstContact.querySelector('.text-gray-400');
                            const emailEl = firstContact.querySelector('.text-[#98fb98]');
                            
                            if(nameEl) nameEl.innerText = cName;
                            if(titleEl) titleEl.innerText = document.getElementById('editContactTitle').value;
                            if(emailEl) emailEl.innerText = document.getElementById('editContactEmail').value;
                        }
                    }

                    partnerModal.classList.remove('active');
                    showMessage('Profile Updated', 'Partner organization details have been successfully saved.');
                });
            }

            // --- CAPACITY OVERVIEW EDIT LOGIC ---
            const editCapacityBtn = document.getElementById("editCapacityBtn");
            const capacityForm = document.getElementById("capacityEditorForm");

            if(editCapacityBtn && capacityModal && capacityForm) {
                editCapacityBtn.addEventListener('click', () => {
                    // Pre-fill metrics
                    document.getElementById('editCapCurrent').value = document.getElementById('capStaffCurrent').innerText;
                    document.getElementById('editCapTotal').value = document.getElementById('capStaffTotal').innerText;
                    document.getElementById('editCapRecruit').value = document.getElementById('capRecruitCount').innerText;

                    // Pre-fill Needs List (Parse HTML to Text)
                    const needsContainer = document.getElementById('capNeedsList');
                    let needsText = '';
                    Array.from(needsContainer.children).forEach(item => {
                        const role = item.querySelector('.text-white').innerText;
                        const desc = item.querySelector('.text-gray-500').innerText;
                        const count = item.querySelector('.text-yellow-400').innerText;
                        needsText += `${role} | ${desc} | ${count}\n`;
                    });
                    document.getElementById('editCapNeeds').value = needsText.trim();

                    // Pre-fill Filled List
                    const filledContainer = document.getElementById('capFilledList');
                    let filledText = '';
                    Array.from(filledContainer.children).forEach(badge => {
                        filledText += badge.innerText + '\n';
                    });
                    document.getElementById('editCapFilled').value = filledText.trim();

                    capacityModal.classList.add('active');
                });

                capacityForm.addEventListener('submit', (e) => {
                    e.preventDefault();

                    // Update Metrics
                    document.getElementById('capStaffCurrent').innerText = document.getElementById('editCapCurrent').value;
                    document.getElementById('capStaffTotal').innerText = document.getElementById('editCapTotal').value;
                    document.getElementById('capRecruitCount').innerText = document.getElementById('editCapRecruit').value;

                    // Re-render Needs List
                    const needsText = document.getElementById('editCapNeeds').value;
                    const needsContainer = document.getElementById('capNeedsList');
                    needsContainer.innerHTML = '';
                    if(needsText) {
                        needsText.split('\n').forEach(line => {
                            if(line.trim()) {
                                const parts = line.split('|').map(s => s.trim());
                                const role = parts[0] || 'Unknown Role';
                                const desc = parts[1] || '';
                                const count = parts[2] || 'Need 1';
                                
                                const div = document.createElement('div');
                                div.className = 'role-list-item';
                                div.innerHTML = `
                                    <div class="flex flex-col">
                                        <span class="text-white font-medium">${role}</span>
                                        <span class="text-xs text-gray-500">${desc}</span>
                                    </div>
                                    <span class="text-xs font-bold text-yellow-400 bg-yellow-400/10 px-2 py-1 rounded">${count}</span>
                                `;
                                needsContainer.appendChild(div);
                            }
                        });
                    }

                    // Re-render Filled List
                    const filledText = document.getElementById('editCapFilled').value;
                    const filledContainer = document.getElementById('capFilledList');
                    filledContainer.innerHTML = '';
                    if(filledText) {
                        filledText.split('\n').forEach(role => {
                            if(role.trim()) {
                                const span = document.createElement('span');
                                span.className = 'role-badge';
                                // Style CEO/Manager differently if detected, simplistic check
                                if(role.toLowerCase().includes('ceo') || role.toLowerCase().includes('manager')) {
                                    span.className += ' text-[#37af4b] border border-[#37af4b]/30';
                                }
                                span.innerText = role.trim();
                                filledContainer.appendChild(span);
                            }
                        });
                    }

                    capacityModal.classList.remove('active');
                    showMessage('Overview Updated', 'Capacity metrics have been updated.');
                });
            }

            // --- CONSULTATION BUTTON LOGIC ---
            const consultBtn = document.getElementById('consultBtn');
            const consultForm = document.getElementById('consultationForm');
            
            if(consultBtn && consultModal) {
                consultBtn.addEventListener('click', () => {
                    consultModal.classList.add('active');
                });
            }

            if(consultForm) {
                consultForm.addEventListener('submit', (e) => {
                    e.preventDefault();
                    consultModal.classList.remove('active');
                    showMessage('Request Sent', 'Your consultation request has been submitted. A team member will reach out shortly.');
                });
            }

            // --- RECRUITMENT TAB LOGIC ---
            // Removed recruitment tab logic as view was deleted

            // --- UTILS ---
            if(document.getElementById("notifyAttendeesBtn")) {
                document.getElementById("notifyAttendeesBtn").addEventListener('click', () => {
                    alert("Simulated Notification sent to " + roster.length + " attendees.");
                });
            }
            
            if(document.getElementById("copyLinkBtn")) {
                document.getElementById("copyLinkBtn").addEventListener('click', () => {
                    navigator.clipboard.writeText(document.getElementById("modalMeetLink").href);
                    alert("Link Copied!");
                });
            }
            
            // --- ATTENDANCE FORM SUBMIT ---
            function initializeForm() {
                const attendanceForm = document.getElementById('attendanceForm');
                if(attendanceForm) {
                    attendanceForm.addEventListener('submit', function(e) {
                        e.preventDefault(); 
                        
                        let presentCount = 0;
                        const studentRadios = attendanceForm.querySelectorAll('input[type="radio"][value="present"]:checked');
                        presentCount = studentRadios.length;
                        
                        const eid = document.getElementById("modalEventId").value;
                        const evtIndex = events.findIndex(x => x.id === eid);
                        
                        if(evtIndex !== -1) {
                            events[evtIndex].actualAttendance = document.getElementById("reportAttendance").value;
                            events[evtIndex].newsletterSignups = document.getElementById("reportSignups").value;
                            events[evtIndex].donorNotes = document.getElementById("reportDonors").value;
                            saveToStorage();
                        }
                       
                        showMessage('Attendance & Report Saved', `Data recorded successfully. ${presentCount} volunteers marked present.`);
                        
                        if (modalDetails) {
                            modalDetails.classList.remove('active');
                            document.body.style.overflow = 'auto';
                        }
                    });
                }
            }
            
            // --- MESSAGE BOX FUNCTIONS ---
            function showMessage(title, message) {
                let messageBoxOverlay = document.getElementById('messageBoxOverlay');
                if (!messageBoxOverlay) {
                    messageBoxOverlay = document.createElement('div');
                    messageBoxOverlay.id = 'messageBoxOverlay';
                    messageBoxOverlay.className = 'message-box-overlay';
                    document.body.appendChild(messageBoxOverlay);
                }
                messageBoxOverlay.innerHTML = `<div class="message-box"><h3>${title}</h3><p>${message}</p><button id="messageBoxCloseButton">OK</button></div>`;
                document.getElementById('messageBoxCloseButton').onclick = () => hideMessageBox();
                messageBoxOverlay.style.visibility = 'visible';
                messageBoxOverlay.style.opacity = '1';
                document.body.style.overflow = 'hidden';
            }

            function hideMessageBox() {
                const messageBoxOverlay = document.getElementById('messageBoxOverlay');
                if (messageBoxOverlay) {
                    messageBoxOverlay.style.opacity = '0';
                    setTimeout(() => {
                        messageBoxOverlay.style.visibility = 'hidden';
                        document.body.style.overflow = 'auto';
                    }, 300);
                }
            }

            // --- CHART.JS INITIALIZATION ---
            function initCharts() {
                if(!document.getElementById('capacityChart') || !document.getElementById('efficiencyChart')) return;

                // Capacity Chart
                const ctxCapacity = document.getElementById('capacityChart').getContext('2d');
                window.capacityChartInstance = new Chart(ctxCapacity, {
                    type: 'bar',
                    data: {
                        labels: ['Prog. Design', 'Ops Readiness', 'Stakeholders', 'Resources', 'Growth'],
                        datasets: [
                            { label: 'CEO', data: [9, 8, 9, 9, 9], backgroundColor: '#37af4b' },
                            { label: 'Ops Mgr', data: [7, 9, 6, 8, 6], backgroundColor: '#2e9b41' },
                            { label: 'Fellows', data: [6, 7, 8, 5, 7], backgroundColor: '#98fb98' }
                        ]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        scales: {
                            x: { stacked: true, ticks: { color: '#9ca3af' }, grid: { color: '#2a2a2a' } },
                            y: { stacked: true, ticks: { color: '#9ca3af' }, grid: { color: '#2a2a2a' }, beginAtZero: true, max: 25 }
                        },
                        plugins: { legend: { labels: { color: '#ffffff' } } }
                    }
                });

                // Program Efficiency Chart (Doughnut)
                const efficiencyScore = 75; // Updated to 75% per request
                const isHealthy = efficiencyScore >= 70; // Benchmark is now 70%
                const efficiencyColor = isHealthy ? '#37af4b' : '#ef4444'; // Green or Red
                
                // Update text display
                const displayEl = document.getElementById('efficiencyValueDisplay');
                if(displayEl) {
                    displayEl.innerText = efficiencyScore + '%';
                    displayEl.style.color = efficiencyColor;
                }

                const ctxEfficiency = document.getElementById('efficiencyChart').getContext('2d');
                window.efficiencyChartInstance = new Chart(ctxEfficiency, {
                    type: 'doughnut',
                    data: {
                        labels: ['Direct Cause', 'Overhead/Admin'],
                        datasets: [{
                            data: [efficiencyScore, 100 - efficiencyScore],
                            backgroundColor: [
                                efficiencyColor, 
                                'rgba(255, 255, 255, 0.05)'
                            ],
                            borderWidth: 0,
                            hoverOffset: 4,
                            cutout: '75%', // Makes it a thin ring
                            borderRadius: 5
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: { 
                            legend: { display: false },
                            tooltip: {
                                callbacks: {
                                    label: function(context) {
                                        return context.label + ': ' + context.raw + '%';
                                    }
                                }
                            }
                        }
                    }
                });

                // Sentiment Chart
                if(document.getElementById('sentimentChart')) {
                    const ctxSentiment = document.getElementById('sentimentChart').getContext('2d');
                    window.sentimentChartInstance = new Chart(ctxSentiment, {
                        type: 'bar',
                        data: {
                            labels: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun'],
                            datasets: [
                                {
                                    label: 'Positive',
                                    data: [60, 62, 65, 63, 68, 68],
                                    backgroundColor: '#37af4b'
                                },
                                {
                                    label: 'Neutral',
                                    data: [30, 28, 25, 27, 22, 25],
                                    backgroundColor: '#9ca3af'
                                },
                                {
                                    label: 'Negative',
                                    data: [10, 10, 10, 10, 10, 7],
                                    backgroundColor: '#ef4444'
                                }
                            ]
                        },
                        options: {
                            responsive: true,
                            maintainAspectRatio: false,
                            scales: {
                                x: { stacked: true, ticks: { color: '#9ca3af' }, grid: { color: '#2a2a2a' } },
                                y: { stacked: true, ticks: { color: '#9ca3af' }, grid: { color: '#2a2a2a' }, beginAtZero: true, max: 100 }
                            },
                            plugins: { legend: { labels: { color: '#ffffff' } } }
                        }
                    });
                }
            }

            // Initial Render
            refreshUI();
            lucide.createIcons();
            initializeForm();
            initCharts();
        });
    </script>
