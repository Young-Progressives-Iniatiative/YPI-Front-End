      : '<path d="M8 12a4 4 0 1 0 0-8 4 4 0 0 0 0 8M8 0a.5.5 0 0 1 .5.5v2a.5.5 0 0 1-1 0v-2A.5.5 0 0 1 8 0m0 13a.5.5 0 0 1 .5.5v2a.5.5 0 0 1-1 0v-2A.5.5 0 0 1 8 13m8-5a.5.5 0 0 1-.5.5h-2a.5.5 0 0 1 0-1h2a.5.5 0 0 1 .5.5M3 8a.5.5 0 0 1-.5.5h-2a.5.5 0 0 1 0-1h2A.5.5 0 0 1 3 8m10.657-5.657a.5.5 0 0 1 0 .707l-1.414 1.415a.5.5 0 1 1-.707-.708l1.414-1.414a.5.5 0 0 1 .707 0m-9.193 9.193a.5.5 0 0 1 0 .707L3.05 13.657a.5.5 0 0 1-.707-.707l1.414-1.414a.5.5 0 0 1 .707 0m9.193 2.121a.5.5 0 0 1-.707 0l-1.414-1.414a.5.5 0 0 1 .707-.707l1.414 1.414a.5.5 0 0 1 0 .707M4.464 4.465a.5.5 0 0 1-.707 0L2.343 3.05a.5.5 0 1 1 .707-.707l1.414 1.414a.5.5 0 0 1 0 .708"/>';
  });

  // Nav Generation
  const navItems = ['Vision', 'Organizing', 'Financials'];
  const navContainer = document.getElementById('main-nav');
  navItems.forEach(item => {
    const btn = document.createElement('button');
    const isActive = item === 'Organizing';
    btn.className = `group flex items-center px-3 py-2 text-xl font-bold tracking-tight font-fm-header transition-all cursor-pointer hover:scale-105`;
    btn.style.color = isActive ? 'var(--nav-active)' : 'var(--nav-inactive)';
    btn.innerHTML = `<span>${item}</span>`;
    btn.onclick = () => {
      document.querySelectorAll('.tab-content').forEach(s => s.classList.remove('active'));
      document.getElementById(`content-${item}`).classList.add('active');
      navContainer.querySelectorAll('button').forEach(b => b.style.color = 'var(--nav-inactive)');
      btn.style.color = 'var(--nav-active)';
    };
    navContainer.appendChild(btn);
  });

  // Recruitment Sidebar Logic
  const sections = [
    { id: 'section-1', label: 'Role Overview', icon: 'briefcase' },
    { id: 'section-2', label: 'Organization Info', icon: 'building' },
    { id: 'section-3', label: 'Mission Alignment', icon: 'compass' },
    { id: 'section-4', label: 'Volunteer Impact', icon: 'chart-bar' },
    { id: 'section-5', label: 'Responsibilities', icon: 'list-check' },
    { id: 'section-6', label: 'Qualifications', icon: 'user-check' },
    { id: 'section-7', label: 'Time Commitment', icon: 'clock' },
    { id: 'section-8', label: 'Schedule', icon: 'calendar' },
    { id: 'section-9', label: 'Benefits', icon: 'gift' },
    { id: 'section-10', label: 'Application Settings', icon: 'settings' },
    { id: 'section-11', label: 'Recruitment Visibility', icon: 'eye' },
    { id: 'section-12', label: 'Discovery Optimization', icon: 'search' },
    { id: 'section-13', label: 'Screening Questions', icon: 'message-circle-question' },
    { id: 'section-14', label: 'Accessibility', icon: 'accessibility' },
    { id: 'section-15', label: 'Safety & Compliance', icon: 'shield-check' },
    { id: 'section-16', label: 'Team Structure', icon: 'users' },
    { id: 'section-17', label: 'Communication', icon: 'message-square' },
    { id: 'section-18', label: 'Onboarding', icon: 'rocket' },
    { id: 'section-19', label: 'Success Metrics', icon: 'target' }
  ];

  const sidebarLinks = document.getElementById('sidebarLinks');
  const scrollContainer = document.querySelector('.scroll-container');

  sections.forEach((sec, idx) => {
    const link = document.createElement('div');
    link.className = 'section-link';
    link.id = `link-${sec.id}`;
    link.innerHTML = `<i data-lucide="${sec.icon}" class="w-4 h-4"></i> ${sec.label} <span class="status-dot" id="dot-${sec.id}"></span>`;
    link.onclick = () => {
      document.getElementById(sec.id).scrollIntoView({ behavior: 'smooth' });
    };
    sidebarLinks.appendChild(link);
  });
  lucide.createIcons();

  // ScrollSpy
  scrollContainer.addEventListener('scroll', () => {
    let current = '';
    sections.forEach(sec => {
      const element = document.getElementById(sec.id);
      if (element) {
        const rect = element.getBoundingClientRect();
        if (rect.top <= 150) current = sec.id;
      }
    });
    if (current) {
      sections.forEach(sec => {
        const link = document.getElementById(`link-${sec.id}`);
        if (link) link.classList.toggle('active', sec.id === current);
      });
    }
  });

  // Tag Toggles
  window.toggleTag = function(el) { el.classList.toggle('selected'); updateScore(); };

  // Add Responsibility
  window.addResponsibility = function() {
    const input = document.getElementById('new-resp');
    if(input.value.trim()) {
      const list = document.getElementById('responsibilities-list');
      const item = document.createElement('div');
      item.className = 'flex items-center gap-2 p-3 bg-[var(--bg-element)] rounded-lg border border-[var(--border-color)] fade-in';
      item.innerHTML = `
        <i class="fa-solid fa-grip-lines text-gray-500 cursor-move"></i>
        <input type="text" class="form-input flex-1 border-0 bg-transparent" value="${input.value}" oninput="updateScore()">
        <button class="text-red-400 hover:text-red-500"><i class="fa-solid fa-xmark"></i></button>
      `;
      list.appendChild(item);
      input.value = '';
      lucide.createIcons();
      updateScore();
    }
  };

  // Completion Score Logic
  window.updateScore = function() {
    // Simple heuristic for demo
    let score = 0;
    const inputs = document.querySelectorAll('.section-target input, .section-target textarea, .section-target select');
    inputs.forEach(i => { if(i.value) score += 1; });
    score = Math.min(100, Math.round((score / 35) * 100));
    
    document.getElementById('completionText').innerText = `${score}%`;
    const circle = document.getElementById('completionCircle');
    const offset = 120 - (120 * score / 100);
    circle.style.strokeDashoffset = offset;

    // Update dots
    sections.forEach(sec => {
      const secEl = document.getElementById(sec.id);
      const dot = document.getElementById(`dot-${sec.id}`);
      const inputsInSec = secEl.querySelectorAll('input, textarea');
      const filled = Array.from(inputsInSec).some(i => i.value);
      dot.classList.toggle('complete', filled);
    });
  };

  updateScore();
});
</script>
</body>
</html>

