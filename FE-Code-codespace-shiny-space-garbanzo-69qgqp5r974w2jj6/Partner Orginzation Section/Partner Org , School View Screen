    font-weight: 700;
    font-style: italic;
    color: #F4B400;
    padding-bottom: 5px;
    border-bottom: 1px solid rgba(244, 180, 0, 0.3);
    margin-bottom: 6px;
    letter-spacing: 0.6px;
    text-transform: uppercase;
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .metrics-section-title::before {
    content: '';
    width: 4px;
    height: 12px;
    background: #F4B400;
    border-radius: 2px;
  }

  .highlight-card {
    background: linear-gradient(135deg, rgba(244,180,0,0.12), rgba(244,180,0,0.04));
    border: 1px solid rgba(244,180,0,0.35);
    border-radius: 6px;
    padding: 10px 14px;
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: 10px;
    transition: all 0.22s ease;
    cursor: default;
  }
  .highlight-card:hover {
    background: linear-gradient(135deg, rgba(244,180,0,0.22), rgba(244,180,0,0.06));
    border-color: #F4B400;
    box-shadow: 0 0 18px rgba(244, 180, 0, 0.22);
    transform: translateX(3px);
  }
  .highlight-label {
    font-size: 0.78rem;
    color: #c0c8d8;
    font-style: italic;
    font-weight: 700;
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .highlight-label small {
    font-size: 0.62rem;
    color: #8899b0;
    font-weight: 400;
    letter-spacing: 0.4px;
    text-transform: uppercase;
  }
  .highlight-value {
    font-size: 1.4rem;
    font-weight: 700;
    color: #F4B400;
    font-style: italic;
    line-height: 1;
    text-shadow: 0 0 10px rgba(244, 180, 0, 0.25);
  }
  .highlight-trend {
    display: inline-flex;
    align-items: center;
    gap: 2px;
    font-size: 0.62rem;
    margin-left: 6px;
    font-style: normal;
    font-weight: 700;
