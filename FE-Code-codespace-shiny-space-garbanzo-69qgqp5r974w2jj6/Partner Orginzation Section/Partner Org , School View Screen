        <!-- Arms -->
        <path d="M -8 -1 L -12 8 L -10 9 L -7 2 Z" fill="#1a3050"/>
        <path d="M 8 -1 L 12 8 L 10 9 L 7 2 Z" fill="#1a3050"/>
        <!-- Cane -->
        <line x1="12" y1="3" x2="14" y2="14" stroke="#F4B400" stroke-width="1.2"/>
        <circle cx="14" cy="2.5" r="1.2" fill="#F4B400"/>
      </g>

      <!-- EST. 1926 small text -->
      <text x="55" y="100" text-anchor="middle" fill="#F4B400" font-size="5" font-family="'Atkinson Hyperlegible', sans-serif" font-weight="700">EST. 1926</text>
    </svg>
  </div>
  <div class="header-content">
    <h1 class="header-title">Bethesda&ndash;Chevy Chase High School</h1>
