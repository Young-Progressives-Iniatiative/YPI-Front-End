<!-- ===== HEADER ===== -->
<header class="header">
  <div class="header-logo">
    <svg viewBox="0 0 110 110" xmlns="http://www.w3.org/2000/svg">
      <!-- Outer ring with text -->
      <circle cx="55" cy="55" r="52" fill="#0d1a33" stroke="#F4B400" stroke-width="3"/>
      <circle cx="55" cy="55" r="49" fill="none" stroke="#F4B400" stroke-width="0.8"/>
      <circle cx="55" cy="55" r="38" fill="#fbf3e0" stroke="#F4B400" stroke-width="1.2"/>

      <!-- Curved text top -->
      <defs>
        <path id="topArc" d="M 17 55 A 38 38 0 0 1 93 55" fill="none"/>
        <path id="bottomArc" d="M 20 60 A 35 35 0 0 0 90 60" fill="none"/>
      </defs>
      <text font-family="'Atkinson Hyperlegible', sans-serif" font-size="7" font-weight="700" fill="#F4B400" letter-spacing="1.2">
        <textPath href="#topArc" startOffset="50%" text-anchor="middle">BETHESDA-CHEVY CHASE</textPath>
      </text>
      <text font-family="'Atkinson Hyperlegible', sans-serif" font-size="6" font-weight="700" fill="#F4B400" letter-spacing="1">
        <textPath href="#bottomArc" startOffset="50%" text-anchor="middle">HIGH SCHOOL</textPath>
      </text>

      <!-- Baron mascot figure -->
      <g transform="translate(55, 56)">
        <!-- Top hat -->
        <rect x="-7" y="-22" width="14" height="10" rx="0.5" fill="#1a1a1a"/>
        <rect x="-9" y="-13" width="18" height="2" rx="0.5" fill="#1a1a1a"/>
        <rect x="-7" y="-19" width="14" height="2" fill="#F4B400" opacity="0.7"/>
        <!-- Head -->
        <circle cx="0" cy="-7" r="5" fill="#f0d4a8"/>
        <!-- Beard -->
