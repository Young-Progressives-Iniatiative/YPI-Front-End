        document.addEventListener('DOMContentLoaded', async () => {
            try {
                // Header Event Listeners
                const desktopThemeCustomizerBtn = document.getElementById('themeCustomizerBtn');
                if (desktopThemeCustomizerBtn) {
                    desktopThemeCustomizerBtn.addEventListener('click', openCustomizer);
                }
                
                document.getElementById('closeCustomizerBtn').addEventListener('click', () => {
                    const customizerOverlay = document.getElementById('customizerOverlay');
                    customizerOverlay.style.opacity = '0';
                    setTimeout(() => customizerOverlay.style.visibility = 'hidden', 300);
                });

                document.getElementById('profileMenuClose').addEventListener('click', () => {
                    const profileMenuOverlay = document.getElementById('profileMenuOverlay');
                    profileMenuOverlay.style.opacity = '0';
                    setTimeout(() => profileMenuOverlay.style.visibility = 'hidden', 300);
                });

                document.getElementById('customizerOverlay').addEventListener('click', (e) => {
                    if (e.target === document.getElementById('customizerOverlay')) {
                        document.getElementById('customizerOverlay').style.opacity = '0';
                        setTimeout(() => document.getElementById('customizerOverlay').style.visibility = 'hidden', 300);
                    }
                });

                document.getElementById('profileMenuOverlay').addEventListener('click', (e) => {
                    if (e.target === document.getElementById('profileMenuOverlay')) {
                        document.getElementById('profileMenuOverlay').style.opacity = '0';
                        setTimeout(() => document.getElementById('profileMenuOverlay').style.visibility = 'hidden', 300);
                    }
                });
                
                // Existing Dashboard Logic
                const firebaseConfig = JSON.parse(typeof __firebase_config !== 'undefined' ? __firebase_config : '{}');
                const currentUserIdDisplay = document.getElementById('currentUserIdDisplay');
                if (!firebaseConfig.apiKey) {
                    console.error("Firebase config is missing or invalid.");
                    currentUserIdDisplay.textContent = 'Error: Firebase config invalid.';
                    return;
                }
                window.firebaseApp = initializeApp(firebaseConfig);
                window.db = getFirestore(window.firebaseApp);
                window.auth = getAuth(window.firebaseApp);
                
                onAuthStateChanged(window.auth, (user) => {
                    if (user) {
                        window.currentUserId = user.uid;
                        currentUserIdDisplay.textContent = `User ID: ${window.currentUserId}`;
                        loadInsightsFromLocalStorage(window.currentUserId);
                    } else {
                        window.currentUserId = null;
                        currentUserIdDisplay.textContent = 'User ID: Not authenticated.';
                    }
                });

                try {
                    if (typeof __initial_auth_token !== 'undefined' && __initial_auth_token) {
                        await signInWithCustomToken(window.auth, __initial_auth_token);
                    } else {
                        await signInAnonymously(window.auth);
                    }
                } catch (authError) {
                    window.currentUserId = crypto.randomUUID();
                    currentUserIdDisplay.textContent = `User ID (Offline): ${window.currentUserId.substring(0,8)}`;
                    loadInsightsFromLocalStorage(window.currentUserId);
                }

                initializeCharts();
                initializeSortable();
                updatePremiumToggleBtn();
                makeTableSortable('projectsCompletedTable');
                makeTableSortable('financialContributionTable');
                makeTableSortable('individualSatisfactionTable');

                const addFinancialContributionBtn = document.getElementById('addFinancialContributionBtn');
                const addFinancialContributionModal = document.getElementById('addFinancialContributionModal');
                const closeFinancialContributionModalBtn = document.getElementById('closeFinancialContributionModalBtn');
                const newFinancialContributionForm = document.getElementById('newFinancialContributionForm');
                const submitInsightBtn = document.getElementById('submitInsightBtn');
                const submitInsightModal = document.getElementById('submitInsightModal');
                const closeInsightModalBtn = document.getElementById('closeInsightModalBtn');
                const newInsightForm = document.getElementById('newInsightForm');
                const togglePremiumAccessBtn = document.getElementById('togglePremiumAccessBtn');
                const allDropdownToggles = document.querySelectorAll('.insights-dropdown-toggle');
                
                document.getElementById('generateReportBtn').addEventListener('click', generateReport);
                document.getElementById('exportCsvBtn').addEventListener('click', exportToCSV);
                addFinancialContributionBtn.addEventListener('click', () => addFinancialContributionModal.classList.add('show'));
                closeFinancialContributionModalBtn.addEventListener('click', () => addFinancialContributionModal.classList.remove('show'));

                newFinancialContributionForm.addEventListener('submit', (event) => {
                    event.preventDefault();
                    addFinancialContributionEntry(
                        document.getElementById('financialContributionVolunteerName').value,
                        document.getElementById('financialContributionTask').value,
                        document.getElementById('financialContributionValue').value
                    );
                    newFinancialContributionForm.reset();
                    addFinancialContributionModal.classList.remove('show');
                });

                submitInsightBtn.addEventListener('click', () => submitInsightModal.classList.add('show'));
                closeInsightModalBtn.addEventListener('click', () => submitInsightModal.classList.remove('show'));

                newInsightForm.addEventListener('submit', async (event) => {
                    event.preventDefault();
                    const title = document.getElementById('insightTitle').value;
                    const desc = document.getElementById('insightDescription').value;
                    const cat = document.getElementById('insightCategory').value;
                    if (window.currentUserId) {
                        addInsightToLocalStorage(title, desc, cat, window.currentUserId);
                        await addInsightToFirestore(title, desc, cat, window.currentUserId);
                    }
                    newInsightForm.reset();
                    submitInsightModal.classList.remove('show');
                });

                togglePremiumAccessBtn.addEventListener('click', () => {
                    window.isPremiumUser = !window.isPremiumUser;
                    localStorage.setItem('isPremiumUser', window.isPremiumUser);
                    updatePremiumToggleBtn();
                    document.querySelectorAll('.card-dropdown-content.show').forEach(openDropdown => {
                        openDropdown.classList.remove('show');
                        const associatedToggle = openDropdown.closest('.card').querySelector('.insights-dropdown-toggle');
                        if (associatedToggle) associatedToggle.classList.remove('open');
                    });
                });

                allDropdownToggles.forEach(toggle => {
                    toggle.addEventListener('click', (event) => {
                        event.stopPropagation();
                        const parentCard = toggle.closest('.card');
                        const dropdownContent = parentCard.querySelector('.card-dropdown-content');
                        if (dropdownContent) populateAndShowDropdown(dropdownContent, toggle, parentCard.id);
                    });
                });

                document.addEventListener('click', (event) => {
                    document.querySelectorAll('.card-dropdown-content.show').forEach(openDropdown => {
                        const parentCard = openDropdown.closest('.card');
                        if (!parentCard.contains(event.target)) {
                            openDropdown.classList.remove('show');
                            const associatedToggle = parentCard.querySelector('.insights-dropdown-toggle');
                            if (associatedToggle) associatedToggle.classList.remove('open');
                        }
                    });
                });

            } catch (e) {
                console.error("Fatal Initialization Error:", e);
                document.getElementById('currentUserIdDisplay').textContent = 'Error: App failed to load.';
            }
        });
