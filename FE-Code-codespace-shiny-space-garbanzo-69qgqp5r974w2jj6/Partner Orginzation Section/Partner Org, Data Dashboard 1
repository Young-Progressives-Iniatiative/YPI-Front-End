        // Function to populate and show a generic card dropdown
        function populateAndShowDropdown(dropdownContentElement, toggleElement, cardId) {
            const overflowList = dropdownContentElement.querySelector('.overflow-list');
            if (!overflowList) return;

            // Close any other open dropdowns first
            document.querySelectorAll('.card-dropdown-content.show').forEach(openDropdown => {
                if (openDropdown !== dropdownContentElement) {
                    openDropdown.classList.remove('show');
                    const associatedToggle = openDropdown.closest('.card').querySelector('.insights-dropdown-toggle');
                    if (associatedToggle) associatedToggle.classList.remove('open');
                }
            });

            // Toggle current dropdown
            dropdownContentElement.classList.toggle('show');
            toggleElement.classList.toggle('open');

            // Populate only if showing
            if (dropdownContentElement.classList.contains('show')) {
                overflowList.innerHTML = ''; // Clear existing content

                // Get the specific premium content for this card
                const premiumContentHtml = getPremiumContentHtml(cardId);
                overflowList.innerHTML = premiumContentHtml;

                // Attach event listeners to premium stat titles (only if premium content is present)
                if (window.isPremiumUser || premiumContentHtml.includes('upgradePremiumBtn')) { // Only attach if there's content to interact with
                    overflowList.querySelectorAll('.premium-stat-title').forEach(titleElement => {
                        titleElement.addEventListener('click', (event) => {
                            event.stopPropagation(); // Prevent dropdown from closing
                            togglePremiumStatDetails(titleElement, cardId);
                        });
                    });
                }


                // Add event listener for the "Upgrade Now" button if present
                const upgradeBtn = dropdownContentElement.querySelector('#upgradePremiumBtn');
                if (upgradeBtn) {
                    upgradeBtn.addEventListener('click', () => {
                        window.isPremiumUser = true;
                        localStorage.setItem('isPremiumUser', 'true');
                        // Reload the dropdown content to show premium data
                        populateAndShowDropdown(dropdownContentElement, toggleElement, cardId);
                        updatePremiumToggleBtn(); // Update the main toggle button state
                    });
                }

                // Append general overflow insights if any (categorized)
                if (window.allOverflowInsightsData.length > 0) {
                    const insightsByCategory = window.allOverflowInsightsData.reduce((acc, insight) => {
                        const category = insight.category || 'Uncategorized';
                        if (!acc[category]) {
                            acc[category] = [];
                        }
                        acc[category].push(insight);
                        return acc;
                    }, {});

                    // Add a separator if there's premium content and also general insights
                    // Check if premiumContentHtml is not just the default "No specific advanced insights" message
                    const hasPremiumContent = premiumContentHtml.trim() !== `<p class="text-sm text-[var(--text-medium)] text-center py-2">No specific advanced insights for this card.</p>`.trim();

                    if (hasPremiumContent) {
                        const separator = document.createElement('hr');
                        separator.classList.add('border-t', 'border-[var(--border-color)]', 'my-4');
                        overflowList.appendChild(separator);
                    }


                    for (const category in insightsByCategory) {
                        const categoryHeader = document.createElement('h4');
                        categoryHeader.classList.add('category-header');
                        categoryHeader.textContent = category;
                        overflowList.appendChild(categoryHeader);

                        insightsByCategory[category].forEach(data => {
                            const insightDiv = document.createElement('div');
                            insightDiv.classList.add('user-insight-item');
                            insightDiv.innerHTML = `<p class="font-semibold text-white mb-1">${data.title}</p><p>${data.description}</p><p class="meta-info">Submitted: ${data.timestamp}</p>`;
                            overflowList.appendChild(insightDiv);
                        });
                    }
                } else if (!window.isPremiumUser && premiumContentHtml.trim() === `<p class="text-sm text-[var(--text-medium)] text-center py-2">No specific advanced insights for this card.</p>`.trim()) {
                    // If no specific premium content and no general insights, show a general message
                    overflowList.innerHTML = '<p class="text-sm text-[var(--text-medium)] text-center py-2">No additional insights available.</p>';
                }
            }
        }

        // Function to update the premium toggle button text and style
        function updatePremiumToggleBtn() {
