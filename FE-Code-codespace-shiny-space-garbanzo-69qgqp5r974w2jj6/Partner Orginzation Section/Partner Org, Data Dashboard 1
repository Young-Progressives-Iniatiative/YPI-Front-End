        function initializeCharts() {
            const roiTrendCtx = document.getElementById('roiTrendChart').getContext('2d');
            let roiGradient = roiTrendCtx.createLinearGradient(0, 0, 0, 400);
            roiGradient.addColorStop(0, 'rgba(124, 58, 237, 0.5)'); 
            roiGradient.addColorStop(1, 'rgba(124, 58, 237, 0.0)');

            new Chart(roiTrendCtx, {
                type: 'line',
                data: {
                    labels: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul'], 
                    datasets: [{
                        label: 'ROI Ratio',
                        data: [2.5, 3.0, 2.8, 3.2, 3.5, 3.1, 3.4], 
                        borderColor: '#7C3AED', 
                        backgroundColor: roiGradient,
                        borderWidth: 3,
                        tension: 0.4, 
                        pointRadius: 0,
                        fill: true,
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false }, tooltip: { enabled: false } },
                    scales: { x: { display: false }, y: { display: false, min: 2.0, max: 4.0 } }
                }
            });

            const hoursByTypeChartCtx = document.getElementById('hoursByTypeChart').getContext('2d');
            let hoursGradient = hoursByTypeChartCtx.createLinearGradient(0, 0, 0, 400);
            hoursGradient.addColorStop(0, 'rgba(249, 115, 22, 0.5)'); 
            hoursGradient.addColorStop(1, 'rgba(249, 115, 22, 0.0)');

            new Chart(hoursByTypeChartCtx, {
                type: 'line',
                data: {
                    labels: ['Community', 'Training', 'Events', 'Mentoring', 'Admin', 'Outreach'],
                    datasets: [{
                        label: 'Hours',
                        data: [300, 250, 400, 200, 350, 500], 
                        borderColor: '#F97316', 
                        backgroundColor: hoursGradient,
                        borderWidth: 3,
                        tension: 0.4,
                        pointRadius: 0,
                        fill: true,
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: { x: { display: false }, y: { display: false, beginAtZero: true } }
                }
            });
        }

        function initializeSortable() {
            const dashboardGrid = document.getElementById('dashboardGrid');
            if (dashboardGrid) {
                new Sortable(dashboardGrid, {
                    animation: 150, 
                    ghostClass: 'sortable-ghost', 
                    handle: '.card-header', 
