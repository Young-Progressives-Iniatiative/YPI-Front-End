            z-index: 999; /* Ensure it's above other content */
            display: none; /* Hidden by default */
            flex-direction: column;
            max-height: 300px; /* Limit height for scrolling */
            overflow-y: auto;
            border: 1px solid var(--border-color);
        }

        .card-dropdown-content.show {
            display: flex;
        }

        .card-dropdown-content .category-header { /* New class for category headers */
            font-size: 1em;
            color: var(--text-light);
            margin-top: 10px;
            margin-bottom: 5px;
            border-bottom: 1px solid var(--border-color);
            padding-bottom: 5px;
        }

        .card-dropdown-content .category-header:first-of-type {
            margin-top: 0; /* No top margin for the first category */
        }

        .card-dropdown-content .overflow-list {
            display: flex;
            flex-direction: column;
            gap: 10px;
        }

        .card-dropdown-content .user-insight-item {
            background-color: rgba(255, 255, 255, 0.03); /* Slightly different background for items in dropdown */
            padding: 8px 12px;
        }

        /* Premium Stat Item Styling */
        .premium-stat-item {
            margin-bottom: 10px;
            border-bottom: 1px solid rgba(255,255,255,0.05);
            padding-bottom: 10px;
        }
        .premium-stat-item:last-of-type {
            border-bottom: none;
            margin-bottom: 0;
            padding-bottom: 0;
        }

        .premium-stat-title {
            font-size: 1.05em;
            font-weight: 600;
            color: var(--text-light);
            cursor: pointer;
            padding: 5px 0;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .premium-stat-title .toggle-arrow {
            transform: rotate(90deg); /* Point right by default */
            transition: transform 0.2s ease-in-out;
        }

        .premium-stat-title .toggle-arrow.open {
            transform: rotate(270deg); /* Point down when open */
        }

        .premium-stat-details {
            margin-top: 10px;
            padding-left: 10px;
            border-left: 2px solid var(--accent-blue);
        }
        .premium-stat-details.hidden {
            display: none;
        }
        .premium-stat-details.show {
            display: block; /* Use block for metrics/tables, flex for charts if needed */
        }

        /* Sortable Table Headers */
        table th {
            position: relative;
            padding-right: 20px; /* Space for indicator */
        }

        table th .sort-indicator {
            position: absolute;
            right: 0;
            top: 50%;
            transform: translateY(-50%);
            font-size: 0.8em;
            color: var(--text-medium);
        }
    </style>
</head>
<body class="bg-[var(--bg-primary)] text-[var(--text-light)] p-5 box-border">
    <div class="dashboard-container w-full max-w-[1400px] flex flex-col gap-5">
