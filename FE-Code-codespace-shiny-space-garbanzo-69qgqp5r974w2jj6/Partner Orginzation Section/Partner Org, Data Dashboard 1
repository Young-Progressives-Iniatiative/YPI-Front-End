        // Function to add a new financial value entry
        function addFinancialContributionEntry(volunteerName, task, value) {
            const tableBody = document.getElementById('financialContributionTableBody');
            const newRow = tableBody.insertRow(0); // Insert at the top
            newRow.classList.add('border-b', 'border-[rgba(255,255,255,0.1)]'); // Add border for consistency

            const volunteerCell = newRow.insertCell(0);
            volunteerCell.classList.add('py-2', 'text-left', 'text-[#e0e0e0]');
            volunteerCell.textContent = volunteerName;

            const taskCell = newRow.insertCell(1);
            taskCell.classList.add('py-2', 'text-left', 'text-[#e0e0e0]');
            taskCell.textContent = task;

            const valueCell = newRow.insertCell(2);
            valueCell.classList.add('py-2', 'text-left', 'text-[#e0e0e0]');
            valueCell.textContent = value;
        }

        // Function to save an insight to localStorage
        function addInsightToLocalStorage(title, description, category, userId) {
            const insightsKey = `userInsights_${userId}`;
            let insights = JSON.parse(localStorage.getItem(insightsKey)) || [];
            insights.unshift({ title, description, category, timestamp: new Date().toLocaleString() }); // Add to the beginning
            localStorage.setItem(insightsKey, JSON.stringify(insights));
            loadInsightsFromLocalStorage(userId); // Reload to update display
        }

        // Function to load insights from localStorage and populate the lists
        function loadInsightsFromLocalStorage(userId) {
            const insightsKey = `userInsights_${userId}`;
            const insights = JSON.parse(localStorage.getItem(insightsKey)) || [];

            const userInsightsList = document.getElementById('userInsightsList');
            userInsightsList.innerHTML = ''; // Clear current display
            window.allOverflowInsightsData = []; // Clear global overflow data

            const displayLimit = 3; // Number of insights to show directly in the card

            if (insights.length === 0) {
                userInsightsList.innerHTML = '<p class="no-insights-message" id="noInsightsMessage">No insights submitted yet.</p>';
                // Hide dropdown toggle for User Insights card if no insights
                const userInsightsToggle = document.querySelector('#userInsightsCard .insights-dropdown-toggle');
                if (userInsightsToggle) userInsightsToggle.style.display = 'none';
            } else {
                const existingNoInsightsMessage = document.getElementById('noInsightsMessage');
                if (existingNoInsightsMessage) {
                    existingNoInsightsMessage.remove();
                }

                insights.forEach((data, index) => {
                    const insightDiv = document.createElement('div');
                    insightDiv.classList.add('user-insight-item');

                    const titleElement = document.createElement('p');
                    titleElement.classList.add('font-semibold', 'text-white', 'mb-1');
                    titleElement.textContent = data.title;

                    const descriptionElement = document.createElement('p');
                    descriptionElement.textContent = data.description;

                    const metaInfo = document.createElement('p');
                    metaInfo.classList.add('meta-info');
                    metaInfo.textContent = `Submitted: ${data.timestamp}`;

                    insightDiv.appendChild(titleElement);
                    insightDiv.appendChild(descriptionElement);
                    insightDiv.appendChild(metaInfo);

                    if (index < displayLimit) {
                        userInsightsList.appendChild(insightDiv);
                    } else {
                        window.allOverflowInsightsData.push(data); // Add to global overflow array
                    }
                });

                // Show/hide dropdown toggle for User Insights card based on overflow
                const userInsightsToggle = document.querySelector('#userInsightsCard .insights-dropdown-toggle');
                if (userInsightsToggle) {
                    userInsightsToggle.style.display = window.allOverflowInsightsData.length > 0 ? 'block' : 'none';
                }
            }
        }

        // Function to add an insight to Firestore (kept for future use/reference, not currently displayed)
        async function addInsightToFirestore(title, description, category, userId) {
            if (!userId) {
                console.error("User ID not available. Cannot submit insight to Firestore.");
                return;
            }
            try {
                const insightsCollectionRef = window.collection(window.db, `artifacts/${window.appId}/users/${userId}/insights`);
                await window.addDoc(insightsCollectionRef, {
                    title: title,
                    description: description,
                    category: category, // Save category to Firestore
                    timestamp: new Date().toLocaleString(),
                    userId: userId
                });
                console.log("Insight added to Firestore!");
            } catch (e) {
                console.error("Error adding document to Firestore: ", e);
            }
        }

