                        });
                    }
                } else if (statId === 'volunteerHoursTrend') {
                    const canvas = statDetails.querySelector('#dropdownVolunteerHoursTrendChart');
                    if (canvas && !Chart.getChart(canvas)) {
                        new Chart(canvas.getContext('2d'), {
