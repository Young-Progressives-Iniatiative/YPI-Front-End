        }

        // Function to make table columns sortable
        function makeTableSortable(tableId) {
            const table = document.getElementById(tableId);
            if (!table) return;

            const headers = table.querySelectorAll('th');
            headers.forEach((header, index) => {
                header.style.cursor = 'pointer'; // Add pointer cursor to indicate sortable
                header.setAttribute('data-sort-dir', 'none'); // Initial sort direction

                // Add sort indicator span
                const sortIndicator = document.createElement('span');
                sortIndicator.classList.add('sort-indicator');
                header.appendChild(sortIndicator);

                header.addEventListener('click', () => {
                    const currentSortDir = header.getAttribute('data-sort-dir');
                    let newSortDir = 'asc';

                    // Determine new sort direction
                    if (currentSortDir === 'asc') {
                        newSortDir = 'desc';
                    } else if (currentSortDir === 'desc') {
                        newSortDir = 'none'; // Cycle to no sort
                    } else {
                        newSortDir = 'asc';
                    }

                    // Reset all other headers
                    headers.forEach(h => {
                        if (h !== header) {
                            h.setAttribute('data-sort-dir', 'none');
                            h.querySelector('.sort-indicator').textContent = '';
                        }
                    });

                    // Update current header's sort direction and indicator
                    header.setAttribute('data-sort-dir', newSortDir);
                    if (newSortDir === 'asc') {
                        sortIndicator.textContent = ' ▲';
                    } else if (newSortDir === 'desc') {
                        sortIndicator.textContent = ' ▼';
                    } else {
                        sortIndicator.textContent = '';
                    }

                    const tbody = table.querySelector('tbody');
                    const rows = Array.from(tbody.querySelectorAll('tr'));

                    if (newSortDir === 'none') {
                        // If no sort, revert to original order (if possible, or just do nothing)
                        // For simplicity, we'll just leave it as is for 'none'
                        return;
                    }

                    rows.sort((rowA, rowB) => {
                        const cellA = rowA.children[index].textContent.trim();
                        const cellB = rowB.children[index].textContent.trim();

                        let valA = cellA;
                        let valB = cellB;

                        // Attempt to convert to number for numerical columns (e.g., Projects, Score, Value)
                        if (!isNaN(parseFloat(cellA)) && !isNaN(parseFloat(cellB))) {
                            valA = parseFloat(cellA.replace(/[^0-9.-]+/g,"")); // Remove non-numeric chars except decimal/sign
                            valB = parseFloat(cellB.replace(/[^0-9.-]+/g,""));
                        } else if (cellA.startsWith('$') && cellB.startsWith('$')) { // Handle currency specifically
                            valA = parseFloat(cellA.replace('$', '').replace(/,/g, ''));
                            valB = parseFloat(cellB.replace('$', '').replace(/,/g, ''));
                        }


                        if (newSortDir === 'asc') {
                            return valA > valB ? 1 : -1;
                        } else { // desc
                            return valA < valB ? 1 : -1;
                        }
                    });

                    // Re-append sorted rows
                    rows.forEach(row => tbody.appendChild(row));
                });
            });
        }
        
