<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Influencer Analytics: Cole Holland</title>
    
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Atkinson+Hyperlegible:ital,wght@0,400;0,700;1,400;1,700&display=swap" rel="stylesheet">
    
    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    
    <!-- Vis.js -->
    <script type="text/javascript" src="https://unpkg.com/vis-network/standalone/umd/vis-network.min.js"></script>
    
    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>

    <style>
        /* --- CSS Variables for Theming --- */
        :root {
            /* --- Dark Mode (Default) --- */
            --bg-body: #1c1c1c;
            --bg-header: #1b1b1b;
            --border-header: #2a2a2a;
            
            --text-primary: #ffffff;
            --text-secondary: #9ca3af;
            
            /* Card Specifics - Dark Mode */
            --card-bg: #1c1c1c;
            --text-card: #ffffff;
            --border-inner: #374151;
            
            /* Accents */
            --accent-color: #98fb98;
            --nav-active: #98fb98;
            --nav-glow: rgba(152, 251, 152, 0.25);
            
            /* Buttons */
            --btn-bg: #2a2d35;
            --btn-border: rgba(59, 130, 246, 0.5);
            --icon-color: #d1d5db;
            
            --logo-filter: none;
        }

        /* --- Light Mode Overrides --- */
        body.light-mode {
            --bg-body: #f3f4f6;
            --bg-header: #fefefe;
            --border-header: #e5e7eb;
            
            --text-primary: #1c1c1c;
            --text-secondary: #4b5563;
            
            /* Card Specifics - Light Mode */
            --card-bg: #fefefe;
            --text-card: #1c1c1c;
            --border-inner: #e5e7eb;
            
            /* Accents - Darker Green for visibility */
            --accent-color: #16a34a;
            --nav-active: #16a34a;
            --nav-glow: rgba(22, 163, 74, 0.15);
            
            /* Buttons */
            --btn-bg: #fefefe;
            --btn-border: rgba(59, 130, 246, 0.3);
            --icon-color: #1c1c1c;
            --logo-filter: invert(1);
        }

        body {
            font-family: 'Atkinson Hyperlegible', sans-serif;
            background-color: var(--bg-body);
            color: var(--text-primary);
            transition: background-color 0.3s ease, color 0.3s ease;
            margin: 0;
        }

        /* Header */
        header {
            background-color: var(--bg-header);
            border-bottom: 1px solid var(--border-header);
            transition: background-color 0.3s ease, border-color 0.3s ease;
        }

        /* Cards - Adaptive */
        .analytics-card {
            background-color: var(--card-bg);
            color: var(--text-card);
            border: 2px solid var(--accent-color);
            border-radius: 0.5rem;
            transition: background-color 0.3s ease, color 0.3s ease, border-color 0.3s ease;
        }

        /* Helper classes */
        .text-card-base { color: var(--text-card); }
        .text-accent { color: var(--accent-color); }
        .bg-accent { background-color: var(--accent-color); }
        .border-inner { border-color: var(--border-inner); }

        /* Navigation Buttons */
        .nav-btn {
            color: var(--text-secondary);
            transition: all 0.3s ease;
        }
        .nav-btn:hover {
            color: var(--text-primary);
            transform: scale(1.05);
        }
        .nav-btn.active {
            color: var(--nav-active);
            filter: drop-shadow(0 0 8px var(--nav-glow));
            transform: scale(1.05);
        }

        /* Scrollbar */
        ::-webkit-scrollbar { width: 6px; height: 6px; }
        ::-webkit-scrollbar-track { background: var(--bg-body); }
        ::-webkit-scrollbar-thumb { background: #333; border-radius: 3px; }
        ::-webkit-scrollbar-thumb:hover { background: var(--accent-color); }
        
        .no-scrollbar::-webkit-scrollbar { display: none; }
        .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }

        /* Modal Styles */
        .modal-enter { opacity: 0; pointer-events: none; transform: scale(0.95); }
        .modal-active { opacity: 1; pointer-events: auto; transform: scale(1); }
        .modal-transition { transition: all 0.2s ease-in-out; }

        /* Custom Tooltip */
        #globalTooltip {
            transition: opacity 0.15s ease, transform 0.1s ease;
            position: absolute; /* Changed from fixed to absolute so it scrolls with the page */
            pointer-events: auto; /* Allow clicking the link inside */
            z-index: 100;
        }
        #globalTooltip.hidden-tooltip {
            opacity: 0;
            pointer-events: none;
            transform: translateY(10px);
        }
    </style>
</head>
<body class="min-h-screen">

    <!-- Header Component -->
    <header class="fixed top-0 left-0 right-0 w-full shadow-lg transition-colors duration-300 z-50">
        <div class="flex items-center h-16 px-6 gap-6 overflow-x-auto no-scrollbar">
            
            <!-- Navigation Controls -->
            <div class="flex items-center mr-2 flex-shrink-0">
                <button class="flex items-center justify-center w-8 h-10 border rounded-l transition-colors group relative hover:opacity-80" style="background-color: var(--btn-bg); border-color: var(--btn-border);">
                    <div class="absolute inset-0 border border-blue-400/30 rounded-l opacity-50"></div>
                    <i data-lucide="chevron-left" class="w-5 h-5 transition-colors" style="color: var(--icon-color)"></i>
                </button>
                <button class="flex items-center justify-center w-8 h-10 transition-colors rounded-r border-y border-r hover:opacity-80" style="background-color: var(--bg-body); border-color: var(--border-header);">
                    <i data-lucide="chevron-right" class="w-5 h-5 text-gray-500"></i>
                </button>
            </div>

            <!-- Logo -->
            <div class="flex-shrink-0 mr-4">
                <div class="h-12 w-auto flex items-center justify-center">
                    <img 
                        src="https://weareypi.com/wp-content/uploads/2025/06/Site-Icon-3.png" 
                        alt="Team Logo" 
                        class="h-full w-auto object-contain drop-shadow-md transition-all duration-300"
                        style="filter: var(--logo-filter)"
                        id="headerLogo"
                        onerror="this.src='https://via.placeholder.com/150x50?text=YPI';"
                    >
                </div>
            </div>

            <!-- Navigation Menu -->
            <nav class="flex items-center gap-2" id="mainNav">
                <!-- Injected via JS -->
            </nav>

            <!-- Theme Switcher -->
            <div class="ml-auto flex items-center pl-4 border-l" style="border-color: var(--border-header)">
                <button id="themeToggle" class="p-2 rounded-full transition-all active:scale-95 hover:bg-black/10" style="color: var(--text-primary)">
                    <i data-lucide="sun" id="themeIcon"></i>
                </button>
            </div>
        </div>
    </header>
    
    <!-- Spacer for fixed header -->
    <div class="h-16"></div>

    <!-- Main Content Area -->
    <div class="p-2 md:p-4 pb-20">
        <div class="flex flex-col md:flex-row gap-4 mb-4">
            
            <!-- Profile Card -->
            <div class="w-full md:w-1/3 flex flex-col gap-2">
                <div class="relative group">
                    <h1 id="profileName" class="text-3xl md:text-4xl font-extrabold italic tracking-tighter transition-colors duration-300" style="color: var(--text-primary)">
                        Cole Holland
                    </h1>
                    <p class="text-[10px] mb-2 font-mono text-accent">A Young Progressive CEO trying to make an impact on the non-profit industry</p>
                    <div class="relative overflow-hidden rounded-lg border-2" style="border-color: var(--accent-color)">
                        <img src="https://weareypi.com/wp-content/uploads/2024/09/YPI-Site-Images_4.jpg" alt="Cole Holland" class="w-full h-auto object-cover opacity-90 group-hover:opacity-100 transition-opacity" onerror="this.src='https://placehold.co/400x400/111/98fb98?text=Cole';">
                        <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent"></div>
                    </div>
                </div>
            </div>

            <!-- Top Analytics -->
            <div class="w-full md:w-2/3 flex flex-col gap-4">
                <div class="grid grid-cols-1 md:grid-cols-12 gap-4 h-full">
                    
                    <!-- Info Box -->
                    <div class="analytics-card md:col-span-4 flex flex-col justify-center space-y-4 p-4">
                        <div class="flex justify-center space-x-4 mb-2">
                            <img src="https://flagcdn.com/w40/us.png" alt="US" class="inline-block h-5 rounded-sm">
                        </div>
                        <div class="space-y-3 text-center text-card-base">
                            <div>
                                <div class="text-gray-400 text-xs uppercase tracking-widest">Date of Creation</div>
                                <div class="font-bold">May 12, 2015</div>
                            </div>
                            <div>
                                <div class="text-gray-400 text-xs uppercase tracking-widest">Largest Audience</div>
                                <div class="flex items-center justify-center gap-2">
                                    <span class="font-bold">Males 25-34 years old</span>
                                    <img src="https://flagcdn.com/w40/us.png" alt="US" class="inline-block h-4 rounded-sm">
                                </div>
                            </div>
                            <div>
                                <div class="text-gray-400 text-xs uppercase tracking-widest">Most Engaged</div>
                                <div class="flex items-center justify-center gap-2">
                                    <span class="font-bold">Women 18-24 years old</span>
                                    <img src="https://flagcdn.com/w40/us.png" alt="US" class="inline-block h-4 rounded-sm">
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Interest Chart -->
                    <div class="analytics-card md:col-span-7 flex flex-col p-3 relative cursor-pointer hover:border-blue-400/50 transition-colors" id="chartContainer">
                        <div class="flex justify-between items-center mb-2 px-2">
                            <div class="flex items-center gap-2">
                                <h3 id="interestTitle" class="text-accent font-bold italic transition-all">Interest Over Time</h3>
                                <button id="resetInterest" class="hidden text-[10px] bg-black/10 dark:bg-white/10 px-2 py-0.5 rounded hover:bg-opacity-20 transition-colors text-card-base">Reset</button>
                            </div>
                            <div class="flex gap-2">
                                <div id="interestIndicator" class="w-2 h-2 rounded-full bg-accent transition-colors duration-500"></div>
                            </div>
                        </div>
                        <div class="h-full min-h-[160px] w-full flex-grow relative pointer-events-none">
                            <canvas id="interestChart"></canvas>
                        </div>
                    </div>

                    <!-- Sidebar Icons -->
                    <div class="md:col-span-1 flex flex-row md:flex-col gap-2 justify-center md:justify-start">
                        <button onclick="updateInterestGraph('Google')" id="btnGoogle" class="analytics-card p-3 rounded-lg border hover:bg-opacity-50 transition-colors group">
                            <svg viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6 text-gray-400 group-hover:text-blue-400 transition-transform group-hover:scale-110">
                                <path d="M12.48 10.92v3.28h7.84c-.24 1.84-.853 3.187-1.787 4.133-1.147 1.147-2.933 2.4-6.053 2.4-4.827 0-8.6-3.893-8.6-8.72s3.773-8.72 8.6-8.72c2.6 0 4.507 1.027 5.907 2.347l2.307-2.307C18.747 1.44 16.133 0 12.48 0 5.867 0 .307 5.387.307 12s5.56 12 12.173 12c3.573 0 6.267-1.173 8.373-3.36 2.16-2.16 2.84-5.213 2.84-7.667 0-.76-.053-1.467-.173-2.053H12.48z" />
                            </svg>
                        </button>
                        <button onclick="updateInterestGraph('Pinterest')" id="btnPinterest" class="analytics-card p-3 rounded-lg border hover:bg-opacity-50 transition-colors group">
                            <svg viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6 text-gray-400 group-hover:text-red-500 transition-transform group-hover:scale-110">
                                <path d="M12.017 0C5.396 0 .029 5.367.029 11.987c0 5.079 3.158 9.417 7.618 11.162-.105-.949-.199-2.403.041-3.439.219-.937 1.406-5.957 1.406-5.957s-.359-.72-.359-1.781c0-1.663.967-2.911 2.168-2.911 1.024 0 1.518.769 1.518 1.688 0 1.029-.653 2.567-.992 3.992-.285 1.193.6 2.165 1.775 2.165 2.128 0 3.768-2.245 3.768-5.487 0-2.861-2.063-4.869-5.008-4.869-3.41 0-5.409 2.562-5.409 5.199 0 1.033.394 2.143.889 2.741.099.12.112.225.085.345-.09.375-.293 1.199-.334 1.363-.053.225-.172.271-.399.165-1.495-.69-2.433-2.878-2.433-4.646 0-3.776 2.748-7.252 7.951-7.252 4.173 0 7.41 2.967 7.41 6.923 0 4.135-2.607 7.462-6.233 7.462-1.214 0-2.354-.629-2.758-1.379l-.749 2.848c-.269 1.045-1.004 2.352-1.498 3.146 1.123.345 2.306.535 3.55.535 6.607 0 11.985-5.365 11.985-11.987C23.97 5.367 18.62 0 12.017 0z" />
                            </svg>
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Stats Grid -->
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-4 mb-4">
            
            <!-- Following -->
            <div class="analytics-card p-3">
                <h3 class="text-accent font-bold italic mb-2 uppercase tracking-wide text-sm border-b border-inner pb-1">FOLLOWING</h3>
                <div class="space-y-1" id="followingStats"></div>
            </div>

            <!-- Engagement & Watch -->
            <div class="flex flex-col gap-4">
                <div class="analytics-card p-3">
                    <h3 class="text-accent font-bold italic mb-2 uppercase tracking-wide text-sm border-b border-inner pb-1">Engagement</h3>
                    <div class="space-y-1" id="engagementStats"></div>
                </div>
                <div class="analytics-card p-3">
                    <h3 class="text-accent font-bold italic mb-2 uppercase tracking-wide text-sm border-b border-inner pb-1">Watch Time</h3>
                    <div class="space-y-1" id="watchTimeStats"></div>
                </div>
            </div>

            <!-- Multi-Tab Section -->
            <div class="analytics-card p-0 flex flex-col h-full overflow-hidden relative min-h-[300px]">
                <!-- Tabs Header -->
                <div class="absolute top-0 left-0 right-0 z-20 flex flex-wrap gap-2 text-[10px] uppercase font-bold text-gray-400 mb-4 border-b pb-2 bg-black/80 backdrop-blur-sm rounded-t px-3 pt-3" style="border-color: var(--border-inner);">
                    <button onclick="switchTab('network')" class="tab-btn hover:text-white transition-colors" id="tab-network">Creator Network Node</button>
                    <button onclick="switchTab('keywords')" class="tab-btn hover:text-white transition-colors" id="tab-keywords">Advertising Keywords</button>
                    <button onclick="switchTab('region')" class="tab-btn text-accent" id="tab-region">Interest By Region</button>
                    <button class="hover:text-white cursor-not-allowed opacity-50">Audience by Age</button>
                    <button class="hover:text-white cursor-not-allowed opacity-50">Recent Content</button>
                </div>

                <!-- Tab Content -->
                <div class="flex-grow relative mt-10">
                    <!-- 1. Region Map -->
                    <div id="view-region" class="w-full h-full absolute inset-0 transition-opacity duration-300">
                        <div class="absolute inset-0 flex items-center justify-center">
                            <svg viewBox="0 0 1010 500" class="w-full h-full" style="background-color: transparent;">
                                <g id="worldMapGroup" fill="currentColor" stroke="none" class="text-gray-600 dark:text-gray-800" style="opacity: 0.4;">
                                    <path d="M50,30 L350,30 L300,150 L200,200 L100,250 L50,150 Z" />
                                    <path d="M220,250 L320,250 L300,480 L200,400 Z" />
                                    <path d="M400,30 L950,30 L900,250 L750,300 L600,200 L450,150 Z" />
                                    <path d="M450,200 L600,200 L550,420 L450,350 Z" />
                                    <path d="M780,350 L920,350 L900,450 L750,450 Z" />
                                </g>
                                <g id="mapHighlights"></g>
                            </svg>
                        </div>
                        <div class="relative z-10 mt-auto bg-black/40 p-2 rounded backdrop-blur-sm border border-white/10 pointer-events-none transition-all duration-300 w-fit absolute bottom-2 left-2">
                            <h4 id="regionTitle" class="font-bold text-xs italic mb-2 text-accent">Interest by Region</h4>
                            <div class="text-xs space-y-1" id="regionList"></div>
                        </div>
                    </div>

                    <!-- 2. Creator Network -->
                    <div id="view-network" class="w-full h-full absolute inset-0 opacity-0 pointer-events-none transition-opacity duration-300">
                        <div id="mynetwork" class="w-full h-full" style="background-color: var(--card-bg);"></div>
                        <div class="absolute bottom-2 right-2 bg-black/80 p-2 rounded border border-[#98fb98]/30 text-[9px] text-gray-300 pointer-events-none">
                            <div class="flex items-center gap-1 mb-1"><div class="w-2 h-2 bg-white"></div> Hub</div>
                            <div class="flex items-center gap-1 mb-1"><div class="w-2 h-2 bg-blue-400 rounded-full"></div> Featured</div>
                            <div class="flex items-center gap-1 mb-1"><div class="w-2 h-2 bg-teal-500 rounded-full"></div> Core Team</div>
                            <div class="flex items-center gap-1 mb-1"><div class="w-2 h-2 bg-orange-500 rounded-full"></div> Partners</div>
                            <div class="flex items-center gap-1"><div class="w-2 h-2 bg-purple-500 rounded-full"></div> Podcast</div>
                        </div>
                    </div>

                    <!-- 3. Advertising Keywords -->
                    <div id="view-keywords" class="w-full h-full absolute inset-0 opacity-0 pointer-events-none transition-opacity duration-300 p-4 overflow-y-auto">
                        <div class="grid grid-cols-1 gap-2" id="keywordList"></div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Bottom Section -->
        <div class="grid grid-cols-1 xl:grid-cols-3 gap-4">
            
            <!-- Sponsorships -->
            <!-- Added id="sponsorshipsCard" and onclick event -->
            <div id="sponsorshipsCard" class="analytics-card xl:col-span-1 p-3 cursor-pointer hover:border-green-400/50 transition-colors" onclick="openSponsorshipsModal()">
                <div class="flex justify-between items-center mb-2 border-b border-inner pb-1">
                    <h3 class="text-accent font-bold italic uppercase tracking-wide text-sm">SPONSORSHIPS</h3>
                    <i data-lucide="maximize-2" class="w-3 h-3 text-gray-500"></i>
                </div>
                <div class="overflow-x-auto pointer-events-none"> <!-- pointer-events-none prevents table interactions from blocking card click -->
                    <table class="w-full text-left text-xs">
                        <thead>
                            <tr class="text-gray-400 border-b border-gray-800">
                                <th class="pb-2"></th>
                                <!-- Removed onmouseenter/onmouseleave, kept onclick. Added pointer-events-auto to allow click through parent container -->
                                <th class="pb-2 text-center cursor-help hover:text-white transition-colors pointer-events-auto" onclick="event.stopPropagation(); toggleTooltip(event, 'VIDS')">VIDS</th>
                                <th class="pb-2 text-center cursor-help hover:text-white transition-colors pointer-events-auto" onclick="event.stopPropagation(); toggleTooltip(event, 'SPON')">SPON</th>
                                <th class="pb-2 text-center cursor-help hover:text-white transition-colors pointer-events-auto" onclick="event.stopPropagation(); toggleTooltip(event, 'MINS')">MINS</th>
                                <th class="pb-2 text-center cursor-help hover:text-white transition-colors pointer-events-auto" onclick="event.stopPropagation(); toggleTooltip(event, 'RET+')">RET+</th>
                                <th class="pb-2 text-center cursor-help hover:text-white transition-colors pointer-events-auto" onclick="event.stopPropagation(); toggleTooltip(event, 'ALIGN')">ALIGN</th>
                                <th class="pb-2 text-center cursor-help hover:text-white transition-colors pointer-events-auto" onclick="event.stopPropagation(); toggleTooltip(event, 'wexRAR+')">wexRAR+</th>
                                <th class="pb-2 text-center cursor-help hover:text-white transition-colors pointer-events-auto" onclick="event.stopPropagation(); toggleTooltip(event, 'exCTAR')">exCTAR</th>
                                <th class="pb-2 text-center cursor-help hover:text-white transition-colors pointer-events-auto" onclick="event.stopPropagation(); toggleTooltip(event, 'wexPSAR')">wexPSAR</th>
                            </tr>
                        </thead>
                        <tbody class="text-gray-400" id="sponsorshipTable"></tbody>
                    </table>
                </div>
            </div>

            <!-- Alignment Score -->
            <div class="analytics-card xl:col-span-1 p-3">
                <h3 class="text-accent font-bold italic mb-2 uppercase tracking-wide text-sm border-b border-inner pb-1">ALIGNMENT SCORE</h3>
                <div class="grid grid-cols-2 gap-4 text-xs">
                    <div>
                        <h4 class="text-accent font-bold mb-1">Most Common Words Used</h4>
                        <p class="text-card-base italic mb-4 leading-relaxed">change, young, volunteer, initiative, community</p>
                        
                        <h4 class="text-accent font-bold mb-1">Subjects</h4>
                        <ul class="text-card-base space-y-2 list-decimal list-inside pl-1 text-[10px]">
                            <li>Assessing the Negative Consequences of Project Rudy for Maryland</li>
                            <li>From Bush to Trump: Evolution of Microtargeting</li>
                            <li>Cultivating Controversy: Mexico-US GMO Corn Conflict</li>
                            <li>Young Progressives Initiative: Countering Right-Wing Extremism</li>
                            <li>Forms of Expression and Racialization in the United States</li>
                            <li>Kids and Parents in the Hyper Digital Age</li>
                        </ul>
                    </div>
                    <div>
                        <h4 class="text-accent font-bold mb-1">YPI</h4>
                        <p class="text-card-base italic mb-4 leading-relaxed">change, young, volunteer, initiative, community</p>

                        <h4 class="text-accent font-bold mb-1">Sentiment Analysis</h4>
                        <p class="text-gray-400 leading-snug">
                            Cole Holland's carries high cultural reach among younger audiences.
                        </p>
                    </div>
                </div>
            </div>

            <!-- Audience Chart -->
            <div class="analytics-card xl:col-span-1 p-3 flex flex-col">
                <h3 class="text-accent font-bold italic mb-2 uppercase tracking-wide text-sm border-b border-inner pb-1">Audience by age and gender</h3>
                <div class="h-48 w-full mt-2 relative">
                    <canvas id="audienceChart"></canvas>
                </div>
            </div>
        </div>
    </div>

    <!-- Google Trends Modal -->
    <div id="googleModal" class="modal-enter fixed inset-0 z-[60] flex items-center justify-center p-4 md:p-10 modal-transition">
        <!-- Backdrop -->
        <div class="absolute inset-0 bg-black/80 backdrop-blur-sm" onclick="closeGoogleModal()"></div>
        
        <!-- Modal Content -->
        <div class="relative w-full h-full max-w-7xl border rounded-xl flex flex-col overflow-hidden shadow-2xl z-[70] transition-colors duration-300" style="background-color: var(--card-bg); border-color: var(--border-inner);">
            <!-- Modal Header -->
            <div class="flex items-center justify-between p-4 border-b" style="border-color: var(--border-inner);">
                <div class="flex items-center gap-4">
                    <button onclick="closeGoogleModal()" class="w-8 h-8 flex items-center justify-center rounded transition-colors" style="background-color: var(--btn-bg); color: var(--text-secondary);">
                        <i data-lucide="chevron-left" class="w-5 h-5"></i>
                    </button>
                    <div class="flex flex-col">
                        <div class="flex items-center gap-2">
                             <img src="https://upload.wikimedia.org/wikipedia/commons/5/53/Google_%22G%22_Logo.svg" alt="G" class="w-6 h-6">
                             <h2 class="text-2xl font-bold tracking-tight" style="color: var(--text-primary)">Interest Over Time</h2>
