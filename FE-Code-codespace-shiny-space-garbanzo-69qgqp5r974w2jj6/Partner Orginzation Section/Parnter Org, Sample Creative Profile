        const globalTooltip = document.getElementById('globalTooltip');
        const tooltipTitle = document.getElementById('tooltipTitle');
        const tooltipDesc = document.getElementById('tooltipDesc');
        const tooltipBtn = document.getElementById('tooltipBtn');
        
        let lockedTooltipKey = null; // Track if a tooltip is locked by click

        function toggleTooltip(e, key) {
            e.stopPropagation(); // Prevent the body click from firing
            
            // If clicking the currently locked item, unlock and hide
            if (lockedTooltipKey === key) {
                lockedTooltipKey = null;
                hideTooltip(true); // force hide
            } else {
                // Lock the new one
                lockedTooltipKey = key;
                showTooltip(e, key);
            }
        }

        function showTooltip(e, key) {
            // If another tooltip is locked and we are just hovering (not clicking), ignore
            if (lockedTooltipKey && lockedTooltipKey !== key) {
                return;
            }

            const def = statDefinitions[key] || { short: "No definition available.", long: "" };
            tooltipTitle.textContent = key;
            tooltipDesc.textContent = def.short;
            
            if (def.long && def.long !== def.short) {
                tooltipBtn.style.display = 'flex';
                tooltipBtn.onclick = (evt) => {
                    evt.stopPropagation(); 
                    openDefinitionModal(key);
                };
            } else {
                tooltipBtn.style.display = 'none';
            }
            
            globalTooltip.classList.remove('hidden-tooltip');
            moveTooltip(e);
        }

        function hideTooltip(force = false) {
            // If tooltip is locked, do not hide on mouseleave unless forced
            if (lockedTooltipKey && !force) return;
            
            globalTooltip.classList.add('hidden-tooltip');
        }

        function moveTooltip(e) {
            // Position tooltip near cursor but prevent overflow
            // We use clientX/Y for viewport boundary checks
            const x = e.clientX + 15;
            const y = e.clientY + 15;
            
            const rect = globalTooltip.getBoundingClientRect();
            const winWidth = window.innerWidth;
            const winHeight = window.innerHeight;

            let finalX = x;
            let finalY = y;

            // Check viewport overflow (shift left/up if needed)
            if (x + rect.width > winWidth) finalX = e.clientX - rect.width - 10;
            if (y + rect.height > winHeight) finalY = e.clientY - rect.height - 10;

            // Apply scroll offset because position is absolute
            globalTooltip.style.left = `${finalX + window.scrollX}px`;
            globalTooltip.style.top = `${finalY + window.scrollY}px`;
        }

        // Close locked tooltip when clicking anywhere else
        document.addEventListener('click', (e) => {
            // If clicking inside the tooltip itself, don't close
            if (globalTooltip.contains(e.target)) return;

            if (lockedTooltipKey) {
                lockedTooltipKey = null;
                hideTooltip(true);
            }
        });
        
        // Global mouse tracker to ensure tooltip appears at correct location
        document.addEventListener('mousemove', (e) => {
            // If tooltip is locked, DO NOT update position on mousemove
            if (lockedTooltipKey) return;

            if (!globalTooltip.classList.contains('hidden-tooltip')) {
                moveTooltip(e);
            }
        });

        // --- Definition Modal Logic ---
        const definitionModal = document.getElementById('definitionModal');
        const defModalTitle = document.getElementById('defModalTitle');
        const defModalContent = document.getElementById('defModalContent');

        definitionModal.classList.add('hidden');
        definitionModal.classList.remove('modal-enter');

        function openDefinitionModal(key) {
            // Hide tooltip first
            hideTooltip(true);

            const def = statDefinitions[key];
            if (!def) return;

            defModalTitle.textContent = key;
            defModalContent.textContent = def.long || def.short;

            definitionModal.classList.remove('hidden');
            setTimeout(() => {
                definitionModal.classList.add('modal-active');
            }, 10);
        }

        function closeDefinitionModal() {
            definitionModal.classList.remove('modal-active');
            setTimeout(() => {
                definitionModal.classList.add('hidden');
            }, 200);
        }


