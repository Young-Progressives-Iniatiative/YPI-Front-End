        // --- CHART GENERATION (Updated for CSS Vars) ---
        function generateLineChartSVG(data, height = 100) {
            const max = Math.max(...data) * 1.05; const min = Math.min(...data) * 0.95; const range = max - min; const width = 100;
            let pathD = ''; const stepX = width / (data.length - 1);
            data.forEach((val, i) => { const x = i * stepX; const normalizedY = ((max - val) / range) * height; pathD += (i===0 ? `M${x},${normalizedY} ` : `L${x},${normalizedY} `); });
            const isPositive = data[data.length - 1] >= data[0];
            const strokeVar = isPositive ? 'var(--chart-pos)' : 'var(--chart-neg)';
            return `<div class="w-full" style="height: ${height}px"><svg viewBox="0 0 ${width} ${height}" preserveAspectRatio="none" class="w-full h-full"><path d="${pathD}" fill="none" stroke="${strokeVar}" stroke-width="2" vector-effect="non-scaling-stroke" stroke-linecap="round" stroke-linejoin="round" /></svg></div>`;
        }
        
        function generateMiniSparklineSVG(data) {
             const height = 60; const width = 300; 
             const max = Math.max(...data) * 1.1; const min = Math.min(...data) * 0.9; const range = max - min;
             let pathD = ''; const stepX = width / (data.length - 1);
             data.forEach((val, i) => { const x = i * stepX; const normalizedY = ((max - val) / range) * height; pathD += (i===0 ? `M${x},${normalizedY} ` : `L${x},${normalizedY} `); });
             const isPositive = data[data.length - 1] >= data[0];
             const strokeVar = isPositive ? 'var(--chart-pos)' : 'var(--chart-neg)';
             const fillVar = isPositive ? 'rgba(119, 219, 137, 0.1)' : 'rgba(239, 68, 68, 0.1)';
             const areaPathD = `${pathD} L${width},${height} L0,${height} Z`;
             return `<svg viewBox="0 0 ${width} ${height}" preserveAspectRatio="none" class="w-full h-full"><path d="${areaPathD}" fill="${fillVar}" stroke="none" /><path d="${pathD}" fill="none" stroke="${strokeVar}" stroke-width="2" vector-effect="non-scaling-stroke" stroke-linecap="round" stroke-linejoin="round" /></svg>`;
        }

        function generateBarChartSVG(height = 200) {
           const width = 800; const barCount = 12; const gap = 10; const groupGap = 30; const totalGroupWidth = (width - (barCount - 1) * groupGap) / barCount; const barWidth = totalGroupWidth / 2 - gap/2;
           let svgContent = '';
           for(let i=0; i<barCount; i++) {
               const h1 = Math.random() * 0.8 * height + 0.1 * height; const h2 = Math.random() * 0.8 * height + 0.1 * height; 
               const x1 = i * (barWidth * 2 + gap + groupGap); const x2 = x1 + barWidth + gap; const y1 = height - h1; const y2 = height - h2;
               svgContent += `<rect x="${x1}" y="${y1}" width="${barWidth}" height="${h1}" fill="var(--chart-pos)" rx="2" /><rect x="${x2}" y="${y2}" width="${barWidth}" height="${h2}" fill="#4b5563" rx="2" />`;
           }
           return `<svg viewBox="0 0 ${width * 1.5} ${height}" preserveAspectRatio="none" class="w-full h-full"><line x1="0" y1="0" x2="${width * 1.5}" y2="0" stroke="var(--chart-grid)" stroke-width="1" stroke-dasharray="4" /><line x1="0" y1="${height/2}" x2="${width * 1.5}" y2="${height/2}" stroke="var(--chart-grid)" stroke-width="1" stroke-dasharray="4" /><line x1="0" y1="${height}" x2="${width * 1.5}" y2="${height}" stroke="var(--chart-grid)" stroke-width="1" />${svgContent}</svg>`;
