<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Football Manager Financial Dashboard</title>
    
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    
    <!-- Google Fonts: Atkinson Hyperlegible -->
    <link href="https://fonts.googleapis.com/css2?family=Atkinson+Hyperlegible:ital,wght@0,400;0,700;1,400;1,700&display=swap" rel="stylesheet">
    
    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>

    <style>
        :root {
            /* --- DARK MODE (Default) --- */
            --bg-body: #1c1c1c;
            --bg-header: #1b1b1b;
            --bg-card: #2b2b2b;
            --bg-chart: #1c1c1c;
            --bg-hover: #323232;
            
            --border-header: #2a2a2a;
            --border-card: rgba(113, 113, 122, 0.3); /* zinc-500/30 */
            
            --text-main: #ffffff;
            --text-secondary: #9ca3af; /* gray-400 */
            --text-accent: #77db89; /* Compliance Green (Light) */
            
            --chart-pos: #77db89;
            --chart-neg: #ef4444;
            --chart-grid: #374151;
            
            /* Navigation */
            --nav-active: #98fb98;
            --nav-glow: rgba(152, 251, 152, 0.25);
            --nav-inactive: #9ca3af;
            --nav-hover: #ffffff;
            
            /* Buttons */
            --btn-bg: #2a2d35;
            --btn-border: rgba(59, 130, 246, 0.5);
            --btn-icon: #d1d5db;
            
            /* Modals */
            --modal-overlay: rgba(0, 0, 0, 0.8);
            --modal-bg: #242424;
            --modal-header-bg: #1e1e1e;
            --modal-border: #4b5563;

            /* Compliance Box (Dark) */
            --comp-bg: rgba(21, 128, 61, 0.9); /* green-700/90 */
            --comp-border: #4ade80; /* green-400 */
            --comp-text: #dcfce7; /* green-100 */
            
            /* Logo */
            --logo-filter: brightness(0) invert(1);
            --logo-opacity: 1;
        }

        [data-theme="light"] {
            /* --- LIGHT MODE --- */
            --bg-body: #f3f4f6;
            --bg-header: #ffffff;
            --bg-card: #ffffff;
            --bg-chart: #f9fafb;
            --bg-hover: #f0fdf4; /* Light green tint hover */
            
            --border-header: #e5e7eb;
            --border-card: #e5e7eb;
            
            --text-main: #1c1c1c; /* Requested Secondary Color as Main Text */
            --text-secondary: #4b5563;
            --text-accent: #15803d; /* Darker Green for Contrast */
            
            --chart-pos: #15803d;
            --chart-neg: #dc2626;
            --chart-grid: #e5e7eb;
            
            /* Navigation */
            --nav-active: #15803d;
            --nav-glow: rgba(21, 128, 61, 0.1);
            --nav-inactive: #6b7280;
            --nav-hover: #111827;
            
            /* Buttons */
            --btn-bg: #ffffff;
            --btn-border: #e5e7eb;
            --btn-icon: #374151;
            
            /* Modals */
            --modal-overlay: rgba(255, 255, 255, 0.8);
            --modal-bg: #ffffff;
            --modal-header-bg: #f3f4f6;
            --modal-border: #e5e7eb;

            /* Compliance Box (Light) */
            --comp-bg: #dcfce7; /* green-100 */
            --comp-border: #16a34a; /* green-600 */
            --comp-text: #14532d; /* green-900 */
            
            /* Logo */
            --logo-filter: none;
            --logo-opacity: 0.9;
        }

        body {
            font-family: 'Atkinson Hyperlegible', sans-serif;
            background-color: var(--bg-body);
            color: var(--text-main);
            transition: background-color 0.3s ease, color 0.3s ease;
        }
        
        /* Apply variables to common utilities via classes if needed, 
           or use arbitrary values in HTML */
        
        .card-base {
            background-color: var(--bg-card);
            border-color: var(--border-card);
        }
        
        .text-accent {
            color: var(--text-accent);
        }

        /* Custom scrollbar */
        ::-webkit-scrollbar {
            width: 8px;
            height: 4px;
        }
        ::-webkit-scrollbar-track {
            background: var(--bg-body); 
        }
        ::-webkit-scrollbar-thumb {
            background: #374151; 
            border-radius: 4px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: #4b5563; 
        }

        .font-fm-header { font-family: 'Atkinson Hyperlegible', sans-serif; }
        .logo-img {
            filter: var(--logo-filter);
            opacity: var(--logo-opacity);
            transition: filter 0.3s ease, opacity 0.3s ease;
        }
        ::selection { background: var(--nav-active); color: var(--bg-body); }
        .modal-enter { opacity: 0; transform: scale(0.95); }
        .modal-enter-active { opacity: 1; transform: scale(1); transition: opacity 300ms, transform 300ms; }
        .modal-exit { opacity: 1; transform: scale(1); }
        .modal-exit-active { opacity: 0; transform: scale(0.95); transition: opacity 200ms, transform 200ms; }
        .group[aria-expanded="true"] .chevron-icon { transform: rotate(180deg); }
    </style>
</head>
<body class="min-h-screen relative">

    <!-- HEADER -->
    <header class="flex flex-col w-full bg-[var(--bg-header)] border-b border-[var(--border-header)] shadow-lg transition-colors duration-300">
        <div class="flex items-center h-16 px-6 gap-6 overflow-x-auto no-scrollbar">
            
            <!-- Navigation Controls -->
            <div class="flex items-center mr-2 flex-shrink-0">
                <button class="flex items-center justify-center w-8 h-10 bg-[var(--btn-bg)] border border-[var(--btn-border)] rounded-l hover:bg-[var(--bg-hover)] transition-colors group relative">
                    <div class="absolute inset-0 border border-blue-400/30 rounded-l opacity-50"></div>
                    <i data-lucide="chevron-left" class="w-5 h-5 text-[var(--btn-icon)] group-hover:text-[var(--text-main)]"></i>
                </button>
                <button class="flex items-center justify-center w-8 h-10 bg-[var(--bg-header)] hover:bg-[var(--border-header)] transition-colors rounded-r border-y border-r border-[var(--border-header)]">
                    <i data-lucide="chevron-right" class="w-5 h-5 text-[var(--text-secondary)]"></i>
                </button>
            </div>

            <!-- Logo -->
            <div class="flex-shrink-0 mr-4">
                <div class="h-12 w-auto flex items-center justify-center">
                    <img src="https://weareypi.com/wp-content/uploads/2025/06/Site-Icon-3.png" alt="Team Logo" class="h-full w-auto object-contain drop-shadow-md logo-img" onerror="this.src='https://via.placeholder.com/150x50?text=LOGO';this.onerror=null;" />
                </div>
            </div>

            <!-- Navigation Menu -->
            <nav class="flex items-center gap-2" id="main-nav">
                <!-- Nav items generated by JS -->
            </nav>

            <!-- Theme Switcher -->
            <div class="ml-auto flex items-center pl-4 border-l border-[var(--border-header)]">
                <button id="theme-toggle" class="p-2 rounded-full hover:bg-[var(--bg-hover)] text-[var(--text-main)] transition-all active:scale-95" aria-label="Toggle Theme">
                    <span class="icon-sun"><i data-lucide="sun" class="w-5 h-5"></i></span>
                    <span class="icon-moon hidden"><i data-lucide="moon" class="w-5 h-5"></i></span>
                </button>
            </div>
        </div>
    </header>

    <!-- MAIN CONTENT -->
    <div class="p-2 md:p-6 transition-colors duration-300">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-6">
          
            <!-- LEFT COLUMN - FINANCIALS (Span 8) -->
            <div class="lg:col-span-8 flex flex-col gap-6">
            
                <!-- Overall Balance -->
                <div onclick="openDashboardModal('balance')" class="card-base border shadow-lg rounded-sm p-4 relative overflow-hidden cursor-pointer hover:border-[var(--text-accent)] hover:bg-[var(--bg-hover)] transition-all group">
                    <div class="flex justify-between items-start mb-3">
                        <h3 class="text-accent font-bold text-xs uppercase tracking-wider group-hover:text-[var(--text-main)] transition-colors">Overall Balance</h3>
                        <div><button onclick="openBalanceReport(event)" class="text-[10px] border border-[var(--text-secondary)] px-2 py-0.5 text-[var(--text-secondary)] group-hover:text-[var(--text-main)] group-hover:border-[var(--text-main)] transition-colors z-10 relative">View Balance Sheet</button></div>
                    </div>
                    <div class="mb-4">
                        <h2 class="text-3xl font-bold text-[var(--text-main)]">$1,258,889</h2>
                    </div>
                    <div class="relative h-48 w-full bg-[var(--bg-chart)] rounded p-2" id="chart-balance"></div>
                    <div class="w-full flex justify-between text-[9px] text-[var(--text-secondary)] px-2 mt-2">
                        <span>Q1 2023</span><span>Q2 2024</span><span>Q3 2025</span><span>Q4 2026</span><span>Q1 2027</span>
                    </div>
                </div>

                <!-- Profit/Loss -->
                <div onclick="openDashboardModal('surplus')" class="card-base border shadow-lg rounded-sm p-4 relative overflow-hidden cursor-pointer hover:border-[var(--text-accent)] hover:bg-[var(--bg-hover)] transition-all group">
                    <div class="flex justify-between items-start mb-3">
                        <h3 class="text-accent font-bold text-xs uppercase tracking-wider group-hover:text-[var(--text-main)] transition-colors">Net Surplus / (Deficit) This Month</h3>
                    </div>
                    <div class="flex justify-between items-end mb-4">
                        <div>
                            <h2 class="text-2xl font-bold text-[var(--text-accent)]">$9,624</h2>
                        </div>
                        <div class="text-right flex gap-6 text-[var(--text-main)]">
                            <div>
                                <div class="text-[10px] text-[var(--text-secondary)] uppercase">YTD Surplus</div>
                                <div class="text-sm font-bold">$73,573</div>
                            </div>
                            <div>
                                <div class="text-[10px] text-[var(--text-secondary)] uppercase">Last Year Total</div>
                                <div class="text-sm font-bold">$143,170</div>
                            </div>
                        </div>
                    </div>
                    <div class="relative h-40 w-full bg-[var(--bg-chart)] rounded p-2 mt-2 group-hover:bg-opacity-80" id="chart-profit"></div>
                    <div class="w-full flex justify-between text-[9px] text-[var(--text-secondary)] px-2 mt-2">
                        <span>Jul</span><span>Aug</span><span>Sep</span><span>Oct</span><span>Nov</span><span>Dec</span><span>Jan</span>
                    </div>
                </div>

                <!-- Income & Expenditure Grid -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
              
                    <!-- Revenue -->
                    <div onclick="openDashboardModal('revenue')" class="card-base border shadow-lg rounded-sm p-4 cursor-pointer hover:border-[var(--text-accent)] hover:bg-[var(--bg-hover)] transition-all group">
                        <div class="flex justify-between items-start mb-3">
                            <h3 class="text-accent font-bold text-xs uppercase tracking-wider group-hover:text-[var(--text-main)] transition-colors">Revenue This Month</h3>
                            <button onclick="openRevenueReport(event)" class="text-[10px] border border-[var(--text-secondary)] px-2 py-0.5 text-[var(--text-secondary)] hover:text-[var(--text-main)] hover:border-[var(--text-main)] hover:bg-[var(--btn-bg)] transition-colors z-10 relative">Report</button>
                        </div>
                        <h2 class="text-xl font-bold text-[var(--text-main)] mb-2">$156,332</h2>
                        <div class="h-20 mb-2 bg-[var(--bg-chart)] rounded p-1 group-hover:bg-opacity-80" id="chart-income"></div>
                        <div class="space-y-1 pt-2 border-t border-[var(--border-card)]">
                            <div class="flex justify-between items-center text-xs py-1 border-b border-[var(--border-card)] last:border-0"><span class="text-[var(--text-secondary)]">Giving</span><span class="text-[var(--text-main)] font-mono">$29k</span></div>
                            <div class="flex justify-between items-center text-xs py-1 border-b border-[var(--border-card)] last:border-0"><span class="text-[var(--text-secondary)]">Grants</span><span class="text-[var(--text-main)] font-mono">$80k</span></div>
                            <div class="flex justify-between items-center text-xs py-1 border-b border-[var(--border-card)] last:border-0"><span class="text-[var(--text-secondary)]">Contracts</span><span class="text-[var(--text-main)] font-mono">$22k</span></div>
                        </div>
                    </div>

                    <!-- Expenses -->
                    <div onclick="openDashboardModal('expenses')" class="card-base border shadow-lg rounded-sm p-4 cursor-pointer hover:border-[var(--text-accent)] hover:bg-[var(--bg-hover)] transition-all group">
                        <div class="flex justify-between items-start mb-3">
                            <h3 class="text-accent font-bold text-xs uppercase tracking-wider group-hover:text-[var(--text-main)] transition-colors">Expenses This Month</h3>
                            <button class="text-[10px] border border-[var(--text-secondary)] px-2 py-0.5 text-[var(--text-secondary)] group-hover:text-[var(--text-main)] group-hover:border-[var(--text-main)] transition-colors">Report</button>
                        </div>
                        <h2 class="text-xl font-bold text-[var(--text-main)] mb-2">$252,573</h2>
                        <div class="h-20 mb-2 bg-[var(--bg-chart)] rounded p-1 group-hover:bg-opacity-80" id="chart-expenses"></div>
                        <div class="space-y-1 pt-2 border-t border-[var(--border-card)]">
                            <div class="flex justify-between items-center text-xs py-1 border-b border-[var(--border-card)] last:border-0"><span class="text-[var(--text-secondary)]">Salaries</span><span class="text-[var(--text-main)] font-mono">$112k</span></div>
                            <div class="flex justify-between items-center text-xs py-1 border-b border-[var(--border-card)] last:border-0"><span class="text-[var(--text-secondary)]">Aid</span><span class="text-[var(--text-main)] font-mono">$19k</span></div>
                            <div class="flex justify-between items-center text-xs py-1 border-b border-[var(--border-card)] last:border-0"><span class="text-[var(--text-secondary)]">Admin</span><span class="text-[var(--text-main)] font-mono">$32k</span></div>
                        </div>
                    </div>

                    <!-- Assets -->
                    <div class="card-base border shadow-lg rounded-sm p-4">
                        <div class="flex justify-between items-start mb-3">
                            <h3 class="text-accent font-bold text-xs uppercase tracking-wider">Total Assets</h3>
                            <button class="text-[10px] border border-[var(--text-secondary)] px-2 py-0.5 text-[var(--text-secondary)] hover:text-[var(--text-main)] hover:border-[var(--text-main)] transition-colors">Assets</button>
                        </div>
                        <h2 class="text-xl font-bold text-[var(--text-main)] mb-2">$1,708,989</h2>
                        <div class="h-20 mb-2 bg-[var(--bg-chart)] rounded p-1" id="chart-assets"></div>
                        <div class="space-y-1 pt-2 border-t border-[var(--border-card)]">
                            <div class="flex justify-between items-center text-xs py-1 border-b border-[var(--border-card)] last:border-0"><span class="text-[var(--text-secondary)]">Cash</span><span class="text-[var(--text-main)] font-mono">$850k</span></div>
                            <div class="flex justify-between items-center text-xs py-1 border-b border-[var(--border-card)] last:border-0"><span class="text-[var(--text-secondary)]">Receivables</span><span class="text-[var(--text-main)] font-mono">$420k</span></div>
                            <div class="flex justify-between items-center text-xs py-1 border-b border-[var(--border-card)] last:border-0"><span class="text-[var(--text-secondary)]">Equipment</span><span class="text-[var(--text-main)] font-mono">$438k</span></div>
                        </div>
                    </div>

                    <!-- Liabilities -->
                    <div class="card-base border shadow-lg rounded-sm p-4">
                        <div class="flex justify-between items-start mb-3">
                            <h3 class="text-accent font-bold text-xs uppercase tracking-wider">Total Liabilities</h3>
                            <button class="text-[10px] border border-[var(--text-secondary)] px-2 py-0.5 text-[var(--text-secondary)] hover:text-[var(--text-main)] hover:border-[var(--text-main)] transition-colors">Debts</button>
                        </div>
                        <h2 class="text-xl font-bold text-[var(--text-main)] mb-2">$450,100</h2>
                        <div class="h-20 mb-2 bg-[var(--bg-chart)] rounded p-1" id="chart-liabilities"></div>
                        <div class="space-y-1 pt-2 border-t border-[var(--border-card)]">
                            <div class="flex justify-between items-center text-xs py-1 border-b border-[var(--border-card)] last:border-0"><span class="text-[var(--text-secondary)]">Bank Loans</span><span class="text-[var(--text-main)] font-mono">$200k</span></div>
                            <div class="flex justify-between items-center text-xs py-1 border-b border-[var(--border-card)] last:border-0"><span class="text-[var(--text-secondary)]">Payables</span><span class="text-[var(--text-main)] font-mono">$150k</span></div>
                            <div class="flex justify-between items-center text-xs py-1 border-b border-[var(--border-card)] last:border-0"><span class="text-[var(--text-secondary)]">Deferred</span><span class="text-[var(--text-main)] font-mono">$100k</span></div>
                        </div>
                    </div>

                </div>
            </div>

            <!-- RIGHT COLUMN - REPORTS (Span 4) -->
            <div class="lg:col-span-4 flex flex-col gap-6">
              
                <!-- Grant Pipeline -->
                <div class="card-base border shadow-lg rounded-sm p-4 flex-1">
                    <div class="flex justify-between items-start mb-3">
                        <h3 class="text-accent font-bold text-xs uppercase tracking-wider">Grant Opportunity Pipeline</h3>
                    </div>
                    <div class="space-y-1">
                        <!-- Report Items -->
                        <div class="flex items-start gap-3 py-3 border-b border-[var(--border-card)] last:border-0">
                            <div class="flex-1">
                                <h4 class="text-accent font-bold text-sm">City Community Fund</h4>
                                <p class="text-[var(--text-secondary)] text-xs mt-1">Application submitted for housing support. Decision pending.</p>
                            </div>
                            <div class="flex items-center justify-center h-8 px-3 rounded border border-green-500 text-green-500 font-bold text-xs bg-[var(--bg-chart)] whitespace-nowrap">$150k</div>
                        </div>
                        <div class="flex items-start gap-3 py-3 border-b border-[var(--border-card)] last:border-0">
                            <div class="flex-1">
                                <h4 class="text-accent font-bold text-sm">National Arts Endowment</h4>
                                <p class="text-[var(--text-secondary)] text-xs mt-1">Drafting narrative. Seeking funding for youth programs.</p>
                            </div>
                            <div class="flex items-center justify-center h-8 px-3 rounded border border-green-500 text-green-500 font-bold text-xs bg-[var(--bg-chart)] whitespace-nowrap">$50k</div>
                        </div>
                        <div class="flex items-start gap-3 py-3 border-b border-[var(--border-card)] last:border-0">
                            <div class="flex-1">
                                <h4 class="text-accent font-bold text-sm">Global Health Initiative</h4>
                                <p class="text-[var(--text-secondary)] text-xs mt-1">LOI stage. High competition expected.</p>
                            </div>
                            <div class="flex items-center justify-center h-8 px-3 rounded border border-green-500 text-green-500 font-bold text-xs bg-[var(--bg-chart)] whitespace-nowrap">$500k</div>
                        </div>
                    </div>
                </div>

                <!-- Non-Profit Designation Suite -->
                <div class="card-base border shadow-lg rounded-sm p-4">
                    <div class="flex justify-between items-start mb-3">
                        <h3 class="text-accent font-bold text-xs uppercase tracking-wider">Non-Profit Designation Requirements</h3>
                    </div>

                    <!-- Type Selector -->
                    <div class="flex items-center justify-between mb-4 bg-[var(--bg-chart)] p-2 rounded border border-[var(--border-card)] relative">
                        <span class="text-xs text-[var(--text-secondary)] uppercase font-bold tracking-wider">Designation:</span>
                        <div class="relative group">
                            <button id="dropdown-trigger" class="flex items-center gap-2 text-xs font-bold text-[var(--text-main)] hover:text-[var(--text-accent)] transition-colors focus:outline-none">
                                <span id="current-designation">501(c)(3) Charitable</span>
                                <i data-lucide="chevron-down" class="w-3 h-3"></i>
                            </button>
                        
                            <!-- Dropdown Menu -->
                            <div id="dropdown-menu" class="absolute right-0 top-full mt-2 w-48 bg-[var(--bg-card)] border border-[var(--border-card)] shadow-xl rounded z-10 hidden">
                                <button onclick="setOrgType('c3')" class="w-full text-left px-3 py-2 text-xs hover:bg-[var(--bg-hover)] text-[var(--text-secondary)] transition-colors">501(c)(3) Charitable</button>
                                <button onclick="setOrgType('c4')" class="w-full text-left px-3 py-2 text-xs hover:bg-[var(--bg-hover)] text-[var(--text-secondary)] transition-colors">501(c)(4) Social Welfare</button>
                                <button onclick="setOrgType('c6')" class="w-full text-left px-3 py-2 text-xs hover:bg-[var(--bg-hover)] text-[var(--text-secondary)] transition-colors">501(c)(6) Business League</button>
                                <button onclick="setOrgType('c7')" class="w-full text-left px-3 py-2 text-xs hover:bg-[var(--bg-hover)] text-[var(--text-secondary)] transition-colors">501(c)(7) Social Club</button>
                            </div>
                        </div>
                    </div>

                    <!-- Action Banner -->
                    <div class="flex items-center gap-3 bg-[var(--bg-chart)] p-3 rounded mb-4 border border-[var(--border-card)]">
                        <div class="w-8 h-8 rounded-full border-2 border-blue-400 text-blue-400 flex items-center justify-center font-bold text-xs">
                            <i data-lucide="check" class="w-4 h-4"></i>
                        </div>
                        <p class="text-xs font-bold text-blue-400 leading-tight" id="action-text">
                            Action required: 2 items pending for 501(c)(3) Charitable compliance.
                        </p>
                    </div>

                    <!-- Checklist Container -->
                    <div class="space-y-1" id="checklist-container">
                        <!-- Checklist items injected via JS -->
                    </div>
                </div>

                <!-- Budget Card -->
                <div class="bg-gradient-to-br from-[var(--bg-card)] to-[var(--bg-chart)] border-none shadow-lg rounded-sm p-4">
                    <h3 class="text-[var(--text-secondary)] font-bold text-xs uppercase tracking-wider mb-1">Monthly Operating Budget</h3>
                    <h2 class="text-3xl font-bold text-[var(--text-main)] mb-2">$335,714 p/m</h2>
                    <div class="space-y-1">
                        <p class="text-red-400 text-sm">Currently spending $341,063 p/m</p>
                        <p class="text-red-400 text-sm opacity-80">Committed spending $341,063 p/m</p>
                    </div>
                    <div class="mt-4 pt-3 border-t border-[var(--border-card)]">
                        <p class="text-[var(--text-secondary)] text-xs">Next Fiscal Year Budget Pending</p>
                    </div>
                </div>

            </div>
        </div>

        <!-- FOOTER (Compliance) -->
        <div class="mt-6">
            <h4 class="text-accent font-bold text-xs uppercase tracking-wider mb-2">Compliance & Deliverables</h4>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                <div class="bg-[var(--comp-bg)] p-4 border-l-4 border-[var(--comp-border)] rounded-sm">
                    <h4 class="font-bold text-sm mb-1 text-[var(--comp-text-head)] flex items-center gap-2">
                        Form 990 Compliance Status
                    </h4>
                    <div class="flex items-start gap-2">
                        <i data-lucide="check" class="w-4 h-4 mt-0.5 text-[var(--comp-text)]"></i>
                        <p class="text-xs text-[var(--comp-text)] leading-tight">Annual return ready for filing.</p>
                    </div>
                </div>
                <div class="bg-[var(--comp-bg)] p-4 border-l-4 border-[var(--comp-border)] rounded-sm">
                    <h4 class="font-bold text-sm mb-1 text-[var(--comp-text-head)] flex items-center gap-2">
                        Form 8872 Reporting
                    </h4>
