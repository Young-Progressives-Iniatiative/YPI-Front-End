        const chartData = {
            balance: [800, 850, 820, 780, 750, 810, 840, 900, 950, 840, 790, 860, 880, 900, 920, 940, 900, 860, 840, 880],
            profit: [40, 20, 40, 70, 100, 60, 30, 90, 110, 70, 60, 65, 40, 30, 80, 100, 110, 90, 70, 60],
            income: [120, 140, 125, 180, 130, 120, 110, 150, 190, 140, 120, 160],
            expense: [140, 145, 142, 148, 190, 145, 142, 146, 180, 145, 142, 145],
            asset: [1220, 1222, 1225, 1218, 1225, 1230, 1235, 1240, 1238, 1242, 1248, 1255],
            debt: [500, 498, 495, 490, 485, 480, 475, 470, 465, 460, 455, 450]
        };

        // 2. CHART GENERATION FUNCTION
        function generateLineChartSVG(data, height = 100) {
            const max = Math.max(...data) * 1.05;
            const min = Math.min(...data) * 0.95;
            const range = max - min;
            const width = 100;

            let pathD = '';
            const stepX = width / (data.length - 1);

            data.forEach((val, i) => {
                const x = i * stepX;
                const normalizedY = ((max - val) / range) * height;
                if (i === 0) {
                    pathD += `M${x},${normalizedY} `;
                } else {
                    pathD += `L${x},${normalizedY} `;
                }
            });

            const isPositiveTrend = data[data.length - 1] >= data[0];
            const lineColor = isPositiveTrend ? "#77db89" : "#ef4444";

            return `
            <div class="w-full" style="height: ${height}px">
                <svg viewBox="0 0 ${width} ${height}" preserveAspectRatio="none" class="w-full h-full">
                    <line x1="0" y1="0" x2="${width}" y2="0" stroke="#374151" stroke-width="0.3" opacity="0.3" />
                    <line x1="0" y1="${height/4}" x2="${width}" y2="${height/4}" stroke="#374151" stroke-width="0.3" opacity="0.3" />
                    <line x1="0" y1="${height/2}" x2="${width}" y2="${height/2}" stroke="#374151" stroke-width="0.3" opacity="0.3" />
                    <line x1="0" y1="${3*height/4}" x2="${width}" y2="${3*height/4}" stroke="#374151" stroke-width="0.3" opacity="0.3" />
                    <line x1="0" y1="${height}" x2="${width}" y2="${height}" stroke="#374151" stroke-width="0.3" opacity="0.3" />
                    <path 
                        d="${pathD}" 
                        fill="none" 
                        stroke="${lineColor}" 
                        stroke-width="2" 
                        vector-effect="non-scaling-stroke"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                    />
                </svg>
            </div>`;
        }

        // 3. UI STATE & RENDERING
        let currentOrgType = 'c3';
        let activeTab = 'Financials';

        function renderChecklist(type) {
            const data = complianceData[type];
            const container = document.getElementById('checklist-container');
            const label = document.getElementById('current-designation');
            const actionText = document.getElementById('action-text');
            
            label.innerText = data.label;
            
            // Calculate pending items
            const pendingCount = data.items.filter(i => !i.checked).length;
            actionText.innerText = `Action required: ${pendingCount} items pending for ${data.label} compliance.`;

            // Render Items
            container.innerHTML = '';
            
            // Sort: Checked items last
            const sortedItems = [...data.items].sort((a, b) => (a.checked === b.checked ? 0 : a.checked ? 1 : -1));

            sortedItems.forEach(item => {
                const div = document.createElement('div');
                div.className = "flex items-center gap-3 py-3 border-b border-gray-800/50 last:border-0 group cursor-pointer hover:bg-white/5 px-2 -mx-2 rounded transition-colors";
                
                const checkClass = item.checked 
                    ? 'bg-green-600 border-green-600' 
                    : 'border-gray-600 group-hover:border-gray-400';
                
                const textClass = item.checked 
                    ? 'text-gray-300 line-through decoration-gray-600' 
                    : 'text-gray-200';

                const icon = item.checked ? '<i data-lucide="check" class="w-3.5 h-3.5 text-white stroke-[3]"></i>' : '';

                div.innerHTML = `
                    <div class="w-5 h-5 rounded-sm flex items-center justify-center border transition-colors ${checkClass}">
                        ${icon}
                    </div>
                    <span class="text-xs font-medium ${textClass}">${item.label}</span>
                `;
                container.appendChild(div);
            });
            lucide.createIcons(); // Re-init icons for new content
        }

        function setOrgType(type) {
            currentOrgType = type;
            renderChecklist(type);
            document.getElementById('dropdown-menu').classList.add('hidden');
            
            // Highlight selected in dropdown (visual only reset)
            const buttons = document.querySelectorAll('#dropdown-menu button');
            buttons.forEach(btn => {
                if(btn.innerText === complianceData[type].label) {
                    btn.classList.add('text-[#77db89]', 'font-bold');
                    btn.classList.remove('text-gray-300');
                } else {
                    btn.classList.remove('text-[#77db89]', 'font-bold');
                    btn.classList.add('text-gray-300');
                }
            });
        }

        // 4. INITIALIZATION
        document.addEventListener('DOMContentLoaded', () => {
            // Render Charts
            document.getElementById('chart-balance').innerHTML = generateLineChartSVG(chartData.balance, 180);
            document.getElementById('chart-profit').innerHTML = generateLineChartSVG(chartData.profit, 140);
            document.getElementById('chart-income').innerHTML = generateLineChartSVG(chartData.income, 72);
            document.getElementById('chart-expenses').innerHTML = generateLineChartSVG(chartData.expense, 72);
            document.getElementById('chart-assets').innerHTML = generateLineChartSVG(chartData.asset, 72);
            document.getElementById('chart-liabilities').innerHTML = generateLineChartSVG(chartData.debt, 72);

            // Setup Navigation
            const navItems = ['Vision', 'Organizing', 'Financials', 'Data Suite', 'Projects', 'Marketing', 'Donors'];
            const navContainer = document.getElementById('main-nav');
            
            navItems.forEach(item => {
                const btn = document.createElement('button');
                const isActive = item === activeTab;
                btn.className = `group flex items-center px-3 py-2 text-xl font-bold tracking-tight font-fm-header transition-all ${
                    isActive 
                    ? 'text-[#98fb98] drop-shadow-[0_0_8px_rgba(152,251,152,0.25)] scale-105' 
                    : 'text-gray-400 hover:text-white hover:scale-105'
                }`;
                btn.innerHTML = `<span>${item}</span>`;
                
                // Add click handler for visual switching (demo purpose)
                btn.addEventListener('click', function() {
                    // Reset all
                    Array.from(navContainer.children).forEach(c => {
                        c.className = 'group flex items-center px-3 py-2 text-xl font-bold tracking-tight font-fm-header transition-all text-gray-400 hover:text-white hover:scale-105';
                    });
                    // Set active
                    this.className = 'group flex items-center px-3 py-2 text-xl font-bold tracking-tight font-fm-header transition-all text-[#98fb98] drop-shadow-[0_0_8px_rgba(152,251,152,0.25)] scale-105';
                });
                
                navContainer.appendChild(btn);
            });

            // Dropdown Toggle
            document.getElementById('dropdown-trigger').addEventListener('click', (e) => {
                e.stopPropagation();
                document.getElementById('dropdown-menu').classList.toggle('hidden');
            });

            // Close dropdown when clicking outside
            document.addEventListener('click', () => {
                document.getElementById('dropdown-menu').classList.add('hidden');
            });

            // Initial Checklist Render
            renderChecklist('c3');
            setOrgType('c3'); // To set initial styling

            // Initialize Icons
            lucide.createIcons();
        });
    </script>
</body>
</html>
