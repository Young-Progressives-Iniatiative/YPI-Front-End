    const textClass = item.checked ? 'text-[var(--text-secondary)] line-through' : 'text-[var(--text-main)]';
    const icon = item.checked ? '<i data-lucide="check" class="w-3.5 h-3.5 text-white stroke-[3]"></i>' : '';
    container.innerHTML += `<div class="flex items-center gap-3 py-3 border-b border-[var(--border-card)] last:border-0 hover:bg-[var(--bg-hover)] px-2 -mx-2 rounded transition-colors cursor-pointer group"><div class="w-5 h-5 rounded-sm flex items-center justify-center border transition-colors ${checkClass}">${icon}</div><span class="text-xs font-medium ${textClass}">${item.label}</span></div>`;
  });
  lucide.createIcons();
}

function setOrgType(type) {
  renderChecklist(type);
  document.getElementById('dropdown-menu').classList.add('hidden');
}

// Modals
function openDashboardModal(type) {
  const data = modalData[type]; if(!data) return;
  document.getElementById('modal-title').innerText = data.title;
  document.getElementById('modal-subtitle').innerText = data.subtitle;
  document.getElementById('modal-stat-month').innerText = data.stats.month;
  document.getElementById('modal-stat-prev').innerText = data.stats.prev;
  document.getElementById('modal-stat-ytd').innerText = data.stats.ytd;
  document.getElementById('modal-chart-container').innerHTML = generateBarChartSVG(250);
  const tbody = document.getElementById('modal-table-body'); tbody.innerHTML = '';
  const totalThisMonth = data.items.reduce((sum, item) => sum + Math.abs(item.thisMonth), 0);
  const formatCurrency = (val) => (typeof val==='string'?val : (val<0?'-':'')+'$'+Math.abs(val).toLocaleString());
  [...new Set(data.items.map(i=>i.category))].forEach(cat => {
    tbody.innerHTML += `<div class="px-2 py-3 mt-4 mb-1 border-b border-[var(--border-card)] text-[var(--text-accent)] font-bold text-xs uppercase tracking-widest">${cat}</div>`;
    data.items.filter(i=>i.category===cat).forEach((row, idx) => {
      const percent = ((Math.abs(row.thisMonth)/totalThisMonth)*100).toFixed(1);
      const rowId = `row-${type}-${idx}`; const chartId = `chart-${type}-${idx}`;
      const rowHTML = `
        <div class="group cursor-pointer rounded transition-colors hover:bg-[var(--bg-hover)] border-l-4 border-transparent hover:border-[var(--text-accent)]" onclick="toggleRow('${rowId}', '${chartId}', [${row.history}])" aria-expanded="false">
          <div class="grid grid-cols-12 gap-4 p-2 items-center">
            <div class="col-span-4 font-medium text-[var(--text-main)] text-sm pl-2 flex items-center gap-2"><i data-lucide="chevron-down" class="chevron-icon w-4 h-4 text-[var(--text-secondary)] transition-transform duration-200"></i> ${row.item}</div>
            <div class="col-span-2 text-right text-[var(--text-secondary)] text-sm font-mono">${formatCurrency(row.thisMonth)}</div>
            <div class="col-span-2 text-right text-sm font-mono text-[var(--text-main)] font-bold">${percent}% <span class="text-[var(--text-secondary)] text-[10px] font-normal ml-1">(${row.std})</span></div>
            <div class="col-span-2 text-right text-[var(--text-secondary)] text-sm font-mono">${formatCurrency(row.lastMonth)}</div>
            <div class="col-span-2 text-right text-[var(--text-secondary)] text-sm font-mono">${formatCurrency(row.ytd)}</div>
          </div>
          <div id="${rowId}" class="hidden bg-[var(--bg-body)] p-4 border-t border-[var(--border-card)] mx-2 mb-2 rounded-b flex flex-col md:flex-row gap-6">
            <div class="w-full md:w-1/4"><h4 class="text-[10px] font-bold text-[var(--text-secondary)] uppercase mb-2">Trend</h4><div id="${chartId}" class="h-20 w-full bg-[var(--bg-chart)] rounded p-1 border border-[var(--border-card)]"></div></div>
            <div class="w-full md:w-3/4"><h4 class="text-[10px] font-bold text-[var(--text-accent)] uppercase mb-2">Tips</h4><ul class="space-y-1 text-xs text-[var(--text-main)]">${row.tips.map(t=>`<li>• ${t}</li>`).join('')}</ul></div>
          </div>
        </div>`;
      tbody.innerHTML += rowHTML;
    });
  });
  document.getElementById('dashboard-modal').classList.remove('hidden');
  lucide.createIcons();
}

function toggleRow(rowId, chartId, data) {
  const el = document.getElementById(rowId);
  el.classList.toggle('hidden');
  el.parentElement.setAttribute('aria-expanded', !el.classList.contains('hidden'));
  if(!el.classList.contains('hidden') && document.getElementById(chartId).innerHTML === '') {
    document.getElementById(chartId).innerHTML = generateMiniSparklineSVG(data);
  }
}

function closeDashboardModal() { document.getElementById('dashboard-modal').classList.add('hidden'); }

// Balance Sheet Modal
function openBalanceSheet(e) {
  if(e) e.stopPropagation();
  document.getElementById('balance-sheet-modal').classList.remove('hidden');
}
function closeBalanceSheet() {
  document.getElementById('balance-sheet-modal').classList.add('hidden');
}

function openRevenueReport(e) { e.stopPropagation(); document.getElementById('revenue-report-modal').classList.remove('hidden'); renderReportView('revenue', 'revenue-report-content'); }
function closeRevenueReport() { document.getElementById('revenue-report-modal').classList.add('hidden'); }
function toggleRevenueView() { renderReportView('revenue', 'revenue-report-content'); }

function renderReportView(type, containerId) {
  const container = document.getElementById(containerId);
  const rows = type === 'revenue' ? revenueTransactions : [];
  const headers = ['Date','Source','Cat','Amt','Status'];
  let html = `<div class="w-full overflow-x-auto"><table class="w-full text-left border-collapse"><thead><tr class="bg-[var(--bg-header)] border-b border-[var(--border-header)] text-xs text-[var(--text-secondary)] uppercase tracking-wider">`;
  headers.forEach(h => html += `<th class="px-4 py-3 font-bold">${h}</th>`);
  html += `</tr></thead><tbody>`;
  rows.forEach(r => {
    html += `<tr class="border-b border-[var(--border-card)] hover:bg-[var(--bg-hover)] transition-colors">
      <td class="px-4 py-3 text-sm text-[var(--text-secondary)]">${r.date}</td>
      <td class="px-4 py-3 text-sm text-[var(--text-main)] font-medium">${r.source || ''}</td>
      <td class="px-4 py-3 text-sm text-[var(--text-secondary)]">${r.category}</td>
      <td class="px-4 py-3 text-sm text-[var(--text-main)] font-mono">$${r.amount.toLocaleString()}</td>
      <td class="px-4 py-3 text-sm"><span class="px-2 py-0.5 rounded text-[10px] font-bold bg-[var(--comp-bg)] text-[var(--comp-text)]">${r.status}</span></td>
    </tr>`;
  });
  html += `</tbody></table></div>`;
  container.innerHTML = html;
}

document.addEventListener('DOMContentLoaded', () => {
  // Theme Toggle
  const themeBtn = document.getElementById('theme-toggle');
  const sunIcon = themeBtn.querySelector('.icon-sun');
  const moonIcon = themeBtn.querySelector('.icon-moon');
  const body = document.body;
  let isDark = true;
  const updateThemeUI = () => {
    if (isDark) {
      body.removeAttribute('data-theme');
      sunIcon.classList.remove('hidden');
      moonIcon.classList.add('hidden');
    } else {
      body.setAttribute('data-theme', 'light');
      sunIcon.classList.add('hidden');
      moonIcon.classList.remove('hidden');
    }
  };
  themeBtn.addEventListener('click', () => { isDark = !isDark; updateThemeUI(); });
  updateThemeUI();

  // Render Main Charts
  document.getElementById('chart-balance').innerHTML = generateLineChartSVG(chartData.balance, 180);
  document.getElementById('chart-profit').innerHTML = generateLineChartSVG(chartData.profit, 140);
  document.getElementById('chart-income').innerHTML = generateLineChartSVG(chartData.income, 72);
  document.getElementById('chart-expenses').innerHTML = generateLineChartSVG(chartData.expense, 72);
  document.getElementById('chart-assets').innerHTML = generateLineChartSVG(chartData.asset, 72);
  document.getElementById('chart-liabilities').innerHTML = generateLineChartSVG(chartData.debt, 72);

  // Nav Logic
  const navItems = ['Vision', 'Organizing', 'Financials', 'Data Suite', 'Projects', 'Marketing', 'Fundraising'];
  const navContainer = document.getElementById('main-nav');
  navItems.forEach(item => {
    const btn = document.createElement('button');
    btn.className = item === 'Financials'
      ? 'group flex items-center px-3 py-2 text-xl font-bold tracking-tight font-fm-header transition-all text-[var(--nav-active)] drop-shadow-[0_0_8px_var(--nav-glow)] scale-105'
      : 'group flex items-center px-3 py-2 text-xl font-bold tracking-tight font-fm-header transition-all text-[var(--nav-inactive)] hover:text-[var(--nav-hover)] hover:scale-105';
    btn.innerHTML = `<span>${item}</span>`;
    btn.onclick = function() {
      Array.from(navContainer.children).forEach(c => c.className = 'group flex items-center px-3 py-2 text-xl font-bold tracking-tight font-fm-header transition-all text-[var(--nav-inactive)] hover:text-[var(--nav-hover)] hover:scale-105');
      this.className = 'group flex items-center px-3 py-2 text-xl font-bold tracking-tight font-fm-header transition-all text-[var(--nav-active)] drop-shadow-[0_0_8px_var(--nav-glow)] scale-105';
    };
    navContainer.appendChild(btn);
  });

  // Dropdowns
  document.getElementById('dropdown-trigger').addEventListener('click', (e) => { e.stopPropagation(); document.getElementById('dropdown-menu').classList.toggle('hidden'); });
  document.addEventListener('click', () => document.getElementById('dropdown-menu').classList.add('hidden'));

  renderChecklist('c3');
  lucide.createIcons();
});
</script>
</body>
</html>

