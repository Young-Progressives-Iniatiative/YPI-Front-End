<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
   <meta charset="UTF-8">
   <meta name="viewport" content="width=device-width, initial-scale=1.0">
   <title>Mark Attendance - Young Progressives Initiative</title>
   <link href="https://cdn.jsdelivr.net/npm/@fontsource/atkinson-hyperlegible@5.0.19/index.min.css" rel="stylesheet">
   <style>
       /* Reset and base styles */
       * {
           margin: 0;
           padding: 0;
           box-sizing: border-box;
       }

       body {
           font-family: 'Atkinson Hyperlegible', sans-serif;
           background-color: var(--theme-body-bg);
           color: var(--theme-body-color);
           line-height: 1.6;
           overflow-x: hidden;
           font-size: 16px;
       }
      
       /* Variables */
       :root {
           --primary-green: #98fb98;
           --dark-background: #1c1c1c;
           --light-gray: #bbb;
           --theme-body-bg: #1c1c1c;
           --theme-body-color: #fff;
           --theme-popup-bg: #bbbbbb;
           --theme-popup-text: #1c1c1c;
           --theme-input-bg: #333;
           --theme-input-border: #444;
           --theme-input-text: #eee;
       }

       html[data-theme='light'] {
           --theme-body-bg: #FEFEFE;
           --theme-body-color: #1c1c1c;
           --theme-popup-bg: #e0e0e0;
           --theme-popup-text: #1c1c1c;
           --theme-input-bg: #fff;
           --theme-input-border: #ccc;
           --theme-input-text: #1c1c1c;
           --primary-green: #98fb98;
           --member-border: #98fb98;
       }

       body {
           background-color: var(--theme-body-bg);
           color: var(--theme-body-color);
           transition: background-color 0.3s ease, color 0.3s ease;
       }

       .main-wrapper {
           width: 100%;
           min-height: 100vh;
           background-color: var(--theme-body-bg);
           display: flex;
           flex-direction: column;
           justify-content: center;
           align-items: center;
           padding: 2rem 0;
       }
      
       .content-body {
           flex: 1;
           width: 100%;
           max-width: 1000px;
           padding: 0 1.5rem;
       }

       .form-page-container {
           max-width: 1100px;
           margin: 0 auto;
           padding: 2.5rem;
           background-color: rgba(128, 128, 128, 0.1);
           border-radius: 1rem;
           border: 1px solid var(--theme-input-border);
       }

       .form-page-container h1 {
           text-align: center;
           color: var(--primary-green);
           margin-bottom: 0.5rem;
           font-size: 2.5rem;
           font-family: 'Atkinson Hyperlegible', sans-serif;
       }

       .event-info {
           text-align: center;
           margin-bottom: 2.5rem;
           font-family: 'Atkinson Hyperlegible', sans-serif;
       }

       .event-info p {
           color: var(--light-gray);
           margin-bottom: 0.75rem;
       }
      
       html[data-theme='light'] .event-info p {
            color: #555;
       }

       .event-badge {
           display: inline-block;
           background-color: rgba(152, 251, 152, 0.15);
           color: var(--primary-green);
           padding: 0.6rem 1.25rem;
           border-radius: 2rem;
           font-weight: bold;
           font-size: 1.1rem;
           border: 1px solid var(--primary-green);
       }

       .attendance-table {
           width: 100%;
           border-collapse: collapse;
           margin-top: 1rem;
           table-layout: fixed;
       }
      
       .attendance-table th, .attendance-table td {
           padding: 1rem;
           text-align: left;
           border-bottom: 1px solid var(--theme-input-border);
           font-family: 'Atkinson Hyperlegible', sans-serif;
           vertical-align: middle;
       }
      
       .attendance-table th {
           background-color: var(--theme-input-bg);
           font-weight: bold;
       }

       /* Column widths */
       .attendance-table th:nth-child(1) { width: 20%; } /* Name */
       .attendance-table th:nth-child(2) { width: 40%; } /* Status */
       .attendance-table th:nth-child(4) { width: 20%; } /* Performance */
       .attendance-table th.hours-col { width: 20%; }

       /* Hide Hours Column by Default */
       .hours-col, .hours-cell {
           display: none;
       }

       .attendance-table tr:hover {
           background-color: rgba(128, 128, 128, 0.1);
       }
      
       .attendance-status {
           display: flex;
           gap: 0.8rem;
           align-items: center;
           flex-wrap: wrap;
       }

       .attendance-status label {
           cursor: pointer;
           display: flex;
           align-items: center;
           gap: 0.4rem;
           font-family: 'Atkinson Hyperlegible', sans-serif;
           font-size: 0.9rem;
       }
      
       .attendance-status input[type="radio"] {
           appearance: none;
           width: 1.1rem;
           height: 1.1rem;
           border: 2px solid var(--theme-input-border);
           border-radius: 50%;
           cursor: pointer;
           transition: background-color 0.2s, border-color 0.2s;
           position: relative;
       }
      
       .attendance-status input[type="radio"]:checked {
           border-color: var(--primary-green);
       }
      
       .attendance-status input[type="radio"]:checked::after {
           content: '';
           display: block;
           width: 0.6rem;
           height: 0.6rem;
           background-color: var(--primary-green);
           border-radius: 50%;
           position: absolute;
           top: 50%;
           left: 50%;
           transform: translate(-50%, -50%);
       }

       .form-input {
           width: 100%;
           padding: 0.75rem;
           border: 1px solid var(--theme-input-border);
           border-radius: 0.25rem;
           background-color: var(--theme-input-bg);
           color: var(--theme-input-text);
           font-size: 1rem;
           font-family: 'Atkinson Hyperlegible', sans-serif;
           cursor: text;
           transition: border-color 0.3s ease;
       }

       .form-input:focus, .rating-select:focus {
           outline: none;
           border-color: var(--primary-green);
       }

       .rating-select {
           width: 100%;
           padding: 0.75rem;
           border: 1px solid var(--theme-input-border);
           border-radius: 0.25rem;
           background-color: var(--theme-input-bg);
           color: var(--theme-input-text);
           font-size: 1rem;
           font-family: 'Atkinson Hyperlegible', sans-serif;
           cursor: pointer;
           transition: border-color 0.3s ease;
       }

       .submit-button {
           background-color: #98fb98;
           color: #1c1c1c;
           border: none;
           padding: 0.9375rem 1.25rem;
           width: 100%;
           border-radius: 0.5rem;
           cursor: pointer;
           font-weight: bold;
           font-size: 1.25rem;
           margin-top: 2rem;
           transition: transform 0.2s;
           font-family: 'Atkinson Hyperlegible', sans-serif;
       }

       .submit-button:hover {
           transform: translateY(-2px);
       }

       .message-box-overlay {
           position: fixed;
           top: 0;
           left: 0;
           width: 100%;
           height: 100%;
           background-color: rgba(0, 0, 0, 0.5);
           z-index: 10000;
           display: flex;
           justify-content: center;
           align-items: center;
           visibility: hidden;
           opacity: 0;
           transition: opacity 0.3s ease-in-out, visibility 0.3s ease-in-out;
       }

       .message-box {
           background-color: var(--theme-body-bg);
           color: var(--theme-body-color);
           padding: 2rem;
           border-radius: 0.75rem;
           box-shadow: 0 0.5rem 1.5rem rgba(0, 0, 0, 0.3);
           max-width: 24rem;
           width: 90%;
           text-align: center;
           position: relative;
       }

       .message-box h3 {
           margin-top: 0;
           margin-bottom: 1rem;
           color: var(--primary-green);
           font-family: 'Atkinson Hyperlegible', sans-serif;
       }

       .message-box p {
           margin-bottom: 1.5rem;
           font-size: 1.1rem;
           font-family: 'Atkinson Hyperlegible', sans-serif;
       }

       .message-box button {
           background-color: var(--primary-green);
           color: #1c1c1c;
           border: none;
           padding: 0.75rem 1.5rem;
           border-radius: 0.375rem;
           cursor: pointer;
           font-weight: bold;
           transition: background-color 0.2s ease, transform 0.2s ease;
           font-family: 'Atkinson Hyperlegible', sans-serif;
       }

       .message-box button:hover {
           background-color: #7fd97f;
           transform: translateY(-1px);
       }

       @media (max-width: 768px) {
           .attendance-table {
               display: block;
               overflow-x: auto;
               white-space: nowrap;
           }
           .form-page-container {
               padding: 1.5rem;
           }
           .attendance-status {
               flex-direction: column;
               align-items: flex-start;
               gap: 0.5rem;
           }
       }
   </style>
   <script>
       (function() {
           try {
               const savedTheme = localStorage.getItem('theme') || 'dark';
               document.documentElement.setAttribute('data-theme', savedTheme);
           } catch (e) {
               console.error("Could not access localStorage to set theme.", e);
           }
       })();
   </script>
</head>
<body>
   <div class="main-wrapper">
     <div class="content-body">
       <main class="form-page-container">
           <h1>Event Attendance</h1>
           <div class="event-info">
               <p>System detected event:</p>
               <span class="event-badge">Community Park Cleanup - July 20, 2025</span>
           </div>
           <form id="attendanceForm">
               <input type="hidden" name="eventId" value="event1">
               <table class="attendance-table">
                   <thead>
                       <tr>
                           <th>Student Name</th>
                           <th>Status</th>
                           <th class="hours-col">Hours (Manual)</th>
                           <th>Performance (1-10)</th>
                       </tr>
                   </thead>
                   <tbody id="student-list">
                       <!-- Rows populated dynamically -->
                   </tbody>
               </table>

               <button type="submit" class="submit-button">Submit Attendance & Log Hours</button>
           </form>
       </main>
     </div>
   </div>

   <div class="message-box-overlay" id="messageBoxOverlay"></div>

   <script>
       document.addEventListener('DOMContentLoaded', function() {
           // Populate student rows dynamically
           const students = [
               'Alex Johnson',
               'Maria Garcia',
               'David Smith',
               'Emily White',
               'Michael Brown'
           ];

           const tbody = document.getElementById('student-list');

           students.forEach((student, index) => {
               const id = `student${index + 1}`;
               const tr = document.createElement('tr');
               
               // Generate options 1-10 for rating
               let ratingOptions = '<option value="" disabled selected>Select Rating</option>';
               for(let i = 1; i <= 10; i++) {
                   ratingOptions += `<option value="${i}">${i}</option>`;
               }

               tr.innerHTML = `
                   <td>${student}</td>
                   <td class="attendance-status">
                       <label><input type="radio" name="${id}_status" value="present" checked data-id="${id}"> Present</label>
                       <label><input type="radio" name="${id}_status" value="early_leave" data-id="${id}"> Early Leave</label>
                       <label><input type="radio" name="${id}_status" value="absent" data-id="${id}"> Absent</label>
                   </td>
                   <td class="hours-cell">
                       <input type="number" name="${id}_hours" class="form-input hours-input" placeholder="Hours" step="0.5" min="0" data-id="${id}">
                   </td>
                   <td>
                       <select name="${id}_rating" class="rating-select" required>
                           ${ratingOptions}
                       </select>
                   </td>
               `;
               tbody.appendChild(tr);
           });

           // Function to update Hours Column visibility
           function updateHoursColumnVisibility() {
               // Check if ANY student is marked as Early Leave
               const isEarlyLeaveSelected = document.querySelectorAll('input[type="radio"][value="early_leave"]:checked').length > 0;
               const displayStyle = isEarlyLeaveSelected ? 'table-cell' : 'none';
               
               // Toggle Header
               document.querySelectorAll('.hours-col').forEach(el => el.style.display = displayStyle);
               // Toggle Cells
               document.querySelectorAll('.hours-cell').forEach(el => el.style.display = displayStyle);
               
               // Update required attribute for validation
               document.querySelectorAll('.hours-input').forEach(input => {
                   if (isEarlyLeaveSelected) {
                       // We handle validation manually in submit to be precise, 
                       // but setting required helps some UX.
                       input.setAttribute('required', '');
                   } else {
                       input.removeAttribute('required');
                   }
               });
           }

           // Listen for changes on status radio buttons
           document.querySelectorAll('input[type="radio"][name$="_status"]').forEach(radio => {
               radio.addEventListener('change', function(e) {
                   updateHoursColumnVisibility();
               });
           });

           // Initial call to set state
           updateHoursColumnVisibility();

           // Message Box Functions
           function showMessage(title, message) {
               let messageBoxOverlay = document.getElementById('messageBoxOverlay');
               if (!messageBoxOverlay) {
                   messageBoxOverlay = document.createElement('div');
                   messageBoxOverlay.id = 'messageBoxOverlay';
                   messageBoxOverlay.className = 'message-box-overlay';
                   document.body.appendChild(messageBoxOverlay);
               }
               messageBoxOverlay.innerHTML = `<div class="message-box"><h3>${title}</h3><p>${message}</p><button id="messageBoxCloseButton">OK</button></div>`;
               document.getElementById('messageBoxCloseButton').onclick = () => hideMessageBox();
               requestAnimationFrame(() => {
                   messageBoxOverlay.style.visibility = 'visible';
                   messageBoxOverlay.style.opacity = '1';
               });
               document.body.style.overflow = 'hidden';
           }

           function hideMessageBox() {
               const messageBoxOverlay = document.getElementById('messageBoxOverlay');
               if (messageBoxOverlay) {
                   messageBoxOverlay.style.opacity = '0';
                   setTimeout(() => {
                       messageBoxOverlay.style.visibility = 'hidden';
                       document.body.style.overflow = 'auto';
                   }, 300);
               }
           }

           // Form Submission Logic
           function initializeForm() {
               const attendanceForm = document.getElementById('attendanceForm');
               if(attendanceForm) {
                   attendanceForm.addEventListener('submit', function(e) {
                       e.preventDefault();
                      
                       // Validation and Summary
                       let presentCount = 0;
                       let totalHours = 0;
                       let isValid = true;

                       document.querySelectorAll('#student-list tr').forEach(tr => {
                           const name = tr.querySelector('td:first-child').innerText;
                           const status = tr.querySelector('input[type="radio"]:checked').value;
                           const hoursInput = tr.querySelector('.hours-input');
                           const ratingSelect = tr.querySelector('.rating-select');
                           
                           // Check Rating
                           if (!ratingSelect.value) {
                               alert(`Please select a performance rating for ${name}.`);
                               isValid = false;
                               ratingSelect.focus();
                           }

                           // Check Hours if Early Leave
                           if (status === 'early_leave') {
                               const hoursVal = parseFloat(hoursInput.value);
                               if (!hoursInput.value || isNaN(hoursVal) || hoursVal <= 0) {
                                   alert(`Please enter valid hours for ${name}.`);
                                   isValid = false;
                                   hoursInput.focus();
                               } else {
                                   presentCount++;
                                   totalHours += hoursVal;
                               }
                           } else if (status === 'present') {
                               presentCount++;
                               // For present, hours might be logged automatically, or 0 here.
                           }
                       });

                       if (isValid) {
                           // Determine message based on whether Early Leave was used
                           let msg = `Attendance for "Community Park Cleanup" has been recorded. ${presentCount} students marked present.`;
                           if (totalHours > 0) {
                               msg += ` Additionally, ${totalHours} manual hours were logged for early leave students.`;
                           }
                           showMessage('Attendance Submitted', msg);
                       }
                   });
               }
           }

           initializeForm();
       });
   </script>
</body>
</html>

