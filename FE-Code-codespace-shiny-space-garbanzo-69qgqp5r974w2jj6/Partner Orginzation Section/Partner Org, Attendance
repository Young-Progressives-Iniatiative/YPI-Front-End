   <script>
       document.addEventListener('DOMContentLoaded', function() {
           // --- THEME TOGGLE SCRIPT ---
           function initializeThemeToggle() {
               const themeButton = document.getElementById('themeButton');
               const htmlElement = document.documentElement;


               if (!themeButton) {
                   console.error("Theme toggle button not found.");
                   return;
               }


               const applyTheme = (theme) => {
                   htmlElement.setAttribute('data-theme', theme);
                   localStorage.setItem('theme', theme);
               };


               const setInitialState = () => {
                   const gearIcon = themeButton.querySelector('.gear-icon');
                   const currentTheme = htmlElement.getAttribute('data-theme') || 'dark';
                   let rotationAngle = (currentTheme === 'light') ? 180 : 0;
                   gearIcon.style.transform = `rotate(${rotationAngle}deg)`;
                   gearIcon.dataset.rotation = rotationAngle;
               };


               themeButton.addEventListener('click', () => {
                   const newTheme = htmlElement.getAttribute('data-theme') === 'light' ? 'dark' : 'light';
                   applyTheme(newTheme);


                   const gearIcon = themeButton.querySelector('.gear-icon');
                   let currentRotation = parseFloat(gearIcon.dataset.rotation) || 0;
                   currentRotation += 180;
                   gearIcon.style.transform = `rotate(${currentRotation}deg)`;
                   gearIcon.dataset.rotation = currentRotation;
               });


               setInitialState();
           }
          
           // --- MESSAGE BOX FUNCTIONS ---
           function showMessage(title, message) {
               let messageBoxOverlay = document.getElementById('messageBoxOverlay');
               if (!messageBoxOverlay) {
                   messageBoxOverlay = document.createElement('div');
                   messageBoxOverlay.id = 'messageBoxOverlay';
                   messageBoxOverlay.className = 'message-box-overlay';
                   document.body.appendChild(messageBoxOverlay);
               }
               messageBoxOverlay.innerHTML = `<div class="message-box"><h3>${title}</h3><p>${message}</p><button id="messageBoxCloseButton">OK</button></div>`;
               document.getElementById('messageBoxCloseButton').onclick = () => hideMessageBox();
               messageBoxOverlay.style.visibility = 'visible';
               messageBoxOverlay.style.opacity = '1';
               document.body.style.overflow = 'hidden';
           }


           function hideMessageBox() {
               const messageBoxOverlay = document.getElementById('messageBoxOverlay');
               if (messageBoxOverlay) {
                   messageBoxOverlay.style.opacity = '0';
                   setTimeout(() => {
                       messageBoxOverlay.style.visibility = 'hidden';
                       document.body.style.overflow = 'auto';
                   }, 300);
               }
           }


           // --- FORM SUBMISSION LOGIC ---
           function initializeForm() {
               const attendanceForm = document.getElementById('attendanceForm');
               if(attendanceForm) {
                   attendanceForm.addEventListener('submit', function(e) {
                       e.preventDefault(); // Prevent actual form submission
                      
                       // In a real application, you would collect the data and send it to your database
                       // to log hours for students marked "Present".
                      
                       let presentCount = 0;
                       const studentRadios = attendanceForm.querySelectorAll('input[type="radio"][value="present"]:checked');
                       presentCount = studentRadios.length;
                      
                       showMessage('Attendance Submitted', `Attendance has been recorded. ${presentCount} students' hours have been logged successfully.`);
                      
                       // Optionally, you might clear the form or redirect
                       // For now, we'll just leave it as is.
                   });
               }
           }


           // --- INITIALIZE ALL SCRIPTS ---
           initializeThemeToggle();
           initializeForm();
       });
   </script>
