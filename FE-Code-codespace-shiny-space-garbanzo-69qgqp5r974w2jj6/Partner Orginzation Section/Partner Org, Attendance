   <style>
       /* Reset and base styles */
       * {
           margin: 0;
           padding: 0;
           box-sizing: border-box;
       }


       body {
           font-family: 'Arial', sans-serif;
           background-color: var(--theme-body-bg);
           color: var(--theme-body-color);
           line-height: 1.6;
           overflow-x: hidden; /* Prevent horizontal scroll */
           font-size: 16px; /* Set base font size for rem calculation */
       }
      
       /* --- GLOBAL & COMMON STYLES --- */
       :root {
           --primary-green: #37af4b;
           --dark-background: #1c1c1c;
           --member-border: #28a745;
           --light-gray: #bbb;
           --danger-red: #ef4444;


           /* Default to Dark Theme */
           --theme-body-bg: #1c1c1c;
           --theme-body-color: #fff;
           --theme-popup-bg: #bbbbbb;
           --theme-popup-text: #1c1c1c;
           --theme-input-bg: #333;
           --theme-input-border: #444;
           --theme-input-text: #eee;
           --theme-navbar-bg: #1c1c1c;
           --theme-navbar-text: #fff;
           --theme-navbar-dropdown-bg: #f0f0f0;
           --theme-navbar-dropdown-text: #1c1c1c;
           --theme-navbar-dropdown-hover-bg: #ddd;
           --theme-button-bg: #FEFEFE;
           --theme-button-text: #1c1c1c;
           --theme-button-border: #1c1c1c;
           --theme-button-hover-bg: #1c1c1c;
           --theme-button-hover-text: #FEFEFE;
       }


       /* Light Theme Definition */
       html[data-theme='light'] {
           --theme-body-bg: #FEFEFE;
           --theme-body-color: #1c1c1c;
           --theme-popup-bg: #e0e0e0;
           --theme-popup-text: #1c1c1c;
           --theme-input-bg: #fff;
           --theme-input-border: #ccc;
           --theme-input-text: #1c1c1c;
           --primary-green: #37af4b;
           --member-border: #37af4b;
           --theme-navbar-bg: #FEFEFE;
           --theme-navbar-text: #1c1c1c;
           --theme-navbar-dropdown-bg: #1c1c1c;
           --theme-navbar-dropdown-text: #FEFEFE;
           --theme-navbar-dropdown-hover-bg: #333;
           --theme-button-bg: #1c1c1c;
           --theme-button-text: #FEFEFE;
           --theme-button-border: #1c1c1c;
           --theme-button-hover-bg: #FEFEFE;
           --theme-button-hover-text: #1c1c1c;
       }
      
       html[data-theme='light'] .desktop-wp-footer,
       html[data-theme='light'] .footer-container {
            background: #1c1c1c;
            color: #FEFEFE;
       }
      
       html[data-theme='light'] .desktop-wp-footer a,
       html[data-theme='light'] .footer-container a {
            color: #FEFEFE;
       }
      
       html[data-theme='light'] .gear-icon {
           stroke: #1c1c1c;
       }


       html[data-theme='light'] .attendance-table th {
           background-color: #f2f2f2;
       }


       html[data-theme='light'] .attendance-table tr:nth-child(even) {
           background-color: #f9f9f9;
       }


       .highlight {
           color: var(--primary-green);
       }
      
       body {
           background-color: var(--theme-body-bg);
           color: var(--theme-body-color);
           transition: background-color 0.3s ease, color 0.3s ease;
       }


       /* --- DESKTOP LAYOUTS & STYLES --- */
       .main-wrapper {
           width: 100%;
           min-height: 100vh;
           background-color: var(--theme-body-bg);
           position: relative;
           display: flex;
           flex-direction: column;
       }
      
       .content-body {
           flex: 1;
       }


       /* --- HEADER AND NAVBAR STYLES --- */
       .desktop-wp-header-container {
           background: linear-gradient(135deg,rgb(5,114,21) 0%,rgb(55,175,75) 100%);
           width: 100%;
       }


       .desktop-wp-header-contents {
           display: flex;
           flex-wrap: nowrap;
           justify-content: space-between;
           align-items: center;
           width: 100%;
           padding: 0 1.25rem;
       }


       .desktop-header-left-group {
           display: flex;
           flex-wrap: nowrap;
           gap: 1.25rem;
           align-items: center;
       }


       .desktop-header-right-group {
           position: relative;
           display: flex;
           flex-wrap: nowrap;
           justify-content: flex-end;
           gap: 1.25rem;
           align-items: center;
       }


       .desktop-header-logo-img {
           width: 7.4375rem;
           height: auto;
           display: block;
       }
      
       .theme-button {
           background-color: transparent;
           border: none;
           cursor: pointer;
           padding: 0.625rem;
           position: relative;
           transition: transform 0.3s ease;
       }
      
       .theme-button:hover {
           transform: scale(1.1);
       }
      
       .gear-icon {
           width: 1.875rem;
           height: 1.875rem;
           fill: none;
           stroke: #FEFEFE;
           stroke-width: 2;
           transition: transform 0.5s ease, stroke 0.3s ease;
       }


       .maxbutton {
           position: relative;
           text-decoration: none;
           display: inline-block;
           vertical-align: middle;
           width: 8.125rem;
           height: 3.125rem;
           border: 2px solid var(--theme-button-border);
           border-radius: 0.25rem;
           background-color: var(--theme-button-bg);
           box-shadow: 0px 0px 2px 0px #333333;
           cursor: pointer;
           transition: background-color 0.3s, color 0.3s, border-color 0.3s;
       }


       .maxbutton:hover {
           background-color: var(--theme-button-hover-bg);
           border-color: var(--theme-button-hover-bg);
       }


       .maxbutton .mb-text {
           color: var(--theme-button-text);
           font-family: Arial, sans-serif;
           font-size: 1.3125rem;
           text-align: center;
           font-weight: bold;
           line-height: 1em;
           display: block;
           padding: 0.75rem 0px 0px 0px;
           transition: color 0.3s;
       }
      
       .maxbutton:hover .mb-text {
           color: var(--theme-button-hover-text);
       }


       .navbar {
           background-color: var(--theme-navbar-bg);
           padding: 0.9375rem 0;
           text-align: center;
           display: flex;
           justify-content: center;
           width: 100%;
           transition: background-color 0.3s ease;
       }
      
       .navbar-menu {
           display: flex;
           list-style-type: none;
           margin: 0;
           padding: 0;
       }
      
       .navbar-item {
           position: relative;
           margin: 0 1.25rem;
       }
      
       .navbar-link {
           color: var(--theme-navbar-text);
           text-decoration: none;
           font-size: 1.125rem;
           padding: 0.625rem 0.3125rem;
           display: flex;
           align-items: center;
           font-weight: bold;
           transition: color 0.3s ease;
       }
      
       .dropdown-icon {
           border: solid var(--theme-navbar-text);
           border-width: 0 2px 2px 0;
           display: inline-block;
           padding: 0.1875rem;
           margin-left: 0.3125rem;
           transform: rotate(45deg);
           transition: transform 0.3s, border-color 0.3s ease;
           will-change: transform;
       }
      
       .navbar-item:hover .dropdown-icon {
           transform: rotate(-135deg);
       }


       .navbar-item:hover .dropdown-menu {
           visibility: visible;
           opacity: 1;
       }
      
       .dropdown-menu {
           display: block;
           visibility: hidden;
           opacity: 0;
           transition: opacity 0.3s ease-in-out, visibility 0.3s ease-in-out;
           position: absolute;
           background-color: var(--theme-navbar-dropdown-bg);
           min-width: 12.5rem;
           box-shadow: 0rem 0.5rem 1rem 0rem rgba(0,0,0,0.1);
           z-index: 1;
           top: 100%;
           left: 0;
           text-align: left;
           border-radius: 0.25rem;
       }
      
       .dropdown-item {
           display: block;
           padding: 0.75rem 0.9375rem;
           color: var(--theme-navbar-dropdown-text);
           text-decoration: none;
           font-size: 1rem;
           font-weight: bold;
       }
      
       .dropdown-item:hover {
           background-color: var(--theme-navbar-dropdown-hover-bg);
       }


       /* --- ATTENDANCE FORM CONTAINER AND STYLES --- */
       .form-page-container {
           max-width: 900px;
           margin: 3rem auto;
           padding: 2rem;
           background-color: rgba(128, 128, 128, 0.1);
           border-radius: 1rem;
           border: 1px solid var(--theme-input-border);
       }


       .form-page-container h1 {
           text-align: center;
           color: var(--primary-green);
           margin-bottom: 0.5rem;
           font-size: 2.5rem;
       }


       .form-page-container p.subtitle {
           text-align: center;
           margin-bottom: 2.5rem;
           font-size: 1.1rem;
           color: var(--light-gray);
       }
      
       html[data-theme='light'] .form-page-container p.subtitle {
            color: #555;
       }


       .form-group {
           margin-bottom: 1.5rem;
       }


       .form-group label {
           display: block;
           margin-bottom: 0.5rem;
           font-weight: bold;
           font-size: 0.9rem;
           color: var(--theme-body-color);
       }


       .form-group select {
           width: 100%;
           padding: 0.75rem;
           border: 1px solid var(--theme-input-border);
           border-radius: 0.25rem;
           background-color: var(--theme-input-bg);
           color: var(--theme-input-text);
           box-sizing: border-box;
           font-size: 1rem;
       }
      
       .attendance-table {
           width: 100%;
           border-collapse: collapse;
           margin-top: 1.5rem;
       }
      
       .attendance-table th, .attendance-table td {
           padding: 1rem;
           text-align: left;
           border-bottom: 1px solid var(--theme-input-border);
       }
      
       .attendance-table th {
           background-color: var(--theme-input-bg);
           font-weight: bold;
       }
      
       .attendance-table tr:hover {
           background-color: rgba(128, 128, 128, 0.1);
       }
      
       .attendance-status {
           display: flex;
           gap: 1rem;
           align-items: center;
       }


       .attendance-status label {
           cursor: pointer;
           display: flex;
           align-items: center;
           gap: 0.5rem;
       }
      
       .attendance-status input[type="radio"] {
           appearance: none;
           width: 1.25rem;
           height: 1.25rem;
           border: 2px solid var(--theme-input-border);
           border-radius: 50%;
           cursor: pointer;
           transition: background-color 0.2s, border-color 0.2s;
           position: relative;
       }
      
       .attendance-status input[type="radio"]:checked {
           border-color: var(--primary-green);
       }
      
       .attendance-status input[type="radio"]:checked::after {
           content: '';
           display: block;
           width: 0.75rem;
           height: 0.75rem;
           background-color: var(--primary-green);
           border-radius: 50%;
           position: absolute;
           top: 50%;
           left: 50%;
           transform: translate(-50%, -50%);
       }


       .submit-button {
           background: linear-gradient(135deg,rgb(5,114,21) 0%,rgb(55,175,75) 100%);
           color: #fff;
           border: none;
           padding: 0.9375rem 1.25rem;
           width: 100%;
           border-radius: 0.5rem;
           cursor: pointer;
           font-weight: bold;
           font-size: 1.25rem;
           margin-top: 2rem;
           transition: transform 0.2s, box-shadow 0.2s;
       }


       .submit-button:hover {
           transform: translateY(-2px);
           box-shadow: 0 4px 10px rgba(55, 175, 75, 0.4);
       }


       /* --- Footer Styles --- */
       .footer-container {
           background: linear-gradient(135deg, rgb(5, 114, 21) 0%, rgb(55, 175, 75) 100%);
           padding: 1rem 0;
           color: #FEFEFE; 
       }


       .footer-content {
