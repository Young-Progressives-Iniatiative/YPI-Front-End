           flex-direction: column;
           align-items: center;
           flex: 1;
           padding: 0.625rem;
       }


       .footer-column.center-column {
           text-align: center;
       }


       .footer-column.right-column {
           align-items: flex-start;
       }


       .footer-container .site-logo {
           width: 10.4125rem;
           height: auto;
           object-fit: contain;
           margin-bottom: -2rem;
       }


       .company-heading {
           font-size: 1.25rem;
           text-align: center;
           font-weight: bold;
           margin: 0;
       }


       .instagram-link {
           display: flex;
           align-items: center;
           text-decoration: none;
           color: white;
           margin-top: 0.625rem;
       }


       .instagram-link img {
           width: 2.5625rem;
           height: auto;
           color: white;
           margin-right: 0.625rem;
       }


       .instagram-link span {
           font-size: 135%;
       }


       .address {
           width: 100%;
           text-align: center;
           margin-top: 1rem;
           padding-bottom: 0.3125rem;
           font-size: 0.8rem;
           color: #ccc;
       }
      
       html[data-theme='light'] .address p {
           color: #1c1c1c;
       }
      
       .spacer-column {
           flex-basis: 6.25rem;
           flex-grow: 0;
       }


       /* Custom message box styles */
       .message-box-overlay {
           position: fixed;
           top: 0;
           left: 0;
           width: 100%;
           height: 100%;
           background-color: rgba(0, 0, 0, 0.5);
           z-index: 10000;
           display: flex;
           justify-content: center;
           align-items: center;
           visibility: hidden;
           opacity: 0;
           transition: opacity 0.3s ease-in-out, visibility 0.3s ease-in-out;
       }


       .message-box {
           background-color: var(--theme-body-bg);
           color: var(--theme-body-color);
           padding: 1.5625rem;
           border-radius: 0.5rem;
           box-shadow: 0 0.3125rem 0.9375rem rgba(0, 0, 0, 0.3);
           max-width: 21.875rem;
           width: 90%;
           text-align: center;
           position: relative;
       }


       .message-box h3 {
           margin-top: 0;
           margin-bottom: 0.9375rem;
           color: var(--primary-green);
       }


       .message-box p {
           margin-bottom: 1.25rem;
           font-size: 1.1rem;
       }


       .message-box button {
           background-color: var(--primary-green);
           color: #1c1c1c;
           border: none;
           padding: 0.625rem 1.25rem;
           border-radius: 0.3125rem;
           cursor: pointer;
           font-weight: bold;
           transition: background-color 0.2s ease;
       }


       .message-box button:hover {
           background-color: #2e9b41;
       }
   </style>
