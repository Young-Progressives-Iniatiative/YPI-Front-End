<script>
document.addEventListener('DOMContentLoaded', () => {
lucide.createIcons();
initNav();
initQueryBuilder();
renderVolunteers();
});

// --- NAV LOGIC ---
function initNav() {
const navItems = ['Volunteer Database', 'Organizing', 'Field Operations', 'Analytics', 'Partner Intelligence'];
const navContainer = document.getElementById('main-nav');
navItems.forEach((item, idx) => {
const btn = document.createElement('button');
const isActive = idx === 0;
btn.className = `group flex items-center px-3 py-2 text-lg font-bold tracking-tight font-fm-header transition-all cursor-pointer ${isActive ? 'text-[#98fb98] drop-shadow-[0_0_8px_rgba(152,251,152,0.25)] scale-105' : 'text-gray-400 hover:text-white hover:scale-105'}`;
btn.innerHTML = `<span>${item}</span>`;
btn.addEventListener('click', function() {
Array.from(navContainer.children).forEach(c => c.className = 'group flex items-center px-3 py-2 text-lg font-bold tracking-tight font-fm-header transition-all cursor-pointer text-gray-400 hover:text-white hover:scale-105');
this.className = 'group flex items-center px-3 py-2 text-lg font-bold tracking-tight font-fm-header transition-all cursor-pointer text-[#98fb98] drop-shadow-[0_0_8px_rgba(152,251,152,0.25)] scale-105';
});
navContainer.appendChild(btn);
});
}

// --- QUERY BUILDER LOGIC ---
const fields = [
{val:'evL+', label:'evL+ Score'},
{val:'gpa', label:'GPA'},
{val:'hours', label:'Volunteer Hours'},
{val:'status', label:'Status'},
{val:'location', label:'Location'},
{val:'role', label:'Role'}
];
const ops = ['is', 'is not', 'is greater than', 'is less than', 'contains'];
let matchMode = 'strict';

function initQueryBuilder() {
addQueryRow(1, 'evL+', 'is greater than', '100');
addQueryRow(2, 'status', 'is not', 'Dormant');
}

window.addQueryRow = function(id, field='', op='', val='') {
const container = document.getElementById('query-rows-container');
const newId = id || Date.now();
const count = container.children.length;
const row = document.createElement('div');
row.className = 'query-row fade-in';
row.dataset.id = newId;

let logicHtml = '';
if(count === 0) {
logicHtml = `<div class="logic-operator">IF</div>`;
} else {
logicHtml = `<select class="logic-select" onchange="updateLogic(this)"><option>AND</option><option>OR</option><option>NOT</option></select>`;
}

let fieldOptions = fields.map(f => `<option value="${f.val}" ${f.val===field?'selected':''}>${f.label}</option>`).join('');
let opOptions = ops.map(o => `<option ${o===op?'selected':''}>${o}</option>`).join('');

row.innerHTML = `
${logicHtml}
<div class="query-input-group">
<select class="query-field" onchange="updateRow()">${fieldOptions}</select>
<div class="w-px h-6 bg-[#333]"></div>
<select class="query-op" onchange="updateRow()">${opOptions}</select>
<div class="w-px h-6 bg-[#333]"></div>
<input type="text" class="query-val" value="${val}" placeholder="Value..." oninput="updateRow()">
</div>
<button class="remove-btn" onclick="this.parentElement.remove(); updateRow()"><i data-lucide="minus-circle" class="w-4 h-4"></i></button>
`;
container.appendChild(row);
lucide.createIcons();
updateRow();
}

window.updateLogic = function(select) {
const val = select.value;
if(val === 'AND') select.style.color = 'var(--highlight-green)';
else if(val === 'OR') select.style.color = '#fbbf24';
else select.style.color = '#ef4444';
}

window.updateRow = function() {
document.getElementById('filter-count').innerText = document.getElementById('query-rows-container').children.length;
}

window.switchTab = function(tab) {
document.getElementById('tab-filters').classList.toggle('active', tab === 'filters');
document.getElementById('tab-library').classList.toggle('active', tab === 'library');
document.getElementById('query-view').classList.toggle('hidden', tab !== 'filters');
document.getElementById('library-view').classList.toggle('hidden', tab !== 'library');
}

window.setMatchMode = function(mode) {
matchMode = mode;
document.getElementById('mode-strict').classList.toggle('active', mode==='strict');
document.getElementById('mode-flex').classList.toggle('active', mode==='flex');
document.getElementById('mode-custom').classList.toggle('active', mode==='custom');
}

// --- VOLUNTEERS RENDER ---
const volunteers = [
{name:'Alex Johnson', role:'Field Organizer', status:'Active', statusClass:'status-active', tags:['Canvassing', 'Leadership', 'Zone 4'], score:'842', hours:'142h', reliability:'High'},
{name:'Maria Garcia', role:'Phone Bank Lead', status:'Priority', statusClass:'status-priority', tags:['Spanish', 'Phone Bank', 'Data'], score:'790', hours:'98h', reliability:'Med'},
{name:'David Smith', role:'Event Staff', status:'Active', statusClass:'status-active', tags:['Logistics', 'Transport', 'Zone 2'], score:'615', hours:'45h', reliability:'High'},
{name:'Emily Chen', role:'Canvasser', status:'Dormant', statusClass:'status-dormant', tags:['Campus', 'Digital Outreach'], score:'320', hours:'12h', reliability:'Low'},
{name:'Michael Brown', role:'Field Coordinator', status:'Priority', statusClass:'status-priority', tags:['Strategy', 'Training', 'Zone 1'], score:'910', hours:'210h', reliability:'High'},
{name:'Sarah Connor', role:'Recruiter', status:'Active', statusClass:'status-active', tags:['Social Media', 'Events'], score:'755', hours:'67h', reliability:'Med'}
];

function renderVolunteers() {
const grid = document.getElementById('volunteers-grid');
grid.innerHTML = '';
volunteers.forEach((v, i) => {
const initials = v.name.split(' ').map(n=>n[0]).join('');
const card = document.createElement('div');
card.className = 'vol-card fade-in';
card.style.animationDelay = `${i*0.05}s`;
card.innerHTML = `
<div class="vol-header">
<div class="vol-avatar">${initials}</div>
<div class="vol-info">
<div class="vol-name">${v.name}</div>
<div class="vol-role">${v.role}</div>
</div>
<span class="vol-status ${v.statusClass}">${v.status}</span>
</div>
<div class="vol-tags">${v.tags.map(t=>`<span class="vol-tag">${t}</span>`).join('')}</div>
<div class="vol-metrics">
<div class="metric-box"><div class="metric-label">evL+ Score</div><div class="metric-val metric-high">${v.score}</div></div>
<div class="metric-box"><div class="metric-label">Hours</div><div class="metric-val">${v.hours}</div></div>
<div class="metric-box"><div class="metric-label">Compatibility</div><div class="metric-val metric-high">92%</div></div>
<div class="metric-box"><div class="metric-label">Reliability</div><div class="metric-val">${v.reliability}</div></div>
</div>
<div class="vol-footer">
<button class="vol-btn btn-primary" onclick="event.stopPropagation(); alert('Message sent to ${v.name}')">Outreach</button>
<button class="vol-btn btn-secondary" onclick="openVolunteerModal('${v.name}', '${v.role}')">View Profile</button>
</div>
`;
card.addEventListener('click', () => openVolunteerModal(v.name, v.role));
grid.appendChild(card);
});
lucide.createIcons();
}

window.openVolunteerModal = function(name, role) {
document.getElementById('modal-name').innerText = name;
document.getElementById('modal-role').innerText = role;
document.getElementById('volunteerModal').classList.add('active');
}

window.closeVolunteerModal = function() {
document.getElementById('volunteerModal').classList.remove('active');
}

// Close modal on outside click
document.getElementById('volunteerModal').addEventListener('click', (e) => {
if(e.target.id === 'volunteerModal') closeVolunteerModal();
});
</script>
</body>
</html>

