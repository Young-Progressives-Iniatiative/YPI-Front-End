<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Nonprofit Applicant Dashboard</title>
    
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    
    <!-- Chart.js for the Radar Chart -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    
    <!-- Google Fonts: Atkinson Hyperlegible -->
    <link href="https://fonts.googleapis.com/css2?family=Atkinson+Hyperlegible:ital,wght@0,400;0,700;1,400;1,700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400&display=swap" rel="stylesheet">
    
    <!-- Lucide Icons -->
    <script src="https://unpkg.com/lucide@latest"></script>

    <style>
        /* --- CORE THEME VARIABLES --- */
        :root {
            --bg-main: #1c1c1c;
            --bg-panel: #1b1b1b;
            --bg-element: #2a2d35;
            --text-main: #ffffff;
            --text-muted: #9ca3af;
            --border-color: #2a2a2a;
            --accent-green: #37af4b;
            --highlight-green: #98fb98;
            --brand-color: #9afda7;
            --nav-inactive: #9ca3af;
            --nav-active: #98fb98;
            --notification-red: #ef4444;
        }

        /* --- LIGHT MODE OVERRIDES --- */
        body.light-mode {
            --bg-main: #f3f4f6;
            --bg-panel: #ffffff;
            --bg-element: #e5e7eb;
            --text-main: #111827;
            --text-muted: #4b5563;
            --border-color: #d1d5db;
            --accent-green: #16a34a;
            --highlight-green: #15803d;
            --brand-color: #16a34a;
            --nav-inactive: #6b7280;
            --nav-active: #16a34a;
        }

        body {
            font-family: 'Atkinson Hyperlegible', sans-serif;
            background-color: var(--bg-main);
            color: var(--text-main);
            margin: 0;
            overflow: hidden; /* Prevent body scroll, handle in dashboard */
            transition: background-color 0.3s ease, color 0.3s ease;
        }
        
        .font-mono { font-family: 'JetBrains Mono', monospace; }
        .font-fm-header { font-family: 'Atkinson Hyperlegible', sans-serif; }

        /* --- LOGO INVERSION --- */
        .logo-img { transition: filter 0.3s ease; }
        body.light-mode .logo-img { filter: invert(1); }

        /* --- TAB CONTENT STYLES --- */
        .tab-content {
            display: none;
            width: 100%;
            height: calc(100vh - 64px); /* Full height minus header */
        }
        
        .tab-content.active {
            display: flex;
            flex-direction: column;
        }

        /* --- UTILS --- */
        .no-scrollbar::-webkit-scrollbar { display: none; }
        .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
        
        .theme-bg-panel { background-color: var(--bg-panel); }
        .theme-bg-element { background-color: var(--bg-element); }
        .theme-border { border-color: var(--border-color); }
        .theme-text-muted { color: var(--text-muted); }
        .theme-text-main { color: var(--text-main); }

        /* Active Tab Effects */
        .nav-active {
            color: var(--nav-active) !important;
            text-shadow: 0 0 8px rgba(152,251,152,0.2);
            transform: scale(1.05);
        }

        /* Context Menu Animation */
        #context-menu {
            transition: opacity 0.1s ease, transform 0.1s ease;
            opacity: 0;
            pointer-events: none;
            transform: scale(0.95);
        }
        #context-menu.visible {
            opacity: 1;
            pointer-events: auto;
            transform: scale(1);
        }
    </style>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        brand: {
                            DEFAULT: '#9afda7',
                            hover: '#84e390',
                            dim: 'rgba(154, 253, 167, 0.1)',
                        }
                    }
                }
            }
        }
    </script>
</head>
