        // ---------------------------------------------------------
        function renderHeaderNotifications() {
            const list = document.getElementById('header-notif-list');
            const badge = document.getElementById('notifBadge');
            const unread = notifications.filter(n => !n.read);
            
            // Update badge visibility
            if (unread.length === 0) {
                badge.classList.add('hidden'); // Hide the bubble
                badge.innerText = ''; // Remove number insert
            } else {
                badge.classList.remove('hidden'); // Show the bubble
                badge.innerText = unread.length;
            }
            
            if (unread.length === 0) {
                 list.innerHTML = `<div class="p-4 text-center text-xs theme-text-muted">No new notifications</div>`;
                 return;
            }

            // Map Applicant data to header notifications
            list.innerHTML = unread.map(item => `
                <div onclick="openFromNotification(${item.id})" class="p-4 border-b theme-border hover:theme-bg-element transition-colors cursor-pointer flex gap-3">
                    <div class="w-8 h-8 rounded-full bg-green-500/20 flex items-center justify-center flex-shrink-0 text-green-500">
                        <i data-lucide="user-plus" class="w-4 h-4"></i>
                    </div>
                    <div class="flex flex-col text-left">
                        <p class="text-xs font-semibold theme-text-main">New Application: ${item.role}</p>
                        <p class="text-[10px] theme-text-muted mt-0.5">${item.applicantName} just applied.</p>
                        <p class="text-[9px] theme-text-muted mt-1">${item.time}</p>
                    </div>
                </div>
            `).join('');
            lucide.createIcons();
        }

        // Global function to trigger opening a notification from the header
        window.openFromNotification = function(id) {
            // 1. Navigate to Notifications tab
            navigateTo('Notifications');
            
            // 2. Select the notification
            selectNotification(id);
            
            // 3. Close the header dropdown (optional hack: click body)
            document.body.click();
        };

        // ---------------------------------------------------------
        // DASHBOARD FUNCTIONS
        // ---------------------------------------------------------
        function initFilters() {
            const container = document.getElementById('filter-container');
            container.innerHTML = filters.map(f => `
                <button 
                    onclick="setFilter('${f}')"
                    class="filter-btn px-3 py-1 rounded-full border whitespace-nowrap transition-colors ${
                        currentFilter === f 
                            ? 'theme-bg-element theme-text-main theme-border'
                            : 'bg-transparent theme-text-muted border-transparent hover:theme-bg-element'
                    }"
                    data-filter="${f}"
                >
                    ${f}
                </button>
            `).join('');
        }

        function setFilter(filter) {
            currentFilter = filter;
            renderList();
            document.querySelectorAll('.filter-btn').forEach(btn => {
                const isSelected = btn.getAttribute('data-filter') === filter;
                btn.className = `filter-btn px-3 py-1 rounded-full border whitespace-nowrap transition-colors ${
                    isSelected 
                        ? 'theme-bg-element theme-text-main theme-border'
                        : 'bg-transparent theme-text-muted border-transparent hover:theme-bg-element'
                }`;
            });
        }

        function renderList() {
            const listContainer = document.getElementById('notification-list');
            const filtered = notifications.filter(n => {
                const matchesSearch = n.applicantName.toLowerCase().includes(searchQuery.toLowerCase()) || 
                                      n.role.toLowerCase().includes(searchQuery.toLowerCase());
                if (!matchesSearch) return false;
                if (currentFilter === 'All') return true;
                if (currentFilter === 'Unread') return !n.read;
                if (currentFilter === 'High Priority') return n.priority === 'High';
                if (currentFilter === 'Reviewing') return n.status === 'Reviewing';
                return true;
            });

            // Unread Count (Sidebar)
            const unreadCount = notifications.filter(n => !n.read).length;
            const badge = document.getElementById('unread-count');
            badge.innerText = `${unreadCount} Unread`;
            badge.className = `text-xs px-2 py-1 rounded-full font-medium ${
                unreadCount > 0 ? 'bg-[var(--nav-active)]/20 text-[var(--nav-active)]' : 'theme-bg-element theme-text-muted'
            }`;

            listContainer.innerHTML = filtered.map(item => `
                <div 
                    onclick="selectNotification(${item.id})"
                    class="p-4 border-b theme-border cursor-pointer hover:theme-bg-element transition-colors group relative ${
                        selectedId === item.id 
                        ? 'bg-[var(--nav-active)]/10 border-l-4 border-l-[var(--nav-active)]' 
                        : 'border-l-4 border-l-transparent'
                    }"
                >
                    <div class="flex justify-between items-start mb-1">
                        <span class="font-semibold text-sm ${!item.read ? 'text-[var(--nav-active)]' : 'theme-text-main'}">
                            ${item.applicantName}
                        </span>
                        <span class="text-xs theme-text-muted whitespace-nowrap">${item.date}</span>
                    </div>
                    <div class="text-xs font-medium theme-text-muted mb-1">
                        New applicant for <span class="theme-text-main">${item.role}</span>
                    </div>
                    <p class="text-xs theme-text-muted line-clamp-2 leading-relaxed opacity-70">
                        ${item.summary.narrative}
                    </p>
                    ${!item.read ? '<span class="absolute top-4 right-4 w-2 h-2 bg-[var(--nav-active)] rounded-full"></span>' : ''}
                </div>
            `).join('');
        }

        function selectNotification(id) {
            selectedId = id;
            // Mark as read immediately when selected
            notifications = notifications.map(n => n.id === id ? { ...n, read: true } : n);
            
            renderList();
            renderDetail();
            renderHeaderNotifications(); // Update header badge too
        }

        function renderDetail() {
            const container = document.getElementById('detail-view');
            const rightPanel = document.getElementById('right-panel');

            // --- EMPTY STATE CHECK ---
            if (selectedId === null) {
                container.innerHTML = `
                    <div class="h-full flex flex-col items-center justify-center text-center opacity-40 select-none">
                        <div class="w-24 h-24 rounded-full bg-[var(--bg-element)] flex items-center justify-center mb-6">
                            <i data-lucide="inbox" class="w-10 h-10 theme-text-muted"></i>
                        </div>
                        <h3 class="text-xl font-bold theme-text-main mb-2">No Applicant Selected</h3>
                        <p class="text-sm theme-text-muted max-w-xs mx-auto">Select a notification from the list or the top-right alert menu to view applicant details.</p>
                    </div>
                `;
                rightPanel.classList.add('hidden'); // Hide right panel
                document.getElementById('pagination-text').innerText = `- of ${notifications.length}`;
                lucide.createIcons();
                return;
            }

            // --- SHOW ACTIVE CONTENT ---
            rightPanel.classList.remove('hidden'); // Show right panel
            const data = notifications.find(n => n.id === selectedId);
            
            document.getElementById('pagination-text').innerText = `${data.id} of ${notifications.length}`;

            // Updated color logic to use new pastel blue/Cinnamoroll palette
            const getRecColor = (rec) => {
                switch (rec) {
                    case 'Interview': return 'bg-emerald-900/30 text-emerald-300 border-emerald-800/50';
                    case 'Advance': return 'bg-blue-900/30 text-blue-300 border-blue-800/50';
                    case 'Redirect': return 'bg-sky-900/30 text-sky-200 border-sky-800/50'; 
                    default: return 'theme-bg-element theme-text-muted';
                }
            };

            container.innerHTML = `
                <div class="mb-8 animate-[fadeIn_0.3s_ease-out]">
                    <div class="text-xs font-mono theme-text-muted mb-2">
                        INTERNAL ID: #${data.id}2024-X
                    </div>
                    <h1 class="text-2xl font-bold theme-text-main mb-2">
                        New Applicant: ${data.role}
                    </h1>
                    <div class="flex items-center gap-4 text-sm theme-text-muted">
                        <div class="flex items-center gap-1">
                            <i data-lucide="user" class="w-4 h-4"></i>
                            <a href="#" class="font-medium text-[var(--nav-active)] hover:underline transition-colors">
                                ${data.applicantName}
                            </a>
                        </div>
                        <span>•</span>
                        <div class="flex items-center gap-1">
                            <i data-lucide="calendar" class="w-4 h-4"></i>
                            <span>${data.date} at ${data.time}</span>
                        </div>
                        <span>•</span>
                        <span class="px-2 py-0.5 rounded text-xs border ${
                            data.priority === 'High' ? 'bg-blue-900/40 text-blue-200 border-blue-800/50' : 'theme-bg-element theme-border theme-text-muted'
                        }">
                            ${data.priority} Priority
                        </span>
                    </div>
                </div>

                <!-- Cinnamoroll Theme Summary Block -->
                <div class="bg-sky-900/10 border border-sky-800/30 rounded-lg p-6 mb-8 animate-[fadeIn_0.4s_ease-out]">
                    <div class="flex items-center gap-2 text-sm text-sky-200/90 mb-3 pb-3 border-b border-sky-800/30">
                        <span class="font-bold tracking-wide text-xs uppercase opacity-70">Education</span>
                        <span class="w-1 h-1 rounded-full bg-sky-300"></span>
                        <span class="font-medium">${data.summary.education}</span>
                        <span class="text-sky-400/50">•</span>
                        <span>GPA ${data.summary.gpa}</span>
                    </div>
                    <p class="theme-text-main leading-relaxed mb-4">
                        ${data.summary.narrative}
                    </p>
                    <div class="theme-bg-panel p-3 rounded border border-sky-800/30 text-sm text-sky-200/70 italic flex gap-3 items-start">
                        <i data-lucide="activity" class="w-4 h-4 shrink-0 mt-0.5"></i>
                        ${data.summary.instruction}
                    </div>
                </div>

                <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-8 animate-[fadeIn_0.5s_ease-out]">
                    <!-- Work Style -->
                    <div class="theme-bg-panel rounded-lg p-5 border theme-border">
                        <div class="flex justify-between items-center mb-4">
                            <h3 class="font-semibold theme-text-main">Work Style Profile</h3>
                            <div class="px-3 py-1 rounded text-xs font-bold border ${getRecColor(data.workStyle.recommendation)}">
                                Rec: ${data.workStyle.recommendation}
                            </div>
                        </div>
                        <div class="space-y-4">
                            <div>
                                <label class="text-xs theme-text-muted uppercase font-bold">Primary Profile</label>
                                <div class="text-sm font-medium text-[var(--nav-active)] bg-[var(--nav-active)]/10 px-3 py-2 rounded border border-[var(--nav-active)]/20 mt-1">
                                    ${data.workStyle.primary}
                                </div>
                            </div>
                            <div class="flex gap-4">
                                <div class="flex-1">
                                    <label class="text-xs theme-text-muted uppercase font-bold">Secondary</label>
                                    <div class="text-sm theme-text-muted mt-1">${data.workStyle.alternate}</div>
                                </div>
                                <div class="flex-1">
                                    <label class="text-xs theme-text-muted uppercase font-bold">Eliminated</label>
                                    <div class="text-sm theme-text-muted mt-1 line-through">${data.workStyle.eliminated}</div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Strengths & Dev -->
                    <div class="flex flex-col gap-4">
                        <div class="flex-1">
                            <h4 class="text-xs font-bold text-emerald-400 uppercase mb-2 flex items-center gap-1">
                                <i data-lucide="check-circle" class="w-3.5 h-3.5"></i> Strengths
                            </h4>
                            <ul class="text-sm space-y-1">
                                ${data.strengths.map(s => `
                                    <li class="flex gap-2 theme-text-main"><span class="text-emerald-500/80">•</span> ${s}</li>
                                `).join('')}
                            </ul>
                        </div>
                        <div class="h-px theme-border border-b"></div>
                        <div class="flex-1">
                            <h4 class="text-xs font-bold text-orange-400 uppercase mb-2 flex items-center gap-1">
                                <i data-lucide="alert-circle" class="w-3.5 h-3.5"></i> Support Needs
                            </h4>
                            <ul class="text-sm space-y-1">
                                ${data.development.map(s => `
                                    <li class="flex gap-2 theme-text-main"><span class="text-orange-500/80">•</span> ${s}</li>
                                `).join('')}
                            </ul>
                        </div>
                    </div>
                </div>

                <div class="mt-8 pt-6 border-t theme-border flex items-center justify-end animate-[fadeIn_0.6s_ease-out]">
                    <div class="flex gap-3">
                        <button class="flex items-center gap-2 px-4 py-2 theme-bg-panel border theme-border rounded shadow-sm text-sm font-medium theme-text-main hover:theme-bg-element transition-colors">
                            <i data-lucide="thumbs-down" class="w-4 h-4"></i> Hold
                        </button>
                        <button class="flex items-center gap-2 px-4 py-2 bg-[var(--nav-active)] border border-transparent rounded shadow-sm text-sm font-bold text-black hover:opacity-90 transition-colors">
                            <i data-lucide="thumbs-up" class="w-4 h-4 text-black"></i> Advance to Interview
                        </button>
                    </div>
                </div>
            `;
            
            // Right Panel Data
            document.getElementById('fit-score').innerText = `${data.workStyle.fitScore}/100`;
            const qnaContainer = document.getElementById('qna-container');
            qnaContainer.innerHTML = data.qna.map(qa => `
                <div class="group">
                    <div class="flex items-start gap-2 mb-1">
                        <i data-lucide="message-square" class="w-3 h-3 theme-text-muted mt-1"></i>
                        <p class="text-xs font-semibold theme-text-main">${qa.q}</p>
                    </div>
                    <div class="pl-5 border-l-2 theme-border ml-1.5">
                        <p class="text-xs theme-text-muted italic">"${qa.a}"</p>
                    </div>
                </div>
            `).join('');

            lucide.createIcons();
            renderChart(data);
        }

        function initListeners() {
            document.getElementById('search-input').addEventListener('input', (e) => {
                searchQuery = e.target.value;
                renderList();
            });

            const markAsRead = () => {
                notifications = notifications.map(n => n.id === selectedId ? { ...n, read: true } : n);
                renderList();
                renderHeaderNotifications(); // Add this
                closeMenus();
            };

            const btnActions = document.getElementById('btn-actions');
            const dropdown = document.getElementById('actions-dropdown');
            
            btnActions.addEventListener('click', (e) => {
                e.stopPropagation();
                dropdown.classList.toggle('hidden');
                document.getElementById('context-menu').classList.remove('visible');
            });

            document.getElementById('action-mark-read').addEventListener('click', markAsRead);
            document.getElementById('ctx-mark-read').addEventListener('click', markAsRead);

            const mainArea = document.getElementById('main-content-area');
            const ctxMenu = document.getElementById('context-menu');
            mainArea.addEventListener('contextmenu', (e) => {
                e.preventDefault();
                closeMenus();
                ctxMenu.style.top = `${e.clientY}px`;
                ctxMenu.style.left = `${e.clientX}px`;
                ctxMenu.classList.add('visible');
            });

            document.addEventListener('click', closeMenus);
            dropdown.addEventListener('click', (e) => e.stopPropagation());
        }

        function closeMenus() {
            document.getElementById('actions-dropdown').classList.add('hidden');
            document.getElementById('context-menu').classList.remove('visible');
        }

        // ---------------------------------------------------------
        // HEADER LOGIC
        // ---------------------------------------------------------
        function setupHeaderLogic() {
            const themeToggle = document.getElementById('themeToggle');
            const notifToggle = document.getElementById('notifToggle');
            const body = document.body;
            
            themeToggle.addEventListener('click', () => {
                body.classList.toggle('light-mode');
                const isLight = body.classList.contains('light-mode');
                
                document.getElementById('themeIconSun').classList.toggle('hidden', isLight);
                document.getElementById('themeIconMoon').classList.toggle('hidden', !isLight);
                document.getElementById('notifIconDark').classList.toggle('hidden', isLight);
                document.getElementById('notifIconLight').classList.toggle('hidden', !isLight);

                // Re-render chart to pick up new variable colors
                if(selectedId !== null) renderDetail();
            });

            // Make the Bell toggle trigger the Notifications view
            notifToggle.addEventListener('click', (e) => {
                // If it was just a simple click (not on dropdown items), navigate to tab
                // Dropdown logic is CSS based, but click goes to main view
                navigateTo('Notifications');
            });

            const navItems = ['Vision', 'Organizing', 'Financials', 'Data Suite', 'Projects', 'Marketing', 'Donors'];
            const navContainer = document.getElementById('main-nav');
            const navHistory = ['Vision'];
            let historyIndex = 0;
            const navBackBtn = document.getElementById('navBackBtn');
            const navForwardBtn = document.getElementById('navForwardBtn');

            function updateNavButtons() {
                if (historyIndex > 0) navBackBtn.classList.remove('opacity-50', 'cursor-not-allowed');
                else navBackBtn.classList.add('opacity-50', 'cursor-not-allowed');
                
                if (historyIndex < navHistory.length - 1) navForwardBtn.classList.remove('opacity-50', 'cursor-not-allowed');
                else navForwardBtn.classList.add('opacity-50', 'cursor-not-allowed');
            }

            // Expose navigateTo globally so other functions can use it
            window.navigateTo = function(tabName, isHistoryNav = false) {
                if (!isHistoryNav) {
                    if (historyIndex < navHistory.length - 1) navHistory.splice(historyIndex + 1);
                    if (navHistory[historyIndex] !== tabName) {
                        navHistory.push(tabName);
                        historyIndex = navHistory.length - 1;
                    }
                }
                
                // Switch Content
                document.querySelectorAll('.tab-content').forEach(s => s.classList.remove('active'));
                const t = document.getElementById(`content-${tabName}`);
                if (t) t.classList.add('active');

                // Handle Tab Styles
                if (tabName === 'Notifications') {
                    // Highlight Bell
                    const bell = document.getElementById('notifToggle');
                    bell.classList.add('nav-active');
                    bell.classList.remove('text-[var(--nav-inactive)]');
                    
                    // Unhighlight Text Tabs
                    Array.from(navContainer.children).forEach(btn => {
                        btn.style.color = 'var(--nav-inactive)';
                        btn.classList.remove('scale-105');
                        btn.style.textShadow = 'none';
                    });
                } else {
                    // Unhighlight Bell
                    const bell = document.getElementById('notifToggle');
                    bell.classList.remove('nav-active');
                    bell.classList.add('text-[var(--nav-inactive)]');

                    // Highlight active Text Tab
                    Array.from(navContainer.children).forEach(btn => {
                        const span = btn.querySelector('span');
                        if (span && span.innerText === tabName) {
                            btn.style.color = 'var(--nav-active)';
                            btn.className = 'group flex items-center px-3 py-2 text-xl font-bold tracking-tight font-fm-header transition-all cursor-pointer scale-105';
                            btn.style.textShadow = '0 0 8px rgba(152,251,152,0.2)';
                        } else {
                            btn.style.color = 'var(--nav-inactive)';
                            btn.className = 'group flex items-center px-3 py-2 text-xl font-bold tracking-tight font-fm-header transition-all cursor-pointer hover:theme-text-main hover:scale-105';
                            btn.style.textShadow = 'none';
                        }
                    });
                }
                updateNavButtons();
            }

            navItems.forEach(item => {
                const btn = document.createElement('button');
                btn.className = 'group flex items-center px-3 py-2 text-xl font-bold tracking-tight font-fm-header transition-all cursor-pointer hover:scale-105';
                btn.innerHTML = `<span>${item}</span>`;
                btn.style.color = item === 'Vision' ? 'var(--nav-active)' : 'var(--nav-inactive)';
                btn.addEventListener('click', () => navigateTo(item));
                navContainer.appendChild(btn);
            });
            
            // Init default state
            navigateTo('Vision');

            navBackBtn.addEventListener('click', () => {
                if (historyIndex > 0) { historyIndex--; navigateTo(navHistory[historyIndex], true); }
            });
            navForwardBtn.addEventListener('click', () => {
                if (historyIndex < navHistory.length - 1) { historyIndex++; navigateTo(navHistory[historyIndex], true); }
            });
        }
    </script>
</body>
</html>
