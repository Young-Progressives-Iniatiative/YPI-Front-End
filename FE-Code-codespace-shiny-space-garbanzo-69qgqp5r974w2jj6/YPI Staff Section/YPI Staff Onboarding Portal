      return {
        seasonName: `Fall ${year}`,
        startDate: `${year}-09-01`,
        endDate: `${year}-12-31`,
        autoDetect: true
      };
    } else if (month >= 0 && month <= 4) {
      return {
        seasonName: `Spring ${year}`,
        startDate: `${year}-01-01`,
        endDate: `${year}-05-31`,
        autoDetect: true
      };
    } else {
      return {
        seasonName: `Fall ${year}`,
        startDate: `${year}-09-01`,
        endDate: `${year}-12-31`,
        autoDetect: true
      };
    }
  };

  const saveSeasonSettings = async (settings) => {
