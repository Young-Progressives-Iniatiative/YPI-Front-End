  const calculateOptimalSchedule = () => {
    if (responses.length === 0) return null;

    const availability = {};
    
    responses.forEach(response => {
      response.availableDates.forEach(date => {
        const key = `${date}-${response.preferredTime}`;
        if (!availability[key]) {
          availability[key] = {
            date,
            time: response.preferredTime,
            count: 0,
            people: []
          };
        }
        availability[key].count++;
        availability[key].people.push(response.fullName);
      });
    });

    const sorted = Object.values(availability).sort((a, b) => b.count - a.count);
    const maxCount = sorted[0]?.count || 0;
    const optimalSlots = sorted.filter(slot => slot.count === maxCount);

    return {
      optimalSlots,
      totalResponses: responses.length,
      allAvailability: sorted
    };
  };

  const handleAdminLogin = () => {
    const apiTokenHash = Array.from('ypi2024').reduce((h, c) => Math.imul(31, h) + c.charCodeAt(0) | 0, 0);
    const inputHash = Array.from(adminPassword).reduce((h, c) => Math.imul(31, h) + c.charCodeAt(0) | 0, 0);
    
    if (inputHash === apiTokenHash) {
      setIsAuthenticated(true);
    } else {
      alert('Incorrect password');
    }
  };

  if (view === 'admin') {
