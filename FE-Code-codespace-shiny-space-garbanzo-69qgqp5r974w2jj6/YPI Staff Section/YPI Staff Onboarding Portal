            <div className="absolute top-0 right-0 w-64 h-64 bg-white opacity-5 rounded-full -mr-32 -mt-32"></div>
            <div className="absolute bottom-0 left-0 w-48 h-48 bg-white opacity-5 rounded-full -ml-24 -mb-24"></div>
            <div className="flex items-center gap-6 mb-2 relative z-10">
              <div className="bg-white p-4 rounded-2xl shadow-xl transform transition-transform hover:scale-105">
                <img 
                  src="https://weareypi.com/wp-content/uploads/2024/09/YPI-Logo.jpg" 
                  alt="YPI Logo" 
                  className="w-20 h-20 object-contain"
                />
              </div>
              <div>
                <h1 className="text-4xl font-bold mb-2 drop-shadow-lg">Onboarding Portal</h1>
                <p className="text-green-100 text-xl font-semibold">Young Progressives Initiative</p>
              </div>
            </div>
          </div>

          <div className="bg-gradient-to-r from-gray-50 to-green-50 px-10 py-4 border-b border-gray-200">
            <button
              onClick={() => setView('admin')}
              className="text-sm text-green-700 hover:text-green-800 font-bold flex items-center gap-2 transition-colors"
            >
              <span className="text-lg">🔐</span> Admin Dashboard
            </button>
          </div>

          <div className="p-10 space-y-10">
            <div className="space-y-8">
              <div className="flex items-center gap-3 pb-4 border-b-2 border-green-100">
                <div className="bg-green-100 p-3 rounded-xl">
                  <User className="w-6 h-6 text-green-600" />
                </div>
                <h2 className="text-2xl font-bold text-gray-900">Personal Information</h2>
              </div>

              <div>
                <label className="block text-base font-bold text-gray-700 mb-3">
                  Full Name <span className="text-red-500">*</span>
                </label>
                <input
                  type="text"
                  value={formData.fullName}
                  onChange={(e) => setFormData({...formData, fullName: e.target.value})}
                  className="w-full px-5 py-4 border-2 border-gray-300 rounded-xl focus:ring-2 focus:ring-green-500 focus:border-green-500 transition-all text-lg shadow-sm hover:shadow-md"
                  placeholder="Enter your full name"
                />
              </div>

              <div>
                <label className="block text-base font-bold text-gray-700 mb-3">
                  Email Address <span className="text-red-500">*</span>
                </label>
                <input
                  type="email"
                  value={formData.email}
                  onChange={(e) => setFormData({...formData, email: e.target.value})}
                  className="w-full px-5 py-4 border-2 border-gray-300 rounded-xl focus:ring-2 focus:ring-green-500 focus:border-green-500 transition-all text-lg shadow-sm hover:shadow-md"
                  placeholder="your.email@example.com"
                />
              </div>
            </div>

            <div className="space-y-8">
              <div className="flex items-center gap-3 pb-4 border-b-2 border-green-100">
                <div className="bg-green-100 p-3 rounded-xl">
                  <Calendar className="w-6 h-6 text-green-600" />
                </div>
                <h2 className="text-2xl font-bold text-gray-900">Your Availability</h2>
              </div>

              <div>
                <label className="block text-base font-bold text-gray-700 mb-4">
                  Select all Mondays you're available <span className="text-red-500">*</span>
                </label>
                <div className="grid grid-cols-1 gap-3">
                  {dateOptions.map(date => (
                    <button
                      key={date.id}
                      type="button"
                      onClick={() => handleDateToggle(date.value)}
                      className={`px-6 py-4 rounded-xl border-2 font-bold text-left transition-all duration-200 shadow-sm hover:shadow-lg transform hover:scale-102 ${
                        formData.availableDates.includes(date.value)
                          ? 'border-green-600 bg-gradient-to-r from-green-50 to-emerald-50 text-green-700 shadow-md'
                          : 'border-gray-300 bg-white text-gray-700 hover:border-green-300'
                      }`}
                    >
                      <span className="text-lg">{date.label}</span>
                    </button>
                  ))}
                </div>
              </div>

              <div>
                <label className="block text-base font-bold text-gray-700 mb-4">
                  Preferred Time Slot <span className="text-red-500">*</span>
                </label>
                <div className="space-y-3">
                  {timeSlots.map(slot => (
                    <label
                      key={slot.id}
                      className={`flex items-center p-5 border-2 rounded-xl cursor-pointer transition-all duration-200 shadow-sm hover:shadow-lg ${
                        formData.preferredTime === slot.value
                          ? 'border-green-600 bg-gradient-to-r from-green-50 to-emerald-50 shadow-md'
                          : 'border-gray-300 bg-white hover:border-green-300'
                      }`}
                    >
                      <input
                        type="radio"
                        name="preferredTime"
                        value={slot.value}
                        checked={formData.preferredTime === slot.value}
                        onChange={(e) => setFormData({...formData, preferredTime: e.target.value})}
                        className="w-5 h-5 text-green-600 focus:ring-green-500 focus:ring-2"
                      />
                      <span className="ml-4 text-gray-900 font-bold text-lg">{slot.label}</span>
                    </label>
                  ))}
                </div>
              </div>
            </div>

            <div>
              <label className="block text-base font-bold text-gray-700 mb-3">
                Additional Notes or Constraints
              </label>
              <textarea
                value={formData.additionalNotes}
                onChange={(e) => setFormData({...formData, additionalNotes: e.target.value})}
                rows="4"
                className="w-full px-5 py-4 border-2 border-gray-300 rounded-xl focus:ring-2 focus:ring-green-500 focus:border-green-500 transition-all resize-none text-lg shadow-sm hover:shadow-md"
                placeholder="Any specific time constraints, timezone information, or other relevant details..."
              />
            </div>

            <div className="pt-6">
              <button
                onClick={handleSubmit}
                className="w-full bg-gradient-to-r from-green-600 via-emerald-600 to-teal-600 text-white py-5 rounded-xl font-bold text-xl hover:from-green-700 hover:via-emerald-700 hover:to-teal-700 transition-all duration-200 shadow-xl hover:shadow-2xl transform hover:scale-105"
              >
                Submit Availability
              </button>
            </div>
          </div>
        </div>

        <p className="text-center text-gray-600 mt-8 text-base font-medium">
          Young Progressives Initiative • Onboarding Team
        </p>
      </div>
    </div>
  );
}
