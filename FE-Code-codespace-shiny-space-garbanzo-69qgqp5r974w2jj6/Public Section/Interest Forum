  <!-- Mobile Version -->
  <div class="mobile-device-frame">
    <div class="sidebar" id="mobileSidebar">
        <button class="close-btn" id="sidebarCloseBtn">&times;</button>
        <nav>
            <ul>
                <li><a href="https://weareypi.com/mission-statement/">Our Mission</a></li>
                <li><a href="https://weareypi.com/meet-ypi-roster/">Meet the YPI Team</a></li>
                <li><a href="https://weareypi.com/donate/">Donate</a></li>
                <li><a href="https://weareypi.com/info-guide/#">Information Guide</a></li>
                <li><a href="https://weareypi.com/need-volunteers/">Need Volunteers?</a></li>
            </ul>
        </nav>
    </div>
    <div class="sidebar-overlay" id="sidebarOverlay"></div>
    
