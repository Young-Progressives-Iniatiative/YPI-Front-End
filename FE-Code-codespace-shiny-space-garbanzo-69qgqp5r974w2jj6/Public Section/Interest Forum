                    <img src="https://logos-world.net/wp-content/uploads/2020/04/Instagram-Emblem.png" alt="Instagram">
                    <span>Instagram</span>
                </a>
            </div>
        </div>
        <div class="address"><p>Young Progressives Initiative L.L.C , Chevy Chase, MD 20815</p></div>
      </footer>
