  <script>
    // Combined script for all page functionality
    document.addEventListener('DOMContentLoaded', function() {
        
        // --- THEME TOGGLE SCRIPT ---
        function initializeThemeToggle() {
            const themeButtons = document.querySelectorAll('.theme-button');
            const htmlElement = document.documentElement;
            themeButtons.forEach(button => {
                button.addEventListener('click', () => {
                    const newTheme = htmlElement.getAttribute('data-theme') === 'light' ? 'dark' : 'light';
                    htmlElement.setAttribute('data-theme', newTheme);
                    localStorage.setItem('theme', newTheme);
                });
            });
        }

        // --- MOBILE SIDEBAR LOGIC ---
        function initializeSidebar() {
            const hamburgerTrigger = document.getElementById('mobileHamburgerTrigger');
            const sidebar = document.getElementById('mobileSidebar');
            const closeBtn = document.getElementById('sidebarCloseBtn');
            const overlay = document.getElementById('sidebarOverlay');
            const body = document.body;

            if (!hamburgerTrigger || !sidebar || !closeBtn || !overlay) return;

            const openSidebar = () => {
                sidebar.classList.add('open');
                overlay.classList.add('active');
                body.classList.add('sidebar-is-open');
            };

            const closeSidebar = () => {
                sidebar.classList.remove('open');
                overlay.classList.remove('active');
                body.classList.remove('sidebar-is-open');
            };

            hamburgerTrigger.addEventListener('click', openSidebar);
            closeBtn.addEventListener('click', closeSidebar);
            overlay.addEventListener('click', closeSidebar);
        }

        // This script handles the form submission using jQuery and AJAX.
        function setupFormSubmission(formId) {
            jQuery(formId).on('submit', function(e) {
                e.preventDefault();
                var formData = jQuery(this).serialize();

                // NOTE: 'ajaxurl' is a global variable in WordPress that points to admin-ajax.php.
                // This will work correctly when the code is on a WordPress page.
                // For local testing, you might need to replace 'ajaxurl' with a direct path.
                jQuery.ajax({
                    type: 'POST',
                    url: typeof ajaxurl !== 'undefined' ? ajaxurl : '/wp-admin/admin-ajax.php', 
                    data: {
                        action: 'ypi_register_member', // This action must be handled in your functions.php
                        formData: formData
                    },
                    success: function(response) {
                        // A more robust check for success from WordPress
                        if(response && response.success) {
                            alert('Thank you for registering with YPI! We will be in touch soon.');
                            jQuery(formId)[0].reset();
                        } else {
                            // Provide more specific feedback if available
                            const errorMessage = response.data ? response.data.message : 'Please try again.';
                            alert('There was an error processing your registration. ' + errorMessage);
                        }
                    },
                    error: function() {
                        alert('There was an error connecting to the server. Please check your internet connection and try again later.');
                    }
                });
            });
        }

        // Initialize all functionalities
        initializeThemeToggle();
        initializeSidebar();
        setupFormSubmission('#ypi-registration-form-desktop');
        setupFormSubmission('#ypi-registration-form-mobile');
    });

    // Dummy function for login popup link in header
    function ypiShowLoginPopup() {
        alert('Login popup would be displayed here.');
    }
  </script>
