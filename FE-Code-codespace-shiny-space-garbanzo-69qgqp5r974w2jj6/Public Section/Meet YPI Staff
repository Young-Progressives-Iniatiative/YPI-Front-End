                    <form>
                        <div>
                            <label for="ypi-username">Username</label>
                            <input type="text" id="ypi-username" required>
                        </div>
                        <div>
                            <label for="ypi-password">Password</label>
                            <input type="password" id="ypi-password" required>
                        </div>
                        <button type="submit">Sign In</button>
                    </form>
                    <div class="popup-links">
                         <!-- Corrected https -->
                        <a href="https://weareypi.com/join-ypi/">Register</a> |
                        <a href="https://weareypi.com/wp-login.php?action=lostpassword">Forgot Password?</a>
                    </div>
                </div>
            `;
             // Function to hide the popup
            const hidePopup = () => {
                overlay.style.opacity = '0';
                // Use setTimeout to allow fade-out animation before hiding
                setTimeout(() => {
                     overlay.style.visibility = 'hidden';
                     document.body.classList.remove('popup-is-open'); // Unlock scroll
                }, 300); // Match CSS transition time
            };

            // Add event listeners
            document.getElementById('ypi-popup-close').onclick = hidePopup;
            overlay.addEventListener('click', (e) => { if (e.target === overlay) hidePopup(); }); // Close on overlay click
            overlay.querySelector('form').onsubmit = (e) => { // Handle form submit
                e.preventDefault(); // Prevent actual form submission
                hidePopup();
                // Replace alert with custom message box
                showMessage('Login Submitted (Demo)', 'Login functionality is not implemented in this example.');
            };

            // Make overlay visible
            overlay.style.visibility = 'visible';
            overlay.style.opacity = '1';
        }

         // --- MESSAGE BOX FUNCTION ---
         // This function displays a simple message box instead of a native browser alert.
         function showMessage(title, message) {
            document.body.classList.add('popup-is-open'); // Lock scroll
            let overlay = document.getElementById('messageBoxOverlay');
            if (!overlay) { // Create overlay if it doesn't exist
                overlay = document.createElement('div');
                overlay.id = 'messageBoxOverlay';
                overlay.className = 'message-box-overlay';
                document.body.appendChild(overlay);
            }
             // Populate overlay content
            overlay.innerHTML = `
                 <div class="message-box">
                    <h3>${title}</h3>
                    <p>${message}</p>
                    <button>OK</button>
                </div>
            `;
             // Function to hide the message box
            const hideMessage = () => {
                overlay.style.opacity = '0';
                setTimeout(() => {
                     overlay.style.visibility = 'hidden';
                     document.body.classList.remove('popup-is-open'); // Unlock scroll
                }, 300);
            };
             // Add event listener to OK button
            overlay.querySelector('button').onclick = hideMessage;
            // Make overlay visible
            overlay.style.visibility = 'visible';
            overlay.style.opacity = '1';
        }


        // Wait for the DOM to be fully loaded before running scripts
        document.addEventListener('DOMContentLoaded', function() {
            
            // --- THEME TOGGLE SCRIPT ---
            function initializeThemeToggle() {
                // Get both desktop and mobile theme buttons
                const themeButtons = [document.getElementById('themeButton'), document.getElementById('mobileThemeButton')]; 
                const htmlElement = document.documentElement;

                if (themeButtons.every(btn => !btn)) return; // Exit if no buttons found

                 // Function to apply theme and update icon rotation
                const applyTheme = (theme) => {
                    htmlElement.setAttribute('data-theme', theme);
                    localStorage.setItem('theme', theme); // Save preference
                    const rotation = (theme === 'light') ? 180 : 0;
                     // Update all gear icons
                    document.querySelectorAll('.gear-icon').forEach(icon => {
                         icon.style.transform = `rotate(${rotation}deg)`;
                         icon.dataset.rotation = rotation; // Store rotation state
                     });
                };

                // Add click listener to all theme buttons found
                themeButtons.forEach(button => {
                     if(button) {
                        button.addEventListener('click', () => {
                            const newTheme = htmlElement.getAttribute('data-theme') === 'light' ? 'dark' : 'light';
                            applyTheme(newTheme);

                            // Animate gear icons on click
                            document.querySelectorAll('.gear-icon').forEach(icon => {
                                let currentRotation = parseFloat(icon.dataset.rotation) || 0;
                                currentRotation += 180;
                                icon.style.transform = `rotate(${currentRotation}deg)`;
                                icon.dataset.rotation = currentRotation; // Update stored state
                            });
                        });
                     }
                });
                // Set initial theme based on localStorage or default to dark
                 applyTheme(localStorage.getItem('theme') || 'dark');
            }

            // --- MOBILE SIDEBAR LOGIC ---
            function initializeSidebar() {
                const hamburgerTrigger = document.getElementById('menuButton');
                const sidebar = document.getElementById('mobileSidebar');
                const closeBtn = document.getElementById('sidebarCloseBtn');
                const overlay = document.getElementById('sidebarOverlay');
                const body = document.body;
                const mobileExploreBtn = document.getElementById('mobileExploreYpiBtn'); // Get mobile login button

                if (!hamburgerTrigger || !sidebar || !closeBtn || !overlay) return;

                const openSidebar = () => {
                    sidebar.classList.add('open');
                    overlay.classList.add('active');
                    body.classList.add('sidebar-is-open'); // Prevent body scroll
                };

                const closeSidebar = () => {
                    sidebar.classList.remove('open');
                    overlay.classList.remove('active');
                    body.classList.remove('sidebar-is-open'); // Re-enable body scroll
                };

                // Event listeners to open/close sidebar
                hamburgerTrigger.addEventListener('click', openSidebar);
                closeBtn.addEventListener('click', closeSidebar);

                overlay.addEventListener('click', closeSidebar);

                 // Handle login button click from within the sidebar
                if(mobileExploreBtn) {
                     mobileExploreBtn.addEventListener('click', (e) => {
                         e.preventDefault();
                         closeSidebar(); // Close sidebar first
                         // Show login popup after sidebar transition animation completes
                         setTimeout(ypiShowLoginPopup, 300);
                     });
                 }
            }

            // --- LOGIN STATE LOGIC (Placeholder) ---
            // This is a demo to show how the UI changes if a user is logged in.
            // In a real app, this would be based on an actual authentication check.
            const elements = {
                notificationBell: document.getElementById('notificationBell'),
                profilePic: document.getElementById('profilePic'),
                exploreYpiBtn: document.getElementById('exploreYpiBtn'),
                mobileNotificationBell: document.getElementById('mobileNotificationBell'),
                mobileProfilePic: document.getElementById('mobileProfilePic'),
                mobileExploreYpiBtn: document.getElementById('mobileExploreYpiBtn') // Reference mobile button
            };

            function updateLoginState(isLoggedIn) {
                 // Simplified logic: toggle display based on isLoggedIn
                const loggedInDisplay = isLoggedIn ? 'flex' : 'none'; // 'flex' for bell
                const loggedOutDisplay = isLoggedIn ? 'none' : 'inline-block'; // 'inline-block' for buttons
                const loggedInBlock = isLoggedIn ? 'block' : 'none'; // 'block' for profile pics

                // Toggle desktop elements
                if(elements.notificationBell) elements.notificationBell.style.display = loggedInDisplay;
                if(elements.profilePic) elements.profilePic.style.display = loggedInBlock;
                if(elements.exploreYpiBtn) elements.exploreYpiBtn.style.display = loggedOutDisplay;

                // Toggle mobile header elements
                if(elements.mobileNotificationBell) elements.mobileNotificationBell.style.display = loggedInDisplay;
                 if(elements.mobileProfilePic) elements.mobileProfilePic.style.display = loggedInBlock;
                 
                 // Hide/show mobile login button in the sidebar nav list item
                 const mobileExploreLi = elements.mobileExploreYpiBtn ? elements.mobileExploreYpiBtn.closest('li') : null;
                 if (mobileExploreLi) {
                    mobileExploreLi.style.display = isLoggedIn ? 'none' : 'block';
                 }
            }

            // Set initial state (e.g., logged out)
            updateLoginState(false); // Change this to true to simulate a logged-in user

            // Add event listener for Desktop Explore YPI button
            if (elements.exploreYpiBtn) {
                elements.exploreYpiBtn.addEventListener('click', ypiShowLoginPopup);
            }
             // Note: Mobile Explore button listener is inside initializeSidebar

            // --- INITIALIZE ALL SCRIPTS ---
            initializeThemeToggle();
            initializeSidebar();
        });
    </script>

