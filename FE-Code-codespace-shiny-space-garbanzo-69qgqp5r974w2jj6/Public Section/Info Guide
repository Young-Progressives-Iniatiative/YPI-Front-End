<script>
    // SCRIPT FROM NEW HEADER FOR LOGIN SIMULATION
    document.addEventListener('DOMContentLoaded', function() {
        const loginBtn = document.getElementById('loginBtn');
        const logoutBtn = document.getElementById('logoutBtn');

        const elements = {
            notificationBell: document.getElementById('notificationBell'),
            profilePic: document.getElementById('profilePic'),
            exploreYpiBtn: document.getElementById('exploreYpiBtn'),
            mobileNotificationBell: document.getElementById('mobileNotificationBell'),
            mobileProfilePic: document.getElementById('mobileProfilePic')
        };

        function updateLoginState(isLoggedIn) {
            if (isLoggedIn) {
                if(elements.notificationBell) elements.notificationBell.style.display = 'flex';
                if(elements.profilePic) elements.profilePic.style.display = 'block';
                if(elements.exploreYpiBtn) elements.exploreYpiBtn.style.display = 'none';
                if(elements.mobileNotificationBell) elements.mobileNotificationBell.style.display = 'flex';
                if(elements.mobileProfilePic) elements.mobileProfilePic.style.display = 'block';
            } else {
                if(elements.notificationBell) elements.notificationBell.style.display = 'none';
                if(elements.profilePic) elements.profilePic.style.display = 'none';
                if(elements.exploreYpiBtn) elements.exploreYpiBtn.style.display = 'inline-block';
                if(elements.mobileNotificationBell) elements.mobileNotificationBell.style.display = 'none';
                if(elements.mobileProfilePic) elements.mobileProfilePic.style.display = 'none';
            }
        }
        
        // This simulates a logged-out state initially.
        // You might want to change this based on actual user status.
        updateLoginState(false); 
        
        // The demo buttons might not exist in the final page, so we check for them.
        if(loginBtn) {
            loginBtn.addEventListener('click', () => updateLoginState(true));
        }
        if(logoutBtn) {
            logoutBtn.addEventListener('click', () => updateLoginState(false));
        }
    });

    // ORIGINAL SCRIPT FROM INFO GUIDE
    document.addEventListener('DOMContentLoaded', function() {
        
        function initializeThemeToggle() {
            const themeButtons = document.querySelectorAll('.theme-button');
            const htmlElement = document.documentElement;

            if (themeButtons.length === 0) return;

            const applyTheme = (theme) => {
                htmlElement.setAttribute('data-theme', theme);
                localStorage.setItem('theme', theme);
            };

            const setInitialState = () => {
                const currentTheme = htmlElement.getAttribute('data-theme') || 'dark';
                document.querySelectorAll('.gear-icon').forEach(icon => {
                    let rotationAngle = (currentTheme === 'light') ? 180 : 0;
                    icon.style.transform = `rotate(${rotationAngle}deg)`;
                    icon.dataset.rotation = rotationAngle;
                });
            };

            themeButtons.forEach(button => {
                button.addEventListener('click', () => {
                    const newTheme = htmlElement.getAttribute('data-theme') === 'light' ? 'dark' : 'light';
                    applyTheme(newTheme);

                    document.querySelectorAll('.gear-icon').forEach(icon => {
                        let currentRotation = parseFloat(icon.dataset.rotation) || 0;
                        currentRotation += 180;
                        icon.style.transform = `rotate(${currentRotation}deg)`;
                        icon.dataset.rotation = currentRotation;
                    });
                });
            });
            
            setInitialState();
        }

        function initializeSidebar() {
            // Note: The new header has a menu button with id="menuButton"
            // The original page used "mobileHamburgerTrigger". I'll add a listener to the new ID.
            const hamburgerTrigger = document.getElementById('menuButton') || document.getElementById('mobileHamburgerTrigger');
            const sidebar = document.getElementById('mobileSidebar');
            const closeBtn = document.getElementById('sidebarCloseBtn');
            const overlay = document.getElementById('sidebarOverlay');
            const body = document.body;

            if (!hamburgerTrigger || !sidebar || !closeBtn || !overlay) return;

            const openSidebar = () => {
                sidebar.classList.add('open');
                overlay.classList.add('active');
                body.classList.add('sidebar-is-open');
            };

            const closeSidebar = () => {
                sidebar.classList.remove('open');
                overlay.classList.remove('active');
                body.classList.remove('sidebar-is-open');
            };

            hamburgerTrigger.addEventListener('click', openSidebar);
            closeBtn.addEventListener('click', closeSidebar);
            overlay.addEventListener('click', closeSidebar);
        }

        initializeThemeToggle();
        initializeSidebar();
    });
</script>
