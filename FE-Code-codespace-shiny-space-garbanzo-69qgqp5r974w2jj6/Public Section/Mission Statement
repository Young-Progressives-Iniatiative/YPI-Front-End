<html lang="en" data-theme="dark">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Our Mission - Young Progressives Initiative</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Atkinson+Hyperlegible:wght@400;700&display=swap" rel="stylesheet">
  <style>
    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    :root {
        --primary-green: #37af4b;
        --dark-background: #1c1c1c;
        --theme-body-bg: #1c1c1c;
        --theme-body-color: #fff;
        --theme-navbar-bg: #1c1c1c;
        --theme-navbar-text: #fff;
        --theme-navbar-dropdown-bg: #f0f0f0;
        --theme-navbar-dropdown-text: #1c1c1c;
        --theme-navbar-dropdown-hover-bg: #ddd;
    }

    html[data-theme='light'] {
        --theme-body-bg: #FEFEFE;
        --theme-body-color: #1c1c1c;
        --theme-navbar-bg: #FEFEFE;
        --theme-navbar-text: #1c1c1c;
        --theme-navbar-dropdown-bg: #1c1c1c;
        --theme-navbar-dropdown-text: #FEFEFE;
        --theme-navbar-dropdown-hover-bg: #333;
    }

    body {
      background-color: var(--theme-body-bg);
      color: var(--theme-body-color);
      font-family: 'Atkinson Hyperlegible', 'Arial', sans-serif;
      line-height: 1.6;
      overflow-x: hidden;
    }
    
    body.sidebar-is-open {
        overflow: hidden;
    }

    /* Desktop Header */
    .desktop-wp-header-container {
        background: linear-gradient(135deg, rgb(5, 114, 21) 0%, rgb(55, 175, 75) 100%);
        width: 100%;
    }
    .desktop-wp-header-contents {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 0.5rem 1.25rem;
        max-width: 1200px;
        margin: 0 auto;
    }
    .desktop-header-left-group, .desktop-header-right-group {
        display: flex;
        align-items: center;
        gap: 1rem;
    }
    .desktop-header-logo-img {
        width: 7.4375rem;
        height: auto;
    }
    .theme-button {
        background-color: transparent;
        border: none;
        padding: 0.5rem;
        cursor: pointer;
    }
    .gear-icon {
        width: 1.875rem;
        height: 1.875rem;
        stroke: #FEFEFE;
        stroke-width: 2;
    }
    html[data-theme='light'] .gear-icon {
        stroke: #1c1c1c;
    }
    .icon-button {
        background: transparent;
        border: none;
        cursor: pointer;
        padding: 0.5rem;
        position: relative;
    }
    .notification-bell-icon {
        width: 1.875rem;
        height: 1.875rem;
        stroke: #FEFEFE;
        stroke-width: 1.5;
    }
    .notification-count {
        position: absolute;
        top: 0.2rem;
        right: 0.2rem;
        background-color: #dc3545;
        color: #fff;
        border-radius: 50%;
        padding: 0.1rem 0.4rem;
        font-size: 0.75rem;
        font-weight: bold;
    }
    .profile-pic {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        object-fit: cover;
        cursor: pointer;
        border: 2px solid var(--primary-green);
    }
    .maxbutton {
        display: inline-block;
        text-decoration: none;
        color: white;
        background-color: rgba(255, 255, 255, 0.15);
        border: 2px solid white;
        padding: 8px 15px;
        border-radius: 5px;
        font-weight: bold;
    }
    .maxbutton:hover {
        background-color: rgba(255, 255, 255, 0.25);
    }

    /* Navigation */
    .navbar {
        background-color: var(--theme-navbar-bg);
        padding: 0.9375rem 0;
        display: flex;
        justify-content: center;
        width: 100%;
    }
    .navbar-menu {
        display: flex;
        list-style-type: none;
        margin: 0;
        padding: 0;
    }
    .navbar-item {
        position: relative;
        margin: 0 1.25rem;
    }
    .navbar-link {
        color: var(--theme-navbar-text);
        text-decoration: none;
        font-size: 1.125rem;
        padding: 0.625rem 0.3125rem;
        display: flex;
        align-items: center;
        font-weight: bold;
    }
    .dropdown-icon {
        border: solid var(--theme-navbar-text);
        border-width: 0 2px 2px 0;
        display: inline-block;
        padding: 0.1875rem;
        margin-left: 0.3125rem;
        transform: rotate(45deg);
        transition: transform 0.3s;
    }
    .navbar-item:hover .dropdown-icon {
        transform: rotate(-135deg);
    }
    .dropdown-menu {
        display: none;
        position: absolute;
        background-color: var(--theme-navbar-dropdown-bg);
        min-width: 12.5rem;
        box-shadow: 0 0.5rem 1rem rgba(0,0,0,0.1);
        z-index: 100;
        top: 100%;
        left: 0;
        border-radius: 0.25rem;
    }
    .navbar-item:hover .dropdown-menu {
        display: block;
    }
    .dropdown-item {
        display: block;
        padding: 0.75rem 0.9375rem;
        color: var(--theme-navbar-dropdown-text);
        text-decoration: none;
        font-size: 1rem;
        font-weight: bold;
    }
    .dropdown-item:hover {
        background-color: var(--theme-navbar-dropdown-hover-bg);
    }

    /* Mobile Header */
    .header-container {
        background: linear-gradient(135deg, rgb(5, 114, 21) 0%, rgb(55, 175, 75) 100%);
        padding: 0.9375rem 1.25rem;
        width: 100%;
        box-shadow: 0 2px 0.625rem rgba(0,0,0,0.3);
    }
    .site-header-mobile {
        display: flex;
        justify-content: space-between;
        align-items: center;
    }
    .site-logo {
        width: 6.9375rem;
        height: auto;
    }
    .mobile-header-controls {
        display: flex;
        align-items: center;
        gap: 1rem;
    }
    .menu-button {
        background: none;
        border: none;
        padding: 0;
        cursor: pointer;
    }
    .menu-icon {
        height: 1.75rem;
        width: 1.75rem;
        color: #FEFEFE;
    }
    .mobile-header-view {
        display: none;
    }

    /* Content */
    .content-wrapper {
        width: 100%;
        padding: 20px;
    }
    .full-width-figure {
        border: 5px solid #38B04C;
        border-radius: 25px;
        overflow: hidden;
        max-width: 1200px;
        margin: 0 auto;
    }
    .full-width-figure img {
        width: 100%;
        height: auto;
        display: block;
    }
    .main-content-area {
        display: flex;
        justify-content: center;
        gap: 20px;
        padding-top: 50px;
        max-width: 1200px;
        margin: 0 auto;
    }
    .text-container {
        flex: 1;
        max-width: 800px;
    }
    .text-container h2 {
        text-align: center;
        font-size: 28px;
        color: #38B04C;
    }
    .text-container p {
        font-size: 16px;
        line-height: 1.6;
    }
    .spacer-30 { height: 30px; }
    .spacer-15 { height: 15px; }
    .spacer-10 { height: 10px; }
    .ad-sidebar {
        flex: 0 0 160px;
    }

    /* Footer */
    .footer-container {
        background: linear-gradient(to right, #148324, #2ca33b);
        color: white;
        padding: 0.75rem 1.5rem 3rem;
    }
    .footer-content {
        max-width: 1400px;
        margin: 0 auto;
        text-align: center;
    }
    .footer-logo {
        height: 12rem;
        width: auto;
        margin: 0 auto;
    }
    .footer-tagline {
        margin-top: -2.5rem;
        font-size: 1.25rem;
        max-width: 20rem;
        font-weight: bold;
        margin-left: auto;
        margin-right: auto;
    }
    .footer-nav {
        margin-top: 2rem;
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 1rem;
    }
    .social-link {
        background-color: white;
        color: #148324;
        border-radius: 50%;
        padding: 0.5rem;
        display: inline-flex;
        transition: background-color 0.2s;
        text-decoration: none;
    }
    .social-link:hover {
        background-color: #e5e7eb;
    }
    .social-icon {
        height: 1.25rem;
        width: 1.25rem;
        fill: currentColor;
    }
    .footer-address {
        margin-top: 2rem;
        font-size: 0.875rem;
        color: #a5f3fc;
    }

    /* Sidebar */
    .sidebar {
        position: fixed;
        top: 0;
        left: 0;
        height: 100vh;
        width: 280px;
        background-color: var(--dark-background);
        z-index: 1000;
        transform: translateX(-100%);
        transition: transform 0.3s;
        padding: 1.25rem;
    }
    html[data-theme='light'] .sidebar {
        background-color: var(--theme-body-bg);
        border-right: 1px solid #ccc;
    }
    .sidebar.open {
        transform: translateX(0);
    }
    .sidebar .close-btn {
        background: none;
        border: none;
        color: var(--theme-body-color);
        font-size: 2.5rem;
        position: absolute;
        top: 10px;
        right: 20px;
        cursor: pointer;
    }
    .sidebar nav ul {
        list-style: none;
        padding: 0;
        margin: 50px 0 0 0;
    }
    .sidebar nav ul li a {
        color: var(--theme-body-color);
        text-decoration: none;
        font-size: 1.2rem;
        display: block;
        padding: 0.5rem 0;
    }
    .sidebar-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-color: rgba(0, 0, 0, 0.5);
        z-index: 999;
        display: none;
    }
    .sidebar-overlay.active {
        display: block;
    }

    @media (max-width: 768px) {
      .desktop-header-view {
          display: none;
      }
      .mobile-header-view {
          display: block;
      }
      .ad-sidebar {
          display: none;
      }
      .main-content-area {
        flex-direction: column;
        padding-top: 30px;
      }
    }
  </style>
</head>
