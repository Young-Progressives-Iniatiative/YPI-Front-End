    <div class="sidebar" id="sidebar"><button class="close-btn" id="closeSidebarBtn" aria-label="Close menu">&times;</button><nav><ul><li><a href="https://weareypi.com/mission-statement/">Our Mission</a></li><li><a href="https://weareypi.com/meet-ypi-roster/">Meet the Team</a></li><li><a href="https://weareypi.com/donate/">Donate</a></li><li><a href="https://weareypi.com/need-volunteers/">Need Volunteers?</a></li><li><button id="mobileThemeButton" class="mobile-theme-button">Toggle Theme</button></li></ul></nav></div>
    <div class="sidebar-overlay" id="sidebarOverlay"></div>

    <!-- =============================================================== -->
    <!--                         COMBINED SCRIPT                         -->
    <!-- =============================================================== -->
    <script>
    document.addEventListener('DOMContentLoaded', function() {
        
        // --- Initialize Firebase ---
        if (window.initializeFirebase) window.initializeFirebase();

        // --- DESKTOP THEME POPUP ---
        const themeButton = document.getElementById('themeButton');
        const popupOverlay = document.getElementById('popupOverlay');
        const themePopup = document.getElementById('themePopup');
        const popupCloseButton = document.getElementById('popupCloseButton');
        const themeSelector = document.getElementById('theme-selector');

        if(themeButton) themeButton.addEventListener('click', () => {
            const currentTheme = document.documentElement.getAttribute('data-theme') || 'dark';
            themeSelector.value = currentTheme;
            popupOverlay.style.visibility = 'visible';
            popupOverlay.style.opacity = '1';
        });
        if(popupCloseButton) popupCloseButton.addEventListener('click', () => {
            popupOverlay.style.visibility = 'hidden';
            popupOverlay.style.opacity = '0';
        });
        if(popupOverlay) popupOverlay.addEventListener('click', e => { if (e.target === popupOverlay) { popupOverlay.style.visibility = 'hidden'; popupOverlay.style.opacity = '0'; }});
        if(themeSelector) themeSelector.addEventListener('change', function() { setTheme(this.value); });
        
        // --- MOBILE THEME BUTTON & SHARED SETTER ---
        const mobileThemeButton = document.getElementById('mobileThemeButton');
        function setTheme(theme) {
            document.documentElement.setAttribute('data-theme', theme);
            try { localStorage.setItem('theme', theme); }
            catch (e) { console.error("Could not save theme", e); }
        }
        if(mobileThemeButton) mobileThemeButton.addEventListener('click', () => {
            const newTheme = document.documentElement.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
            setTheme(newTheme);
            if(window.closeSidebar) window.closeSidebar();
        });

        // --- POPUPS (MESSAGE & LOGIN) ---
        const messagePopup = document.getElementById('messagePopup');
        window.showMessage = (title, text) => {
            if(!messagePopup) return;
            messagePopup.querySelector('#messagePopupTitle').textContent = title;
            messagePopup.querySelector('#messagePopupText').textContent = text;
            messagePopup.style.display = 'flex';
        };
        if(messagePopup) {
            messagePopup.querySelector('#messagePopupClose').addEventListener('click', () => messagePopup.style.display = 'none');
            messagePopup.addEventListener('click', e => { if (e.target === messagePopup) messagePopup.style.display = 'none'; });
        }
        
        const loginPopup = document.getElementById('loginPopup');
        window.ypiShowLoginPopup = () => { if(loginPopup) loginPopup.style.display = 'flex'; };
        const closeLoginPopup = () => { if(loginPopup) loginPopup.style.display = 'none'; };
        if(loginPopup) {
            loginPopup.querySelector('#loginPopupClose').addEventListener('click', closeLoginPopup);
            loginPopup.addEventListener('click', e => { if (e.target === loginPopup) closeLoginPopup(); });
            loginPopup.querySelector('#signInButton').addEventListener('click', () => {
                if (window.auth && window.fbSignInAnonymously) {
                    window.fbSignInAnonymously(window.auth)
                        .then(() => { closeLoginPopup(); showMessage('Success', 'You are now logged in!'); })
                        .catch((error) => { showMessage('Error', 'Could not sign in. Please try again.'); });
                } else { showMessage('Error', 'Authentication service is not ready.'); }
            });
        }

        // --- DESKTOP NOTIFICATION DROPDOWN ---
        const bell = document.getElementById('notificationBell');
        const dropdown = document.getElementById('notificationDropdown');
        if(bell && dropdown) {
            bell.addEventListener('click', e => { e.stopPropagation(); dropdown.classList.toggle('active'); });
            dropdown.querySelector('#notificationDropdownClose').addEventListener('click', e => { e.stopPropagation(); dropdown.classList.remove('active'); });
            dropdown.querySelector('#notificationList').addEventListener('click', e => {
                const item = e.target.closest('.notification-item');
                if (item && !item.classList.contains('read')) {
                    if(window.markNotificationAsRead) window.markNotificationAsRead(item.dataset.id);
                }
            });
            document.addEventListener('click', e => {
                if (dropdown.classList.contains('active') && !dropdown.contains(e.target) && !e.target.closest('.icon-button')) {
                    dropdown.classList.remove('active');
                }
            });
        }

        // --- DESKTOP SLIDESHOW ---
        let slideIndex = 0;
        const slides = document.querySelectorAll('.main-wrapper .slideshow-container .slide');
        const dotsContainer = document.getElementById('dotsContainer');
        const slideTexts = document.querySelectorAll('.desktop-slideshow-text');
        if (slides.length > 0) {
            let slideInterval = setInterval(() => plusSlides(1), 5000);
            function resetInterval() { clearInterval(slideInterval); slideInterval = setInterval(() => plusSlides(1), 5000); }
            function showSlides(n) {
                slideIndex = (n + slides.length) % slides.length;
                slides.forEach(s => s.style.display = "none");
                slideTexts.forEach(t => t.classList.remove('active'));
                dots.forEach(d => d.classList.remove("active"));
                slides[slideIndex].style.display = "block";
                slideTexts[slideIndex].classList.add('active');
                dots[slideIndex].classList.add("active");
            }
            function plusSlides(n) { showSlides(slideIndex += n); }
            slides.forEach((_, i) => { const dot = document.createElement('span'); dot.classList.add('dot'); dot.addEventListener('click', () => { showSlides(slideIndex = i); resetInterval(); }); dotsContainer.appendChild(dot); });
            const dots = dotsContainer.querySelectorAll(".dot");
            document.getElementById('prevBtn').addEventListener('click', () => { plusSlides(-1); resetInterval(); });
            document.getElementById('nextBtn').addEventListener('click', () => { plusSlides(1); resetInterval(); });
            showSlides(slideIndex);
        }

        // --- MOBILE SLIDESHOW ---
        let mobileSlideIndex = 0;
        const mobileSlides = document.querySelectorAll('.mobile-slide');
        function showMobileSlides() {
            if (mobileSlides.length === 0) return;
            mobileSlides.forEach((slide, index) => slide.classList.toggle('active', index === mobileSlideIndex));
            mobileSlideIndex = (mobileSlideIndex + 1) % mobileSlides.length;
        }
        setInterval(showMobileSlides, 5000);

        // --- MOBILE SIDEBAR ---
        const menuButton = document.getElementById('menuButton');
        const sidebar = document.getElementById('sidebar');
        const closeSidebarBtn = document.getElementById('closeSidebarBtn');
        const sidebarOverlay = document.getElementById('sidebarOverlay');
        window.closeSidebar = () => {
            if(!sidebar || !sidebarOverlay) return;
            sidebar.classList.remove('open');
            sidebarOverlay.classList.remove('active');
            document.body.classList.remove('sidebar-is-open');
        }
        if(menuButton) menuButton.addEventListener('click', () => {
            sidebar.classList.add('open');
            sidebarOverlay.classList.add('active');
            document.body.classList.add('sidebar-is-open');
        });
        if(closeSidebarBtn) closeSidebarBtn.addEventListener('click', window.closeSidebar);
        if(sidebarOverlay) sidebarOverlay.addEventListener('click', window.closeSidebar);
        
        // --- MOBILE DYNAMIC TEXT ---
        const dynamicVerb = document.getElementById('dynamic-verb'), dynamicAction = document.getElementById('dynamic-action'), dynamicNoun = document.getElementById('dynamic-noun');
        if (dynamicVerb && dynamicAction && dynamicNoun) {
            const verbs = ["Change", "Impact"], actions = ["vote.", "create community engagement."], nouns = ["Change", "Impact", "Community Engagement"];
            let vIdx = 0, aIdx = 0, nIdx = 0;
            setInterval(() => {
                [dynamicVerb, dynamicAction, dynamicNoun].forEach(el => el.classList.add('fade-out'));
                setTimeout(() => {
                    dynamicVerb.textContent = verbs[vIdx = (vIdx + 1) % verbs.length];
                    dynamicAction.textContent = actions[aIdx = (aIdx + 1) % actions.length];
                    dynamicNoun.textContent = nouns[nIdx = (nIdx + 1) % nouns.length];
                    [dynamicVerb, dynamicAction, dynamicNoun].forEach(el => el.classList.remove('fade-out'));
                }, 300);
            }, 3500);
        }

        // --- DYNAMIC CONTENT LOADING (COMBINED) ---
        async function loadDynamicContent() {
            const postsApiUrl = 'https://weareypi.com/wp-json/wp/v2/posts?_embed&per_page=9';
            const volunteersApiUrl = 'https://weareypi.com/wp-json/wp/v2/posts?_embed&categories=15&per_page=10';
            try {
                const [postsResponse, volunteersResponse] = await Promise.all([fetch(postsApiUrl), fetch(volunteersApiUrl)]);
                const posts = postsResponse.ok ? await postsResponse.json() : [];
                const volunteers = volunteersResponse.ok ? await volunteersResponse.json() : [];

                // Desktop Population
                if(document.querySelector('.main-wrapper')) {
                    const dtSpotlightTitle = document.querySelector('.main-wrapper .spotlight-title a'), dtSpotlightImage = document.querySelector('.main-wrapper .spotlight-image-container img'), dtVolunteersGrid = document.querySelector('.main-wrapper .volunteers-grid'), dtNewsGrid = document.querySelector('.main-wrapper .news-grid');
                    if (posts.length > 0) { const a = posts[0], i = a._embedded?.['wp:featuredmedia']?.[0]?.source_url; if(dtSpotlightTitle){ dtSpotlightTitle.innerHTML = a.title.rendered; dtSpotlightTitle.href = a.link; } if(dtSpotlightImage){ dtSpotlightImage.src = i || 'https://placehold.co/600x400/1e1e1e/ffffff?text=Image'; dtSpotlightImage.alt = a.title.rendered; } }
                    if (dtNewsGrid) { const n = posts.slice(1, 5); dtNewsGrid.innerHTML = n.length > 0 ? n.map(p => `<div class="news-item" onclick="location.href='${p.link}'"><div class="news-image"><img src="${p._embedded?.['wp:featuredmedia']?.[0]?.media_details?.sizes?.medium?.source_url || 'https://placehold.co/300x169/1e1e1e/ffffff?text=Image'}" alt="${p.title.rendered}"></div><div class="news-title"><a href="${p.link}">${p.title.rendered}</a></div></div>`).join('') : '<p class="loading-placeholder col-span-full text-center">No news found.</p>'; }
                    if (dtVolunteersGrid) { dtVolunteersGrid.innerHTML = volunteers.length > 0 ? volunteers.slice(0, 3).map(v => `<div class="volunteer-card" onclick="location.href='${v.link}'"><div class="volunteer-image"><img src="${v._embedded?.['wp:featuredmedia']?.[0]?.media_details?.sizes?.medium?.source_url || 'https://placehold.co/300x169/1e1e1e/ffffff?text=Image'}" alt="${v.title.rendered}"></div><div class="volunteer-name"><a href="${v.link}">${v.title.rendered}</a></div></div>`).join('') : '<p class="loading-placeholder col-span-full text-center">No volunteers found.</p>'; }
                }

                // Mobile Population
                if(document.querySelector('.mobile-device-frame')) {
                    const mobVolContainer = document.getElementById('volunteer-card'), mobNewsGrid = document.getElementById('news-grid');
                    if (mobVolContainer && volunteers.length > 0) { const v = volunteers[0]; mobVolContainer.innerHTML = `<img src="${v._embedded?.['wp:featuredmedia']?.[0]?.source_url || 'https://placehold.co/100x100/1e1e1e/ffffff?text=?'}" alt="Volunteer" class="spotlight-photo"><h3 class="spotlight-name">${v.title.rendered}</h3>`; } else if (mobVolContainer) { mobVolContainer.innerHTML = `<p class="loading-placeholder">No volunteer found.</p>`; }
                    if (mobNewsGrid && posts.length > 0) { mobNewsGrid.innerHTML = posts.slice(0, 3).map(p => `<a href="${p.link}" target="_blank" class="news-card"><img src="${p._embedded?.['wp:featuredmedia']?.[0]?.source_url || 'https://placehold.co/400x225/1e1e1e/ffffff?text=Image'}" alt="" class="news-card-image"><div class="news-card-content"><h3 class="news-card-title">${p.title.rendered}</h3><p class="news-card-excerpt">${p.excerpt.rendered.replace(/<[^>]*>?/gm, '').substring(0, 100)}...</p></div></a>`).join(''); } else if (mobNewsGrid) { mobNewsGrid.innerHTML = `<p class="loading-placeholder">No news found.</p>`; }
                }
            } catch (error) { console.error("Error loading dynamic content:", error); }
        }
        loadDynamicContent();
    });
    </script>
