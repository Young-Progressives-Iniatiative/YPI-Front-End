    <!-- Added Google Font: Atkinson Hyperlegible --><link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Atkinson+Hyperlegible:wght@400;700&display=swap" rel="stylesheet">
    <!-- Importing Tailwind CSS for styling --><script src="https://cdn.tailwindcss.com"></script>

    <!-- Firebase SDKs & Notification Logic --><script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-app.js";
        import { getAuth, signInAnonymously, onAuthStateChanged, signInWithCustomToken } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-auth.js";
        import { getFirestore, collection, query, onSnapshot, addDoc, updateDoc, doc, serverTimestamp, setLogLevel } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-firestore.js";

        window.fbSignInAnonymously = signInAnonymously;

        let app;
        let db;
        let auth;
        let currentUserId = null;
        let unsubscribeNotifications = null;

        const appId = typeof __app_id !== 'undefined' ? __app_id : 'default-app-id';
        const firebaseConfig = typeof __firebase_config !== 'undefined' ? JSON.parse(__firebase_config) : {}; 

        function updateHeaderUI(user) {
            const isLoggedIn = !!user;
            const elements = {
                notificationBell: document.getElementById('notificationBell'),
                profilePic: document.getElementById('profilePic'),
                exploreYpiBtn: document.getElementById('exploreYpiBtn'),
            };
            
            if (elements.notificationBell) elements.notificationBell.style.display = isLoggedIn ? 'flex' : 'none';
            if (elements.profilePic) elements.profilePic.style.display = isLoggedIn ? 'block' : 'none';
            if (elements.exploreYpiBtn) elements.exploreYpiBtn.style.display = isLoggedIn ? 'none' : 'inline-block';
        }

        async function initializeFirebase() {
            try {
                updateHeaderUI(null);

                if (Object.keys(firebaseConfig).length > 0) {
                    app = initializeApp(firebaseConfig);
                    db = getFirestore(app);
                    auth = getAuth(app);
                    window.auth = auth;
                    setLogLevel('debug');
                    
                    onAuthStateChanged(auth, (user) => {
                        updateHeaderUI(user);
                        if (user) {
                            currentUserId = user.uid;
                            console.log("Firebase authenticated. User ID:", currentUserId);
                            setupNotificationListener();
                        } else {
                            console.log("User is not logged in.");
                            currentUserId = null;
                            if (unsubscribeNotifications) {
                                unsubscribeNotifications();
                                unsubscribeNotifications = null;
                            }
                        }
                    });

                    if (typeof __initial_auth_token !== 'undefined' && __initial_auth_token) {
                        await signInWithCustomToken(auth, __initial_auth_token).catch(err => {
                            console.error("Initial custom token sign-in failed:", err);
                             updateHeaderUI(null);
                        });
                    } else {
                        updateHeaderUI(null);
                    }
                } else {
                    updateHeaderUI(null);
                    console.warn("Firebase config not found.");
                }
            } catch (error) {
                updateHeaderUI(null);
                console.error("Error initializing Firebase:", error);
            }
        }
        
        window.initializeFirebase = initializeFirebase;

        function setupNotificationListener() {
            if (unsubscribeNotifications) unsubscribeNotifications();
            if (!db || !currentUserId) return;
            const notificationsRef = collection(db, `artifacts/${appId}/users/${currentUserId}/notifications`);
            const q = query(notificationsRef);
            
            unsubscribeNotifications = onSnapshot(q, (snapshot) => {
                const notifications = [];
                let unreadCount = 0;
                snapshot.forEach((doc) => {
                    const data = doc.data();
                    notifications.push({ id: doc.id, ...data });
                    if (!data.read) unreadCount++;
                });
                notifications.sort((a, b) => (b.timestamp?.toDate() || 0) - (a.timestamp?.toDate() || 0));
                if (window.updateNotificationsUI) {
                    window.updateNotificationsUI(notifications, unreadCount);
                }
            }, (error) => console.error("Error getting notifications:", error));
        }

        window.markNotificationAsRead = async (notificationId) => {
            if (!db || !currentUserId || !notificationId) return;
            const notificationRef = doc(db, `artifacts/${appId}/users/${currentUserId}/notifications`, notificationId);
            await updateDoc(notificationRef, { read: true });
        };

        window.updateNotificationsUI = (notifications, unreadCount) => {
            const list = document.getElementById('notificationList');
            const countEl = document.getElementById('notificationCount');
            if (!list || !countEl) return;

            list.innerHTML = notifications.length === 0 
                ? '<p class="notification-empty-message">No new notifications.</p>' 
                : notifications.map(n => {
                    const time = n.timestamp?.toDate ? new Date(n.timestamp.toDate()).toLocaleString() : 'Just now';
                    return `<div class="notification-item ${n.read ? 'read' : ''}" data-id="${n.id}" data-title="${n.title}" data-message="${n.message}" data-read="${n.read}">
                                <div class="notification-item-title">${n.title}</div>
                                <p>${n.message}</p>
                                <div class="notification-item-time">${time}</div>
                            </div>`;
                }).join('');
            countEl.textContent = unreadCount;
            countEl.style.display = unreadCount > 0 ? 'flex' : 'none';
        };
    </script>
