        .unified-header-wrapper {}
        .desktop-wp-header-container { background: linear-gradient(135deg, rgb(5, 114, 21) 0%, rgb(55, 175, 75) 100%); width: 100%; }
        .desktop-wp-header-contents { display: flex; justify-content: space-between; align-items: center; padding: 0.5rem 1.25rem; max-width: 1200px; margin: 0 auto; }
        .desktop-header-left-group, .desktop-header-right-group { display: flex; align-items: center; }
        .desktop-header-right-group { position: relative; gap: 1rem; }
        .desktop-header-logo-img { width: 7.4375rem; height: auto; }
        .theme-button { background-color: transparent; border: none; padding: 0; cursor: pointer; }
        .gear-icon { width: 1.875rem; height: 1.875rem; fill: none; stroke: #FEFEFE; stroke-width: 2; }
        .icon-button { background: transparent; border: none; cursor: pointer; padding: 0.5rem; position: relative; line-height: 0; }
        .notification-bell-icon { width: 1.875rem; height: 1.875rem; stroke: #FEFEFE; stroke-width: 1.5; }
        .notification-count { position: absolute; top: 0.2rem; right: 0.2rem; background-color: #dc3545; color: #fff; border-radius: 50%; padding: 0.1rem 0.4rem; font-size: 0.75rem; font-weight: bold; display: flex; align-items: center; justify-content: center; }
        .profile-pic { width: 40px; height: 40px; border-radius: 50%; object-fit: cover; cursor: pointer; border: 2px solid var(--primary-green); }
        .maxbutton { display: inline-block; text-decoration: none; color: white !important; background-color: rgba(255, 255, 255, 0.15); border: 2px solid white; padding: 8px 15px; border-radius: 5px; font-weight: bold; }
        .navbar { background-color: var(--theme-navbar-bg); padding: 0.9375rem 0; display: flex; justify-content: center; width: 100%; }
        .navbar-menu { display: flex; list-style-type: none; margin: 0; padding: 0; }
        .navbar-item { position: relative; margin: 0 1.25rem; }
        .navbar-link { color: var(--theme-navbar-text); text-decoration: none; font-size: 1.125rem; padding: 0.625rem 0.3125rem; display: flex; align-items: center; font-weight: bold; }
        .dropdown-icon { border: solid var(--theme-navbar-text); border-width: 0 2px 2px 0; display: inline-block; padding: 0.1875rem; margin-left: 0.3125rem; transform: rotate(45deg); }
        .dropdown-menu { display: none; position: absolute; background-color: var(--theme-navbar-dropdown-bg); min-width: 12.5rem; box-shadow: 0rem 0.5rem 1rem 0rem rgba(0,0,0,0.1); z-index: 100; }
        .navbar-item:hover .dropdown-menu { display: block; }
        .dropdown-item { display: block; padding: 0.75rem 0.9375rem; color: var(--theme-navbar-dropdown-text); text-decoration: none; font-size: 1rem; font-weight: bold; }
        .dropdown-item:hover { background-color: var(--theme-navbar-dropdown-hover-bg); }
        .header-container { background: linear-gradient(135deg, rgb(5, 114, 21) 0%, rgb(55, 175, 75) 100%); padding: 0.9375rem 1.25rem; width: 100%; box-shadow: 0 2px 0.625rem rgba(0,0,0,0.3); }
        header.site-header-mobile { display: flex; justify-content: space-between; align-items: center; min-height: 2.5rem; width: 100%; }
        .site-header-mobile .site-logo { width: 6.9375rem; height: auto; display: block; }
        .mobile-header-controls { display: flex; align-items: center; gap: 1rem; }
        .menu-button { background: none; border: none; padding: 0; cursor: pointer; line-height: 0; }
        .menu-icon { height: 1.75rem; width: 1.75rem; color: #FEFEFE; display: block; }
        .mobile-header-view { display: none; }
        @media (max-width: 768px) {
            .desktop-header-view { display: none; }
            .mobile-header-view { display: block; }
        }

        /* Contact Form Specific Styles */
        .form-input:focus { box-shadow: 0 0 0 2px #2563eb; }
        .custom-container-bg { background-color: rgba(42, 42, 42, 0.5); }
        .custom-panel-bg { background-color: #2a2a2a; }
        .custom-icon-bg { background-color: #3f3f46; }
        .custom-text-secondary { color: #a3a3a3; }
        .custom-text-label { color: #d4d4d4; }
        .custom-link-color { color: #a3a3a3; }
        .custom-link-color:hover { color: #4ade80; }
