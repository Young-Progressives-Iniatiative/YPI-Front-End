    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const themeToggleButton = document.getElementById('themeButton');
            const themeToggleButtonMobile = document.getElementById('themeButtonMobile');
            const menuButton = document.getElementById('menuButton');
            const closeButton = document.getElementById('closeButton');
            const sidebar = document.getElementById('sidebar');
            const sidebarOverlay = document.getElementById('sidebarOverlay');
            
            // Theme Toggler
            const applyTheme = (theme) => {
                document.documentElement.setAttribute('data-theme', theme);
                document.body.setAttribute('data-theme', theme); // Keep body attribute for compatibility if needed
                localStorage.setItem('theme', theme);
            };

            const toggleTheme = () => {
                const currentTheme = localStorage.getItem('theme') || 'dark';
                const newTheme = currentTheme === 'dark' ? 'light' : 'dark';
                applyTheme(newTheme);
            };

            themeToggleButton.addEventListener('click', toggleTheme);
            themeToggleButtonMobile.addEventListener('click', toggleTheme);

            // Load saved theme
            const savedTheme = localStorage.getItem('theme');
            if (savedTheme) {
                applyTheme(savedTheme);
            }

            // Mobile Sidebar
            const openSidebar = () => {
                sidebar.classList.add('open');
                sidebarOverlay.classList.add('active');
                document.body.classList.add('sidebar-is-open');
            };

            const closeSidebar = () => {
                sidebar.classList.remove('open');
                sidebarOverlay.classList.remove('active');
                document.body.classList.remove('sidebar-is-open');
            };

            menuButton.addEventListener('click', openSidebar);
            closeButton.addEventListener('click', closeSidebar);
            sidebarOverlay.addEventListener('click', closeSidebar);

            // Payment Slideshow
            const slidesWrapper = document.getElementById('slidesWrapper');
            const dotsContainer = document.getElementById('slideshowDots');
            let currentSlide = 0;
            let slideCount = 0;
            
            if (slidesWrapper) {
                slideCount = slidesWrapper.children.length;

                // Create dots
                for (let i = 0; i < slideCount; i++) {
                    const dot = document.createElement('button');
                    dot.classList.add('slideshow-dot');
                    dot.setAttribute('aria-label', `Go to slide ${i + 1}`);
                    dot.addEventListener('click', () => goToSlide(i));
                    dotsContainer.appendChild(dot);
                }
                
                window.changeSlide = (n) => {
                    goToSlide(currentSlide + n);
                };

                const goToSlide = (n) => {
                    currentSlide = (n + slideCount) % slideCount;
                    slidesWrapper.style.transform = `translateX(-${currentSlide * 100}%)`;
                    updateDots();
                };
                
                const updateDots = () => {
                    const dots = dotsContainer.children;
                    for (let i = 0; i < dots.length; i++) {
                        dots[i].classList.toggle('active', i === currentSlide);
                    }
                };

                // Initialize first slide
                goToSlide(0);
            }

            // Review System
            const reviewForm = document.getElementById('review-form');
            const starRatingContainer = reviewForm.querySelector('.star-rating');
            const stars = starRatingContainer.querySelectorAll('.star');
            const ratingInput = document.getElementById('rating-value');
            const reviewsContainer = document.getElementById('reviews-container');

            let currentRating = 0;

            stars.forEach((star, index) => {
                star.addEventListener('mouseover', () => {
                    stars.forEach((s, i) => s.classList.toggle('hover', i <= index));
                });

                star.addEventListener('mouseout', () => {
                    stars.forEach(s => s.classList.remove('hover'));
                });

                star.addEventListener('click', () => {
                    currentRating = index + 1;
                    ratingInput.value = currentRating;
                    stars.forEach((s, i) => s.classList.toggle('selected', i < currentRating));
                });
            });

            reviewForm.addEventListener('submit', (e) => {
                e.preventDefault();
                const name = document.getElementById('reviewer-name').value;
                const reviewText = document.getElementById('review-text').value;

                if (currentRating === 0) {
                    showMessage('Rating Required', 'Please select a star rating.');
                    return;
                }
                
                // In a real app, you'd send this to a server.
                // For now, we'll just display it locally.
                addReview(name, currentRating, reviewText);
                
                // Reset form
                reviewForm.reset();
                stars.forEach(s => s.classList.remove('selected'));
                currentRating = 0;
                ratingInput.value = 0;
                showMessage('Success!', 'Thank you for your review.');
            });

            function addReview(name, rating, text) {
                if (!reviewsContainer.querySelector('h4')) {
                    const title = document.createElement('h4');
                    title.textContent = 'Submitted Reviews';
                    reviewsContainer.prepend(title);
                }

                const reviewCard = document.createElement('div');
                reviewCard.className = 'review-card';

                let starHTML = '';
                for (let i = 0; i < 5; i++) {
                    starHTML += `<svg class="star ${i < rating ? '' : 'empty'}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z"/></svg>`;
                }

                reviewCard.innerHTML = `
                    <div class="review-card-header">
                        <span class="review-card-name">${escapeHTML(name)}</span>
                        <div class="review-card-stars">${starHTML}</div>
                    </div>
                    <p class="review-card-text">${escapeHTML(text)}</p>
                `;
                
                const existingTitle = reviewsContainer.querySelector('h4');
                if (existingTitle) {
                    existingTitle.after(reviewCard);
                } else {
                    reviewsContainer.appendChild(reviewCard);
                }
            }
            
            function escapeHTML(str) {
                return str.replace(/[&<>'"]/g, 
                    tag => ({
                        '&': '&amp;',
                        '<': '&lt;',
                        '>': '&gt;',
                        "'": '&#39;',
                        '"': '&quot;'
                    }[tag] || tag)
                );
            }

            // Message Box
            const messageBoxOverlay = document.getElementById('messageBoxOverlay');
            const messageBoxButton = document.getElementById('messageBoxButton');
            const messageBoxTitle = document.getElementById('messageBoxTitle');
            const messageBoxText = document.getElementById('messageBoxText');
            
            function showMessage(title, text) {
                messageBoxTitle.textContent = title;
                messageBoxText.textContent = text;
                messageBoxOverlay.style.visibility = 'visible';
                messageBoxOverlay.style.opacity = '1';
            }

            function hideMessage() {
                messageBoxOverlay.style.opacity = '0';
                setTimeout(() => {
                    messageBoxOverlay.style.visibility = 'hidden';
                }, 300);
            }
            
            messageBoxButton.addEventListener('click', hideMessage);
            messageBoxOverlay.addEventListener('click', (e) => {
                if(e.target === messageBoxOverlay) {
                    hideMessage();
                }
            });
        });
    </script>
