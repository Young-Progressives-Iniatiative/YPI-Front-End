<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>YPI Campaign - Unified Page</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Atkinson+Hyperlegible:wght@400;700&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        /* CSS Reset */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        /* Base Body Styles */
        body {
            font-family: 'Atkinson Hyperlegible', 'Arial', sans-serif;
            background-color: var(--theme-body-bg);
            color: var(--theme-body-color);
            line-height: 1.6;
            overflow-x: hidden;
            font-size: 16px;
            transition: background-color 0.3s ease, color 0.3s ease;
        }

        body.sidebar-is-open {
            overflow: hidden;
        }
        
        /* Color Themes */
        :root {
            --primary-green: #37af4b;
            --dark-background: #1c1c1c;
            --member-border: #28a745;
            --light-gray: #bbb;
            --theme-body-bg: #1c1c1c;
            --theme-body-color: #fff;
            --theme-popup-bg: #bbbbbb;
            --theme-popup-text: #1c1c1c;
            --theme-input-bg: #333;
            --theme-input-border: #444;
            --theme-input-text: #eee;
            --theme-navbar-bg: #1c1c1c;
            --theme-navbar-text: #fff;
            --theme-navbar-dropdown-bg: #f0f0f0;
            --theme-navbar-dropdown-text: #1c1c1c;
            --theme-navbar-dropdown-hover-bg: #ddd;
            --mobile-bottom-content-bg: linear-gradient(135deg, #1a1a1a 0%, #2d2d2d 100%);
            --mobile-section-bg: #2a2a2a;
        }
        
        html[data-theme='light'] {
            --theme-body-bg: #FEFEFE;
            --theme-body-color: #1c1c1c;
            --theme-popup-bg: #e0e0e0;
            --theme-popup-text: #1c1c1c;
            --theme-input-bg: #fff;
            --theme-input-border: #ccc;
            --theme-input-text: #1c1c1c;
            --theme-navbar-bg: #FEFEFE;
            --theme-navbar-text: #1c1c1c;
            --theme-navbar-dropdown-bg: #1c1c1c;
            --theme-navbar-dropdown-text: #FEFEFE;
            --theme-navbar-dropdown-hover-bg: #333;
            --mobile-bottom-content-bg: linear-gradient(135deg, #f0f0f0 0%, #e9e9e9 100%);
            --mobile-section-bg: #f5f5f5;
        }

        html[data-theme='light'] .ypi-campaign-wrapper,
        html[data-theme='light'] .ypi-form-column,
        html[data-theme='light'] .ypi-visual-column {
            background-color: #f0f0f0 !important;
        }
        html[data-theme='light'] .ypi-subtitle {
            color: #333 !important;
        }
        html[data-theme='light'] .gear-icon {
            stroke: #1c1c1c;
        }
        
        /* WordPress Block Styles */
        .wp-block-columns {
            display: flex;
            margin-bottom: 1.75em;
            flex-wrap: wrap; 
        }
        .image-grid {
            gap: 1rem;
            width: 100%;
        }
        .image-grid .wp-block-column {
            display: flex;
            flex-direction: column;
            gap: 1rem;
            min-width: 0;
        }
        .wp-block-image img {
            max-width: 100%;
            height: auto;
            display: block;
            border-radius: 8px;
        }
        .bottom-image {
            margin-top: 1rem;
        }
        
        /* GiveWP Component Styles */
        .give-form-wrap {
            background-color: var(--mobile-section-bg);
            padding: 1.5rem;
            border-radius: 8px;
            border: 1px solid var(--primary-green);
            margin-bottom: 2rem;
            text-align: center;
        }
        html[data-theme='light'] .give-form-wrap {
            background-color: #f5f5f5;
        }
        .donation-image {
            width: 100%;
            height: auto;
            border-radius: 8px;
            margin-bottom: 1rem;
        }
        .donation-description {
            margin-bottom: 1.5rem;
            font-size: 1rem;
            line-height: 1.5;
            color: var(--light-gray);
        }
        html[data-theme='light'] .donation-description {
            color: #333;
        }
        
        /* Review System Styles */
        .reviews-section-wrap {
            text-align: left;
        }
        .reviews-title {
            font-size: 1.5rem;
            font-weight: bold;
            color: var(--primary-green);
            margin-bottom: 1.5rem;
            text-align: center;
        }
        #review-form {
            background-color: var(--mobile-section-bg);
            padding: 1.5rem;
            border-radius: 8px;
            margin-bottom: 2rem;
        }
        html[data-theme='light'] #review-form {
             background-color: #f5f5f5;
        }
        .form-field {
            margin-bottom: 1rem;
        }
        .form-field label {
            display: block;
            margin-bottom: 0.5rem;
            font-weight: bold;
        }
        .form-field input[type="text"],
        .form-field input[type="email"],
        .form-field textarea {
            width: 100%;
            padding: 0.75rem;
            border: 1px solid var(--theme-input-border);
            border-radius: 4px;
            background-color: var(--theme-input-bg);
            color: var(--theme-input-text);
        }
        .star-rating {
            display: flex;
            gap: 0.25rem;
        }
        .star-rating .star {
            cursor: pointer;
            width: 24px;
            height: 24px;
            fill: var(--light-gray);
            transition: fill 0.2s;
        }
        .star-rating .star.hover,
        .star-rating .star.selected {
            fill: #f5b32a;
        }
        #reviews-container h4 {
            font-size: 1.2rem;
            color: var(--light-gray);
            margin-top: 2rem;
            margin-bottom: 1rem;
            border-bottom: 1px solid var(--theme-input-border);
            padding-bottom: 0.5rem;
        }
        .review-card {
            background-color: var(--mobile-section-bg);
            padding: 1rem;
            border-radius: 8px;
            margin-bottom: 1rem;
            border-left: 4px solid var(--primary-green);
        }
        html[data-theme='light'] .review-card {
             background-color: #f5f5f5;
        }
        .review-card-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 0.5rem;
        }
        .review-card-name {
            font-weight: bold;
        }
        .review-card-stars {
            display: flex;
        }
        .review-card-stars .star {
             width: 16px;
             height: 16px;
             fill: #f5b32a;
        }
         .review-card-stars .star.empty {
             fill: var(--light-gray);
        }
        .review-card-text {
            font-size: 0.95rem;
            color: var(--light-gray);
        }
        html[data-theme='light'] .review-card-text {
            color: #555;
        }
        .admin-controls {
            display: none;
            gap: 0.5rem;
            margin-top: 0.5rem;
        }
        body.admin-mode .admin-controls {
            display: flex;
        }
        .admin-btn {
            padding: 0.25rem 0.5rem;
            font-size: 0.8rem;
            border-radius: 4px;
            cursor: pointer;
        }
        .approve-btn { background-color: #28a745; color: white; border: none; }
        .demote-btn { background-color: #ffc107; color: black; border: none; }
        .delete-btn { background-color: #dc3545; color: white; border: none; }
        
        .btn-primary {
            width: 100%;
            background-color: var(--primary-green);
            color: #fff;
            font-size: 1.2rem;
            font-weight: bold;
            padding: 1rem;
            border: none;
            border-radius: 4px;
            cursor: pointer;
            transition: background-color 0.2s;
            margin-top: 1rem;
        }
        .btn-primary:hover {
            background-color: #2e9b41;
        }
        
        /* Payment Options Styles - Mobile */
        .payment-options {
            display: flex;
            flex-direction: column;
            gap: 0.75rem;
            margin-top: 1.5rem;
        }
        .payment-option-btn {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 0.75rem;
            width: 100%;
            padding: 0.875rem 1rem;
            border: 2px solid var(--primary-green);
            border-radius: 4px;
            background-color: transparent;
            color: var(--theme-body-color);
            font-size: 1.1rem;
            font-weight: bold;
            cursor: pointer;
            transition: all 0.2s;
            text-decoration: none;
        }
        .payment-option-btn:hover {
            background-color: var(--primary-green);
            color: #fff;
            transform: translateY(-2px);
            box-shadow: 0 4px 8px rgba(55, 175, 75, 0.3);
        }
        .payment-option-btn svg {
            width: 24px;
            height: 24px;
            flex-shrink: 0;
            fill: var(--theme-body-color);
        }
        .payment-option-btn:hover svg {
            fill: #fff;
        }
        html[data-theme='light'] .payment-option-btn svg {
            fill: #1c1c1c;
        }
        html[data-theme='light'] .payment-option-btn:hover svg {
            fill: #fff;
        }

        /* Payment Slideshow Styles - Desktop */
        .payment-slideshow-container {
            position: relative;
            margin-top: 1.5rem;
            overflow: hidden;
            border-radius: 8px;
            border: 1px solid rgba(55, 175, 75, 0.2);
        }
        .payment-slides-wrapper {
            display: flex;
            transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .payment-slide {
            min-width: 100%;
            padding: 1.25rem 2rem;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            text-align: center;
            gap: 1rem;
        }
        .payment-slide-icon {
            width: 48px;
            height: 48px;
            opacity: 0.7;
            transition: opacity 0.3s ease;
        }
        .payment-slide:hover .payment-slide-icon {
            opacity: 1;
        }
        .payment-slide-icon svg {
            width: 100%;
            height: 100%;
        }
        .payment-slide-icon svg path {
            fill: var(--theme-body-color);
        }
        .payment-slide-title {
            font-size: 1.25rem;
            font-weight: 600;
            color: var(--theme-body-color);
            margin: 0;
        }
        .payment-slide-description {
            font-size: 0.9rem;
            color: var(--light-gray);
            max-width: 380px;
            margin: 0;
            line-height: 1.5;
            opacity: 0.8;
        }
        html[data-theme='light'] .payment-slide-description {
            color: #666;
        }
        .payment-slide-btn {
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
            padding: 0.65rem 1.5rem;
            background-color: transparent;
            color: var(--primary-green);
            border: 1px solid var(--primary-green);
            border-radius: 4px;
            font-size: 0.95rem;
            font-weight: 600;
            text-decoration: none;
            cursor: pointer;
            transition: all 0.3s ease;
            margin-top: 0.5rem;
        }
        .payment-slide-btn:hover {
            background-color: var(--primary-green);
            color: #fff;
            transform: translateY(-1px);
            box-shadow: 0 2px 8px rgba(55, 175, 75, 0.2);
        }
        .slideshow-nav {
            position: absolute;
            top: 50%;
            transform: translateY(-50%);
            background-color: transparent;
            color: var(--theme-body-color);
            border: 1px solid rgba(255, 255, 255, 0.2);
            width: 32px;
            height: 32px;
            border-radius: 50%;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.2rem;
            transition: all 0.3s ease;
            z-index: 10;
            opacity: 0.4;
        }
        .slideshow-nav:hover {
            opacity: 1;
            background-color: rgba(55, 175, 75, 0.1);
            border-color: var(--primary-green);
        }
        .slideshow-nav.prev {
            left: 10px;
        }
        .slideshow-nav.next {
            right: 10px;
        }
        .slideshow-dots {
            display: flex;
            justify-content: center;
            gap: 0.4rem;
            padding: 0.75rem 0 1rem;
        }
        .slideshow-dot {
            width: 6px;
            height: 6px;
            border-radius: 50%;
            background-color: transparent;
            border: 1px solid var(--light-gray);
            cursor: pointer;
            transition: all 0.3s ease;
            opacity: 0.4;
        }
        .slideshow-dot:hover {
            opacity: 0.7;
        }
        .slideshow-dot.active {
            background-color: var(--primary-green);
            border-color: var(--primary-green);
            opacity: 1;
            transform: scale(1.3);
        }
        
        #copy-buttons-container {
            display: none;
            gap: 1rem;
            margin-top: 1.5rem;
        }
        .btn-secondary {
            flex: 1;
            background-color: var(--theme-input-bg);
            color: var(--theme-body-color);
            border: 1px solid var(--primary-green);
        }

        /* Main Layout */
        .main-wrapper {
            width: 100%;
            min-height: 100vh;
            background-color: var(--theme-body-bg);
            position: relative;
            display: flex;
            flex-direction: column;
        }
        .content-body {
            flex: 1;
        }

        /* Desktop Header */
        .desktop-header-view {
            display: none; /* Hidden by default, shown on larger screens */
        }
        .desktop-wp-header-container {
            background: linear-gradient(135deg, rgb(5, 114, 21) 0%, rgb(55, 175, 75) 100%);
            width: 100%;
        }
        .desktop-wp-header-contents {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0.5rem 1.25rem;
            max-width: 1200px;
            margin: 0 auto;
        }
        .desktop-header-left-group {
            display: flex;
            align-items: center;
        }
        .desktop-header-right-group {
            position: relative;
            display: flex;
            align-items: center;
            gap: 1rem;
        }
        .desktop-header-logo-img {
            width: 7.4375rem;
            height: auto;
        }
        .theme-button {
            background-color: transparent;
            border: none;
            padding: 0;
            cursor: pointer;
        }
        .gear-icon {
            width: 1.875rem;
            height: 1.875rem;
            fill: none;
            stroke: #FEFEFE;
            stroke-width: 2;
        }
        .icon-button {
            background: transparent;
            border: none;
            cursor: pointer;
            padding: 0.5rem;
            position: relative;
            line-height: 0;
        }
        .notification-bell-icon {
            width: 1.875rem;
            height: 1.875rem;
            stroke: #FEFEFE;
            stroke-width: 1.5;
        }
        .notification-count {
            position: absolute;
            top: 0.2rem;
            right: 0.2rem;
            background-color: #dc3545;
            color: #fff;
            border-radius: 50%;
            padding: 0.1rem 0.4rem;
            font-size: 0.75rem;
            font-weight: bold;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        .profile-pic {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            object-fit: cover;
            cursor: pointer;
            border: 2px solid var(--primary-green);
        }
        .maxbutton {
            display: inline-block;
            text-decoration: none;
            color: white !important;
            background-color: rgba(255, 255, 255, 0.15);
            border: 2px solid white;
            padding: 8px 15px;
            border-radius: 5px;
            font-weight: bold;
        }

        /* Navigation Bar Styles */
        .navbar {
            background-color: var(--theme-navbar-bg);
            padding: 0.9375rem 0;
            display: flex;
            justify-content: center;
            width: 100%;
        }
        .navbar-menu {
            display: flex;
            list-style-type: none;
            margin: 0;
            padding: 0;
        }
        .navbar-item {
            position: relative;
            margin: 0 1.25rem;
        }
        .navbar-link {
            color: var(--theme-navbar-text);
            text-decoration: none;
            font-size: 1.125rem;
            padding: 0.625rem 0.3125rem;
            display: flex;
            align-items: center;
            font-weight: bold;
        }
        .dropdown-icon {
            border: solid var(--theme-navbar-text);
            border-width: 0 2px 2px 0;
            display: inline-block;
            padding: 0.1875rem;
            margin-left: 0.3125rem;
            transform: rotate(45deg);
        }
        .dropdown-menu {
            display: none;
            position: absolute;
            background-color: var(--theme-navbar-dropdown-bg);
            min-width: 12.5rem;
            box-shadow: 0rem 0.5rem 1rem 0rem rgba(0,0,0,0.1);
            z-index: 100;
        }
        .navbar-item:hover .dropdown-menu {
             display: block;
        }
        .dropdown-item {
            display: block;
            padding: 0.75rem 0.9375rem;
            color: var(--theme-navbar-dropdown-text);
            text-decoration: none;
            font-size: 1rem;
            font-weight: bold;
        }
         .dropdown-item:hover {
            background-color: var(--theme-navbar-dropdown-hover-bg);
        }

        /* Mobile Header Styles */
        .mobile-header-view {
             display: block; /* Shown by default */
        }
        .header-container {
            background: linear-gradient(135deg, rgb(5, 114, 21) 0%, rgb(55, 175, 75) 100%);
            padding: 0.9375rem 1.25rem;
            width: 100%;
            box-shadow: 0 2px 0.625rem rgba(0,0,0,0.3);
        }
        header.site-header-mobile {
            display: flex;
            justify-content: space-between;
            align-items: center;
            min-height: 2.5rem;
            width: 100%;
        }
        .site-header-mobile .site-logo {
            width: 6.9375rem;
            height: auto;
            display: block;
        }
        .mobile-header-controls {
            display: flex;
            align-items: center;
            gap: 1rem;
        }
        .menu-button {
            background: none;
            border: none;
            padding: 0;
            cursor: pointer;
            line-height: 0;
        }
        .menu-icon {
            height: 1.75rem;
            width: 1.75rem;
            color: #FEFEFE;
            display: block;
        }

        /* Sidebar Styles */
        .sidebar {
            position: fixed;
            top: 0;
            left: 0;
            height: 100vh;
            width: 280px;
            background-color: var(--dark-background);
            z-index: 1000;
            transform: translateX(-100%);
            transition: transform 0.3s ease-in-out;
            padding: 1.25rem;
            box-shadow: 5px 0 15px rgba(0,0,0,0.2);
            display: flex;
            flex-direction: column;
        }
        html[data-theme='light'] .sidebar {
            background-color: var(--theme-body-bg);
        }
        .sidebar.open {
            transform: translateX(0);
        }
        .sidebar .close-btn {
            background: none;
            border: none;
            color: var(--theme-body-color);
            font-size: 2.5rem;
            position: absolute;
            top: 10px;
            right: 20px;
            cursor: pointer;
            line-height: 1;
        }
        .sidebar nav {
            margin-top: 50px;
        }
        .sidebar nav ul {
            list-style: none;
            padding: 0;
            margin: 0;
        }
        .sidebar nav ul li {
            margin-bottom: 1rem;
        }
        .sidebar nav ul li a {
            color: var(--theme-body-color);
            text-decoration: none;
            font-size: 1.2rem;
            padding: 0.5rem 0;
            display: block;
            transition: color 0.3s ease;
        }
        .sidebar nav ul li a:hover,
        .sidebar nav ul li a:focus {
            color: var(--primary-green);
        }
        .sidebar-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0, 0, 0, 0.5);
            z-index: 999;
            opacity: 0;
            visibility: hidden;
            transition: opacity 0.3s ease-in-out, visibility 0s 0.3s;
        }
        .sidebar-overlay.active {
            opacity: 1;
            visibility: visible;
            transition: opacity 0.3s ease-in-out;
        }

        /* Message Box */
        .message-box-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0, 0, 0, 0.5);
            z-index: 10000;
            display: flex;
            justify-content: center;
            align-items: center;
            visibility: hidden;
            opacity: 0;
            transition: opacity 0.3s ease-in-out, visibility 0.3s ease-in-out;
        }
        .message-box {
            background-color: var(--theme-body-bg);
            color: var(--theme-body-color);
            padding: 1.5625rem;
            border-radius: 0.5rem;
            box-shadow: 0 0.3125rem 0.9375rem rgba(0, 0, 0, 0.3);
            max-width: 21.875rem;
            width: 90%;
            text-align: center;
            position: relative;
        }
        .message-box h3 {
            margin-top: 0;
            margin-bottom: 0.9375rem;
            color: var(--primary-green);
        }
        .message-box p {
            margin-bottom: 1.25rem;
            font-size: 1.1rem;
        }
        .message-box button {
            background-color: var(--primary-green);
            color: #1c1c1c;
            border: none;
            padding: 0.625rem 1.25rem;
            border-radius: 0.3125rem;
            cursor: pointer;
            font-weight: bold;
            transition: background-color 0.2s ease;
        }
        .message-box button:hover {
            background-color: #2e9b41;
        }

        /* Responsive Adjustments */
        @media (max-width: 768px) {
            .ypi-main-content {
                flex-direction: column;
            }
            .ypi-form-column, .ypi-visual-column {
                flex-basis: 100% !important; /* Override inline styles */
                padding: 1rem !important; /* Adjust padding */
            }
            .payment-slideshow-container {
                display: none;
            }
            .payment-options {
                display: flex;
            }
            .image-grid {
                flex-direction: column;
            }
        }
        
        @media (min-width: 769px) {
            .mobile-header-view {
                display: none;
            }
            .desktop-header-view {
                display: block;
            }
            .payment-slideshow-container {
                display: block;
            }
            .payment-options {
                display: none;
            }
            .image-grid {
                flex-wrap: nowrap;
            }
            .image-grid > .wp-block-column {
                flex: 1 1 50%;
            }
        }
    </style>
</head>
<body>

    <div class="main-wrapper">
        <header class="unified-header-wrapper">
            <!-- MOBILE HEADER -->
            <div class="mobile-header-view">
                <div class="header-container">
                    <header class="site-header-mobile">
                        <a href="https://weareypi.com/" class="custom-logo-link" rel="home">
                            <img src="https://weareypi.com/wp-content/uploads/2025/06/Site-Icon-3.png" class="site-logo" alt="YPI">
                        </a>
