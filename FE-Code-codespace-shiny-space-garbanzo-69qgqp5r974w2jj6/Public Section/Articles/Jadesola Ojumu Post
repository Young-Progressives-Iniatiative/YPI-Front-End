.donation-amounts button:hover { background-color: var(--theme-card-bg); border-color: var(--primary-green); }
.donation-amounts button.selected { background-color: var(--primary-green); color: #fff; border-color: var(--primary-green); }
.donate-other-btn { grid-column: 1 / -1; text-align: center; }
