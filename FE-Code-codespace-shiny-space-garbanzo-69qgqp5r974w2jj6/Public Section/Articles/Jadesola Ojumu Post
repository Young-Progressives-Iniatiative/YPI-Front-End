.custom-amount-input:focus { outline: none; border-color: var(--primary-green); box-shadow: 0 0 0 3px rgba(55, 175, 75, 0.3); }
.donate-submit-btn { width: 100%; padding: 1rem; font-size: 1.2rem; font-weight: 700; letter-spacing: 0.5px; }
/* --- END DONATE MODAL --- */


