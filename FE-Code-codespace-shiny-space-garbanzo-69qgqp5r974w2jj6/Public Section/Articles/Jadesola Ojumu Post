/* --- END NEW FOOTTER STYLES --- */


/* --- RESPONSIVE STYLES --- */
/* Show mobile header, hide desktop */
@media (max-width: 768px) {
.desktop-header-view { display: none; }
.mobile-header-view { display: block; }
.article-header { padding: 1.5rem 1rem 1rem; }
