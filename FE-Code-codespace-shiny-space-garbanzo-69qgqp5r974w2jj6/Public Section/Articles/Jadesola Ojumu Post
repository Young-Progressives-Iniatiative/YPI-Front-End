#donate-modal-backdrop.visible .donate-modal-content { transform: scale(1); }
#close-donate-modal-btn { position: absolute; top: 1rem; right: 1rem; background: none; border: none; color: var(--light-gray); font-size: 1.75rem; cursor: pointer;
