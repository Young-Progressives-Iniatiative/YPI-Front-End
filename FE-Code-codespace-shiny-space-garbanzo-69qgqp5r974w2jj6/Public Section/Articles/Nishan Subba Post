    <script type="module">
        // --- GLOBAL HELPER FUNCTIONS ---
        const $ = (selector) => document.querySelector(selector);
        const $$ = (selector) => document.querySelectorAll(selector);

        document.addEventListener('DOMContentLoaded', () => {

            // --- THEME TOGGLING LOGIC ---
            try {
                const themeToggles = $$('.theme-toggle-input');
                const sunIcons = $$('.ph-sun');
                const moonIcons = $$('.ph-moon');

                function setIconState(isDarkMode) {
                    sunIcons.forEach(icon => icon.style.opacity = isDarkMode ? '1' : '0');
                    moonIcons.forEach(icon => icon.style.opacity = isDarkMode ? '0' : '1');
                }

                function setTheme(isDarkMode) {
                    document.documentElement.setAttribute('data-theme', isDarkMode ? 'dark' : 'light');
                    localStorage.setItem('ypi-theme', isDarkMode ? 'dark' : 'light');
                    themeToggles.forEach(toggle => toggle.checked = !isDarkMode); // true = light, false = dark in CSS
                    setIconState(isDarkMode);
                }

                function syncToggles(changedToggle) {
                    const isDarkMode = !changedToggle.checked; // true = light, false = dark
                    themeToggles.forEach(toggle => {
                        if (toggle !== changedToggle) {
                            toggle.checked = changedToggle.checked;
                        }
                    });
                    setTheme(isDarkMode);
                }

                // Initial theme load
                const savedTheme = localStorage.getItem('ypi-theme') || 'dark'; // Default to dark
                const isDark = savedTheme === 'dark';
                setTheme(isDark);

                // Add event listeners to both toggles
                themeToggles.forEach(toggle => {
                    toggle.addEventListener('change', () => syncToggles(toggle));
                });
            } catch (e) {
                console.error("Error in theme toggle logic:", e);
            }

            // --- MOBILE SIDEBAR LOGIC ---
            try {
                // *** MODIFIED: Pointing to #menuButton from new Header file ***
                const openSidebarBtn = $('#menuButton'); 
                const closeSidebarBtn = $('#close-sidebar-btn');
                const mobileSidebar = $('#mobile-sidebar');

                if (openSidebarBtn && closeSidebarBtn && mobileSidebar) {
                    openSidebarBtn.addEventListener('click', () => {
                        mobileSidebar.classList.add('open');
                        document.body.classList.add('sidebar-is-open');
                    });

                    closeSidebarBtn.addEventListener('click', () => {
                        mobileSidebar.classList.remove('open');
                        document.body.classList.remove('sidebar-is-open');
                    });
                } else {
                    console.warn('Mobile sidebar elements not found.');
                }
            } catch (e) {
                console.error("Error in mobile sidebar logic:", e);
            }

            // --- DONATE MODAL LOGIC ---
            try {
                const donateButtons = $$('#desktop-donate-btn, #mobile-donate-btn');
                const modalBackdrop = $('#donate-modal-backdrop');
                const closeModalBtn = $('#close-donate-modal-btn');
                const amountButtons = $$('.donation-amount-btn');
                const customAmountInput = $('.custom-amount-input');
                const donateSubmitBtn = $('.donate-submit-btn');

                let selectedAmount = 50; // Default amount

                function openModal() {
                    if (modalBackdrop) modalBackdrop.classList.add('visible');
                }

                function closeModal() {
                    if (modalBackdrop) modalBackdrop.classList.remove('visible');
                }

                function updateSubmitButton() {
                    if (donateSubmitBtn) donateSubmitBtn.textContent = `Donate $${selectedAmount}`;
                }

                // Open modal
                donateButtons.forEach(btn => btn.addEventListener('click', openModal));

                // Close modal
                if (closeModalBtn) closeModalBtn.addEventListener('click', closeModal);
                if (modalBackdrop) {
                    modalBackdrop.addEventListener('click', (e) => {
                        if (e.target === modalBackdrop) {
                            closeModal();
                        }
                    });
                }

                // Handle amount selection
                amountButtons.forEach(button => {
                    button.addEventListener('click', () => {
                        amountButtons.forEach(btn => btn.classList.remove('selected'));
                        button.classList.add('selected');
                        const amount = button.dataset.amount;

                        if (amount === 'other') {
                            if (customAmountInput) customAmountInput.classList.remove('hidden');
                            if (donateSubmitBtn) donateSubmitBtn.classList.add('hidden');
                        } else {
                            if (customAmountInput) customAmountInput.classList.add('hidden');
                            if (donateSubmitBtn) donateSubmitBtn.classList.remove('hidden');
                            selectedAmount = parseInt(amount, 10);
                            updateSubmitButton();
                        }
                    });
                });

                // Handle custom amount input
                if (customAmountInput) {
                    customAmountInput.addEventListener('input', (e) => {
                        const value = parseInt(e.target.value, 10);
                        if (isNaN(value) || value <= 0) {
                            if (donateSubmitBtn) donateSubmitBtn.classList.add('hidden');
                        } else {
                            selectedAmount = value;
                            if (donateSubmitBtn) {
                                donateSubmitBtn.classList.remove('hidden');
                                updateSubmitButton();
                            }
                        }
                    });
                }
            } catch (e) {
                console.error("Error in donate modal logic:", e);
            }


            // --- LOGIN STATE LOGIC (from Header file) ---
            // This is a simulation.
            try {
                const elements = {
                   notificationBell: $('#notificationBell'),
                   profilePic: $('#profilePic'),
                   exploreYpiBtn: $('#exploreYpiBtn'),
                   mobileNotificationBell: $('#mobileNotificationBell'),
                   mobileProfilePic: $('#mobileProfilePic')
                };

                function updateLoginState(isLoggedIn) {
                   if (isLoggedIn) {
                       // Show user icons, hide explore button
                       if(elements.notificationBell) elements.notificationBell.style.display = 'flex';
                       if(elements.profilePic) elements.profilePic.style.display = 'block';
                       if(elements.exploreYpiBtn) elements.exploreYpiBtn.style.display = 'none';
                       if(elements.mobileNotificationBell) elements.mobileNotificationBell.style.display = 'flex';
                       if(elements.mobileProfilePic) elements.mobileProfilePic.style.display = 'block';
                   } else {
                       // Hide user icons, show explore button
                       if(elements.notificationBell) elements.notificationBell.style.display = 'none';
                       if(elements.profilePic) elements.profilePic.style.display = 'none';
                       if(elements.exploreYpiBtn) elements.exploreYpiBtn.style.display = 'inline-block';
                       if(elements.mobileNotificationBell) elements.mobileNotificationBell.style.display = 'none';
                       if(elements.mobileProfilePic) elements.mobileProfilePic.style.display = 'none';
                   }
                }

                // Set initial state to logged out
                updateLoginState(false);

                // You can test this by changing the state, e.g.:
                // updateLoginState(true); 
                
            } catch (e) {
                console.error("Error in login state logic:", e);
            }


            // --- DYNAMIC DATE "TIME AGO" LOGIC ---
            try {
                calculateTimeAgo();
                // Update the time ago every minute
                setInterval(calculateTimeAgo, 60000);
            } catch (e) {
                console.error("Error setting up timeAgo interval:", e);
            }

        }); // End DOMContentLoaded

        /**
         * Calculates the time elapsed since a given date and updates an element's text.
         */
        function calculateTimeAgo() {
            const dateSpan = document.querySelector('[data-publish-date]');
            const displayElement = document.getElementById('dynamic-date-display');
            
            if (!dateSpan || !displayElement) {
                // console.warn('Dynamic date elements not found.');
                return;
            }

            try {
                const publishDateStr = dateSpan.dataset.publishDate;
                const publishDate = new Date(publishDateStr);
                
                const now = new Date(); 
                const seconds = Math.floor((now - publishDate) / 1000);

                if (seconds < 0) {
                    displayElement.textContent = "just now";
                    return;
                }
                if (seconds < 60) {
                    displayElement.textContent = "just now";
                    return;
                }
                
                let interval = seconds / 31536000; // years
                if (interval > 1) {
                    const val = Math.floor(interval);
                    displayElement.textContent = val + (val === 1 ? " year ago" : " years ago");
                    return;
                }
                interval = seconds / 2592000; // months
                if (interval > 1) {
                    const val = Math.floor(interval);
                    displayElement.textContent = val + (val === 1 ? " month ago" : " months ago");
                    return;
                }
                interval = seconds / 86400; // days
                if (interval > 1) {
                    const val = Math.floor(interval);
                    displayElement.textContent = val + (val === 1 ? " day ago" : " days ago");
                    return;
                }
                interval = seconds / 3600; // hours
                if (interval > 1) {
                    const val = Math.floor(interval);
                    displayElement.textContent = val + (val === 1 ? " hour ago" : " hours ago");
                    return;
                }
                interval = seconds / 60; // minutes
                if (interval > 1) {
                    const val = Math.floor(interval);
                    displayElement.textContent = val + (val === 1 ? " minute ago" : " minutes ago");
                    return;
                }
                displayElement.textContent = Math.floor(seconds) + (Math.floor(seconds) === 1 ? " second ago" : " seconds ago");
            } catch (e) {
                console.error("Error calculating time ago:", e);
                // Updated fallback to match the new post
                displayElement.textContent = "on Oct 28, 2025"; // Fallback
            }
        }
    </script>

