/* --- DONATE MODAL (from Jordyn Carter) --- */
#donate-modal-backdrop { 
    position: fixed; 
    top: 0; 
    left: 0; 
    width: 100%; 
    height: 100%; 
    background-color: var(--theme-modal-backdrop); 
    z-index: 2000; 
    display: flex; 
    align-items: center;
    justify-content: center; 
    padding: 1rem; 
    opacity: 0; 
    visibility: hidden; 
    transition: opacity 0.3s ease, visibility 0.3s ease; 
}
#donate-modal-backdrop.visible { 
    opacity: 1; 
    visibility: visible; 
}
.donate-modal-content { 
    background-color: var(--theme-modal-bg); 
    border-radius: 16px; 
    padding: 2rem; 
    width: 100%; 
    max-width: 500px; 
    box-shadow: 0 10px 30px rgba(0,0,0,0.3); 
    position: relative;
    transform: scale(0.95); 
    transition: transform 0.3s cubic-bezier(0.25, 0.1, 0.25, 1); 
}
#donate-modal-backdrop.visible .donate-modal-content { 
    transform: scale(1); 
}
#close-donate-modal-btn { 
    position: absolute; 
    top: 1rem; 
    right: 1rem; 
    background: none; 
    border: none; 
    color: var(--light-gray); 
    font-size: 1.75rem; 
    cursor: pointer;
    transition: color 0.2s ease; 
}
#close-donate-modal-btn:hover { color: var(--theme-body-color); }
.donate-modal-content h2 { 
    font-size: 1.8rem; 
    font-weight: 700; 
    color: var(--theme-heading-color); 
    margin-bottom: 0.5rem; 
    text-align: center; 
}
.donate-modal-content p { 
    text-align: center; 
    margin-bottom: 1.5rem; 
    color: var(--light-gray); 
    font-size: 1rem; 
}
.donation-amounts { 
    display: grid; 
    grid-template-columns: repeat(3, 1fr); 
    gap: 0.75rem; 
    margin-bottom: 1.5rem; 
}
.donation-amounts button, .donate-other-btn { 
    width: 100%; 
    padding: 1rem; 
    font-size: 1.1rem; 
    font-weight: 600; 
    border-radius: 8px; 
    cursor: pointer; 
    transition: all 0.2s ease;
    border: 2px solid var(--theme-input-border); 
    background-color: var(--theme-input-bg); 
    color: var(--theme-body-color); 
}
.donation-amounts button:hover { 
    background-color: var(--theme-card-bg); 
    border-color: var(--primary-green); 
}
.donation-amounts button.selected { 
    background-color: var(--primary-green); 
    color: #fff; 
    border-color: var(--primary-green); 
}
.donate-other-btn { 
    grid-column: 1 / -1; 
    text-align: center; 
}
.custom-amount-input { 
    width: 100%; 
    padding: 1rem; 
    font-size: 1.2rem; 
    font-weight: 600; 
    border-radius: 8px; 
    border: 2px solid var(--theme-input-border); 
    background-color: var(--theme-input-bg); 
    color: var(--theme-input-text);
    margin-bottom: 1.5rem; 
    text-align: center; 
}
.custom-amount-input:focus { 
    outline: none; 
    border-color: var(--primary-green); 
    box-shadow: 0 0 0 3px rgba(55, 175, 75, 0.3); 
}
/* General Action Button Style (from Jordyn Carter) */
.action-button {
    background-color: var(--theme-button-bg);
    color: var(--theme-button-text);
    padding: 0.5rem 1rem;
    border: none;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.9rem;
    cursor: pointer;
    transition: background-color 0.3s ease;
    display: inline-block;
}
.action-button:hover {
    background-color: var(--theme-button-hover-bg);
}
.donate-submit-btn { 
    width: 100%; 
    padding: 1rem; 
    font-size: 1.2rem; 
    font-weight: 700; 
    letter-spacing: 0.5px; 
}
/* --- END DONATE MODAL --- */


