   padding: 8px 15px;
   border-radius: 5px;
   font-weight: bold;
}

/* Theme Toggle (Using label/input structure from Jordyn Carter) */
.theme-toggle-switch {
    position: relative;
    display: inline-block;
    width: 50px;
    height: 28px;
}
.theme-toggle-switch input {
    opacity: 0;
    width: 0;
    height: 0;
}
.theme-slider {
    position: absolute;
    cursor: pointer;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-color: #555;
    transition: .4s;
    border-radius: 34px;
}
.theme-slider:before {
    position: absolute;
    content: "";
    height: 20px;
    width: 20px;
    left: 4px;
    bottom: 4px;
    background-color: white;
    transition: .4s;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
}
.theme-slider-icon {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    font-size: 14px;
    color: #f0f0f0;
    transition: opacity 0.3s ease;
}
.theme-slider-icon.ph-sun { right: 6px; opacity: 1; }
.theme-slider-icon.ph-moon { left: 6px; opacity: 0; color: #333; }
input:checked + .theme-slider { background-color: var(--primary-green); }
input:checked + .theme-slider:before { transform: translateX(22px); }
input:checked + .theme-slider .ph-sun { opacity: 0; }
input:checked + .theme-slider .ph-moon { opacity: 1; }


/* Navigation Bar Styles */
.navbar {
   background-color: var(--theme-navbar-bg);
   padding: 0.9375rem 0;
   display: flex;
   justify-content: center;
   width: 100%;
