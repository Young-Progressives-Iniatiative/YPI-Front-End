/* --- ARTICLE CONTENT STYLES (from Jordyn Carter) --- */
.article-wrapper { 
    max-width: 1100px; 
    margin: 2rem auto; 
    padding: 0 2.5%; 
}
.article-content-container { 
    background-color: var(--theme-card-bg); 
    border: 1px solid var(--theme-card-border); 
