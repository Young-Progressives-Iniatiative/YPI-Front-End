                    <a href="https://www.linkedin.com/company/103394900" class="social-link">
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16"><title>LinkedIn</title><path d="M0 1.146C0 .513.526 0 1.175 0h13.65C15.474 0 16 .513 16 1.146v13.708c0 .633-.526 1.146-1.175 1.146H1.175C.526 16 0 15.487 0 14.854zm4.943 12.248V6.169H2.542v7.225zm-1.2-8.212c.837 0 1.358-.554 1.358-1.248-.015-.709-.52-1.248-1.342-1.248S2.4 3.226 2.4 3.934c0 .694.521 1.248 1.327 1.248zm4.908 8.212V9.359c0-.216.016-.432.08-.586.173-.431.568-.878 1.232-.878.869 0 1.216.662 1.216 1.634v3.865h2.401V9.25c0-2.22-1.184-3.252-2.764-3.252-1.274 0-1.845.7-2.165 1.193v.025h-.016l.016-.025V6.169h-2.4c.03.678 0 7.225 0 7.225z"/></svg>
                    </a>
                    <!-- Add other social links as needed -->
                </nav>
                <div class="address">
                    <p>Young Progressives Initiative L.L.C</p>
                    <p>Chevy Chase, MD 20815</p>
                </div>
            </div>
        </footer>
    </div>

    <!-- POPUP OVERLAYS (Used by JS) -->
    <div class="login-popup-overlay" id="loginPopupOverlay"></div>
    <div class="message-box-overlay" id="messageBoxOverlay"></div>

    <script>
        // --- GLOBAL ELEMENTS & LOGIN STATE ---
        
        // Store common element references
        const elements = {
            // Desktop
            exploreYpiBtn: document.getElementById('exploreYpiBtn'),
            notificationBell: document.getElementById('notificationBell'),
            profilePic: document.getElementById('profilePic'),
            // Mobile
            mobileExploreYpiBtn: document.getElementById('mobileExploreYpiBtn'),
            mobileNotificationBell: document.getElementById('mobileNotificationBell'),
            mobileProfilePic: document.getElementById('mobileProfilePic'),
        };

        /**
         * Updates the UI to reflect login state.
         * @param {boolean} [isLoggedIn] - Force a state. If null, reads from localStorage.
         */
        function updateLoginState(isLoggedIn) {
            if (isLoggedIn === undefined || isLoggedIn === null) {
                isLoggedIn = localStorage.getItem('isLoggedIn') === 'true';
            }

            // Store the state
            localStorage.setItem('isLoggedIn', isLoggedIn);

            // Define elements to show/hide based on login state
            const loggedOutElements = [elements.exploreYpiBtn, elements.mobileExploreYpiBtn];
            const loggedInElements = [
                elements.notificationBell, elements.profilePic,
                elements.mobileNotificationBell, elements.mobileProfilePic
            ];

            if (isLoggedIn) {
                loggedOutElements.forEach(el => el ? el.style.display = 'none' : null);
                loggedInElements.forEach(el => el ? el.style.display = 'flex' : null); // Use flex or block as appropriate
                // Adjust for specific elements
                if(elements.profilePic) elements.profilePic.style.display = 'block';
                if(elements.mobileProfilePic) elements.mobileProfilePic.style.display = 'block';
                if(elements.mobileExploreYpiBtn) {
                     elements.mobileExploreYpiBtn.style.display = 'none'; // Hide login button in sidebar
                     elements.mobileExploreYpiBtn.textContent = 'Logout'; // Change text
                }
            } else {
                loggedOutElements.forEach(el => el ? el.style.display = 'inline-block' : null);
                loggedInElements.forEach(el => el ? el.style.display = 'none' : null);
                // Adjust for specific elements
                if (elements.exploreYpiBtn) elements.exploreYpiBtn.textContent = 'Login';
                if(elements.mobileExploreYpiBtn) {
                    elements.mobileExploreYpiBtn.style.display = 'block'; // Show login button in sidebar
                    elements.mobileExploreYpiBtn.textContent = 'Login';
                }
            }
        }
        
        /**
         * Shows a modal message box.
         * @param {string} title - The title of the message.
         * @param {string} message - The body text of the message.
         */
        function showMessage(title, message) {
            let overlay = document.getElementById('messageBoxOverlay');
            if (!overlay) {
                overlay = document.createElement('div');
                overlay.id = 'messageBoxOverlay';
                overlay.className = 'message-box-overlay';
                document.body.appendChild(overlay);
            }
            overlay.innerHTML = `
                <div class="message-box">
                    <h3>${title}</h3>
                    <p>${message}</p>
                    <button class="maxbutton" style="background-color: var(--primary-green); border: none; color: white; margin-top: 1rem; padding: 0.5rem 1rem;">OK</button>
                </div>
            `;
            overlay.style.visibility = 'visible';
            overlay.style.opacity = '1';
            document.body.classList.add('popup-is-open');

            const hide = () => {
                overlay.style.opacity = '0';
                setTimeout(() => { 
                    overlay.style.visibility = 'hidden'; 
                    document.body.classList.remove('popup-is-open');
                    overlay.innerHTML = '';
                }, 300);
            };
            overlay.querySelector('button').onclick = hide;
            overlay.addEventListener('click', e => { if (e.target === overlay) hide(); });
        }
        
        // --- END GLOBAL ---


        /**
         * Shows a modal login popup.
         */
        function ypiShowLoginPopup() {
            let overlay = document.getElementById('loginPopupOverlay');
            if (!overlay) {
                overlay = document.createElement('div');
                overlay.id = 'loginPopupOverlay';
                overlay.className = 'login-popup-overlay';
                document.body.appendChild(overlay);
            }
            overlay.innerHTML = `
                <div class="login-popup">
                    <span class="login-popup-close">&times;</span>
                    <img src="https://weareypi.com/wp-content/uploads/2025/05/YPI-POP-UP-LOGO-Start-2-2-1.png" alt="YPI Logo" style="display: block; max-width: 80%; height: auto; margin: 0 auto 1.5rem;">
                    <h3>Login Credentials</h3>
                    <form id="ypi-login-form">
                        <input type="text" id="ypi-username" name="username" placeholder="Username" required>
                        <input type="password" id="ypi-password" name="password" placeholder="Password" required>
                        <button type="submit" class="maxbutton"><span class="mb-text" style="padding:0;">Sign In</span></button>
                    </form>
                </div>
            `;
            overlay.style.visibility = 'visible';
            overlay.style.opacity = '1';
            document.body.classList.add('popup-is-open');

            const hide = () => {
                overlay.style.opacity = '0';
                setTimeout(() => { 
                    overlay.style.visibility = 'hidden'; 
                    document.body.classList.remove('popup-is-open'); 
                    overlay.innerHTML = ''; // Clear content after hiding
                }, 300);
            };
            overlay.querySelector('.login-popup-close').onclick = hide;
            // Close if clicking outside the modal box
            overlay.addEventListener('click', e => { if (e.target === overlay) hide(); });
            // Handle form submission
            overlay.querySelector('form').onsubmit = e => {
                e.preventDefault();
                const username = document.getElementById('ypi-username').value;
                // Simulate successful login
                if (username) { // Basic check if username is entered
                     updateLoginState(true); // Update UI to logged-in state
                     hide();
                     // Optionally show a welcome message
                     // showMessage('Welcome!', 'You have successfully logged in.'); 
                } else {
                     showMessage('Login Failed', 'Please enter valid credentials.');
                }
            };
        }
        
        // --- SLIDESHOW LOGIC (REMOVED from global scope) ---
        
        // Wait for the DOM to be fully loaded before running scripts
        document.addEventListener('DOMContentLoaded', function() {

            // --- THEME TOGGLE LOGIC ---
            const themeButtons = [document.getElementById('themeButton'), document.getElementById('mobileThemeButton')];
            const htmlEl = document.documentElement;

            /**
             * Applies the selected theme and saves it to localStorage.
             * @param {string} theme - 'light' or 'dark'
             */
            const applyTheme = (theme) => {
                htmlEl.setAttribute('data-theme', theme);
                localStorage.setItem('theme', theme);
                const rotation = (theme === 'light') ? 180 : 0;
                // Update gear icon rotation and stroke for both buttons
                themeButtons.forEach(btn => {
                    if (btn) {
                        const icon = btn.querySelector('.gear-icon');
                        if (icon) {
                            icon.style.transform = `rotate(${rotation}deg)`;
                            icon.dataset.rotation = rotation;
                             // Keep stroke white regardless of theme for header consistency
                            icon.style.stroke = '#FEFEFE'; 
                        }
                    }
                });
            };

            // Add click listeners to both theme buttons
            themeButtons.forEach(btn => {
                if (btn) {
                    btn.addEventListener('click', () => {
                        const currentTheme = htmlEl.getAttribute('data-theme');
                        const newTheme = currentTheme === 'light' ? 'dark' : 'light';
                        applyTheme(newTheme);
                        // Animate rotation (already handled in applyTheme if using dataset)
                    });
                }
            });
            // Apply saved theme on page load, default to 'dark'
            applyTheme(localStorage.getItem('theme') || 'dark');
            
             // Initial check of login state from localStorage
            updateLoginState();
            
            // --- NEW SLIDESHOW LOGIC ---
            
            /**
             * Core function to display the correct slide and dot.
             * @param {HTMLElement} slideshow - The specific slideshow container being controlled.
             * @param {number} n - The target slide index.
             */
            function showSlides(slideshow, n) {
                const slides = slideshow.querySelectorAll('.slide');
                const dots = slideshow.querySelectorAll('.dot');
                let slideIndex = n; // Use the passed index
                
                // Wrap around logic
                if (n > slides.length) { slideIndex = 1; }
                if (n < 1) { slideIndex = slides.length; }
                
                slideshow.dataset.slideIndex = slideIndex; // Update the index in dataset

                // Hide all slides
                for (let i = 0; i < slides.length; i++) {
                    slides[i].style.display = "none";
                    slides[i].style.opacity = "0";
                    slides[i].classList.remove('active-slide'); // Remove class just in case
                }
                
                // Deactivate all dots
                for (let i = 0; i < dots.length; i++) {
                    dots[i].className = dots[i].className.replace(" active-dot", "");
                }

                // Show the current slide and activate the current dot
                const currentSlide = slides[slideIndex - 1];
                if (currentSlide) {
                     currentSlide.style.display = "block"; // 1. Make it take space
                     // 2. Use a tiny delay to allow the 'display' change to render,
                     //    so the opacity transition will fire.
                     setTimeout(() => {
                        currentSlide.style.opacity = "1";
                     }, 10);
                }
                const currentDot = dots[slideIndex - 1];
                if (currentDot) {
                    currentDot.className += " active-dot";
                }
            }
            
            /**
             * Initializes all slideshows on the page.
             * Finds all elements, sets their initial slide index,
             * shows the first slide, and attaches event listeners.
             */
            function initializeSlideshows() {
                const slideshows = document.querySelectorAll('.candid-slideshow-container');
                
                slideshows.forEach(slideshow => {
                    // Explicitly hide all slides on init
                    const slides = slideshow.querySelectorAll('.slide');
                    slides.forEach(slide => {
                        slide.style.display = 'none';
                        slide.style.opacity = '0';
                    });

                    slideshow.dataset.slideIndex = "1";
                    const dots = slideshow.querySelectorAll('.dot');
                    
                    // Attach listener for 'prev' button
                    const prevButton = slideshow.querySelector('.prev');
                    if (prevButton) {
                        prevButton.addEventListener('click', () => {
                            let slideIndex = parseInt(slideshow.dataset.slideIndex, 10);
                            slideIndex--;
                            showSlides(slideshow, slideIndex);
                        });
                    }
                    
                    // Attach listener for 'next' button
                    const nextButton = slideshow.querySelector('.next');
                    if (nextButton) {
                        nextButton.addEventListener('click', () => {
                            let slideIndex = parseInt(slideshow.dataset.slideIndex, 10);
                            slideIndex++;
                            showSlides(slideshow, slideIndex);
                        });
                    }
                    
                    // Attach listeners for dots
                    dots.forEach((dot, index) => {
                        dot.addEventListener('click', () => {
                            showSlides(slideshow, index + 1);
                        });
                    });

                    // Show the first slide
                    showSlides(slideshow, 1); 
                });
            }

            // Initialize all slideshows
            initializeSlideshows();

            // Add click listeners to login buttons to show the popup
            if(elements.exploreYpiBtn) {
                elements.exploreYpiBtn.addEventListener('click', (e) => {
                    // Only show popup if button is visible (i.e., logged out)
                     if (elements.exploreYpiBtn.style.display !== 'none') {
                         ypiShowLoginPopup();
                     }
                });
            }
             if(elements.mobileExploreYpiBtn) {
                 elements.mobileExploreYpiBtn.addEventListener('click', (e) => {
                     // Only show popup if button is visible (i.e., logged out)
                     if (elements.mobileExploreYpiBtn.style.display !== 'none') {
                           ypiShowLoginPopup();
                     }
                 });
             }

            // --- MOBILE SIDEBAR ---
            const hamburger = document.getElementById('menuButton');
            const sidebar = document.getElementById('mobileSidebar');
            const closeBtn = document.getElementById('sidebarCloseBtn');
            const overlay = document.getElementById('sidebarOverlay');

            if (hamburger && sidebar && closeBtn && overlay) {
                const openSidebar = () => {
                    sidebar.classList.add('open');
                    overlay.classList.add('active');
                    document.body.classList.add('sidebar-is-open');
                };
                const closeSidebar = () => {
                    sidebar.classList.remove('open');
                    overlay.classList.remove('active');
                    document.body.classList.remove('sidebar-is-open');
                };
                hamburger.onclick = openSidebar;
                closeBtn.onclick = closeSidebar;
                overlay.onclick = closeSidebar;
                
                 // Close sidebar when a nav link is clicked (optional)
                sidebar.querySelectorAll('nav a').forEach(link => {
                    link.addEventListener('click', closeSidebar);
                });
                 // Close sidebar when mobile login button is clicked before showing popup
                 if(elements.mobileExploreYpiBtn) {
                     elements.mobileExploreYpiBtn.addEventListener('click', (e) => {
                         if (elements.mobileExploreYpiBtn.style.display !== 'none') { // only if login button
                            closeSidebar(); // Close sidebar first
                            // ypiShowLoginPopup will be called by the other listener
                         }
                     });
                 }
            }

        });
    </script>
</body>
