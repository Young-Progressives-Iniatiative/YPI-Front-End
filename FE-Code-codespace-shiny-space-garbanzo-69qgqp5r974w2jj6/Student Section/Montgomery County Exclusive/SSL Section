<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
 <meta charset="UTF-8" />
 <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
 <title>Section I - Student Information</title>
 <link rel="preconnect" href="https://fonts.googleapis.com">
 <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
 <link href="https://fonts.googleapis.com/css2?family=Atkinson+Hyperlegible:wght@400;700&display=swap" rel="stylesheet">


 <style>
   :root {
     --primary-green: #37af4b;
     --light-gray: #bbb;
     --theme-body-bg: #1c1c1c;
     --theme-body-color: #fefefe;
     --theme-input-bg: #1c1c1c;
     --theme-input-border: #444;
     --theme-input-text: #fefefe;
     --theme-button-bg: #1c1c1c;
     --theme-button-border: #444;
     --theme-button-text: #fefefe;
   }


   html[data-theme='light'] {
     --theme-body-bg: #fefefe;
     --theme-body-color: #1c1c1c;
     --theme-input-bg: #fefefe;
     --theme-input-border: #ccc;
     --theme-input-text: #1c1c1c;
     --theme-button-bg: #fefefe;
     --theme-button-border: #ccc;
     --theme-button-text: #1c1c1c;
   }


   body {
     font-family: 'Atkinson Hyperlegible', sans-serif;
     background-color: var(--theme-body-bg);
     color: var(--theme-body-color);
     margin: 0;
     padding: 2rem;
     display: flex;
     justify-content: center;
     align-items: center;
     min-height: 100vh;
     flex-direction: column;
   }
  
   .theme-switcher {
       position: fixed;
       top: 1rem;
       right: 1rem;
       padding: 0.5rem 1rem;
       border-radius: 0.375rem;
       cursor: pointer;
       background-color: var(--theme-button-bg);
       color: var(--theme-button-text);
       border: 1px solid var(--theme-button-border);
       font-family: 'Atkinson Hyperlegible', sans-serif;
       font-weight: 500;
       transition: background-color 0.2s, color 0.2s;
   }


   .theme-switcher:hover {
       opacity: 0.8;
   }


   .form-container {
     width: 100%;
     max-width: 800px;
     background-color: transparent; /* Changed for better theme blending */
     padding: 2rem;
     border-radius: 0.75rem;
     border: 1px solid var(--theme-input-border);
     box-shadow: 0 10px 15px rgba(0, 0, 0, 0.1);
   }


   .section-heading {
     font-size: 1.5rem;
     font-weight: 600;
     margin-bottom: 1rem;
     border-bottom: 1px solid var(--theme-input-border);
     color: var(--primary-green);
     padding-bottom: 0.5rem;
   }


   .text-sm {
     font-size: 0.875rem;
     color: var(--light-gray);
     margin-bottom: 1.5rem;
   }


   .input-group {
     margin-bottom: 1rem;
   }


   .label {
     display: block;
     font-size: 1.125rem;
     font-weight: 500;
     margin-bottom: 0.5rem;
     color: var(--primary-green);
   }


   .text-input {
     width: 100%;
     box-sizing: border-box;
     padding: 0.75rem 1rem;
     background-color: var(--theme-input-bg);
     color: var(--theme-input-text);
     border: 1px solid var(--theme-input-border);
     border-radius: 0.375rem;
     transition: border 0.2s, box-shadow 0.2s;
   }


   .text-input:focus {
     border-color: #3b82f6;
     outline: none;
     box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.5);
   }


   .grid-2-cols {
     display: grid;
     grid-template-columns: 1fr;
     gap: 1rem;
   }


   @media (min-width: 768px) {
     .grid-2-cols {
       grid-template-columns: 1fr 1fr;
     }
   }
 </style>
</head>


<body>


 <button class="theme-switcher" id="themeSwitcher">Toggle Theme</button>
  <div class="form-container">
   <h2 class="section-heading">SECTION I. STUDENT INFORMATION</h2>
   <p class="text-sm">
     To be completed by the student prior to review from the nonprofit tax exempt organization.
   </p>


   <div class="input-group">
     <label for="studentName" class="label">Student Name (Last, First, Middle)</label>
     <input type="text" id="studentName" class="text-input">
   </div>


   <div class="grid-2-cols">
     <div class="input-group">
       <label for="studentId" class="label">Student ID</label>
       <input type="text" id="studentId" class="text-input">
     </div>
     <div class="input-group">
       <label for="school" class="label">School</label>
       <input type="text" id="school" class="text-input">
     </div>
   </div>


   <div class="grid-2-cols">
     <div class="input-group">
       <label for="firstPeriodTeacher" class="label">First Period Teacher</label>
       <input type="text" id="firstPeriodTeacher" class="text-input">
     </div>
     <div class="input-group">
       <label for="grade" class="label">Grade</label>
       <input type="text" id="grade" class="text-input">
     </div>
   </div>


   <div class="input-group">
     <label for="studentEmail" class="label">E-mail</label>
     <input type="email" id="studentEmail" class="text-input">
   </div>


   <div class="grid-2-cols">
     <div class="input-group">
       <label for="parentName" class="label">Parent/Guardian Name</label>
       <input type="text" id="parentName" class="text-input">
     </div>
     <div class="input-group">
       <label for="parentPhone" class="label">Phone: Home or Cell</label>
       <input type="text" id="parentPhone" class="text-input" placeholder="___-___-____">
     </div>
   </div>
 </div>


 <script>
   const themeSwitcher = document.getElementById('themeSwitcher');
   const doc = document.documentElement;


   themeSwitcher.addEventListener('click', () => {
     const currentTheme = doc.getAttribute('data-theme');
     if (currentTheme === 'dark') {
       doc.setAttribute('data-theme', 'light');
     } else {
       doc.setAttribute('data-theme', 'dark');
     }
   });
 </script>


</body>
</html>