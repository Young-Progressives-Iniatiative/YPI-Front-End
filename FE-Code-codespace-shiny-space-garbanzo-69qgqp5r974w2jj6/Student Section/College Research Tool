<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>School List — College Research Tool</title>
<link href="https://fonts.googleapis.com/css2?family=Atkinson+Hyperlegible:ital,wght@0,400;0,700;1,400;1,700&display=swap" rel="stylesheet"/>
<script src="https://cdn.tailwindcss.com"></script>
<script>
  tailwind.config = {
    theme: {
      extend: {
        colors: {
          bg: '#0f1117',
          surface: '#181c27',
          surface2: '#1f2435',
          accent: '#bf5700',
        },
        fontFamily: {
          sans: ['Atkinson Hyperlegible', 'sans-serif'],
        }
      }
    }
  }
</script>
<style>
  /* Custom Scrollbar */
  ::-webkit-scrollbar { width: 6px; height: 6px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.1); border-radius: 4px; }
  ::-webkit-scrollbar-thumb:hover { background: rgba(255,255,255,0.2); }

  /* Animations */
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .animate-fade-up { animation: fadeUp 0.4s ease forwards; }
  .delay-100 { animation-delay: 0.1s; }
  .delay-200 { animation-delay: 0.2s; }

  /* Hide scrollbar for tabs/sidebar on mobile but keep functionality */
  .no-scrollbar::-webkit-scrollbar { display: none; }
  .no-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
</style>
</head>
<body class="bg-bg text-gray-200 font-sans h-screen flex flex-col overflow-hidden">

<!-- TOP HEADER -->
<header class="h-24 bg-surface border-b border-white/10 flex items-center justify-between px-6 md:px-8 shrink-0 z-30">
  <div class="flex items-center gap-4">
    <div class="w-12 h-12 bg-accent text-white rounded-lg flex items-center justify-center font-bold text-2xl">🎓</div>
    <h1 class="font-bold text-2xl tracking-wide text-gray-100 hidden sm:block">College Research Tool</h1>
  </div>
  
  <div class="flex items-center gap-6">
    <div class="relative hidden md:block">
      <input type="text" placeholder="Search schools..." class="bg-surface2 border border-white/10 rounded-lg px-5 py-2.5 text-base text-gray-200 focus:outline-none focus:border-accent w-80 transition-colors placeholder:text-gray-500" />
      <span class="absolute right-4 top-2.5 text-gray-500 text-lg">🔍</span>
    </div>
    <button class="text-base font-semibold text-gray-400 hover:text-white transition-colors">Compare</button>
    <div class="w-px h-8 bg-white/10 mx-1"></div>
    <button class="w-12 h-12 text-xl rounded-full bg-surface2 border border-white/10 flex items-center justify-center hover:bg-white/5 transition-colors">
      👤
    </button>
  </div>
</header>

<!-- MAIN LAYOUT WRAPPER -->
<div class="flex-1 flex flex-col md:flex-row overflow-hidden">
  
  <!-- SIDEBAR -->
  <aside class="w-full md:w-1/4 bg-surface border-b md:border-b-0 md:border-r border-white/10 flex flex-row md:flex-col overflow-x-auto md:overflow-y-auto shrink-0 p-3 gap-3 no-scrollbar z-20">
    <button class="md:w-full flex-shrink-0 flex items-center justify-center gap-2 p-3 border-2 border-dashed border-white/15 rounded-xl text-gray-400 font-bold tracking-wide hover:border-white hover:text-white hover:bg-white/5 transition-all mb-1">
      + Add School
    </button>

    <!-- School cards -->
    <div class="school-card active flex-shrink-0 flex items-center gap-3 p-2 md:p-3 rounded-xl cursor-pointer border-2 bg-white border-[#b45a38] opacity-100 shadow-lg transition-all w-48 md:w-auto" 
         onclick="selectSchool(this, 'texas', '#b45a38', '🤘', 'University of Texas', 'at Austin', 'Longhorns', 'white')">
      <div class="w-10 h-10 rounded-lg flex items-center justify-center text-xl shrink-0 bg-white text-[#b45a38] shadow-sm">🤘</div>
      <div class="flex-1 min-w-0">
        <div class="text-sm font-bold truncate text-[#b45a38]">University of Texas</div>
      </div>
      <div class="bg-green-100 text-green-700 text-xs font-bold px-2 py-1 rounded border border-green-300 shrink-0">8.0</div>
    </div>

    <!-- GEORGETOWN CARD (Inverted Theme: Gray BG, Navy Text, Navy Border) -->
    <div class="school-card flex-shrink-0 flex items-center gap-3 p-2 md:p-3 rounded-xl cursor-pointer border-2 bg-[#a2aaad] border-[#002147] opacity-60 hover:opacity-100 transition-all w-48 md:w-auto" 
         onclick="selectSchool(this, 'georgetown', '#002147', 'G', 'Georgetown', 'University', 'Hoyas', '#a2aaad')">
      <div class="w-10 h-10 rounded-lg flex items-center justify-center text-xl shrink-0 bg-transparent text-[#002147] font-serif font-bold shadow-none">G</div>
      <div class="flex-1 min-w-0">
        <div class="text-sm font-bold truncate text-[#002147]">Georgetown Univ.</div>
      </div>
      <div class="bg-green-100 text-green-700 text-xs font-bold px-2 py-1 rounded border border-green-300 shrink-0">8.0</div>
    </div>

    <!-- FORDHAM CARD (Inverted Theme: Gray BG, Maroon Text, Black Border) -->
    <div class="school-card flex-shrink-0 flex items-center gap-3 p-2 md:p-3 rounded-xl cursor-pointer border-2 bg-[#bcc0c2] border-[#000000] opacity-60 hover:opacity-100 transition-all w-48 md:w-auto" 
         onclick="selectSchool(this, 'fordham', '#7a112c', 'F', 'Fordham', 'University', 'Rams', '#bcc0c2')">
      <div class="w-10 h-10 rounded-lg flex items-center justify-center text-xl shrink-0 bg-transparent text-[#7a112c] font-serif font-bold shadow-none">F</div>
      <div class="flex-1 min-w-0">
        <div class="text-sm font-bold truncate text-[#7a112c]">Fordham University</div>
      </div>
      <div class="bg-green-100 text-green-700 text-xs font-bold px-2 py-1 rounded border border-green-300 shrink-0">8.0</div>
    </div>

    <!-- DELAWARE CARD (Inverted Theme: Yellow BG, Blue Text, Blue Border) -->
    <div class="school-card flex-shrink-0 flex items-center gap-3 p-2 md:p-3 rounded-xl cursor-pointer border-2 bg-[#f8d000] border-[#004a98] opacity-60 hover:opacity-100 transition-all w-48 md:w-auto" 
         onclick="selectSchool(this, 'delaware', '#004a98', '🦆', 'University of Delaware', '', 'Blue Hens', '#f8d000')">
      <div class="w-10 h-10 rounded-lg flex items-center justify-center text-xl shrink-0 bg-transparent text-[#004a98] shadow-none">🦆</div>
      <div class="flex-1 min-w-0">
        <div class="text-sm font-bold truncate text-[#004a98]">Univ. of Delaware</div>
      </div>
      <div class="bg-green-100 text-green-700 text-xs font-bold px-2 py-1 rounded border border-green-300 shrink-0">8.0</div>
    </div>

    <!-- UCLA CARD (Inverted Theme: Yellow BG, Blue Text, Blue Border) -->
    <div class="school-card flex-shrink-0 flex items-center gap-3 p-2 md:p-3 rounded-xl cursor-pointer border-2 bg-[#ffb71b] border-[#0971ce] opacity-60 hover:opacity-100 transition-all w-48 md:w-auto" 
         onclick="selectSchool(this, 'ucla', '#0971ce', 'UCLA', 'University of California,', 'Los Angeles', 'Bruins', '#ffb71b')">
      <div class="w-10 h-10 rounded-lg flex items-center justify-center text-xs shrink-0 bg-transparent text-[#0971ce] font-bold shadow-none">UCLA</div>
      <div class="flex-1 min-w-0">
        <div class="text-sm font-bold truncate text-[#0971ce]">University of California, Los Angeles</div>
      </div>
      <div class="bg-green-100 text-green-700 text-xs font-bold px-2 py-1 rounded border border-green-300 shrink-0">8.0</div>
    </div>

    <!-- STANFORD CARD (Primary Red: #8c1515) -->
    <div class="school-card flex-shrink-0 flex items-center gap-3 p-2 md:p-3 rounded-xl cursor-pointer border-2 bg-white border-[#8c1515] opacity-60 hover:opacity-100 transition-all w-48 md:w-auto" 
         onclick="selectSchool(this, 'stanford', '#8c1515', '🌲', 'Stanford', 'University', 'Cardinal', 'white')">
      <div class="w-10 h-10 rounded-lg flex items-center justify-center text-xl shrink-0 bg-transparent text-[#8c1515] shadow-none">🌲</div>
      <div class="flex-1 min-w-0">
        <div class="text-sm font-bold truncate text-[#8c1515]">Stanford University</div>
      </div>
      <div class="bg-green-100 text-green-700 text-xs font-bold px-2 py-1 rounded border border-green-300 shrink-0">8.0</div>
    </div>
  </aside>

  <!-- MAIN CONTENT -->
  <div class="flex-1 flex flex-col min-w-0 overflow-hidden bg-bg relative">

    <!-- Scrollable Inner Content -->
    <div class="flex-1 overflow-y-auto">
      <!-- Header Area Wrapper -->
      <div class="p-4 md:p-6 lg:p-8">
        
        <!-- Responsive Header Card -->
        <div id="schoolHeaderBg" class="p-6 md:p-8 rounded-2xl border-2 border-white shadow-[0_8px_40px_rgba(0,0,0,0.4)] relative overflow-hidden flex flex-col xl:flex-row gap-8 items-start xl:items-stretch transition-all duration-500" style="background-color: #b45a38;">
            
            <!-- Left Column: Branding & Badges -->
            <div class="flex flex-col flex-1 z-10 w-full xl:w-auto">
              
              <!-- Top Row: Logo & Text -->
              <div class="flex flex-col md:flex-row items-start gap-6 relative">
                <!-- Logo Box -->
                <div id="headerLogo" class="w-48 h-48 md:w-64 md:h-64 bg-white/10 backdrop-blur-sm rounded-xl flex items-center justify-center text-[6rem] md:text-[9rem] shadow-lg border border-white/20 shrink-0 transition-colors">
                  🤘
                </div>
                
                <!-- Text Info -->
                <div class="flex flex-col items-start text-left pt-2">
                  <h1 id="headerMainTitle" class="text-3xl md:text-4xl lg:text-5xl font-bold text-white leading-tight transition-colors">
                    <span id="headerTitle1">University of Texas</span><br/>
                    <span id="headerTitle2">at Austin</span>
                  </h1>
                  <div id="headerSubtitle" class="text-xs md:text-sm font-bold tracking-widest text-white/70 uppercase mt-2">Longhorns</div>
                </div>
              </div>

              <!-- Bottom Row: Actions & Badges -->
              <div class="flex flex-wrap items-center gap-2 mt-6 justify-start">
                <button id="headerStatusBtn" class="flex items-center justify-center gap-2.5 bg-white/10 hover:bg-white/20 border border-white text-white rounded-xl px-5 py-2 text-lg md:text-xl font-bold transition-colors backdrop-blur-md">
                  ✏️ Insert Status Here
                </button>
                
                <div class="hidden sm:block w-px h-6 bg-white/20 mx-2"></div>

                <!-- Dynamic Badges Container -->
                <div id="dynamicBadges" class="flex flex-wrap items-center gap-2">
                  <div class="flex items-center gap-1 bg-green-500/20 text-green-400 border border-green-500/30 px-2.5 py-1 rounded text-xs font-bold">
                    <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"></path></svg>
                    A+ Niche
                  </div>
                  <div class="bg-white/10 text-white/90 border border-white/20 px-2.5 py-1 rounded text-xs font-semibold tracking-wide">#12 in US</div>
                  <div class="bg-white/10 text-white/90 border border-white/20 px-2.5 py-1 rounded text-xs font-semibold tracking-wide">#18 in World</div>
                  <div class="bg-white/10 text-white/90 border border-white/20 px-2.5 py-1 rounded text-xs font-semibold tracking-wide">🏈 SEC</div>
                  <div class="bg-white/10 text-white/90 border border-white/20 px-2.5 py-1 rounded text-xs font-semibold tracking-wide">🇺🇸 Texas</div>
                </div>
              </div>
            </div>

          <!-- Middle Column: Stats Grid -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-6 gap-y-3 z-10 w-full xl:w-auto xl:my-auto">
            <div class="flex items-center gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" width="20" height="20" viewBox="0 0 48 48" class="opacity-80 shrink-0">
                <image xlink:href="data:image/png;base64," x="0" y="0" width="48" height="48"/>
              </svg>
              <span class="text-sm text-white/70">Location</span> <span class="text-white/30 px-1">·</span> <span id="statLocation" class="text-sm font-bold text-white">Austin, TX</span>
            </div>
            <div class="flex items-center gap-2"><span class="text-lg opacity-80">🏛️</span> <span class="text-sm text-white/70">Type</span> <span class="text-white/30 px-1">·</span> <span id="statType" class="text-sm font-bold text-white">Public Research</span></div>
            <div class="flex items-center gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" width="20" height="20" viewBox="0 0 20 20" class="opacity-80 shrink-0">
                <image xlink:href="data:image/png;base64," x="0" y="0" width="20" height="20"/>
              </svg>
              <span class="text-sm text-white/70">Acceptance</span> <span class="text-white/30 px-1">·</span> <span id="statAcceptance" class="text-sm font-bold text-white">18%</span>
            </div>
            <div class="flex items-center gap-2"><span class="text-lg opacity-80">🧑‍🎓</span> <span class="text-sm text-white/70">Students</span> <span class="text-white/30 px-1">·</span> <span id="statStudents" class="text-sm font-bold text-white">52,384</span></div>
            <div class="flex items-center gap-2">
              <svg xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" width="20" height="20" viewBox="0 0 20 20" class="opacity-80 shrink-0">
                <image xlink:href="data:image/png;base64," x="0" y="0" width="20" height="20"/>
              </svg>
              <span class="text-sm text-white/70">Grad Rate</span> <span class="text-white/30 px-1">·</span> <span id="statGradRate" class="text-sm font-bold text-white">88%</span>
            </div>
            <div class="flex items-center gap-2"><span class="text-lg opacity-80">💼</span> <span class="text-sm text-white/70">Internships</span> <span class="text-white/30 px-1">·</span> <span id="statInternships" class="text-sm font-bold text-white">97%</span></div>
            <div class="flex items-center gap-2"><span class="text-lg opacity-80">🎓</span> <span class="text-sm text-white/70">Career Place.</span> <span class="text-white/30 px-1">·</span> <span id="statCareer" class="text-sm font-bold text-white">90%</span></div>
            <div class="flex items-center gap-2"><span class="text-lg opacity-80">📚</span> <span class="text-sm text-white/70">Adv. Degree</span> <span class="text-white/30 px-1">·</span> <span id="statAdvDegree" class="text-sm font-bold text-white">75%</span></div>
            <div class="flex items-center gap-2 sm:col-span-2"><span class="text-lg opacity-80">🏦</span> <span class="text-sm text-white/70">Endowment</span> <span class="text-white/30 px-1">·</span> <span id="statEndowment" class="text-sm font-bold text-white">$20.85 Billion</span></div>
          </div>

          <!-- Right Column: Score Panel -->
          <div class="flex flex-col gap-3 w-full xl:w-56 shrink-0 bg-black/25 backdrop-blur-md p-4 rounded-xl border border-white/10 z-10">
            
            <div>
              <div class="flex justify-between items-end mb-1">
                <div class="text-[10px] font-bold tracking-wider text-white/60 uppercase">Interest Rating</div>
                <div class="text-[10px] font-bold text-white/80">8,200/10k</div>
              </div>
              <div class="h-1.5 w-full bg-black/40 rounded-full overflow-hidden">
                <div class="h-full bg-gradient-to-r from-green-400 to-blue-500 rounded-full" style="width: 82%"></div>
              </div>
            </div>

            <div>
              <div class="flex justify-between items-end mb-1">
                <div class="text-[10px] font-bold tracking-wider text-white/60 uppercase">Admittance Score</div>
                <div class="text-[10px] font-bold text-white/80">6,500/10k</div>
              </div>
              <div class="h-1.5 w-full bg-black/40 rounded-full overflow-hidden">
                <div class="h-full bg-gradient-to-r from-yellow-400 to-orange-500 rounded-full" style="width: 65%"></div>
              </div>
            </div>

            <div>
              <div class="flex justify-between items-end mb-1">
                <div class="text-[10px] font-bold tracking-wider text-white/60 uppercase">Fin. Aid Likelihood</div>
                <div class="text-[10px] font-bold text-white/80">5,000/10k</div>
              </div>
              <div class="h-1.5 w-full bg-black/40 rounded-full overflow-hidden">
                <div class="h-full bg-gradient-to-r from-red-500 to-orange-600 rounded-full" style="width: 50%"></div>
              </div>
            </div>

            <div class="mt-2 bg-black/30 border border-green-400/30 rounded-lg p-3 text-center">
              <div class="text-3xl font-bold text-green-400 leading-none">8.0</div>
              <div class="text-[10px] text-white/50 uppercase tracking-wider font-bold mt-1">Total Match Score</div>
              <div class="text-[9px] text-white/40 mt-1.5 leading-snug">This school appears to be an excellent match given your preferences.</div>
            </div>

          </div>
        </div>
      </div> <!-- /Header Wrapper -->

      <!-- Tabs Container -->
      <div class="flex overflow-x-auto border-b border-white/10 bg-surface px-4 md:px-8 shrink-0 no-scrollbar">
        <button class="tab-btn px-4 md:px-6 py-3 text-xs md:text-sm font-bold uppercase tracking-wider text-gray-500 hover:text-gray-200 border-b-2 border-transparent whitespace-nowrap transition-colors" onclick="switchTab('economics', this)">Economics</button>
        <button class="tab-btn px-4 md:px-6 py-3 text-xs md:text-sm font-bold uppercase tracking-wider text-gray-500 hover:text-gray-200 border-b-2 border-transparent whitespace-nowrap transition-colors" onclick="switchTab('academics', this)">Academic Standards</button>
        <button class="tab-btn px-4 md:px-6 py-3 text-xs md:text-sm font-bold uppercase tracking-wider text-gray-500 hover:text-gray-200 border-b-2 border-transparent whitespace-nowrap transition-colors" onclick="switchTab('safety', this)">Safety</button>
        <button class="tab-btn active px-4 md:px-6 py-3 text-xs md:text-sm font-bold uppercase tracking-wider text-accent border-b-2 border-accent whitespace-nowrap transition-colors" onclick="switchTab('social', this)">Social &amp; Political Culture</button>
      </div>

      <!-- TABS CONTENT AREA -->
      <div class="p-4 md:p-6 lg:p-8 relative">
        
        <!-- Hidden div to pre-load dynamic Tailwind color classes -->
        <div class="hidden bg-green-500/20 text-green-400 bg-yellow-500/20 text-yellow-500 bg-red-500/20 text-red-400 bg-blue-500/20 text-blue-400"></div>

        <!-- TAB: SOCIAL (Active Default) -->
        <div id="tab-social" class="tab-pane grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
          
          <!-- Political Treemap -->
          <div class="bg-surface border border-white/10 p-5 rounded-2xl animate-fade-up">
            <h3 class="text-base font-bold text-gray-100 mb-4 flex items-center gap-2"><span class="text-xl">🗳️</span> Student Political Self-ID</h3>
            
            <div id="politicsChartContainer">
              <!-- Default chart loaded manually, will be overwritten by JS -->
              <div class="flex flex-col md:flex-row gap-1 h-40 md:h-32 text-white font-bold text-sm">
                <div class="bg-gradient-to-br from-[#1a3a6e] to-[#2455b0] rounded-lg p-3 flex flex-col justify-end relative overflow-hidden group hover:brightness-110 transition-all" style="flex-basis: 65%;">
                  <span class="z-10">65%</span>
                  <span class="text-[10px] font-medium opacity-70 z-10">Liberal</span>
                </div>
                <div class="flex flex-row md:flex-col gap-1 h-full" style="flex-basis: 35%;">
                  <div class="bg-gradient-to-br from-[#4a3080] to-[#7046bf] rounded-lg p-2 flex flex-col justify-end flex-1 hover:brightness-110 transition-all">
                    <span>15%</span><span class="text-[9px] font-medium opacity-70 leading-none">Moderate</span>
                  </div>
                  <div class="flex gap-1 flex-1">
                    <div class="bg-gradient-to-br from-[#305050] to-[#3d7070] rounded-lg p-2 flex flex-col justify-end hover:brightness-110 transition-all" style="flex-basis: 52%;">
                      <span>11%</span><span class="text-[9px] font-medium opacity-70 leading-none">Other</span>
                    </div>
                    <div class="bg-gradient-to-br from-[#6e2020] to-[#b03030] rounded-lg p-2 flex flex-col justify-end hover:brightness-110 transition-all" style="flex-basis: 48%;">
                      <span>10%</span><span class="text-[9px] font-medium opacity-70 leading-none">Conserv.</span>
                    </div>
                  </div>
                </div>
              </div>
            </div>
            <div class="mt-4 text-xs text-gray-500">Data From: <span class="font-bold text-gray-300">NICHE</span></div>
          </div>

          <!-- Niche Grades -->
          <div class="bg-surface border border-white/10 p-5 rounded-2xl animate-fade-up delay-100">
            <h3 class="text-base font-bold text-gray-100 mb-4 flex items-center gap-2"><span class="text-xl">⭐</span> Campus Life Ratings</h3>
            
            <div class="flex flex-col gap-3">
              <div class="flex items-center gap-4 pb-3 border-b border-white/5">
                <div id="ratingPartyGrade" class="w-10 h-10 rounded-lg bg-green-500/20 text-green-400 flex items-center justify-center font-bold text-sm shrink-0">A+</div>
                <div class="text-sm text-gray-200 flex-1">Party Scene <span class="text-gray-500 text-xs cursor-help ml-1" title="Based on student reviews and nightlife access.">ⓘ</span></div>
              </div>
              <div class="flex items-center gap-4 pb-3 border-b border-white/5">
                <div id="ratingSafetyGrade" class="w-10 h-10 rounded-lg bg-yellow-500/20 text-yellow-500 flex items-center justify-center font-bold text-sm shrink-0">C+</div>
                <div class="text-sm text-gray-200 flex-1">Safety <span class="text-gray-500 text-xs cursor-help ml-1" title="Campus crime rates and local area safety.">ⓘ</span></div>
              </div>
              <div class="flex items-center gap-4 pb-3 border-b border-white/5">
                <div id="ratingFoodGrade" class="w-10 h-10 rounded-lg bg-green-500/20 text-green-400 flex items-center justify-center font-bold text-sm shrink-0">A</div>
                <div class="text-sm text-gray-200 flex-1">Campus Food <span class="text-gray-500 text-xs cursor-help ml-1" title="Dining hall quality and meal plan options.">ⓘ</span></div>
              </div>
