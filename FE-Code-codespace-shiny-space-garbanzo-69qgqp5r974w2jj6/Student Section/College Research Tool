              <span>${data.politics.oth}%</span><span class="text-[9px] font-medium opacity-70 leading-none">Other</span>
            </div>
            <div class="bg-gradient-to-br from-[#6e2020] to-[#b03030] rounded-lg p-2 flex flex-col justify-end hover:brightness-110 transition-all" style="flex-basis: ${conBasis}%;">
              <span>${data.politics.con}%</span><span class="text-[9px] font-medium opacity-70 leading-none">Conserv.</span>
            </div>
          </div>
        </div>
      </div>
    `;

    // Update Ratings
    const getGradeClass = (grade) => {
      if(grade.includes('A')) return 'bg-green-500/20 text-green-400';
      if(grade.includes('B')) return 'bg-blue-500/20 text-blue-400';
      if(grade.includes('C')) return 'bg-yellow-500/20 text-yellow-500';
      return 'bg-red-500/20 text-red-400';
    };

    const applyGrade = (id, grade) => {
      const el = document.getElementById(id);
      el.textContent = grade;
      el.className = `w-10 h-10 rounded-lg flex items-center justify-center font-bold text-sm shrink-0 ${getGradeClass(grade)}`;
    };

    applyGrade('ratingPartyGrade', data.ratings.party);
    applyGrade('ratingSafetyGrade', data.ratings.safety);
    applyGrade('ratingFoodGrade', data.ratings.food);
    applyGrade('ratingDormsGrade', data.ratings.dorms);

    document.getElementById('greekMen').textContent = data.ratings.frats;
    document.getElementById('greekWomen').textContent = data.ratings.sororities;

    // Update Sentiment
    document.getElementById('sentimentScore').textContent = data.sentiment.score;
    document.getElementById('sentimentMatch').textContent = data.sentiment.match;
    document.getElementById('sentimentDesc').innerHTML = `
      ${data.sentiment.desc}
      <br/><br/>
      <strong class="text-gray-200">Key Positive Themes:</strong> ${data.sentiment.pos}
      <br/><br/>
      <strong class="text-gray-200">Key Concerns:</strong> ${data.sentiment.neg}
    `;

    // Update Clubs
    const buildClubs = (list, color) => list.map(c => `<li class="flex items-center gap-2 bg-surface2 px-3 py-2 rounded-lg text-sm text-gray-200"><div class="w-2 h-2 rounded-full bg-${color}-400 shrink-0"></div> ${c}</li>`).join('');
    document.getElementById('clubsAllied').innerHTML = buildClubs(data.clubs.allied, 'green');
    document.getElementById('clubsUnaligned').innerHTML = buildClubs(data.clubs.unaligned, 'yellow');
    document.getElementById('clubsHostile').innerHTML = buildClubs(data.clubs.hostile, 'red');

    // Update Professors
    document.getElementById('professorsList').innerHTML = data.professors.map(p => `
      <div class="flex items-center gap-3 bg-surface2 p-3 rounded-xl">
        <div class="w-10 h-10 rounded-full bg-accent/20 border border-accent/40 flex items-center justify-center text-lg shrink-0">${p.icon}</div>
        <div>
          <div class="text-sm font-bold text-gray-200">${p.name}</div>
          <div class="text-xs text-gray-500">${p.title}</div>
        </div>
      </div>
    `).join('');
  }
</script>
</body>
</html>
