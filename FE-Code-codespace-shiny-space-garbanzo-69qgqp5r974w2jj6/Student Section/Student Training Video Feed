<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
   <meta charset="UTF-8">
   <meta name="viewport" content="width=device-width, initial-scale=1.0">
   <title>Volunteer Video Queue</title>
   <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
   <script src="https://cdn.tailwindcss.com"></script>
   <style>
       * {
           margin: 0;
           padding: 0;
           box-sizing: border-box;
       }


       body {
           font-family: 'Arial', sans-serif;
           background-color: var(--theme-body-bg);
           color: var(--theme-body-color);
           line-height: 1.6;
           overflow-x: hidden;
           font-size: 16px;
       }


       body.customizer-is-open, body.tour-is-active {
           overflow: hidden;
       }


       :root {
           --primary-green: #37af4b;
           --dark-background: #1c1c1c;
           --member-border: #28a745;
           --light-gray: #bbb;
           --wp--preset--spacing--20: 5rem;
           --theme-body-bg: #1c1c1c;
           --theme-body-color: #fff;
           --theme-popup-bg: #bbbbbb;
           --theme-popup-text: #1c1c1c;
           --theme-input-bg: #333;
           --theme-input-border: #444;
           --theme-input-text: #eee;
           --theme-navbar-bg: #1c1c1c;
           --theme-navbar-text: #fff;
           --theme-navbar-dropdown-bg: #f0f0f0;
           --theme-navbar-dropdown-text: #1c1c1c;
           --theme-navbar-dropdown-hover-bg: #ddd;
           --theme-button-bg: #FEFEFE;
           --theme-button-text: #1c1c1c;
           --theme-button-border: #1c1c1c;
           --theme-button-hover-bg: #1c1c1c;
           --theme-button-hover-text: #FEFEFE;
           --mobile-section-bg: #2a2a2a;
           --logo-color: #FEFEFE;
           --theme-header-bg: linear-gradient(135deg, rgb(5, 114, 21) 0%, rgb(55, 175, 75) 100%);
       }


       html[data-theme='light'] {
           --theme-body-bg: #FEFEFE;
           --theme-body-color: #1c1c1c;
           --theme-popup-bg: #e0e0e0;
           --theme-popup-text: #1c1c1c;
           --theme-input-bg: #fff;
           --theme-input-border: #ccc;
           --theme-input-text: #1c1c1c;
           --primary-green: #37af4b;
           --member-border: #37af4b;
           --theme-navbar-bg: #FEFEFE;
           --theme-navbar-text: #1c1c1c;
           --theme-navbar-dropdown-bg: #1c1c1c;
           --theme-navbar-dropdown-text: #FEFEFE;
           --theme-navbar-dropdown-hover-bg: #333;
           --theme-button-bg: #1c1c1c;
           --theme-button-text: #FEFEFE;
           --theme-button-border: #1c1c1c;
           --theme-button-hover-bg: #FEFEFE;
           --theme-button-hover-text: #1c1c1c;
           --mobile-section-bg: #f0f0f0;
           --logo-color: #1c1c1c;
       }
      
       html[data-theme='light'] .header-container {
            --theme-header-bg: #FEFEFE;
       }


       html[data-theme='light'] .desktop-wp-footer,
       html[data-theme='light'] .desktop-wp-footer a {
           background: #1c1c1c;
           color: #FEFEFE;
       }


       html[data-theme='light'] .desktop-bottom-content {
           background: #dddddd;
       }


       html[data-theme='light'] .address p {
           color: #1c1c1c;
       }


       .main-wrapper {
           width: 100%;
           min-height: 100vh;
           background-color: var(--theme-body-bg);
           position: relative;
           display: flex;
           flex-direction: column;
           transition: background-color 0.3s, color 0.3s;
       }


       .content-body {
           flex: 1;
           padding: 7rem 2rem 2rem 2rem; /* Adjusted padding for fixed header */
       }


       /* Header Styles */
       .header-container {
           background: var(--theme-header-bg);
           height: 5rem;
           padding: 0 1.25rem;
           position: fixed;
           top: 0; left: 0;
           width: 100%;
           z-index: 50;
           display: flex;
           align-items: center;
       }
       .header-contents {
           display: flex;
           justify-content: space-between;
           align-items: center;
           width: 100%;
           height: 100%;
       }
       .header-left, .header-right {
           display: flex;
           gap: 1.25rem;
           align-items: center;
           height: 100%;
       }
       .header-logo {
           height: 70%;
           width: auto;
           object-fit: contain;
       }
       .icon-button {
           background: transparent;
           border: none;
           cursor: pointer;
           padding: 0.5rem;
           position: relative;
       }
       .gear-icon, .notification-bell-icon {
           width: 1.875rem;
           height: 1.875rem;
           stroke: #FEFEFE;
           stroke-width: 1.5;
       }
       .profile-pic {
           width: 45px;
           height: 45px;
           border-radius: 50%;
           object-fit: cover;
           cursor: pointer;
           border: 2px solid var(--primary-green);
       }
     
       /* Footer Styles */
       .footer-container {
           background: linear-gradient(135deg, rgb(5, 114, 21) 0%, rgb(55, 175, 75) 100%);
           padding: 1rem 0;
           color: #FEFEFE;
       }


       .footer-content {
           max-width: 1200px;
           margin: auto;
           padding: 1.25rem;
           display: flex;
           justify-content: center;
           align-items: center;
           flex-wrap: wrap;
       }
       .footer-column {
           display: flex;
           flex-direction: column;
           align-items: center;
           padding: 0.625rem;
           text-align: center;
       }
       .footer-container .site-logo {
           width: 10.4125rem;
           height: auto;
           object-fit: contain;
           margin-top: -25px;
           filter: var(--logo-filter);
       }
       .company-heading {
           font-size: 1.25rem;
           text-align: center;
           font-weight: bold;
           margin: 0;
       }
       .address {
           width: 100%;
           text-align: center;
           margin-top: 1rem;
           padding-bottom: 0.3125rem;
           font-size: 0.8rem;
           color: #ccc;
       }
      
       /* Video List Styles - Adapted for new theme */
       .video-list {
           max-width: 900px;
           margin: 0 auto;
       }


       .video-item {
           background-color: var(--mobile-section-bg);
           border: 1px solid var(--theme-input-border);
           display: flex;
           margin-bottom: 20px;
           gap: 15px;
           padding: 15px;
           border-radius: 8px;
           box-shadow: 0 4px 8px rgba(0,0,0,0.2);
       }


       .thumbnail {
           position: relative;
           flex-shrink: 0;
       }


       .thumbnail img {
           width: 246px;
           height: 138px;
           border-radius: 5px;
           display: block;
       }
      
       .play-button {
           position: absolute;
           top: 50%;
           left: 50%;
           transform: translate(-50%, -50%);
           width: 40px;
           height: 40px;
           background-color: rgba(0, 0, 0, 0.7);
           border-radius: 50%;
           display: flex;
           align-items: center;
           justify-content: center;
           cursor: pointer;
           opacity: 0;
           transition: opacity 0.3s;
       }
      
       .thumbnail:hover .play-button {
           opacity: 1;
       }


       .play-button::before {
           content: '▶';
           color: #FFFFFF;
           font-size: 20px;
           padding-left: 4px;
       }
      
       .timestamp {
           position: absolute;
           bottom: 8px;
           right: 8px;
           background-color: rgba(0, 0, 0, 0.75);
           color: #FFFFFF;
           padding: 2px 5px;
           font-size: 12px;
           border-radius: 3px;
       }


       .video-details {
           flex: 1;
           display: flex;
           flex-direction: column;
       }
      
       .org-info {
           display: flex;
           align-items: center;
           margin-bottom: 5px;
       }


       .org-logo {
           width: 30px;
           height: 30px;
           background-color: var(--member-border);
           border-radius: 50%;
           margin-right: 10px;
           display: flex;
           align-items: center;
           justify-content: center;
       }
      
       .org-logo img {
           width: 20px;
           height: 20px;
       }
      
       .org-name {
           font-size: 14px;
           color: var(--light-gray);
       }


       .video-details h3 {
           font-size: 18px;
           font-weight: bold;
           margin: 5px 0;
           color: var(--theme-body-color);
       }


       .video-details p {
           font-size: 14px;
           margin: 5px 0;
           color: var(--light-gray);
       }


       .progress-bar-container {
           display: flex;
           align-items: center;
           gap: 10px;
           margin-top: auto;
           padding-top: 10px;
       }
      
       .progress-bar {
           width: 100%;
           height: 8px;
           appearance: none;
           border-radius: 4px;
           overflow: hidden;
           background-color: var(--theme-input-border);
       }
      
       .progress-bar::-webkit-progress-bar {
           background-color: var(--theme-input-border);
       }
       .progress-bar::-webkit-progress-value {
           background-color: var(--primary-green);
       }


       .progress-bar::-moz-progress-bar {
           background-color: var(--primary-green);
       }
      
       .completion-percentage {
           font-size: 14px;
           color: var(--primary-green);
           font-weight: bold;
           min-width: 40px;
           text-align: right;
       }
      
       .due-date {
           color: var(--theme-body-color);
           font-weight: bold;
           font-size: 14px;
       }
      
       .due-date span {
           color: var(--primary-green);
       }


       /* Responsive design */
       @media (max-width: 768px) {
           .video-item {
               flex-direction: column;
           }
           .thumbnail img {
               width: 100%;
               height: auto;
           }
            .content-body {
               padding: 6rem 1rem 1rem 1rem;
           }
       }
      
