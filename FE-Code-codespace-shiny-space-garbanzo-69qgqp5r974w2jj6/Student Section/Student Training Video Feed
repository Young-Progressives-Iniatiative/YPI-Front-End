           try {
               if (Object.keys(firebaseConfig).length > 0) {
                   app = initializeApp(firebaseConfig);
                   db = getFirestore(app);
                   auth = getAuth(app);
                   setLogLevel('debug');


                   onAuthStateChanged(auth, async (user) => {
                       if (user) {
                           currentUserId = user.uid;
                           console.log("Firebase authenticated. User ID:", currentUserId);
                           setupNotificationListener();
                           setupVideoQueueListener(); // Fetch videos for the user
                       } else {
                           try {
                               if (initialAuthToken) {
                                   await signInWithCustomToken(auth, initialAuthToken);
                               } else {
                                   await signInAnonymously(auth);
                               }
                           } catch (error) {
                               console.error("Firebase authentication failed:", error);
                               if (window.showMessage) {
                                   window.showMessage('Authentication Error', 'Failed to authenticate with Firebase.');
                               }
                           }
                       }
                   });
               } else {
                   console.warn("Firebase config not found.");
                   if (window.showMessage) {
                       window.showMessage('Configuration Error', 'Firebase configuration is missing.');
                   }
               }
           } catch (error) {
               console.error("Error initializing Firebase:", error);
               if (window.showMessage) {
                   window.showMessage('Initialization Error', 'Failed to initialize Firebase.');
               }
           }
       }
      
       window.onload = initializeFirebase;


       function setupNotificationListener() {
           if (!db || !currentUserId) return;
           const notificationsRef = collection(db, `artifacts/${appId}/users/${currentUserId}/notifications`);
           const q = query(notificationsRef);
         
           onSnapshot(q, (snapshot) => {
               const notifications = [];
               let unreadCount = 0;
               snapshot.forEach((doc) => {
                   const data = doc.data();
                   notifications.push({ id: doc.id, ...data });
                   if (!data.read) unreadCount++;
               });


               notifications.sort((a, b) => (b.timestamp?.toDate() || 0) - (a.timestamp?.toDate() || 0));


               if (window.updateNotificationsUI) {
                   window.updateNotificationsUI(notifications, unreadCount);
               }
           }, (error) => {
               console.error("Error getting notifications:", error);
           });
       }


       function setupVideoQueueListener() {
           if (!db || !currentUserId) return;


           const videoQueueRef = collection(db, `artifacts/${appId}/users/${currentUserId}/videoQueue`);
           const q = query(videoQueueRef);
          
           onSnapshot(q, (snapshot) => {
               const videos = [];
               snapshot.forEach((doc) => {
                   videos.push({ id: doc.id, ...doc.data() });
               });
               videos.sort((a, b) => (a.order || 0) - (b.order || 0));
              
               if (window.renderVideoQueue) {
                   window.renderVideoQueue(videos);
               }
           }, (error) => {
               console.error("Error getting video queue:", error);
               if (window.renderVideoQueue) {
                   window.renderVideoQueue([]);
               }
           });
       }


       window.addNewNotification = async (title, message) => {
           if (!db || !currentUserId) {
               if (window.showMessage) window.showMessage('Error', 'Cannot add notification: User not authenticated.');
               return;
           }
           try {
               await addDoc(collection(db, `artifacts/${appId}/users/${currentUserId}/notifications`), {
                   title,
                   message,
                   timestamp: serverTimestamp(),
                   read: false
               });
           } catch (e) {
               console.error("Error adding document: ", e);
           }
       };


       window.markNotificationAsRead = async (notificationId) => {
           if (!db || !currentUserId || !notificationId) return;
           const notificationRef = doc(db, `artifacts/${appId}/users/${currentUserId}/notifications`, notificationId);
           await updateDoc(notificationRef, { read: true });
       };


       window.updateNotificationsUI = (notifications, unreadCount) => {
           const list = document.getElementById('notificationList');
           const countEl = document.getElementById('notificationCount');
           if (!list || !countEl) return;


           if (notifications.length === 0) {
               list.innerHTML = '<p class="p-4 text-center text-sm text-gray-500 dark:text-gray-400">No new notifications.</p>';
           } else {
               list.innerHTML = '';
               notifications.forEach(n => {
                   const item = document.createElement('div');
                   item.className = `notification-item ${n.read ? 'read' : ''}`;
                   const time = n.timestamp?.toDate ? new Date(n.timestamp.toDate()).toLocaleString() : 'Just now';
                 
                   item.innerHTML = `
                       <div class="notification-item-title">${n.title}</div>
                       <p>${n.message}</p>
                       <div class="notification-item-time">${time}</div>
                   `;
                   item.onclick = async () => {
                       if (window.showMessage) window.showMessage(n.title, n.message);
                       if (!n.read) await window.markNotificationAsRead(n.id);
                   };
                   list.appendChild(item);
               });
           }
         
           countEl.textContent = unreadCount;
           countEl.style.display = unreadCount > 0 ? 'flex' : 'none';
       };
   </script>
   <script>
       (function() {
           try {
               const savedTheme = localStorage.getItem('theme') || 'dark';
               document.documentElement.setAttribute('data-theme', savedTheme);
           } catch (e) {
               console.error("Could not access localStorage to set theme.", e);
           }
       })();


       function showMessage(title, message, type = 'info') {
           try {
               let messageBoxOverlay = document.getElementById('messageBoxOverlay');
               if (!messageBoxOverlay) {
                   messageBoxOverlay = document.createElement('div');
                   messageBoxOverlay.id = 'messageBoxOverlay';
                   messageBoxOverlay.className = 'message-box-overlay';
                   document.body.appendChild(messageBoxOverlay);
               }
               messageBoxOverlay.innerHTML = `<div class="message-box"><h3>${title}</h3><p>${message}</p><button id="messageBoxCloseButton">OK</button></div>`;
               document.getElementById('messageBoxCloseButton').onclick = () => hideMessageBox();
               messageBoxOverlay.style.visibility = 'visible';
               messageBoxOverlay.style.opacity = '1';
               document.body.classList.add('customizer-is-open');
           } catch (e) {
               console.error('Error in showMessage:', e);
           }
       }


       function hideMessageBox() {
           try {
               const messageBoxOverlay = document.getElementById('messageBoxOverlay');
               if (messageBoxOverlay) {
                   messageBoxOverlay.style.opacity = '0';
                   setTimeout(() => {
                       messageBoxOverlay.style.visibility = 'hidden';
                       document.body.classList.remove('customizer-is-open');
                   }, 300);
               }
           } catch (e) {
               console.error('Error in hideMessageBox:', e);
           }
       }
      
       window.showMessage = showMessage;


       function renderVideoQueue(videos) {
           const videoListContainer = document.querySelector('.video-list');
           if (!videoListContainer) return;


           if (!videos || videos.length === 0) {
               videoListContainer.innerHTML = `<div style="text-align: center; font-family: Arial, sans-serif; font-size: 2.5rem; font-weight: bold; color: white; -webkit-text-stroke: 2px var(--primary-green); padding-top: 10vh;">You are All Caught Up</div>`;
               return;
           }


           videoListContainer.innerHTML = videos.map(video => {
               const dueDate = video.dueDate?.toDate ? new Date(video.dueDate.toDate()).toLocaleDateString() : 'N/A';
               return `
               <article class="video-item">
                   <div class="thumbnail">
                       <img src="${video.thumbnailUrl || 'https://placehold.co/246x138/1A1A1A/FFFFFF?text=Video'}" alt="${video.title || 'Video'} Thumbnail">
                       <div class="play-button"></div>
                       <span class="timestamp">${video.duration || '00:00'}</span>
                   </div>
                   <div class="video-details">
                       <div class="org-info">
                           <div class="org-logo">
                               <img src="${video.organizationLogoUrl || 'https://placehold.co/20x20/FFFFFF/000000?text=O'}" alt="${video.organizationName || 'Organization'} Logo">
                           </div>
                           <p class="org-name">Hosted by: ${video.organizationName || 'Organization'}</p>
                       </div>
                       <h3>${video.title || 'Video Title'}</h3>
                       <p>${video.description || 'Video description.'}</p>
                       <div class="progress-bar-container">
                           <progress class="progress-bar" value="${video.progress || 0}" max="100"></progress>
                           <span class="completion-percentage">${video.progress || 0}%</span>
                       </div>
                       <p class="due-date">Due by: <span>${dueDate}</span></p>
                   </div>
               </article>
           `}).join('');
       }
       window.renderVideoQueue = renderVideoQueue;


       function hexToHSL(hex){if(!hex)return 0;try{hex=hex.replace(/^#/,"");let r=parseInt(hex.substr(0,2),16)/255,g=parseInt(hex.substr(2,2),16)/255,b=parseInt(hex.substr(4,2),16)/255,max=Math.max(r,g,b),min=Math.min(r,g,b),h,s,l=(max+min)/2;if(max===min)h=s=0;else{let d=max-min;s=l>.5?d/(2-max-min):d/(max+min);switch(max){case r:h=(g-b)/d+(g<b?6:0);break;case g:h=(b-r)/d+2;break;case b:h=(r-g)/d+4}h/=6}return h*360}catch(e){console.error("Error in hexToHSL:",e);return 0}}
      
       function showProfileMenu(){try{const e=document.getElementById("profileMenuOverlay"),t=document.getElementById("profileMenuTitle"),o=document.getElementById("signOutButton"),n=document.getElementById("profileMenuClose"),i=localStorage.getItem("simulatedUserId");i&&(localStorage.getItem(`isAdmin_${i}`),t.textContent="",o.style.display="block",o.onclick=()=>{try{const e=localStorage.getItem("simulatedUserId");localStorage.removeItem(`firstLogin_${e}`),localStorage.removeItem(`isAdmin_${e}`),localStorage.removeItem(`customTheme_${e}`),localStorage.removeItem(`cardPositions_${e}`),localStorage.setItem("simulatedUserId","Guest"),localStorage.setItem("isAdmin_Guest","false"),showMessage("Signed Out","You have been signed out.","info"),setTimeout(()=>window.location.reload(),1e3)}catch(e){console.error("Error in signOutButton click:",e),showMessage("Error","An error occurred while signing out.")}}),e.style.visibility="visible",e.style.opacity="1",document.body.classList.add("customizer-is-open"),n.onclick=()=>{try{e.style.opacity="0",setTimeout(()=>{e.style.visibility="hidden",document.body.classList.remove("customizer-is-open")},300)}catch(e){console.error("Error in profileMenuClose click:",e)}},e.addEventListener("click",t=>{try{t.target===e&&(e.style.opacity="0",setTimeout(()=>{e.style.visibility="hidden",document.body.classList.remove("customizer-is-open")},300))}catch(e){console.error("Error in profileMenuOverlay click:",e)}})}catch(e){console.error("Error in showProfileMenu:",e),showMessage("Error","An error occurred while showing the profile menu.")}}


       document.addEventListener('DOMContentLoaded', function() {
           try {
               document.querySelector('.main-wrapper').style.display = 'flex';
           } catch (e) {
               console.error('Error during page load:', e);
               showMessage('Error', 'An error occurred while loading the page. Please try again.');
           }
          
           const notificationBell = document.getElementById('notificationBell');
           const notificationDropdown = document.getElementById('notificationDropdown');
           const notificationDropdownClose = document.getElementById('notificationDropdownClose');


           notificationBell.addEventListener('click', (e) => {
               e.stopPropagation();
               notificationDropdown.classList.toggle('active');
           });
           notificationDropdownClose.addEventListener('click', () => notificationDropdown.classList.remove('active'));
           document.addEventListener('click', (e) => {
               if (!notificationDropdown.contains(e.target) && !notificationBell.contains(e.target)) {
                   notificationDropdown.classList.remove('active');
               }
           });


           try {
               const desktopThemeCustomizerBtn = document.getElementById('themeCustomizerBtn');
               const customizerOverlay = document.getElementById('themeCustomizerOverlay');
               const closeCustomizerBtn = document.getElementById('closeCustomizerBtn');
               const profilePic = document.getElementById('profilePic');


               if (profilePic) profilePic.onclick = showProfileMenu;
              
               function openCustomizer() {
                   try {
                       customizerOverlay.style.visibility = 'visible';
                       customizerOverlay.style.opacity = '1';
                       document.body.classList.add('customizer-is-open');
                   } catch (e) {
                       console.error('Error in openCustomizer:', e);
                       showMessage('Error', 'An error occurred while opening the theme customizer.');
                   }
               }


               function closeCustomizer() {
                   try {
                       customizerOverlay.style.opacity = '0';
                       setTimeout(() => {
                           customizerOverlay.style.visibility = 'hidden';
                           document.body.classList.remove('customizer-is-open');
                       }, 300);
                   } catch (e) {
                       console.error('Error in closeCustomizer:', e);
                   }
               }


               if (desktopThemeCustomizerBtn) desktopThemeCustomizerBtn.addEventListener('click', openCustomizer);
               if(closeCustomizerBtn) closeCustomizerBtn.addEventListener('click', closeCustomizer);


               if (customizerOverlay) {
                   customizerOverlay.addEventListener('click', (e) => {
                       try {
                           if (e.target === customizerOverlay) {
                               closeCustomizer();
                           }
                       } catch (e) {
                           console.error('Error in customizerOverlay click:', e);
                       }
                   });
               }
           } catch (e) {
               console.error('Error in DOMContentLoaded handler:', e);
               showMessage('Error', 'An error occurred while initializing the page.');
           }
       });
   </script>
