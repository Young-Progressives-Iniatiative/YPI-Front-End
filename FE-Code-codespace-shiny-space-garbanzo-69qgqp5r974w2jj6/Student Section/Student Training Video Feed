<!DOCTYPE html>
<html lang="en" data-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Volunteer Adventure Log</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', 'Segoe UI', Arial, sans-serif;
            background-color: var(--theme-body-bg);
            color: var(--theme-body-color);
            line-height: 1.6;
            overflow-x: hidden;
            transition: background 0.3s ease;
        }

        :root {
            --primary-green: #37af4b;
            --theme-body-bg: #121212;
            --theme-body-color: #ffffff;
            --card-bg: #1e1e1e;
            --card-border: #333333;
            --text-muted: #a0a0a0;
            --header-gradient: linear-gradient(135deg, #057215 0%, #37af4b 100%);
        }

        html[data-theme='light'] {
            --theme-body-bg: #f8f9fa;
            --theme-body-color: #1a1a1a;
            --card-bg: #ffffff;
            --card-border: #e0e0e0;
            --text-muted: #666666;
            --header-gradient: #ffffff;
        }

        /* Header */
        .header-container {
            background: var(--header-gradient);
            height: 4.5rem;
            padding: 0 1.5rem;
            position: fixed;
            top: 0; left: 0;
            width: 100%;
            z-index: 50;
            display: flex;
            align-items: center;
            box-shadow: 0 2px 15px rgba(0,0,0,0.1);
        }

        html[data-theme='light'] .header-container { border-bottom: 1px solid var(--card-border); }

        .header-logo {
            height: 2.8rem;
            width: auto;
        }

        /* Layout Container */
        .main-content {
            display: flex;
            padding-top: 4.5rem;
            min-height: 100vh;
            width: 100%;
            transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
        }

        /* Left Side: Video Player */
        .video-player-side {
            flex: 1;
            background: #000;
            display: none; /* Hidden by default */
            flex-direction: column;
            position: sticky;
            top: 4.5rem;
            height: calc(100vh - 4.5rem);
            border-right: 1px solid var(--card-border);
        }

        .video-player-side.active {
            display: flex;
            animation: slideInLeft 0.5s ease;
        }

        @keyframes slideInLeft {
            from { opacity: 0; transform: translateX(-50px); }
            to { opacity: 1; transform: translateX(0); }
        }

        .video-placeholder {
            flex: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            background: #000;
            position: relative;
        }

        .video-info-overlay {
            padding: 2rem;
            background: var(--theme-body-bg);
            border-top: 1px solid var(--card-border);
        }

        .close-player {
            position: absolute;
            top: 1rem;
            left: 1rem;
            z-index: 10;
            background: rgba(0,0,0,0.5);
            color: white;
            border: none;
            padding: 0.5rem 1rem;
            border-radius: 20px;
            cursor: pointer;
            backdrop-filter: blur(5px);
        }

        /* Right Side: Feed */
        .feed-side {
            flex: 1;
            padding: 2rem 1rem;
            max-width: 700px;
            margin: 0 auto;
            transition: max-width 0.5s ease;
        }

        /* When playing, the feed becomes a sidebar */
        .playing-mode .feed-side {
            max-width: 400px;
            margin: 0;
            border-left: 1px solid var(--card-border);
            overflow-y: auto;
            height: calc(100vh - 4.5rem);
            position: sticky;
            top: 4.5rem;
            padding: 1.5rem;
        }

        .adventure-card {
            background: var(--card-bg);
            border: 1px solid var(--card-border);
            border-radius: 16px;
            margin-bottom: 1.5rem;
            overflow: hidden;
            transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s;
            display: flex;
            flex-direction: column;
            cursor: pointer;
        }

        .adventure-card:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(0,0,0,0.15);
            border-color: var(--primary-green);
        }

        .adventure-card.selected {
            border: 2px solid var(--primary-green);
            background: rgba(55, 175, 75, 0.05);
        }

        .card-banner {
            height: 160px;
            position: relative;
            background: #000;
        }

        .playing-mode .card-banner { height: 100px; }

        .card-banner img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            opacity: 0.8;
        }

        .status-badge {
            position: absolute;
            top: 12px;
            right: 12px;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 0.7rem;
            font-weight: 700;
            text-transform: uppercase;
            backdrop-filter: blur(8px);
            background: rgba(0,0,0,0.6);
            color: white;
            border: 1px solid rgba(255,255,255,0.1);
        }

        .card-content { padding: 1.25rem; }
        .playing-mode .card-content { padding: 0.75rem; }

        .card-category {
            font-size: 0.7rem;
            font-weight: 700;
            color: var(--primary-green);
            text-transform: uppercase;
            margin-bottom: 4px;
        }

        .card-title { font-size: 1.2rem; font-weight: 700; margin-bottom: 8px; }
        .playing-mode .card-title { font-size: 1rem; }

        .card-desc {
            font-size: 0.9rem;
            color: var(--text-muted);
            margin-bottom: 1.25rem;
            line-height: 1.5;
        }
        .playing-mode .card-desc { display: none; }

        /* Progress Tracker */
        .progress-container {
            background: rgba(128,128,128,0.1);
            height: 8px;
            border-radius: 4px;
            overflow: hidden;
            margin-bottom: 8px;
        }

        .progress-bar {
            height: 100%;
            background: var(--primary-green);
            transition: width 0.6s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .card-footer {
            display: flex;
            justify-content: space-between;
            align-items: center;
            font-size: 0.75rem;
            font-weight: 600;
            color: var(--text-muted);
        }

        .icon-btn {
            background: transparent;
            border: none;
            color: inherit;
            cursor: pointer;
            padding: 0.5rem;
            border-radius: 50%;
        }

        .icon-btn:hover { background: rgba(128,128,128,0.1); }

        @media (max-width: 900px) {
            .main-content.playing-mode { flex-direction: column; }
            .video-player-side { height: 300px; position: relative; top: 0; }
            .playing-mode .feed-side { max-width: 100%; position: relative; top: 0; border-left: none; }
        }

        @media (min-width: 901px) and (max-width: 1200px) {
            .playing-mode .feed-side { max-width: 300px; }
        }
    </style>
</head>
<body>

    <header class="header-container">
        <div class="flex justify-between items-center w-full">
            <img class="header-logo" src="https://weareypi.com/wp-content/uploads/2025/06/Site-Icon-3.png" alt="YPI">
            
            <div class="flex items-center gap-2">
                <button class="icon-btn" id="themeBtn">
                    <i class="fas fa-adjust text-xl"></i>
                </button>
                <img src="https://placehold.co/40x40/37af4b/FFFFFF?text=A" class="w-10 h-10 rounded-full border-2 border-[#37af4b] ml-2" alt="Avatar">
            </div>
        </div>
    </header>

    <main class="main-content" id="layoutWrapper">
        <!-- Left Section: Video Player -->
        <section class="video-player-side" id="playerSide">
            <button class="close-player" onclick="closePlayer()">
                <i class="fas fa-chevron-left mr-2"></i> Back to Feed
            </button>
            <div class="video-placeholder">
                <iframe id="videoIframe" width="100%" height="100%" src="" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>
            </div>
            <div class="video-info-overlay">
                <div id="playerCategory" class="card-category">Category</div>
                <h1 id="playerTitle" class="text-2xl font-bold mb-2">Adventure Title</h1>
                <p id="playerDesc" class="text-muted">Loading description...</p>
            </div>
        </section>

        <!-- Right Section: Feed -->
        <section class="feed-side">
            <div id="adventureFeed">
                <!-- Feed items injected here -->
            </div>
        </section>
    </main>

    <script>
        const ADVENTURE_DATA = [
            {
                id: 1,
                category: "Environmental",
                title: "River Clean-up Briefing",
                description: "Essential safety protocols and waste sorting guidelines for the Anacostia River restoration project.",
                progress: 85,
                status: "In Progress",
                dueDate: "Jan 12",
                image: "https://images.unsplash.com/photo-1532996122724-e3c354a0b15b?w=500&q=80",
                videoUrl: "https://www.youtube.com/embed/dQw4w9WgXcQ"
            },
            {
                id: 2,
                category: "Advocacy",
                title: "Local Policy Workshop",
                description: "Understanding how to present environmental data to city council members effectively.",
                progress: 30,
                status: "Active",
                dueDate: "Jan 18",
                image: "https://images.unsplash.com/photo-1517048676732-d65bc937f952?w=500&q=80",
                videoUrl: "https://www.youtube.com/embed/9No-FiE9ywg"
            },
            {
                id: 3,
                category: "Social Aid",
                title: "Crisis Response Foundations",
                description: "Training for immediate community assistance during localized weather emergencies.",
                progress: 0,
                status: "Locked",
                dueDate: "Feb 05",
                image: "https://images.unsplash.com/photo-1469571486292-0ba58a3f068b?w=500&q=80",
                videoUrl: "https://www.youtube.com/embed/6Xv28pAt4W0"
            }
        ];

        let selectedId = null;

        function renderFeed() {
            const container = document.getElementById('adventureFeed');
            
            container.innerHTML = ADVENTURE_DATA.map(item => `
                <div class="adventure-card ${selectedId === item.id ? 'selected' : ''}" onclick="selectAdventure(${item.id})">
                    <div class="card-banner">
                        <img src="${item.image}" alt="${item.title}">
                        <div class="status-badge">
                            ${item.status}
                        </div>
                    </div>
                    <div class="card-content">
                        <div class="card-category">${item.category}</div>
                        <h2 class="card-title">${item.title}</h2>
                        <p class="card-desc">${item.description}</p>
                        
                        <div class="progress-container">
                            <div class="progress-bar" style="width: ${item.progress}%"></div>
                        </div>
                        
                        <div class="card-footer">
                            <span>${item.progress}% COMPLETE</span>
                            <span class="flex items-center gap-1">
                                <i class="far fa-calendar-alt"></i> DUE ${item.dueDate}
                            </span>
                        </div>
                    </div>
                </div>
            `).join('');
        }

        function selectAdventure(id) {
            const item = ADVENTURE_DATA.find(a => a.id === id);
            if (!item) return;

            selectedId = id;
            
            document.getElementById('layoutWrapper').classList.add('playing-mode');
            document.getElementById('playerSide').classList.add('active');
            
            document.getElementById('videoIframe').src = item.videoUrl;
            document.getElementById('playerTitle').innerText = item.title;
            document.getElementById('playerCategory').innerText = item.category;
            document.getElementById('playerDesc').innerText = item.description;

            renderFeed();
            window.scrollTo({ top: 0, behavior: 'smooth' });
        }

        function closePlayer() {
            selectedId = null;
            document.getElementById('layoutWrapper').classList.remove('playing-mode');
            document.getElementById('playerSide').classList.remove('active');
            document.getElementById('videoIframe').src = "";
            renderFeed();
        }

        const themeBtn = document.getElementById('themeBtn');
        themeBtn.onclick = () => {
            const current = document.documentElement.getAttribute('data-theme');
            const next = current === 'dark' ? 'light' : 'dark';
            document.documentElement.setAttribute('data-theme', next);
            localStorage.setItem('adventure-theme', next);
        };

        window.onload = () => {
            const savedTheme = localStorage.getItem('adventure-theme') || 'dark';
            document.documentElement.setAttribute('data-theme', savedTheme);
            renderFeed();
        };
    </script>
</body>
</html>
